{
  "manifest_version": "1.3",
  "module": {
    "id": "construction_material_control",
    "key": "construction_material_control",
    "name": "Materials",
    "version": "2.2.1",
    "description": "Material requests, receipts, and usage control for construction sites.",
    "category": "Construction",
    "icon_key": "lucide:PackageOpen"
  },
  "depends_on": {
    "required": [
      { "module": "contacts", "version": ">=1.0.0" },
      { "module": "catalog", "version": ">=1.1.0" },
      { "module": "construction_projects", "version": ">=2.2.0" },
      { "module": "construction_workforce", "version": ">=2.2.0" }
    ]
  },
  "app": {
    "home": "page:material_log.list_page",
    "defaults": {
      "entity_home_page": "page:material_log.list_page",
      "entity_form_page": "page:material_log.form_page",
      "entities": {
        "entity.material_request": {
          "entity_home_page": "page:material_request.list_page",
          "entity_form_page": "page:material_request.form_page"
        },
        "entity.material_receipt": {
          "entity_home_page": "page:material_receipt.list_page",
          "entity_form_page": "page:material_receipt.form_page"
        },
        "entity.material_log": {
          "entity_home_page": "page:material_log.list_page",
          "entity_form_page": "page:material_log.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Construction",
        "mode": "inline",
        "items": [
          { "label": "Material Requests", "to": "page:material_request.list_page" },
          { "label": "Material Receipts", "to": "page:material_receipt.list_page" },
          { "label": "Material Usage", "to": "page:material_log.list_page" }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.material_request",
      "display_field": "material_request.description",
      "fields": [
        { "id": "material_request.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "material_request.project_id", "type": "lookup", "label": "Project", "entity": "entity.construction_project", "display_field": "construction_project.name", "required": true },
        { "id": "material_request.site_id", "type": "lookup", "label": "Site", "entity": "entity.construction_site", "display_field": "construction_site.name" },
        { "id": "material_request.request_date", "type": "date", "label": "Request Date", "required": true },
        { "id": "material_request.item_id", "type": "lookup", "label": "Catalog Item", "entity": "entity.item", "display_field": "item.name" },
        { "id": "material_request.description", "type": "string", "label": "Description", "required_when": { "op": "in", "field": "material_request.status", "value": ["requested", "approved", "fulfilled"] } },
        { "id": "material_request.quantity", "type": "number", "label": "Quantity", "required": true },
        { "id": "material_request.unit", "type": "enum", "label": "Unit", "default": "bag", "options": [{ "value": "bag", "label": "Bag" }, { "value": "kg", "label": "kg" }, { "value": "ton", "label": "Ton" }, { "value": "m3", "label": "m3" }, { "value": "piece", "label": "Piece" }] },
        { "id": "material_request.requested_by_worker_id", "type": "lookup", "label": "Requested By", "entity": "entity.construction_worker", "display_field": "construction_worker.full_name", "required_when": { "op": "in", "field": "material_request.status", "value": ["requested", "approved", "fulfilled"] } },
        { "id": "material_request.needed_by_date", "type": "date", "label": "Needed By", "required_when": { "op": "in", "field": "material_request.status", "value": ["requested", "approved"] } },
        {
          "id": "material_request.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "requested", "label": "Requested" },
            { "value": "approved", "label": "Approved" },
            { "value": "fulfilled", "label": "Fulfilled" },
            { "value": "cancelled", "label": "Cancelled" }
          ]
        },
        { "id": "material_request.approved_by", "type": "user", "label": "Approved By", "required_when": { "op": "in", "field": "material_request.status", "value": ["approved", "fulfilled"] } },
        { "id": "material_request.notes", "type": "text", "label": "Notes" },
        { "id": "material_request.created_at", "type": "datetime", "label": "Created At" }
      ]
    },
    {
      "id": "entity.material_receipt",
      "display_field": "material_receipt.invoice_ref",
      "fields": [
        { "id": "material_receipt.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "material_receipt.project_id", "type": "lookup", "label": "Project", "entity": "entity.construction_project", "display_field": "construction_project.name", "required": true },
        { "id": "material_receipt.site_id", "type": "lookup", "label": "Site", "entity": "entity.construction_site", "display_field": "construction_site.name" },
        { "id": "material_receipt.receipt_date", "type": "date", "label": "Receipt Date", "required": true },
        { "id": "material_receipt.item_id", "type": "lookup", "label": "Catalog Item", "entity": "entity.item", "display_field": "item.name", "required": true },
        { "id": "material_receipt.supplier_contact_id", "type": "lookup", "label": "Supplier", "entity": "entity.contact", "display_field": "contact.name", "required_when": { "op": "in", "field": "material_receipt.status", "value": ["received", "posted"] } },
        { "id": "material_receipt.quantity", "type": "number", "label": "Quantity", "required": true },
        { "id": "material_receipt.unit", "type": "enum", "label": "Unit", "default": "bag", "options": [{ "value": "bag", "label": "Bag" }, { "value": "kg", "label": "kg" }, { "value": "ton", "label": "Ton" }, { "value": "m3", "label": "m3" }, { "value": "piece", "label": "Piece" }] },
        { "id": "material_receipt.unit_cost", "type": "number", "label": "Unit Cost", "required_when": { "op": "eq", "field": "material_receipt.status", "value": "posted" } },
        { "id": "material_receipt.total_cost", "type": "number", "label": "Total Cost", "required_when": { "op": "eq", "field": "material_receipt.status", "value": "posted" } },
        { "id": "material_receipt.received_by", "type": "user", "label": "Received By", "required_when": { "op": "in", "field": "material_receipt.status", "value": ["received", "posted"] } },
        { "id": "material_receipt.invoice_ref", "type": "string", "label": "Invoice / Delivery Ref", "required_when": { "op": "in", "field": "material_receipt.status", "value": ["received", "posted"] } },
        {
          "id": "material_receipt.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "received", "label": "Received" },
            { "value": "posted", "label": "Posted" }
          ]
        },
        { "id": "material_receipt.notes", "type": "text", "label": "Notes" },
        { "id": "material_receipt.attachments", "type": "attachments", "label": "Attachments" },
        { "id": "material_receipt.created_at", "type": "datetime", "label": "Created At" }
      ]
    },
    {
      "id": "entity.material_log",
      "display_field": "material_log.material_type",
      "fields": [
        { "id": "material_log.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "material_log.project_id", "type": "lookup", "label": "Project", "entity": "entity.construction_project", "display_field": "construction_project.name", "required": true },
        { "id": "material_log.site_id", "type": "lookup", "label": "Site", "entity": "entity.construction_site", "display_field": "construction_site.name" },
        { "id": "material_log.work_item_id", "type": "lookup", "label": "Work Item", "entity": "entity.construction_work_item", "display_field": "construction_work_item.title" },
        { "id": "material_log.log_date", "type": "date", "label": "Log Date", "required": true },
        { "id": "material_log.item_id", "type": "lookup", "label": "Catalog Item", "entity": "entity.item", "display_field": "item.name" },
        { "id": "material_log.material_type", "type": "string", "label": "Material Type", "required": true },
        { "id": "material_log.quantity", "type": "number", "label": "Quantity", "required": true },
        { "id": "material_log.unit", "type": "string", "label": "Unit", "required": true },
        { "id": "material_log.unit_cost", "type": "number", "label": "Unit Cost" },
        { "id": "material_log.total_cost", "type": "number", "label": "Total Cost", "required_when": { "op": "eq", "field": "material_log.status", "value": "approved" } },
        { "id": "material_log.entered_by_worker_id", "type": "lookup", "label": "Entered By Worker", "entity": "entity.construction_worker", "display_field": "construction_worker.full_name", "required_when": { "op": "in", "field": "material_log.status", "value": ["submitted", "approved"] } },
        { "id": "material_log.supervisor_id", "type": "user", "label": "Supervisor", "required_when": { "op": "eq", "field": "material_log.status", "value": "approved" } },
        {
          "id": "material_log.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "submitted", "label": "Submitted" },
            { "value": "approved", "label": "Approved" }
          ]
        },
        { "id": "material_log.notes", "type": "text", "label": "Notes" },
        { "id": "material_log.photo", "type": "attachments", "label": "Photos" },
        { "id": "material_log.created_at", "type": "datetime", "label": "Created At" }
      ]
    }
  ],
  "actions": [
    { "id": "action.material_request_new", "kind": "open_form", "label": "+ New Request", "target": "material_request.form" },
    { "id": "action.material_receipt_new", "kind": "open_form", "label": "+ New Receipt", "target": "material_receipt.form" },
    { "id": "action.material_log_new", "kind": "open_form", "label": "+ New Usage Log", "target": "material_log.form" },
    { "id": "action.material_request_send", "kind": "update_record", "label": "Request", "entity_id": "entity.material_request", "patch": { "material_request.status": "requested" }, "enabled_when": { "op": "eq", "field": "material_request.status", "value": "draft" }, "visible_when": { "op": "eq", "field": "material_request.status", "value": "draft" } },
    { "id": "action.material_request_approve", "kind": "update_record", "label": "Approve", "entity_id": "entity.material_request", "patch": { "material_request.status": "approved" }, "enabled_when": { "op": "eq", "field": "material_request.status", "value": "requested" }, "visible_when": { "op": "eq", "field": "material_request.status", "value": "requested" } },
    { "id": "action.material_request_fulfill", "kind": "update_record", "label": "Fulfill", "entity_id": "entity.material_request", "patch": { "material_request.status": "fulfilled" }, "enabled_when": { "op": "eq", "field": "material_request.status", "value": "approved" }, "visible_when": { "op": "eq", "field": "material_request.status", "value": "approved" } },
    { "id": "action.material_receipt_receive", "kind": "update_record", "label": "Receive", "entity_id": "entity.material_receipt", "patch": { "material_receipt.status": "received" }, "enabled_when": { "op": "eq", "field": "material_receipt.status", "value": "draft" }, "visible_when": { "op": "eq", "field": "material_receipt.status", "value": "draft" } },
    { "id": "action.material_receipt_post", "kind": "update_record", "label": "Post", "entity_id": "entity.material_receipt", "patch": { "material_receipt.status": "posted" }, "enabled_when": { "op": "eq", "field": "material_receipt.status", "value": "received" }, "visible_when": { "op": "eq", "field": "material_receipt.status", "value": "received" } },
    { "id": "action.material_log_submit", "kind": "update_record", "label": "Submit", "entity_id": "entity.material_log", "patch": { "material_log.status": "submitted" }, "enabled_when": { "op": "eq", "field": "material_log.status", "value": "draft" }, "visible_when": { "op": "eq", "field": "material_log.status", "value": "draft" } },
    { "id": "action.material_log_approve", "kind": "update_record", "label": "Approve", "entity_id": "entity.material_log", "patch": { "material_log.status": "approved" }, "enabled_when": { "op": "eq", "field": "material_log.status", "value": "submitted" }, "visible_when": { "op": "eq", "field": "material_log.status", "value": "submitted" } }
  ],
  "views": [
    {
      "id": "material_request.list",
      "kind": "list",
      "entity": "entity.material_request",
      "columns": [
        { "field_id": "material_request.request_date" },
        { "field_id": "material_request.project_id" },
        { "field_id": "material_request.item_id" },
        { "field_id": "material_request.quantity" },
        { "field_id": "material_request.unit" },
        { "field_id": "material_request.status" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.material_request_new" }],
        "open_record_target": "page:material_request.form_page",
        "search": { "enabled": true, "placeholder": "Search material requests...", "fields": ["material_request.description", "material_request.notes"] },
        "filters": [
          { "id": "draft", "label": "Draft", "domain": { "op": "eq", "field": "material_request.status", "value": "draft" } },
          { "id": "requested", "label": "Requested", "domain": { "op": "eq", "field": "material_request.status", "value": "requested" } },
          { "id": "approved", "label": "Approved", "domain": { "op": "eq", "field": "material_request.status", "value": "approved" } }
        ]
      }
    },
    {
      "id": "material_request.form",
      "kind": "form",
      "entity": "entity.material_request",
      "sections": [
        {
          "id": "request",
          "title": "Request",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "material_request.project_id",
            "material_request.site_id",
            "material_request.request_date",
            "material_request.item_id",
            "material_request.description",
            "material_request.quantity",
            "material_request.unit",
            "material_request.requested_by_worker_id",
            "material_request.needed_by_date",
            "material_request.approved_by"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": ["material_request.notes"]
        }
      ],
      "header": {
        "statusbar": { "field_id": "material_request.status" },
        "secondary_actions": [{ "action_id": "action.material_request_send" }, { "action_id": "action.material_request_approve" }, { "action_id": "action.material_request_fulfill" }],
        "tabs": {
          "style": "lifted",
          "default_tab": "request_tab",
          "tabs": [
            { "id": "request_tab", "label": "Request", "sections": ["request"] },
            { "id": "notes_tab", "label": "Notes", "sections": ["notes"] }
          ]
        }
      }
    },
    {
      "id": "material_request.graph",
      "kind": "graph",
      "entity": "entity.material_request",
      "default": { "type": "bar", "group_by": "material_request.status", "measure": "sum:material_request.quantity" }
    },
    {
      "id": "material_receipt.list",
      "kind": "list",
      "entity": "entity.material_receipt",
      "columns": [
        { "field_id": "material_receipt.receipt_date" },
        { "field_id": "material_receipt.project_id" },
        { "field_id": "material_receipt.item_id" },
        { "field_id": "material_receipt.supplier_contact_id" },
        { "field_id": "material_receipt.quantity" },
        { "field_id": "material_receipt.total_cost" },
        { "field_id": "material_receipt.status" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.material_receipt_new" }],
        "open_record_target": "page:material_receipt.form_page",
        "search": { "enabled": true, "placeholder": "Search material receipts...", "fields": ["material_receipt.invoice_ref", "material_receipt.notes"] }
      }
    },
    {
      "id": "material_receipt.form",
      "kind": "form",
      "entity": "entity.material_receipt",
      "sections": [
        {
          "id": "receipt",
          "title": "Receipt",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "material_receipt.project_id",
            "material_receipt.site_id",
            "material_receipt.receipt_date",
            "material_receipt.item_id",
            "material_receipt.supplier_contact_id",
            "material_receipt.quantity",
            "material_receipt.unit",
            "material_receipt.unit_cost",
            "material_receipt.total_cost",
            "material_receipt.received_by",
            "material_receipt.invoice_ref"
          ]
        },
        {
          "id": "supporting",
          "title": "Supporting",
          "fields": [
            "material_receipt.notes",
            "material_receipt.attachments"
          ]
        }
      ],
      "header": {
        "statusbar": { "field_id": "material_receipt.status" },
        "secondary_actions": [{ "action_id": "action.material_receipt_receive" }, { "action_id": "action.material_receipt_post" }],
        "tabs": {
          "style": "lifted",
          "default_tab": "receipt_tab",
          "tabs": [
            { "id": "receipt_tab", "label": "Receipt", "sections": ["receipt"] },
            { "id": "supporting_tab", "label": "Supporting", "sections": ["supporting"] }
          ]
        }
      }
    },
    {
      "id": "material_receipt.graph",
      "kind": "graph",
      "entity": "entity.material_receipt",
      "default": { "type": "bar", "group_by": "material_receipt.item_id", "measure": "sum:material_receipt.total_cost" }
    },
    {
      "id": "material_log.list",
      "kind": "list",
      "entity": "entity.material_log",
      "columns": [
        { "field_id": "material_log.log_date" },
        { "field_id": "material_log.project_id" },
        { "field_id": "material_log.site_id" },
        { "field_id": "material_log.material_type" },
        { "field_id": "material_log.quantity" },
        { "field_id": "material_log.unit" },
        { "field_id": "material_log.total_cost" },
        { "field_id": "material_log.status" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.material_log_new" }],
        "open_record_target": "page:material_log.form_page",
        "search": { "enabled": true, "placeholder": "Search material usage...", "fields": ["material_log.notes"] },
        "filters": [
          { "id": "draft", "label": "Draft", "domain": { "op": "eq", "field": "material_log.status", "value": "draft" } },
          { "id": "submitted", "label": "Submitted", "domain": { "op": "eq", "field": "material_log.status", "value": "submitted" } },
          { "id": "approved", "label": "Approved", "domain": { "op": "eq", "field": "material_log.status", "value": "approved" } }
        ]
      }
    },
    {
      "id": "material_log.calendar",
      "kind": "calendar",
      "entity": "entity.material_log",
      "calendar": {
        "title_field": "material_log.material_type",
        "date_start": "material_log.log_date",
        "color_field": "material_log.project_id",
        "default_scale": "month"
      }
    },
    {
      "id": "material_log.form",
      "kind": "form",
      "entity": "entity.material_log",
      "sections": [
        {
          "id": "usage",
          "title": "Usage",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "material_log.project_id",
            "material_log.site_id",
            "material_log.work_item_id",
            "material_log.log_date",
            "material_log.item_id",
            "material_log.material_type",
            "material_log.quantity",
            "material_log.unit",
            "material_log.unit_cost",
            "material_log.total_cost",
            "material_log.entered_by_worker_id",
            "material_log.supervisor_id"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "material_log.notes",
            "material_log.photo"
          ]
        }
      ],
      "header": {
        "statusbar": { "field_id": "material_log.status" },
        "secondary_actions": [{ "action_id": "action.material_log_submit" }, { "action_id": "action.material_log_approve" }],
        "tabs": {
          "style": "lifted",
          "default_tab": "usage_tab",
          "tabs": [
            { "id": "usage_tab", "label": "Usage", "sections": ["usage"] },
            { "id": "notes_tab", "label": "Notes", "sections": ["notes"] }
          ]
        }
      }
    },
    {
      "id": "material_log.graph",
      "kind": "graph",
      "entity": "entity.material_log",
      "default": { "type": "bar", "group_by": "material_log.material_type", "measure": "sum:material_log.quantity" }
    }
  ],
  "workflows": [
    {
      "id": "workflow.material_request_status",
      "entity": "entity.material_request",
      "status_field": "material_request.status",
      "states": [
        { "id": "draft", "label": "Draft" },
        { "id": "requested", "label": "Requested" },
        { "id": "approved", "label": "Approved" },
        { "id": "fulfilled", "label": "Fulfilled" },
        { "id": "cancelled", "label": "Cancelled" }
      ]
    },
    {
      "id": "workflow.material_receipt_status",
      "entity": "entity.material_receipt",
      "status_field": "material_receipt.status",
      "states": [
        { "id": "draft", "label": "Draft" },
        { "id": "received", "label": "Received" },
        { "id": "posted", "label": "Posted" }
      ]
    },
    {
      "id": "workflow.material_log_status",
      "entity": "entity.material_log",
      "status_field": "material_log.status",
      "states": [
        { "id": "draft", "label": "Draft" },
        { "id": "submitted", "label": "Submitted" },
        { "id": "approved", "label": "Approved" }
      ]
    }
  ],
  "pages": [
    {
      "id": "material_request.list_page",
      "title": "Material Requests",
      "layout": "single",
      "header": { "variant": "none", "actions": [{ "action_id": "action.material_request_new" }] },
      "content": [{ "kind": "container", "variant": "card", "content": [{ "kind": "view_modes", "entity_id": "entity.material_request", "default_mode": "list", "modes": [{ "mode": "list", "target": "view:material_request.list" }, { "mode": "graph", "target": "view:material_request.graph" }, { "mode": "pivot", "target": "view:material_request.list", "default_group_by": "material_request.project_id" }] }] }]
    },
    {
      "id": "material_request.form_page",
      "title": "Material Request",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [{ "kind": "record", "entity_id": "entity.material_request", "record_id_query": "record", "content": [{ "kind": "grid", "columns": 12, "gap": "md", "items": [{ "span": 8, "content": [{ "kind": "container", "variant": "card", "content": [{ "kind": "view", "target": "view:material_request.form" }] }] }, { "span": 4, "content": [{ "kind": "container", "variant": "card", "content": [{ "kind": "chatter", "entity_id": "entity.material_request", "record_ref": "$record.id" }] }] }] }] }]
