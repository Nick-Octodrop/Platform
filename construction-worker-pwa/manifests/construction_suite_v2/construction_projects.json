{
  "manifest_version": "1.3",
  "module": {
    "id": "construction_projects",
    "key": "construction_projects",
    "name": "Projects",
    "version": "2.2.1",
    "description": "Construction projects, work packages, and execution planning.",
    "category": "Construction",
    "icon_key": "lucide:Building2"
  },
  "depends_on": {
    "required": [
      { "module": "contacts", "version": ">=1.0.0" },
      { "module": "construction_core", "version": ">=2.2.0" }
    ]
  },
  "app": {
    "home": "page:construction_project.list_page",
    "defaults": {
      "entity_home_page": "page:construction_project.list_page",
      "entity_form_page": "page:construction_project.form_page",
      "entities": {
        "entity.construction_project": {
          "entity_home_page": "page:construction_project.list_page",
          "entity_form_page": "page:construction_project.form_page"
        },
        "entity.construction_work_item": {
          "entity_home_page": "page:construction_work_item.list_page",
          "entity_form_page": "page:construction_work_item.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Construction",
        "mode": "inline",
        "items": [
          { "label": "Projects", "to": "page:construction_project.list_page" },
          { "label": "Work Items", "to": "page:construction_work_item.list_page" }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.construction_project",
      "display_field": "construction_project.name",
      "fields": [
        { "id": "construction_project.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "construction_project.name", "type": "string", "label": "Project Name", "required": true },
        { "id": "construction_project.code", "type": "string", "label": "Project Code" },
        { "id": "construction_project.client_contact_id", "type": "lookup", "label": "Client", "entity": "entity.contact", "display_field": "contact.name" },
        { "id": "construction_project.site_id", "type": "lookup", "label": "Primary Site", "entity": "entity.construction_site", "display_field": "construction_site.name" },
        { "id": "construction_project.site_location", "type": "string", "label": "Site Location" },
        {
          "id": "construction_project.status",
          "type": "enum",
          "label": "Status",
          "default": "planned",
          "options": [
            { "value": "planned", "label": "Planned" },
            { "value": "active", "label": "Active" },
            { "value": "on_hold", "label": "On Hold" },
            { "value": "completed", "label": "Completed" },
            { "value": "cancelled", "label": "Cancelled" }
          ]
        },
        {
          "id": "construction_project.project_type",
          "type": "enum",
          "label": "Project Type",
          "default": "building",
          "options": [
            { "value": "building", "label": "Building" },
            { "value": "renovation", "label": "Renovation" },
            { "value": "fitout", "label": "Fitout" },
            { "value": "maintenance", "label": "Maintenance" },
            { "value": "other", "label": "Other" }
          ]
        },
        {
          "id": "construction_project.priority",
          "type": "enum",
          "label": "Priority",
          "default": "medium",
          "options": [
            { "value": "low", "label": "Low" },
            { "value": "medium", "label": "Medium" },
            { "value": "high", "label": "High" }
          ]
        },
        { "id": "construction_project.project_manager_id", "type": "user", "label": "Project Manager" },
        { "id": "construction_project.site_manager_id", "type": "user", "label": "Site Manager" },
        { "id": "construction_project.start_date", "type": "date", "label": "Start Date", "required_when": { "op": "in", "field": "construction_project.status", "value": ["active", "on_hold", "completed"] } },
        { "id": "construction_project.target_end_date", "type": "date", "label": "Target End Date", "required_when": { "op": "in", "field": "construction_project.status", "value": ["active", "on_hold", "completed"] } },
        { "id": "construction_project.contract_value", "type": "number", "label": "Contract Value" },
        { "id": "construction_project.labor_budget", "type": "number", "label": "Labor Budget" },
        { "id": "construction_project.material_budget", "type": "number", "label": "Material Budget" },
        { "id": "construction_project.other_budget", "type": "number", "label": "Other Budget" },
        { "id": "construction_project.notes", "type": "text", "label": "Notes" },
        { "id": "construction_project.attachments", "type": "attachments", "label": "Attachments" },
        { "id": "construction_project.created_at", "type": "datetime", "label": "Created At" }
      ]
    },
    {
      "id": "entity.construction_work_item",
      "display_field": "construction_work_item.title",
      "fields": [
        { "id": "construction_work_item.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "construction_work_item.project_id", "type": "lookup", "label": "Project", "entity": "entity.construction_project", "display_field": "construction_project.name", "required": true },
        { "id": "construction_work_item.site_id", "type": "lookup", "label": "Site", "entity": "entity.construction_site", "display_field": "construction_site.name" },
        { "id": "construction_work_item.title", "type": "string", "label": "Title", "required": true },
        { "id": "construction_work_item.sequence_code", "type": "string", "label": "Sequence / Code" },
        {
          "id": "construction_work_item.phase",
          "type": "enum",
          "label": "Phase",
          "default": "structure",
          "options": [
            { "value": "preliminaries", "label": "Preliminaries" },
            { "value": "foundation", "label": "Foundation" },
            { "value": "structure", "label": "Structure" },
            { "value": "mep", "label": "MEP" },
            { "value": "finishing", "label": "Finishing" },
            { "value": "handover", "label": "Handover" },
            { "value": "other", "label": "Other" }
          ]
        },
        { "id": "construction_work_item.cost_code_id", "type": "lookup", "label": "Cost Code", "entity": "entity.construction_cost_code", "display_field": "construction_cost_code.name" },
        { "id": "construction_work_item.assigned_crew_id", "type": "lookup", "label": "Assigned Crew", "entity": "entity.construction_crew", "display_field": "construction_crew.name" },
        { "id": "construction_work_item.owner_id", "type": "user", "label": "Owner", "required_when": { "op": "in", "field": "construction_work_item.status", "value": ["in_progress", "blocked", "done"] } },
        {
          "id": "construction_work_item.status",
          "type": "enum",
          "label": "Status",
          "default": "pending",
          "options": [
            { "value": "pending", "label": "Pending" },
            { "value": "in_progress", "label": "In Progress" },
            { "value": "blocked", "label": "Blocked" },
            { "value": "done", "label": "Done" },
            { "value": "cancelled", "label": "Cancelled" }
          ]
        },
        { "id": "construction_work_item.progress_percent", "type": "number", "label": "Progress %" },
        { "id": "construction_work_item.planned_start_date", "type": "date", "label": "Planned Start", "required_when": { "op": "in", "field": "construction_work_item.status", "value": ["in_progress", "blocked", "done"] } },
        { "id": "construction_work_item.planned_end_date", "type": "date", "label": "Planned End", "required_when": { "op": "in", "field": "construction_work_item.status", "value": ["blocked", "done"] } },
        { "id": "construction_work_item.notes", "type": "text", "label": "Notes" },
        { "id": "construction_work_item.created_at", "type": "datetime", "label": "Created At" }
      ]
    }
  ],
  "actions": [
    { "id": "action.construction_project_new", "kind": "open_form", "label": "+ New Project", "target": "construction_project.form" },
    { "id": "action.construction_work_item_new", "kind": "open_form", "label": "+ New Work Item", "target": "construction_work_item.form" },
    {
      "id": "action.construction_project_activate",
      "kind": "update_record",
      "label": "Start Project",
      "entity_id": "entity.construction_project",
      "patch": { "construction_project.status": "active" },
      "enabled_when": { "op": "eq", "field": "construction_project.status", "value": "planned" },
      "visible_when": { "op": "eq", "field": "construction_project.status", "value": "planned" }
    },
    {
      "id": "action.construction_project_hold",
      "kind": "update_record",
      "label": "Put On Hold",
      "entity_id": "entity.construction_project",
      "patch": { "construction_project.status": "on_hold" },
      "enabled_when": { "op": "eq", "field": "construction_project.status", "value": "active" },
      "visible_when": { "op": "eq", "field": "construction_project.status", "value": "active" }
    },
    {
      "id": "action.construction_project_resume",
      "kind": "update_record",
      "label": "Resume Project",
      "entity_id": "entity.construction_project",
      "patch": { "construction_project.status": "active" },
      "enabled_when": { "op": "eq", "field": "construction_project.status", "value": "on_hold" },
      "visible_when": { "op": "eq", "field": "construction_project.status", "value": "on_hold" }
    },
    {
      "id": "action.construction_project_complete",
      "kind": "update_record",
      "label": "Complete",
      "entity_id": "entity.construction_project",
      "patch": { "construction_project.status": "completed" },
      "enabled_when": { "op": "in", "field": "construction_project.status", "value": ["active", "on_hold"] },
      "visible_when": { "op": "in", "field": "construction_project.status", "value": ["active", "on_hold"] }
    },
    {
      "id": "action.construction_project_cancel",
      "kind": "update_record",
      "label": "Cancel Project",
      "entity_id": "entity.construction_project",
      "patch": { "construction_project.status": "cancelled" },
      "enabled_when": { "op": "in", "field": "construction_project.status", "value": ["planned", "active", "on_hold"] },
      "visible_when": { "op": "in", "field": "construction_project.status", "value": ["planned", "active", "on_hold"] }
    },
    {
      "id": "action.construction_work_item_start",
      "kind": "update_record",
      "label": "Start",
      "entity_id": "entity.construction_work_item",
      "patch": { "construction_work_item.status": "in_progress" },
      "enabled_when": { "op": "eq", "field": "construction_work_item.status", "value": "pending" },
      "visible_when": { "op": "eq", "field": "construction_work_item.status", "value": "pending" }
    },
    {
      "id": "action.construction_work_item_block",
      "kind": "update_record",
      "label": "Block",
      "entity_id": "entity.construction_work_item",
      "patch": { "construction_work_item.status": "blocked" },
      "enabled_when": { "op": "eq", "field": "construction_work_item.status", "value": "in_progress" },
      "visible_when": { "op": "eq", "field": "construction_work_item.status", "value": "in_progress" }
    },
    {
      "id": "action.construction_work_item_resume",
      "kind": "update_record",
      "label": "Resume",
      "entity_id": "entity.construction_work_item",
      "patch": { "construction_work_item.status": "in_progress" },
      "enabled_when": { "op": "eq", "field": "construction_work_item.status", "value": "blocked" },
      "visible_when": { "op": "eq", "field": "construction_work_item.status", "value": "blocked" }
    },
    {
      "id": "action.construction_work_item_done",
      "kind": "update_record",
      "label": "Mark Done",
      "entity_id": "entity.construction_work_item",
      "patch": { "construction_work_item.status": "done", "construction_work_item.progress_percent": 100 },
      "enabled_when": { "op": "in", "field": "construction_work_item.status", "value": ["in_progress", "blocked"] },
      "visible_when": { "op": "in", "field": "construction_work_item.status", "value": ["in_progress", "blocked"] }
    },
    {
      "id": "action.construction_work_item_cancel",
      "kind": "update_record",
      "label": "Cancel",
      "entity_id": "entity.construction_work_item",
      "patch": { "construction_work_item.status": "cancelled" },
      "enabled_when": { "op": "in", "field": "construction_work_item.status", "value": ["pending", "in_progress", "blocked"] },
      "visible_when": { "op": "in", "field": "construction_work_item.status", "value": ["pending", "in_progress", "blocked"] }
    }
  ],
  "triggers": [
    { "id": "construction_projects.record.project.created", "event": "record.created", "entity_id": "entity.construction_project" },
    { "id": "construction_projects.record.project.updated", "event": "record.updated", "entity_id": "entity.construction_project" },
    { "id": "construction_projects.record.work_item.created", "event": "record.created", "entity_id": "entity.construction_work_item" },
    { "id": "construction_projects.record.work_item.updated", "event": "record.updated", "entity_id": "entity.construction_work_item" }
  ],
  "views": [
    {
      "id": "construction_project.list",
      "kind": "list",
      "entity": "entity.construction_project",
      "columns": [
        { "field_id": "construction_project.name" },
        { "field_id": "construction_project.code" },
        { "field_id": "construction_project.client_contact_id" },
        { "field_id": "construction_project.site_id" },
        { "field_id": "construction_project.status" },
        { "field_id": "construction_project.priority" },
        { "field_id": "construction_project.project_manager_id" },
        { "field_id": "construction_project.target_end_date" }
      ],
      "header": {
        "primary_actions": [
          { "action_id": "action.construction_project_new" }
        ],
        "open_record_target": "page:construction_project.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search projects...",
          "fields": [
            "construction_project.name",
            "construction_project.code",
            "construction_project.site_location"
          ]
        },
        "filters": [
          { "id": "open", "label": "Open", "domain": { "op": "in", "field": "construction_project.status", "value": ["planned", "active", "on_hold"] } },
          { "id": "active", "label": "Active", "domain": { "op": "eq", "field": "construction_project.status", "value": "active" } },
          { "id": "completed", "label": "Completed", "domain": { "op": "eq", "field": "construction_project.status", "value": "completed" } }
        ]
      }
    },
    {
      "id": "construction_project.kanban",
      "kind": "kanban",
      "entity": "entity.construction_project",
      "card": {
        "title_field": "construction_project.name",
        "subtitle_fields": [
          "construction_project.code",
          "construction_project.site_location"
        ],
        "badge_fields": [
          "construction_project.status",
          "construction_project.priority",
          "construction_project.project_type"
        ]
      }
    },
    {
      "id": "construction_project.calendar",
      "kind": "calendar",
      "entity": "entity.construction_project",
      "calendar": {
        "title_field": "construction_project.name",
        "date_start": "construction_project.start_date",
        "color_field": "construction_project.status",
        "default_scale": "month"
      }
    },
    {
      "id": "construction_project.form",
      "kind": "form",
      "entity": "entity.construction_project",
      "sections": [
        {
          "id": "main",
          "title": "Project",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "construction_project.name",
            "construction_project.code",
            "construction_project.client_contact_id",
            "construction_project.site_id",
            "construction_project.site_location",
            "construction_project.project_type",
            "construction_project.priority",
            "construction_project.project_manager_id",
            "construction_project.site_manager_id",
            "construction_project.start_date",
            "construction_project.target_end_date"
          ]
        },
        {
          "id": "commercial",
          "title": "Commercial",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "construction_project.contract_value",
            "construction_project.labor_budget",
            "construction_project.material_budget",
            "construction_project.other_budget"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "construction_project.notes",
            "construction_project.attachments"
          ]
        }
      ],
      "header": {
        "statusbar": { "field_id": "construction_project.status" },
        "secondary_actions": [
          { "action_id": "action.construction_project_activate" },
          { "action_id": "action.construction_project_hold" },
          { "action_id": "action.construction_project_resume" },
          { "action_id": "action.construction_project_complete" },
          { "action_id": "action.construction_project_cancel" }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "main_tab",
          "tabs": [
            { "id": "main_tab", "label": "Project", "sections": ["main"] },
            { "id": "commercial_tab", "label": "Commercial", "sections": ["commercial"] },
            { "id": "notes_tab", "label": "Notes", "sections": ["notes"] }
          ]
        }
      }
    },
    {
      "id": "construction_project.graph",
      "kind": "graph",
      "entity": "entity.construction_project",
      "default": {
        "type": "bar",
        "group_by": "construction_project.status",
        "measure": "count"
      }
    },
    {
      "id": "construction_work_item.list",
      "kind": "list",
      "entity": "entity.construction_work_item",
      "columns": [
        { "field_id": "construction_work_item.project_id" },
        { "field_id": "construction_work_item.title" },
        { "field_id": "construction_work_item.phase" },
        { "field_id": "construction_work_item.cost_code_id" },
        { "field_id": "construction_work_item.assigned_crew_id" },
        { "field_id": "construction_work_item.status" },
        { "field_id": "construction_work_item.progress_percent" },
        { "field_id": "construction_work_item.planned_end_date" }
      ],
      "header": {
        "primary_actions": [
          { "action_id": "action.construction_work_item_new" }
        ],
        "open_record_target": "page:construction_work_item.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search work items...",
          "fields": [
            "construction_work_item.title",
            "construction_work_item.sequence_code",
            "construction_work_item.notes"
          ]
        },
        "filters": [
          { "id": "open", "label": "Open", "domain": { "op": "in", "field": "construction_work_item.status", "value": ["pending", "in_progress", "blocked"] } },
          { "id": "done", "label": "Done", "domain": { "op": "eq", "field": "construction_work_item.status", "value": "done" } }
        ]
      }
    },
    {
      "id": "construction_work_item.kanban",
      "kind": "kanban",
      "entity": "entity.construction_work_item",
      "card": {
        "title_field": "construction_work_item.title",
        "subtitle_fields": [
          "construction_work_item.sequence_code",
          "construction_work_item.phase"
        ],
        "badge_fields": [
          "construction_work_item.status",
          "construction_work_item.progress_percent"
        ]
      }
    },
    {
      "id": "construction_work_item.calendar",
      "kind": "calendar",
      "entity": "entity.construction_work_item",
      "calendar": {
        "title_field": "construction_work_item.title",
        "date_start": "construction_work_item.planned_start_date",
        "color_field": "construction_work_item.status",
        "default_scale": "month"
      }
    },
    {
      "id": "construction_work_item.form",
      "kind": "form",
      "entity": "entity.construction_work_item",
      "sections": [
        {
          "id": "main",
          "title": "Work Item",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "construction_work_item.project_id",
            "construction_work_item.site_id",
            "construction_work_item.title",
            "construction_work_item.sequence_code",
            "construction_work_item.phase",
            "construction_work_item.cost_code_id",
            "construction_work_item.assigned_crew_id",
            "construction_work_item.owner_id",
            "construction_work_item.progress_percent",
            "construction_work_item.planned_start_date",
            "construction_work_item.planned_end_date"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "construction_work_item.notes"
          ]
        }
      ],
      "header": {
        "statusbar": { "field_id": "construction_work_item.status" },
        "secondary_actions": [
          { "action_id": "action.construction_work_item_start" },
          { "action_id": "action.construction_work_item_block" },
          { "action_id": "action.construction_work_item_resume" },
          { "action_id": "action.construction_work_item_done" },
          { "action_id": "action.construction_work_item_cancel" }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "main_tab",
          "tabs": [
            { "id": "main_tab", "label": "Work Item", "sections": ["main"] },
            { "id": "notes_tab", "label": "Notes", "sections": ["notes"] }
          ]
        }
      }
    },
    {
      "id": "construction_work_item.graph",
      "kind": "graph",
      "entity": "entity.construction_work_item",
      "default": {
        "type": "bar",
        "group_by": "construction_work_item.status",
        "measure": "count"
      }
    }
  ],
  "workflows": [
    {
      "id": "workflow.construction_project_status",
      "entity": "entity.construction_project",
      "status_field": "construction_project.status",
      "states": [
        { "id": "planned", "label": "Planned" },
        { "id": "active", "label": "Active" },
        { "id": "on_hold", "label": "On Hold" },
        { "id": "completed", "label": "Completed" },
        { "id": "cancelled", "label": "Cancelled" }
      ]
    },
    {
      "id": "workflow.construction_work_item_status",
      "entity": "entity.construction_work_item",
      "status_field": "construction_work_item.status",
      "states": [
        { "id": "pending", "label": "Pending" },
        { "id": "in_progress", "label": "In Progress" },
        { "id": "blocked", "label": "Blocked" },
        { "id": "done", "label": "Done" },
        { "id": "cancelled", "label": "Cancelled" }
      ]
    }
  ],
  "pages": [
    {
      "id": "construction_project.list_page",
      "title": "Projects",
      "layout": "single",
      "header": { "variant": "none", "actions": [{ "action_id": "action.construction_project_new" }] },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.construction_project",
              "default_mode": "kanban",
              "modes": [
                { "mode": "kanban", "target": "view:construction_project.kanban", "default_group_by": "construction_project.status" },
                { "mode": "list", "target": "view:construction_project.list" },
                { "mode": "calendar", "target": "view:construction_project.calendar" },
                { "mode": "graph", "target": "view:construction_project.graph" },
                { "mode": "pivot", "target": "view:construction_project.list", "default_group_by": "construction_project.status" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "construction_project.form_page",
      "title": "Project",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.construction_project",
