.git
.gitignore

# OS/editor
**/.DS_Store
**/Thumbs.db
**/.idea
**/.vscode

# Python
**/__pycache__
**/*.py[cod]
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.coverage
**/.coverage.*
**/htmlcov
**/.venv
**/venv
**/env

# Node/Vite
**/node_modules
**/dist
**/.vite

# Environment/secrets
**/.env
**/.env.*
!**/.env.example

# Local data/artifacts
**/db-migration
**/*.dump
**/*.sql.gz
**/perf_results.log

# Runtime/temp files
**/*.log
**/*.tmp
**/*.swp

# Non-runtime project files
tests/
fly.toml
