{
  "manifest_version": "1.3",
  "module": {
    "id": "luke_contacts",
    "key": "luke_contacts",
    "name": "Contacts",
    "version": "1.0.0",
    "description": "Customers, suppliers, and factory partners for a commercial workflow workspace.",
    "category": "Commercial",
    "icon_key": "lucide:Users"
  },
  "app": {
    "home": "page:nl_contact.list_page",
    "defaults": {
      "entity_home_page": "page:nl_contact.list_page",
      "entity_form_page": "page:nl_contact.form_page",
      "entities": {
        "entity.nl_contact": {
          "entity_home_page": "page:nl_contact.list_page",
          "entity_form_page": "page:nl_contact.form_page"
        }
      }
    }
  },
  "entities": [
    {
      "id": "entity.nl_contact",
      "display_field": "nl_contact.name",
      "fields": [
        { "id": "nl_contact.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "nl_contact.name", "type": "string", "label": "Name", "required": true },
        {
          "id": "nl_contact.contact_type",
          "type": "enum",
          "label": "Type",
          "required": true,
          "default": "customer",
          "options": [
            { "value": "customer", "label": "Customer" },
            { "value": "supplier", "label": "Supplier" },
            { "value": "factory_partner", "label": "Factory Partner" }
          ]
        },
        { "id": "nl_contact.company_entity_scope", "type": "tags", "label": "Entity Scope" },
        { "id": "nl_contact.email", "type": "string", "label": "Email" },
        { "id": "nl_contact.phone", "type": "string", "label": "Phone" },
        { "id": "nl_contact.website", "type": "string", "label": "Website" },
        { "id": "nl_contact.country", "type": "string", "label": "Country" },
        {
          "id": "nl_contact.currency_preference",
          "type": "enum",
          "label": "Currency Preference",
          "default": "EUR",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" }
          ]
        },
        { "id": "nl_contact.billing_address", "type": "text", "label": "Billing Address" },
        { "id": "nl_contact.shipping_address", "type": "text", "label": "Shipping Address" },
        { "id": "nl_contact.notes", "type": "text", "label": "Notes" },
        { "id": "nl_contact.is_active", "type": "bool", "label": "Active", "default": true }
      ]
    }
  ],
  "actions": [
    { "id": "action.refresh", "kind": "refresh", "label": "Refresh" },
    { "id": "action.contact_new", "kind": "open_form", "label": "New Contact", "target": "nl_contact.form" },
    {
      "id": "action.contact_deactivate",
      "kind": "update_record",
      "entity_id": "entity.nl_contact",
      "label": "Deactivate",
      "patch": { "nl_contact.is_active": false },
      "visible_when": { "op": "eq", "field": "nl_contact.is_active", "value": true }
    },
    {
      "id": "action.contact_activate",
      "kind": "update_record",
      "entity_id": "entity.nl_contact",
      "label": "Activate",
      "patch": { "nl_contact.is_active": true },
      "visible_when": { "op": "eq", "field": "nl_contact.is_active", "value": false }
    }
  ],
  "views": [
    {
      "id": "nl_contact.list",
      "kind": "list",
      "entity": "entity.nl_contact",
      "columns": [
        { "field_id": "nl_contact.name" },
        { "field_id": "nl_contact.contact_type" },
        { "field_id": "nl_contact.country" },
        { "field_id": "nl_contact.email" },
        { "field_id": "nl_contact.phone" },
        { "field_id": "nl_contact.is_active" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.contact_new" }],
        "open_record_target": "page:nl_contact.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search contacts...",
          "fields": ["nl_contact.name", "nl_contact.email", "nl_contact.country"]
        },
        "filters": [
          { "id": "all", "label": "All Contacts", "domain": { "op": "exists", "field": "nl_contact.name" } },
          { "id": "customers", "label": "Customers", "domain": { "op": "eq", "field": "nl_contact.contact_type", "value": "customer" } },
          { "id": "suppliers", "label": "Suppliers", "domain": { "op": "eq", "field": "nl_contact.contact_type", "value": "supplier" } },
          { "id": "factory_partners", "label": "Factory Partners", "domain": { "op": "eq", "field": "nl_contact.contact_type", "value": "factory_partner" } },
          { "id": "active", "label": "Active", "domain": { "op": "eq", "field": "nl_contact.is_active", "value": true } }
        ]
      }
    },
    {
      "id": "nl_contact.form",
      "kind": "form",
      "entity": "entity.nl_contact",
      "sections": [
        {
          "id": "main",
          "title": "Contact",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_contact.name",
            "nl_contact.contact_type",
            "nl_contact.country",
            "nl_contact.currency_preference",
            "nl_contact.email",
            "nl_contact.phone",
            "nl_contact.website",
            "nl_contact.is_active"
          ]
        },
        {
          "id": "addresses",
          "title": "Addresses",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_contact.billing_address",
            "nl_contact.shipping_address"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "nl_contact.company_entity_scope",
            "nl_contact.notes"
          ]
        }
      ],
      "header": {
        "secondary_actions": [
          { "action_id": "action.contact_activate" },
          { "action_id": "action.contact_deactivate" },
          { "action_id": "action.refresh" }
        ]
      }
    },
    {
      "id": "nl_contact.kanban",
      "kind": "kanban",
      "entity": "entity.nl_contact",
      "card": {
        "title_field": "nl_contact.name",
        "subtitle_fields": [
          "nl_contact.country",
          "nl_contact.currency_preference"
        ],
        "badge_fields": [
          "nl_contact.contact_type",
          "nl_contact.is_active"
        ]
      }
    },
    {
      "id": "nl_contact.graph",
      "kind": "graph",
      "entity": "entity.nl_contact",
      "default": {
        "type": "bar",
        "group_by": "nl_contact.contact_type",
        "measure": "count"
      }
    }
  ],
  "pages": [
    {
      "id": "nl_contact.list_page",
      "title": "Contacts",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.nl_contact",
              "default_mode": "list",
              "default_filter_id": "active",
              "modes": [
                { "mode": "list", "target": "view:nl_contact.list" },
                { "mode": "kanban", "target": "view:nl_contact.kanban", "default_group_by": "nl_contact.contact_type" },
                { "mode": "graph", "target": "view:nl_contact.graph" },
                { "mode": "pivot", "target": "view:nl_contact.list", "default_group_by": "nl_contact.contact_type" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "nl_contact.form_page",
      "title": "Contact",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.nl_contact",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "view", "target": "view:nl_contact.form" }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "chatter", "entity_id": "entity.nl_contact", "record_ref": "$record.id" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "workflows": [],
  "transformations": []
}
