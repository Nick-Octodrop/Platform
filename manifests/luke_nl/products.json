{
  "manifest_version": "1.3",
  "module": {
    "id": "luke_products",
    "key": "luke_products",
    "name": "Products",
    "version": "1.0.0",
    "description": "Product catalogue items for quoting and purchasing.",
    "category": "Commercial",
    "icon_key": "lucide:Package2"
  },
  "depends_on": {
    "required": [
      { "module": "luke_contacts", "version": ">=1.0.0" }
    ]
  },
  "app": {
    "home": "page:nl_product.list_page",
    "defaults": {
      "entity_home_page": "page:nl_product.list_page",
      "entity_form_page": "page:nl_product.form_page",
      "entities": {
        "entity.nl_product": {
          "entity_home_page": "page:nl_product.list_page",
          "entity_form_page": "page:nl_product.form_page"
        }
      }
    }
  },
  "entities": [
    {
      "id": "entity.nl_product",
      "display_field": "nl_product.name",
      "fields": [
        { "id": "nl_product.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "nl_product.code", "type": "string", "label": "Code", "required": true },
        { "id": "nl_product.name", "type": "string", "label": "Name", "required": true },
        { "id": "nl_product.description", "type": "text", "label": "Description" },
        { "id": "nl_product.category", "type": "string", "label": "Category" },
        {
          "id": "nl_product.uom",
          "type": "enum",
          "label": "UOM",
          "default": "EA",
          "options": [
            { "value": "EA", "label": "Each" },
            { "value": "SET", "label": "Set" },
            { "value": "KIT", "label": "Kit" },
            { "value": "LOT", "label": "Lot" }
          ]
        },
        {
          "id": "nl_product.default_sales_currency",
          "type": "enum",
          "label": "Sales Currency",
          "default": "EUR",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" }
          ]
        },
        {
          "id": "nl_product.default_sales_price",
          "type": "number",
          "label": "Sales Price",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "nl_product.default_sales_currency", "precision": 2 }
        },
        {
          "id": "nl_product.default_purchase_currency",
          "type": "enum",
          "label": "Purchase Currency",
          "default": "USD",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" }
          ]
        },
        {
          "id": "nl_product.default_buy_price",
          "type": "number",
          "label": "Buy Price",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "nl_product.default_purchase_currency", "precision": 2 }
        },
        {
          "id": "nl_product.preferred_supplier_id",
          "type": "lookup",
          "label": "Preferred Supplier",
          "entity": "entity.nl_contact",
          "display_field": "nl_contact.name"
        },
        { "id": "nl_product.supplier_factory_reference", "type": "string", "label": "Supplier / Factory Ref" },
        { "id": "nl_product.internal_notes", "type": "text", "label": "Internal Notes" },
        { "id": "nl_product.is_active", "type": "bool", "label": "Active", "default": true }
      ]
    }
  ],
  "actions": [
    { "id": "action.refresh", "kind": "refresh", "label": "Refresh" },
    { "id": "action.product_new", "kind": "open_form", "label": "New Product", "target": "nl_product.form" },
    {
      "id": "action.product_activate",
      "kind": "update_record",
      "entity_id": "entity.nl_product",
      "label": "Activate",
      "patch": { "nl_product.is_active": true },
      "visible_when": { "op": "eq", "field": "nl_product.is_active", "value": false }
    },
    {
      "id": "action.product_deactivate",
      "kind": "update_record",
      "entity_id": "entity.nl_product",
      "label": "Deactivate",
      "patch": { "nl_product.is_active": false },
      "visible_when": { "op": "eq", "field": "nl_product.is_active", "value": true }
    }
  ],
  "views": [
    {
      "id": "nl_product.list",
      "kind": "list",
      "entity": "entity.nl_product",
      "columns": [
        { "field_id": "nl_product.code" },
        { "field_id": "nl_product.name" },
        { "field_id": "nl_product.default_sales_price" },
        { "field_id": "nl_product.default_sales_currency" },
        { "field_id": "nl_product.default_buy_price" },
        { "field_id": "nl_product.default_purchase_currency" },
        { "field_id": "nl_product.preferred_supplier_id" },
        { "field_id": "nl_product.is_active" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.product_new" }],
        "open_record_target": "page:nl_product.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search products...",
          "fields": ["nl_product.code", "nl_product.name", "nl_product.description"]
        },
        "filters": [
          { "id": "active", "label": "Active Products", "domain": { "op": "eq", "field": "nl_product.is_active", "value": true } },
          { "id": "inactive", "label": "Inactive Products", "domain": { "op": "eq", "field": "nl_product.is_active", "value": false } },
          { "id": "eur_sales", "label": "EUR Sales Items", "domain": { "op": "eq", "field": "nl_product.default_sales_currency", "value": "EUR" } },
          { "id": "usd_sales", "label": "USD Sales Items", "domain": { "op": "eq", "field": "nl_product.default_sales_currency", "value": "USD" } }
        ]
      }
    },
    {
      "id": "nl_product.form",
      "kind": "form",
      "entity": "entity.nl_product",
      "sections": [
        {
          "id": "core",
          "title": "Product Catalogue",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_product.code",
            "nl_product.name",
            "nl_product.category",
            "nl_product.uom",
            "nl_product.description",
            "nl_product.is_active"
          ]
        },
        {
          "id": "pricing",
          "title": "Pricing",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_product.default_sales_currency",
            "nl_product.default_sales_price",
            "nl_product.default_purchase_currency",
            "nl_product.default_buy_price"
          ]
        },
        {
          "id": "purchasing",
          "title": "Purchasing Notes",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_product.preferred_supplier_id",
            "nl_product.supplier_factory_reference",
            "nl_product.internal_notes"
          ]
        }
      ],
      "header": {
        "secondary_actions": [
          { "action_id": "action.product_activate" },
          { "action_id": "action.product_deactivate" },
          { "action_id": "action.refresh" }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "core",
          "tabs": [
            { "id": "core", "label": "Summary", "sections": ["core"] },
            { "id": "pricing", "label": "Pricing", "sections": ["pricing"] },
            { "id": "purchasing", "label": "Purchasing", "sections": ["purchasing"] }
          ]
        }
      }
    },
    {
      "id": "nl_product.kanban",
      "kind": "kanban",
      "entity": "entity.nl_product",
      "card": {
        "title_field": "nl_product.code",
        "subtitle_fields": [
          "nl_product.name",
          "nl_product.uom"
        ],
        "badge_fields": [
          "nl_product.default_sales_currency",
          "nl_product.is_active"
        ]
      }
    },
    {
      "id": "nl_product.graph",
      "kind": "graph",
      "entity": "entity.nl_product",
      "default": {
        "type": "bar",
        "group_by": "nl_product.category",
        "measure": "count"
      }
    }
  ],
  "pages": [
    {
      "id": "nl_product.list_page",
      "title": "Products",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.nl_product",
              "default_mode": "list",
              "default_filter_id": "active",
              "modes": [
                { "mode": "list", "target": "view:nl_product.list" },
                { "mode": "kanban", "target": "view:nl_product.kanban", "default_group_by": "nl_product.category" },
                { "mode": "graph", "target": "view:nl_product.graph" },
                { "mode": "pivot", "target": "view:nl_product.list", "default_group_by": "nl_product.category" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "nl_product.form_page",
      "title": "Product",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.nl_product",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "view", "target": "view:nl_product.form" }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "chatter", "entity_id": "entity.nl_product", "record_ref": "$record.id" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "workflows": [],
  "transformations": []
}
