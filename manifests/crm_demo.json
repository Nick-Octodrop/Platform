{
  "manifest_version": "1.3",
  "module": {
    "id": "crm_demo",
    "name": "CRM",
    "version": "1.0.0",
    "description": "Sales CRM demo with leads, pipeline opportunities, and follow-up activities using the Contacts module.",
    "category": "Sales",
    "icon_key": "lucide:BadgeDollarSign"
  },
  "app": {
    "home": "page:crm_opportunity.list_page",
    "defaults": {
      "entity_home_page": "page:crm_opportunity.list_page",
      "entity_form_page": "page:crm_opportunity.form_page",
      "entities": {
        "entity.crm_lead": {
          "entity_home_page": "page:crm_lead.list_page",
          "entity_form_page": "page:crm_lead.form_page"
        },
        "entity.crm_opportunity": {
          "entity_home_page": "page:crm_opportunity.list_page",
          "entity_form_page": "page:crm_opportunity.form_page"
        },
        "entity.crm_activity": {
          "entity_home_page": "page:crm_activity.list_page",
          "entity_form_page": "page:crm_activity.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "CRM",
        "items": [
          {
            "label": "Pipeline",
            "to": "page:crm_opportunity.list_page"
          },
          {
            "label": "Leads",
            "to": "page:crm_lead.list_page"
          },
          {
            "label": "Activities",
            "to": "page:crm_activity.list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.crm_lead",
      "display_field": "crm_lead.title",
      "fields": [
        {
          "id": "crm_lead.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "crm_lead.title",
          "type": "string",
          "label": "Lead Title",
          "required": true
        },
        {
          "id": "crm_lead.status",
          "type": "enum",
          "label": "Status",
          "required": true,
          "default": "new",
          "options": [
            { "value": "new", "label": "New" },
            { "value": "contacted", "label": "Contacted" },
            { "value": "qualified", "label": "Qualified" },
            { "value": "unqualified", "label": "Unqualified" },
            { "value": "converted", "label": "Converted" }
          ]
        },
        {
          "id": "crm_lead.source",
          "type": "enum",
          "label": "Source",
          "default": "website",
          "options": [
            { "value": "website", "label": "Website" },
            { "value": "referral", "label": "Referral" },
            { "value": "email", "label": "Email" },
            { "value": "phone", "label": "Phone" },
            { "value": "social", "label": "Social" },
            { "value": "event", "label": "Event" },
            { "value": "other", "label": "Other" }
          ]
        },
        {
          "id": "crm_lead.priority",
          "type": "enum",
          "label": "Priority",
          "default": "normal",
          "options": [
            { "value": "low", "label": "Low" },
            { "value": "normal", "label": "Normal" },
            { "value": "high", "label": "High" },
            { "value": "urgent", "label": "Urgent" }
          ]
        },
        {
          "id": "crm_lead.contact_id",
          "type": "lookup",
          "label": "Primary Contact",
          "entity": "entity.contact",
          "display_field": "contact.display_name",
          "required": true
        },
        {
          "id": "crm_lead.company_name",
          "type": "string",
          "label": "Company"
        },
        {
          "id": "crm_lead.assignee_id",
          "type": "lookup",
          "label": "Owner",
          "entity": "entity.contact",
          "display_field": "contact.display_name"
        },
        {
          "id": "crm_lead.estimated_value",
          "type": "number",
          "label": "Estimated Value",
          "default": 0
        },
        {
          "id": "crm_lead.currency",
          "type": "string",
          "label": "Currency",
          "default": "USD"
        },
        {
          "id": "crm_lead.next_touch_at",
          "type": "datetime",
          "label": "Next Touch"
        },
        {
          "id": "crm_lead.disqualify_reason",
          "type": "text",
          "label": "Disqualify Reason"
        },
        {
          "id": "crm_lead.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "crm_lead.tags",
          "type": "tags",
          "label": "Tags"
        }
      ]
    },
    {
      "id": "entity.crm_opportunity",
      "display_field": "crm_opportunity.name",
      "fields": [
        {
          "id": "crm_opportunity.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "crm_opportunity.name",
          "type": "string",
          "label": "Opportunity",
          "required": true
        },
        {
          "id": "crm_opportunity.stage",
          "type": "enum",
          "label": "Stage",
          "required": true,
          "default": "qualification",
          "options": [
            { "value": "qualification", "label": "Qualification" },
            { "value": "discovery", "label": "Discovery" },
            { "value": "proposal", "label": "Proposal" },
            { "value": "negotiation", "label": "Negotiation" },
            { "value": "won", "label": "Won" },
            { "value": "lost", "label": "Lost" }
          ]
        },
        {
          "id": "crm_opportunity.status",
          "type": "enum",
          "label": "Status",
          "default": "open",
          "options": [
            { "value": "open", "label": "Open" },
            { "value": "won", "label": "Won" },
            { "value": "lost", "label": "Lost" }
          ]
        },
        {
          "id": "crm_opportunity.lead_id",
          "type": "lookup",
          "label": "Source Lead",
          "entity": "entity.crm_lead",
          "display_field": "crm_lead.title"
        },
        {
          "id": "crm_opportunity.contact_id",
          "type": "lookup",
          "label": "Primary Contact",
          "entity": "entity.contact",
          "display_field": "contact.display_name",
          "required": true
        },
        {
          "id": "crm_opportunity.assignee_id",
          "type": "lookup",
          "label": "Account Owner",
          "entity": "entity.contact",
          "display_field": "contact.display_name"
        },
        {
          "id": "crm_opportunity.amount",
          "type": "number",
          "label": "Amount",
          "default": 0
        },
        {
          "id": "crm_opportunity.currency",
          "type": "string",
          "label": "Currency",
          "default": "USD"
        },
        {
          "id": "crm_opportunity.probability_pct",
          "type": "number",
          "label": "Probability %",
          "default": 25
        },
        {
          "id": "crm_opportunity.expected_close_at",
          "type": "datetime",
          "label": "Expected Close"
        },
        {
          "id": "crm_opportunity.actual_close_at",
          "type": "datetime",
          "label": "Actual Close"
        },
        {
          "id": "crm_opportunity.deal_type",
          "type": "enum",
          "label": "Deal Type",
          "default": "new_business",
          "options": [
            { "value": "new_business", "label": "New Business" },
            { "value": "upsell", "label": "Upsell" },
            { "value": "renewal", "label": "Renewal" },
            { "value": "cross_sell", "label": "Cross-sell" }
          ]
        },
        {
          "id": "crm_opportunity.loss_reason",
          "type": "text",
          "label": "Loss Reason"
        },
        {
          "id": "crm_opportunity.competitor",
          "type": "string",
          "label": "Competitor"
        },
        {
          "id": "crm_opportunity.next_step",
          "type": "string",
          "label": "Next Step"
        },
        {
          "id": "crm_opportunity.next_step_due_at",
          "type": "datetime",
          "label": "Next Step Due"
        },
        {
          "id": "crm_opportunity.summary",
          "type": "text",
          "label": "Summary"
        },
        {
          "id": "crm_opportunity.internal_notes",
          "type": "text",
          "label": "Internal Notes"
        },
        {
          "id": "crm_opportunity.attachments",
          "type": "attachments",
          "label": "Files",
          "ui": {
            "button_label": "Attach proposal files",
            "title": "Opportunity Files",
            "description": "Add proposals, quotes, and call notes."
          }
        },
        {
          "id": "crm_opportunity.tags",
          "type": "tags",
          "label": "Tags"
        }
      ]
    },
    {
      "id": "entity.crm_activity",
      "display_field": "crm_activity.subject",
      "fields": [
        {
          "id": "crm_activity.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "crm_activity.subject",
          "type": "string",
          "label": "Subject",
          "required": true
        },
        {
          "id": "crm_activity.type",
          "type": "enum",
          "label": "Type",
          "default": "task",
          "options": [
            { "value": "task", "label": "Task" },
            { "value": "call", "label": "Call" },
            { "value": "meeting", "label": "Meeting" },
            { "value": "email", "label": "Email" },
            { "value": "demo", "label": "Demo" }
          ]
        },
        {
          "id": "crm_activity.status",
          "type": "enum",
          "label": "Status",
          "default": "todo",
          "options": [
            { "value": "todo", "label": "To Do" },
            { "value": "in_progress", "label": "In Progress" },
            { "value": "done", "label": "Done" },
            { "value": "cancelled", "label": "Cancelled" }
          ]
        },
        {
          "id": "crm_activity.priority",
          "type": "enum",
          "label": "Priority",
          "default": "normal",
          "options": [
            { "value": "low", "label": "Low" },
            { "value": "normal", "label": "Normal" },
            { "value": "high", "label": "High" },
            { "value": "urgent", "label": "Urgent" }
          ]
        },
        {
          "id": "crm_activity.opportunity_id",
          "type": "lookup",
          "label": "Opportunity",
          "entity": "entity.crm_opportunity",
          "display_field": "crm_opportunity.name"
        },
        {
          "id": "crm_activity.lead_id",
          "type": "lookup",
          "label": "Lead",
          "entity": "entity.crm_lead",
          "display_field": "crm_lead.title"
        },
        {
          "id": "crm_activity.contact_id",
          "type": "lookup",
          "label": "Contact",
          "entity": "entity.contact",
          "display_field": "contact.display_name"
        },
        {
          "id": "crm_activity.assignee_id",
          "type": "lookup",
          "label": "Assigned To",
          "entity": "entity.contact",
          "display_field": "contact.display_name"
        },
        {
          "id": "crm_activity.starts_at",
          "type": "datetime",
          "label": "Start",
          "required": true
        },
        {
          "id": "crm_activity.ends_at",
          "type": "datetime",
          "label": "End"
        },
        {
          "id": "crm_activity.outcome",
          "type": "text",
          "label": "Outcome"
        },
        {
          "id": "crm_activity.location",
          "type": "string",
          "label": "Location"
        },
        {
          "id": "crm_activity.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "crm_activity.tags",
          "type": "tags",
          "label": "Tags"
        }
      ]
    }
  ],
  "relations": [
    { "from": "crm_lead.contact_id", "to": "contact.id", "label_field": "contact.display_name" },
    { "from": "crm_lead.assignee_id", "to": "contact.id", "label_field": "contact.display_name" },
    { "from": "crm_opportunity.lead_id", "to": "crm_lead.id", "label_field": "crm_lead.title" },
    { "from": "crm_opportunity.contact_id", "to": "contact.id", "label_field": "contact.display_name" },
    { "from": "crm_opportunity.assignee_id", "to": "contact.id", "label_field": "contact.display_name" },
    { "from": "crm_activity.opportunity_id", "to": "crm_opportunity.id", "label_field": "crm_opportunity.name" },
    { "from": "crm_activity.lead_id", "to": "crm_lead.id", "label_field": "crm_lead.title" },
    { "from": "crm_activity.contact_id", "to": "contact.id", "label_field": "contact.display_name" },
    { "from": "crm_activity.assignee_id", "to": "contact.id", "label_field": "contact.display_name" }
  ],
  "workflows": [
    {
      "id": "crm_lead_status_workflow",
      "entity": "entity.crm_lead",
      "status_field": "crm_lead.status",
      "states": [
        { "id": "new", "label": "New" },
        { "id": "contacted", "label": "Contacted" },
        { "id": "qualified", "label": "Qualified" },
        { "id": "unqualified", "label": "Unqualified" },
        { "id": "converted", "label": "Converted" }
      ]
    },
    {
      "id": "crm_activity_status_workflow",
      "entity": "entity.crm_activity",
      "status_field": "crm_activity.status",
      "states": [
        { "id": "todo", "label": "To Do" },
        { "id": "in_progress", "label": "In Progress" },
        { "id": "done", "label": "Done" },
        { "id": "cancelled", "label": "Cancelled" }
      ]
    }
  ],
  "actions": [
    { "id": "action.refresh", "kind": "refresh", "label": "Refresh" },
    { "id": "action.crm_lead_new", "kind": "open_form", "target": "crm_lead.form", "label": "New Lead" },
    { "id": "action.crm_opportunity_new", "kind": "open_form", "target": "crm_opportunity.form", "label": "New Opportunity" },
    { "id": "action.crm_activity_new", "kind": "open_form", "target": "crm_activity.form", "label": "New Activity" },

    {
      "id": "action.lead_mark_contacted",
      "kind": "update_record",
      "entity_id": "entity.crm_lead",
      "label": "Mark Contacted",
      "patch": { "crm_lead.status": "contacted" },
      "visible_when": { "op": "eq", "field": "crm_lead.status", "value": "new" }
    },
    {
      "id": "action.lead_qualify",
      "kind": "update_record",
      "entity_id": "entity.crm_lead",
      "label": "Qualify",
      "patch": { "crm_lead.status": "qualified" },
      "visible_when": {
        "op": "or",
        "conditions": [
          { "op": "eq", "field": "crm_lead.status", "value": "new" },
          { "op": "eq", "field": "crm_lead.status", "value": "contacted" }
        ]
      }
    },
    {
      "id": "action.lead_disqualify",
      "kind": "refresh",
      "label": "Disqualify",
      "modal_id": "modal.lead_disqualify",
      "visible_when": {
        "op": "or",
        "conditions": [
          { "op": "eq", "field": "crm_lead.status", "value": "new" },
          { "op": "eq", "field": "crm_lead.status", "value": "contacted" },
          { "op": "eq", "field": "crm_lead.status", "value": "qualified" }
        ]
      }
    },
    {
      "id": "action.lead_disqualify_confirm",
      "kind": "update_record",
      "entity_id": "entity.crm_lead",
      "label": "Confirm Disqualify",
      "patch": {
        "crm_lead.status": "unqualified",
        "crm_lead.disqualify_reason": { "ref": "$record.crm_lead.disqualify_reason" }
      }
    },
    { "id": "action.lead_disqualify_decline", "kind": "refresh", "label": "Keep Lead" },

    {
      "id": "action.opportunity_advance_discovery",
      "kind": "update_record",
      "entity_id": "entity.crm_opportunity",
      "label": "Move to Discovery",
      "patch": { "crm_opportunity.stage": "discovery", "crm_opportunity.probability_pct": 35 },
      "visible_when": { "op": "eq", "field": "crm_opportunity.stage", "value": "qualification" }
    },
    {
      "id": "action.opportunity_advance_proposal",
      "kind": "update_record",
      "entity_id": "entity.crm_opportunity",
      "label": "Move to Proposal",
      "patch": { "crm_opportunity.stage": "proposal", "crm_opportunity.probability_pct": 60 },
      "visible_when": { "op": "eq", "field": "crm_opportunity.stage", "value": "discovery" }
    },
    {
      "id": "action.opportunity_advance_negotiation",
      "kind": "update_record",
      "entity_id": "entity.crm_opportunity",
      "label": "Move to Negotiation",
      "patch": { "crm_opportunity.stage": "negotiation", "crm_opportunity.probability_pct": 80 },
      "visible_when": { "op": "eq", "field": "crm_opportunity.stage", "value": "proposal" }
    },
    {
      "id": "action.opportunity_mark_won",
      "kind": "update_record",
      "entity_id": "entity.crm_opportunity",
      "label": "Mark Won",
      "patch": {
        "crm_opportunity.stage": "won",
        "crm_opportunity.status": "won",
        "crm_opportunity.probability_pct": 100
      },
      "visible_when": {
        "op": "or",
        "conditions": [
          { "op": "eq", "field": "crm_opportunity.stage", "value": "proposal" },
          { "op": "eq", "field": "crm_opportunity.stage", "value": "negotiation" }
        ]
      }
    },
    {
      "id": "action.opportunity_mark_lost",
      "kind": "refresh",
      "label": "Mark Lost",
      "modal_id": "modal.opportunity_lost_reason",
      "visible_when": {
        "op": "or",
        "conditions": [
          { "op": "eq", "field": "crm_opportunity.stage", "value": "qualification" },
          { "op": "eq", "field": "crm_opportunity.stage", "value": "discovery" },
          { "op": "eq", "field": "crm_opportunity.stage", "value": "proposal" },
          { "op": "eq", "field": "crm_opportunity.stage", "value": "negotiation" }
        ]
      }
    },
    {
      "id": "action.opportunity_mark_lost_confirm",
      "kind": "update_record",
      "entity_id": "entity.crm_opportunity",
      "label": "Confirm Lost",
      "patch": {
        "crm_opportunity.stage": "lost",
        "crm_opportunity.status": "lost",
        "crm_opportunity.loss_reason": { "ref": "$record.crm_opportunity.loss_reason" }
      }
    },
    { "id": "action.opportunity_mark_lost_decline", "kind": "refresh", "label": "Keep Open" },
    {
      "id": "action.opportunity_reopen",
      "kind": "update_record",
      "entity_id": "entity.crm_opportunity",
      "label": "Reopen",
      "patch": { "crm_opportunity.stage": "qualification", "crm_opportunity.status": "open", "crm_opportunity.probability_pct": 25 },
      "visible_when": {
        "op": "or",
        "conditions": [
          { "op": "eq", "field": "crm_opportunity.stage", "value": "won" },
          { "op": "eq", "field": "crm_opportunity.stage", "value": "lost" }
        ]
      }
    },

    {
      "id": "action.crm_activity_new_for_opportunity",
      "kind": "create_record",
      "entity_id": "entity.crm_activity",
      "label": "Log Follow-up",
      "defaults": {
        "crm_activity.opportunity_id": { "ref": "$record.id" },
        "crm_activity.contact_id": { "ref": "$record.crm_opportunity.contact_id" },
        "crm_activity.assignee_id": { "ref": "$record.crm_opportunity.assignee_id" },
        "crm_activity.subject": "Follow-up",
        "crm_activity.type": "task",
        "crm_activity.status": "todo"
      },
      "visible_when": { "op": "exists", "field": "crm_opportunity.name" }
    },
    {
      "id": "action.crm_activity_mark_done",
      "kind": "update_record",
      "entity_id": "entity.crm_activity",
      "label": "Mark Done",
      "patch": { "crm_activity.status": "done" }
    },
    {
      "id": "action.crm_activity_start",
      "kind": "update_record",
      "entity_id": "entity.crm_activity",
      "label": "Start",
      "patch": { "crm_activity.status": "in_progress" }
    }
  ],
  "modals": [
    {
      "id": "modal.opportunity_lost_reason",
      "title": "Mark Opportunity Lost",
      "description": "Add a reason before closing this opportunity as lost.",
      "entity_id": "entity.crm_opportunity",
      "fields": ["crm_opportunity.loss_reason"],
      "actions": [
        {
          "action_id": "action.opportunity_mark_lost_decline",
          "label": "Keep Open",
          "variant": "soft",
          "close_on_success": true
        },
        {
          "action_id": "action.opportunity_mark_lost_confirm",
          "label": "Confirm Lost",
          "variant": "primary",
          "close_on_success": true
        }
      ]
    },
    {
      "id": "modal.lead_disqualify",
      "title": "Disqualify Lead",
      "description": "Capture why this lead is not a fit.",
      "entity_id": "entity.crm_lead",
      "fields": ["crm_lead.disqualify_reason"],
      "actions": [
        {
          "action_id": "action.lead_disqualify_decline",
          "label": "Keep Lead",
          "variant": "soft",
          "close_on_success": true
        },
        {
          "action_id": "action.lead_disqualify_confirm",
          "label": "Confirm Disqualify",
          "variant": "primary",
          "close_on_success": true
        }
      ]
    }
  ],
  "triggers": [
    { "id": "crm_demo.opportunity.created", "event": "record.created", "entity_id": "entity.crm_opportunity" },
    { "id": "crm_demo.opportunity.updated", "event": "record.updated", "entity_id": "entity.crm_opportunity" },
    { "id": "crm_demo.activity.created", "event": "record.created", "entity_id": "entity.crm_activity" },
    { "id": "crm_demo.action.opportunity_mark_lost_confirm", "event": "action.clicked", "action_id": "action.opportunity_mark_lost_confirm" }
  ],
  "views": [
    {
      "id": "crm_lead.list",
      "entity": "entity.crm_lead",
      "kind": "list",
      "columns": [
        { "field_id": "crm_lead.title" },
        { "field_id": "crm_lead.status" },
        { "field_id": "crm_lead.source" },
        { "field_id": "crm_lead.priority" },
        { "field_id": "crm_lead.contact_id" },
        { "field_id": "crm_lead.assignee_id" },
        { "field_id": "crm_lead.estimated_value" },
        { "field_id": "crm_lead.next_touch_at" }
      ],
      "open_record": { "to": "page:crm_lead.form_page", "param": "record" },
      "header": {
        "primary_actions": [{ "action_id": "action.crm_lead_new" }],
        "search": {
