{
  "manifest_version": "1.3",
  "module": {
    "id": "construction_time_entries",
    "key": "construction_time_entries",
    "name": "Construction Time Entries",
    "version": "1.0.0",
    "description": "Attendance and labor time records for worker clock in, clock out, and approvals.",
    "category": "Construction",
    "icon_key": "lucide:Timer"
  },
  "depends_on": {
    "required": [
      {
        "module": "construction_projects",
        "version": ">=1.0.0"
      },
      {
        "module": "construction_workers",
        "version": ">=1.0.0"
      }
    ]
  },
  "app": {
    "home": "page:time_entry.list_page",
    "defaults": {
      "entity_home_page": "page:time_entry.list_page",
      "entity_form_page": "page:time_entry.form_page",
      "entities": {
        "entity.time_entry": {
          "entity_home_page": "page:time_entry.list_page",
          "entity_form_page": "page:time_entry.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Construction",
        "items": [
          {
            "label": "Time Entries",
            "to": "page:time_entry.list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.time_entry",
      "display_field": "time_entry.entry_date",
      "fields": [
        {
          "id": "time_entry.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "time_entry.project_id",
          "type": "lookup",
          "label": "Project",
          "entity": "entity.construction_project",
          "display_field": "construction_project.name",
          "required": true
        },
        {
          "id": "time_entry.worker_id",
          "type": "lookup",
          "label": "Worker",
          "entity": "entity.construction_worker",
          "display_field": "construction_worker.full_name",
          "required": true
        },
        {
          "id": "time_entry.entry_date",
          "type": "date",
          "label": "Entry Date",
          "required": true
        },
        {
          "id": "time_entry.check_in_at",
          "type": "datetime",
          "label": "Check In"
        },
        {
          "id": "time_entry.check_out_at",
          "type": "datetime",
          "label": "Check Out"
        },
        {
          "id": "time_entry.hours_worked",
          "type": "number",
          "label": "Hours Worked"
        },
        {
          "id": "time_entry.status",
          "type": "enum",
          "label": "Status",
          "default": "open",
          "options": [
            { "value": "open", "label": "Open" },
            { "value": "closed", "label": "Closed" },
            { "value": "approved", "label": "Approved" }
          ]
        },
        {
          "id": "time_entry.source",
          "type": "enum",
          "label": "Source",
          "default": "pwa",
          "options": [
            { "value": "pwa", "label": "PWA" },
            { "value": "portal", "label": "Portal" },
            { "value": "manual", "label": "Manual" }
          ]
        },
        {
          "id": "time_entry.supervisor_id",
          "type": "user",
          "label": "Supervisor"
        },
        {
          "id": "time_entry.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "time_entry.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.time_entry_new",
      "kind": "open_form",
      "label": "+ New Time Entry",
      "target": "time_entry.form"
    },
    {
      "id": "action.time_entry_close",
      "kind": "update_record",
      "label": "Close Entry",
      "entity_id": "entity.time_entry",
      "patch": {
        "time_entry.status": "closed"
      },
      "enabled_when": {
        "op": "eq",
        "field": "time_entry.status",
        "value": "open"
      },
      "visible_when": {
        "op": "eq",
        "field": "time_entry.status",
        "value": "open"
      }
    },
    {
      "id": "action.time_entry_approve",
      "kind": "update_record",
      "label": "Approve",
      "entity_id": "entity.time_entry",
      "patch": {
        "time_entry.status": "approved"
      },
      "enabled_when": {
        "op": "eq",
        "field": "time_entry.status",
        "value": "closed"
      },
      "visible_when": {
        "op": "eq",
        "field": "time_entry.status",
        "value": "closed"
      }
    },
    {
      "id": "action.time_entry_reopen",
      "kind": "update_record",
      "label": "Reopen",
      "entity_id": "entity.time_entry",
      "patch": {
        "time_entry.status": "open"
      },
      "enabled_when": {
        "op": "in",
        "field": "time_entry.status",
        "value": ["closed", "approved"]
      },
      "visible_when": {
        "op": "in",
        "field": "time_entry.status",
        "value": ["closed", "approved"]
      }
    }
  ],
  "triggers": [
    {
      "id": "construction_time_entries.record.created",
      "event": "record.created",
      "entity_id": "entity.time_entry"
    },
    {
      "id": "construction_time_entries.record.updated",
      "event": "record.updated",
      "entity_id": "entity.time_entry"
    },
    {
      "id": "construction_time_entries.workflow.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.time_entry",
      "status_field": "time_entry.status"
    }
  ],
  "views": [
    {
      "id": "time_entry.list",
      "kind": "list",
      "entity": "entity.time_entry",
      "columns": [
        { "field_id": "time_entry.entry_date" },
        { "field_id": "time_entry.project_id" },
        { "field_id": "time_entry.worker_id" },
        { "field_id": "time_entry.check_in_at" },
        { "field_id": "time_entry.check_out_at" },
        { "field_id": "time_entry.hours_worked" },
        { "field_id": "time_entry.status" },
        { "field_id": "time_entry.source" }
      ],
      "header": {
        "primary_actions": [
          { "action_id": "action.time_entry_new" }
        ],
        "open_record_target": "page:time_entry.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search time entries...",
          "fields": [
            "time_entry.entry_date",
            "time_entry.status",
            "time_entry.source"
          ]
        }
      }
    },
    {
      "id": "time_entry.form",
      "kind": "form",
      "entity": "entity.time_entry",
      "sections": [
        {
          "id": "main",
          "title": "Time Entry",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "time_entry.project_id",
            "time_entry.worker_id",
            "time_entry.entry_date",
            "time_entry.status",
            "time_entry.check_in_at",
            "time_entry.check_out_at",
            "time_entry.hours_worked",
            "time_entry.source",
            "time_entry.supervisor_id"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "time_entry.notes"
          ]
        }
      ],
      "header": {
        "statusbar": {
          "field_id": "time_entry.status"
        },
        "secondary_actions": [
          { "action_id": "action.time_entry_close" },
          { "action_id": "action.time_entry_approve" },
          { "action_id": "action.time_entry_reopen" }
        ]
      }
    },
    {
      "id": "time_entry.graph",
      "kind": "graph",
      "entity": "entity.time_entry",
      "default": {
        "type": "bar",
        "group_by": "time_entry.project_id",
        "measure": "count"
      }
    },
    {
      "id": "time_entry.calendar",
      "kind": "calendar",
      "entity": "entity.time_entry",
      "calendar": {
        "title_field": "time_entry.worker_id",
        "date_start": "time_entry.check_in_at",
        "color_field": "time_entry.project_id",
        "default_scale": "week"
      }
    }
  ],
  "pages": [
    {
      "id": "time_entry.list_page",
      "title": "Time Entries",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          { "action_id": "action.time_entry_new" }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.time_entry",
              "default_mode": "list",
              "modes": [
                { "mode": "list", "target": "view:time_entry.list" },
                { "mode": "calendar", "target": "view:time_entry.calendar" },
                { "mode": "graph", "target": "view:time_entry.graph" },
                { "mode": "pivot", "target": "view:time_entry.list", "default_group_by": "time_entry.project_id" }
              ],
              "default_filter_id": "all"
            }
          ]
        }
      ]
    },
    {
      "id": "time_entry.form_page",
      "title": "Time Entry",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.time_entry",
          "record_id_query": "record",
          "content": [
            {
              "kind": "container",
              "variant": "card",
              "content": [
                {
                  "kind": "view",
                  "target": "view:time_entry.form"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "interfaces": {
    "dashboardable": [
      {
        "entity_id": "entity.time_entry",
        "enabled": true,
        "scope": "module_and_global",
        "date_field": "time_entry.entry_date",
        "measures": ["count", "sum:time_entry.hours_worked"],
        "group_bys": [
          "time_entry.project_id",
          "time_entry.worker_id",
          "time_entry.status",
          "time_entry.source"
        ],
        "default_widgets": [
          {
            "id": "time_entries_by_project",
            "type": "group",
            "title": "Time Entries by Project",
            "group_by": "time_entry.project_id",
            "measure": "count"
          }
        ]
      }
    ],
    "schedulable": [
      {
        "entity_id": "entity.time_entry",
        "enabled": true,
        "scope": "module_only",
        "title_field": "time_entry.worker_id",
        "date_start": "time_entry.check_in_at",
        "owner_field": "time_entry.supervisor_id",
        "status_field": "time_entry.status",
        "color_field": "time_entry.project_id"
      }
    ]
  },
  "relations": [],
  "workflows": [
    {
      "id": "workflow.time_entry_status",
      "entity": "entity.time_entry",
      "status_field": "time_entry.status",
      "states": [
        { "id": "open", "label": "Open", "order": 1 },
        { "id": "closed", "label": "Closed", "order": 2 },
        { "id": "approved", "label": "Approved", "order": 3 }
      ]
    }
  ],
  "transformations": [],
  "modals": [],
  "queries": {}
}
