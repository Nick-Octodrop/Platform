  "modals": [
    {
      "id": "modal.quote_mark_lost",
      "title": "Mark Quote Lost",
      "description": "Capture why the quote was lost before moving it out of the active pipeline.",
      "entity_id": "entity.biz_quote",
      "fields": [
        "biz_quote.loss_reason"
      ],
      "actions": [
        {
          "kind": "update_record",
          "entity_id": "entity.biz_quote",
          "label": "Mark Lost",
          "patch": {
            "biz_quote.status": "lost",
            "biz_quote.loss_reason": { "ref": "$record.biz_quote.loss_reason" }
          }
        },
        {
          "kind": "close_modal",
          "label": "Close",
          "variant": "ghost"
        }
      ]
    },
    {
      "id": "modal.quote_mark_expired",
      "title": "Mark Quote Expired",
      "description": "Capture the expiry note before closing this quote out of the live pipeline.",
      "entity_id": "entity.biz_quote",
      "fields": [
        "biz_quote.loss_reason"
      ],
      "actions": [
        {
          "kind": "update_record",
          "entity_id": "entity.biz_quote",
          "label": "Mark Expired",
          "patch": {
            "biz_quote.status": "expired",
            "biz_quote.loss_reason": { "ref": "$record.biz_quote.loss_reason" }
          }
        },
        {
          "kind": "close_modal",
          "label": "Close",
          "variant": "ghost"
        }
      ]
