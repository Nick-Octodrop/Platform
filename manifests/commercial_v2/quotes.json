            {
              "id": "quote_open_count",
              "label": "Open Quotes",
              "subtitle": "Draft and sent pipeline",
              "entity_id": "entity.biz_quote",
              "measure": "count",
              "domain": { "op": "in", "field": "biz_quote.status", "value": ["draft", "sent"] },
              "icon": "lucide:FileCheck2",
              "tone": "primary",
              "format": "number"
            },
            {
              "id": "quote_ready_to_convert_count",
              "label": "Ready To Convert",
              "subtitle": "Accepted without an order yet",
              "entity_id": "entity.biz_quote",
              "measure": "count",
              "domain": {
                "op": "and",
                "conditions": [
                  { "op": "eq", "field": "biz_quote.status", "value": "accepted" },
                  { "op": "not", "condition": { "op": "exists", "field": "biz_quote.linked_customer_order_id" } }
                ]
              },
              "icon": "lucide:BadgeCheck",
              "tone": "warning",
              "format": "number"
            },
            {
              "id": "quote_sent_count",
              "label": "Awaiting Decision",
              "subtitle": "Sent to customer",
              "entity_id": "entity.biz_quote",
              "measure": "count",
              "domain": { "op": "eq", "field": "biz_quote.status", "value": "sent" },
              "icon": "lucide:Send",
              "tone": "success",
              "format": "number"
            },
            {
              "id": "quote_exception_count",
              "label": "Exceptions",
              "subtitle": "Lost and expired",
              "entity_id": "entity.biz_quote",
              "measure": "count",
              "domain": { "op": "in", "field": "biz_quote.status", "value": ["lost", "expired"] },
