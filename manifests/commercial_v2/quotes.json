{
  "manifest_version": "1.3",
  "module": {
    "id": "biz_quotes",
    "key": "biz_quotes",
    "name": "Quotes",
    "version": "1.0.0",
    "description": "NLight quote workflow from pricing and customer approval through order conversion.",
    "category": "Commercial",
    "icon_key": "lucide:FileCheck2"
  },
  "depends_on": {
    "required": [
      { "module": "biz_contacts", "version": ">=1.0.0" },
      { "module": "biz_products", "version": ">=1.0.0" },
      { "module": "biz_purchase_orders", "version": ">=1.0.0" },
      { "module": "biz_invoices", "version": ">=1.0.0" },
      { "module": "biz_orders", "version": ">=1.0.0" }
    ]
  },
  "app": {
    "home": "page:biz_quote.list_page",
    "defaults": {
      "entity_home_page": "page:biz_quote.list_page",
      "entity_form_page": "page:biz_quote.form_page",
      "entities": {
        "entity.biz_quote": {
          "entity_home_page": "page:biz_quote.list_page",
          "entity_form_page": "page:biz_quote.form_page"
        },
        "entity.biz_quote_line": {
          "entity_home_page": "page:biz_quote_line.list_page",
          "entity_form_page": "page:biz_quote_line.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Commercial",
        "mode": "inline",
        "items": [
          { "label": "Quotes", "to": "page:biz_quote.list_page" },
          { "label": "Draft", "to": "page:biz_quote.draft_page" },
          { "label": "Sent", "to": "page:biz_quote.sent_page" },
          { "label": "Ready To Convert", "to": "page:biz_quote.ready_to_convert_page" }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.biz_quote",
      "label": "Quote",
      "display_field": "biz_quote.quote_number",
      "fields": [
        { "id": "biz_quote.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "biz_quote.quote_number", "type": "string", "label": "Quote Number", "readonly": true },
        {
          "id": "biz_quote.status",
          "type": "enum",
          "label": "Status",
          "ui": { "widget": "steps" },
          "required": true,
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "sent", "label": "Sent" },
            { "value": "accepted", "label": "Accepted" },
            { "value": "lost", "label": "Lost" },
            { "value": "expired", "label": "Expired" }
          ]
        },
        { "id": "biz_quote.quote_date", "type": "date", "label": "Quote Date" },
        { "id": "biz_quote.expiry_date", "type": "date", "label": "Expiry Date" },
        {
          "id": "biz_quote.sales_entity",
          "type": "enum",
          "label": "Sales Entity",
          "default": "NLight BV",
          "options": [
            { "value": "NLight BV", "label": "NLight BV" },
            { "value": "EcoTech FZCO", "label": "EcoTech FZCO" }
          ]
        },
        {
          "id": "biz_quote.customer_id",
          "type": "lookup",
          "label": "Customer",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name",
          "required": true
        },
        { "id": "biz_quote.customer_contact_name", "type": "string", "label": "Customer Contact" },
        { "id": "biz_quote.customer_reference", "type": "string", "label": "Customer Reference" },
        {
          "id": "biz_quote.currency",
          "type": "enum",
          "label": "Currency",
          "default": "EUR",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" },
            { "value": "GBP", "label": "GBP" },
            { "value": "AED", "label": "AED" }
          ]
        },
        { "id": "biz_quote.sales_owner", "type": "string", "label": "Sales Owner" },
        {
          "id": "biz_quote.follow_up_date",
          "type": "date",
          "label": "Follow Up Date",
          "visible_when": {
            "op": "in",
            "field": "biz_quote.status",
            "value": ["draft", "sent"]
          }
        },
        { "id": "biz_quote.payment_terms", "type": "string", "label": "Payment Terms" },
        { "id": "biz_quote.incoterm", "type": "string", "label": "Incoterm" },
        { "id": "biz_quote.shipping_terms", "type": "string", "label": "Shipping Terms" },
        { "id": "biz_quote.validity_notes", "type": "text", "label": "Validity Notes" },
        {
          "id": "biz_quote.loss_reason",
          "type": "text",
          "label": "Loss / Expiry Reason",
          "required_when": {
            "op": "in",
            "field": "biz_quote.status",
            "value": ["lost", "expired"]
          }
        },
        { "id": "biz_quote.internal_notes", "type": "text", "label": "Internal Notes" },
        { "id": "biz_quote.customer_notes", "type": "text", "label": "Customer Notes" },
        { "id": "biz_quote.pdf_template_name", "type": "string", "label": "PDF Template Name" },
        {
          "id": "biz_quote.linked_customer_order_id",
          "type": "lookup",
          "label": "Linked Order",
          "entity": "entity.biz_order",
          "display_field": "biz_order.order_number",
          "readonly": true,
          "visible_when": { "op": "exists", "field": "biz_quote.linked_customer_order_id" }
        },
        { "id": "biz_quote.linked_customer_order_number", "type": "string", "label": "Linked Order", "readonly": true },
        {
          "id": "biz_quote.subtotal",
          "type": "number",
          "label": "Subtotal",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency_field": "biz_quote.currency", "precision": 2 },
          "compute": {
            "aggregate": {
              "op": "sum",
              "entity": "entity.biz_quote_line",
              "field": "biz_quote_line.line_total",
              "where": {
                "op": "eq",
                "field": "biz_quote_line.quote_id",
                "value": { "ref": "$parent.id" }
              }
            }
          }
        },
        {
          "id": "biz_quote.discount_total",
          "type": "number",
          "label": "Discount Total",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "biz_quote.currency", "precision": 2 }
        },
        {
          "id": "biz_quote.tax_total",
          "type": "number",
          "label": "Tax Total",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "biz_quote.currency", "precision": 2 }
        },
        {
          "id": "biz_quote.grand_total",
          "type": "number",
          "label": "Grand Total",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency_field": "biz_quote.currency", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "add",
                  "args": [
                    {
                      "op": "sub",
                      "args": [
                        { "ref": "$current.biz_quote.subtotal" },
                        { "ref": "$current.biz_quote.discount_total" }
                      ]
                    },
                    { "ref": "$current.biz_quote.tax_total" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "biz_quote.estimated_buy_total",
          "type": "number",
          "label": "Estimated Buy Total",
          "readonly": true,
          "default": 0,
          "compute": {
            "aggregate": {
              "op": "sum",
              "entity": "entity.biz_quote_line",
              "field": "biz_quote_line.buy_total",
              "where": {
                "op": "eq",
                "field": "biz_quote_line.quote_id",
                "value": { "ref": "$parent.id" }
              }
            }
          }
        },
        {
          "id": "biz_quote.estimated_margin_amount",
          "type": "number",
          "label": "Estimated Margin Amount",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    { "ref": "$current.biz_quote.grand_total" },
                    { "ref": "$current.biz_quote.estimated_buy_total" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "biz_quote.estimated_margin_percent",
          "type": "number",
          "label": "Estimated Margin %",
          "readonly": true,
          "default": 0,
          "format": { "kind": "percent", "precision": 2 },
          "compute": {
            "expression": {
              "op": "if",
              "condition": { "op": "gt", "field": "biz_quote.grand_total", "value": 0 },
              "then": {
                "op": "round",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "div",
                        "args": [
                          { "ref": "$current.biz_quote.estimated_margin_amount" },
                          { "ref": "$current.biz_quote.grand_total" }
                        ]
                      },
                      100
                    ]
                  },
                  2
                ]
              },
              "else": 0
            }
          }
        }
      ]
    },
    {
      "id": "entity.biz_quote_line",
      "label": "Quote Line",
      "display_field": "biz_quote_line.description",
      "fields": [
        { "id": "biz_quote_line.id", "type": "uuid", "label": "ID", "readonly": true },
        {
          "id": "biz_quote_line.quote_id",
          "type": "lookup",
          "label": "Quote",
          "entity": "entity.biz_quote",
          "display_field": "biz_quote.quote_number",
          "required": true
        },
        {
          "id": "biz_quote_line.line_type",
          "type": "enum",
          "label": "Line Type",
          "default": "catalogue",
          "options": [
            { "value": "catalogue", "label": "Catalogue" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        {
          "id": "biz_quote_line.product_id",
          "type": "lookup",
          "label": "Product",
          "entity": "entity.biz_product",
          "display_field": "biz_product.name"
        },
        { "id": "biz_quote_line.description", "type": "string", "label": "Description", "required": true },
        {
          "id": "biz_quote_line.sales_entity_snapshot",
          "type": "enum",
          "label": "Sales Entity Snapshot",
          "default": "NLight BV",
          "options": [
            { "value": "NLight BV", "label": "NLight BV" },
            { "value": "EcoTech FZCO", "label": "EcoTech FZCO" }
          ]
        },
        {
          "id": "biz_quote_line.currency_snapshot",
          "type": "enum",
          "label": "Currency Snapshot",
          "default": "EUR",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" },
            { "value": "GBP", "label": "GBP" },
            { "value": "AED", "label": "AED" }
          ]
        },
        {
          "id": "biz_quote_line.uom",
          "type": "enum",
          "label": "UOM",
          "default": "EA",
          "options": [
            { "value": "EA", "label": "Each" },
            { "value": "SET", "label": "Set" },
            { "value": "KIT", "label": "Kit" },
            { "value": "LOT", "label": "Lot" },
            { "value": "PALLET", "label": "Pallet" },
            { "value": "CONTAINER", "label": "Container" },
            { "value": "M", "label": "Meter" }
          ]
        },
        { "id": "biz_quote_line.quantity", "type": "number", "label": "Qty", "default": 1 },
        { "id": "biz_quote_line.unit_price", "type": "number", "label": "Unit Price", "default": 0 },
        { "id": "biz_quote_line.line_discount_percent", "type": "number", "label": "Discount %", "default": 0 },
        {
          "id": "biz_quote_line.line_total",
          "type": "number",
          "label": "Line Total",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    {
                      "op": "mul",
                      "args": [
                        { "ref": "$current.biz_quote_line.quantity" },
                        { "ref": "$current.biz_quote_line.unit_price" }
                      ]
                    },
                    {
                      "op": "sub",
                      "args": [
                        1,
                        {
                          "op": "div",
                          "args": [
                            { "ref": "$current.biz_quote_line.line_discount_percent" },
                            100
                          ]
                        }
                      ]
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        { "id": "biz_quote_line.default_buy_price_snapshot", "type": "number", "label": "Buy Price Snapshot", "default": 0 },
        {
          "id": "biz_quote_line.buy_currency_snapshot",
          "type": "enum",
          "label": "Buy Currency Snapshot",
          "default": "USD",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" },
            { "value": "GBP", "label": "GBP" },
            { "value": "AED", "label": "AED" }
          ]
        },
        {
          "id": "biz_quote_line.buy_total",
          "type": "number",
          "label": "Buy Total",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    { "ref": "$current.biz_quote_line.quantity" },
                    { "ref": "$current.biz_quote_line.default_buy_price_snapshot" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "biz_quote_line.estimated_margin_amount",
          "type": "number",
          "label": "Estimated Margin Amount",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    { "ref": "$current.biz_quote_line.line_total" },
                    { "ref": "$current.biz_quote_line.buy_total" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "biz_quote_line.estimated_margin_percent",
          "type": "number",
          "label": "Estimated Margin %",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "if",
              "condition": { "op": "gt", "field": "biz_quote_line.line_total", "value": 0 },
              "then": {
                "op": "round",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "div",
                        "args": [
                          { "ref": "$current.biz_quote_line.estimated_margin_amount" },
                          { "ref": "$current.biz_quote_line.line_total" }
                        ]
                      },
                      100
                    ]
                  },
                  2
                ]
              },
              "else": 0
            }
          }
        }
      ],
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
        "allow_attachments": true,
        "tracked_fields": [
          "biz_quote_line.quote_id",
          "biz_quote_line.line_type",
          "biz_quote_line.product_id",
          "biz_quote_line.description",
          "biz_quote_line.uom",
          "biz_quote_line.quantity",
          "biz_quote_line.unit_price",
          "biz_quote_line.line_discount_percent",
          "biz_quote_line.line_total",
          "biz_quote_line.default_buy_price_snapshot",
          "biz_quote_line.buy_total"
        ]
      }
    }
  ],
  "workflows": [
    {
      "id": "quote_status_workflow",
      "entity": "entity.biz_quote",
      "status_field": "biz_quote.status",
      "states": [
        { "id": "draft", "label": "Draft", "required_fields": ["biz_quote.customer_id", "biz_quote.currency"] },
        { "id": "sent", "label": "Sent", "required_fields": ["biz_quote.customer_id", "biz_quote.expiry_date"] },
        { "id": "accepted", "label": "Accepted", "required_fields": ["biz_quote.customer_id", "biz_quote.expiry_date"] },
        { "id": "lost", "label": "Lost" },
        { "id": "expired", "label": "Expired" }
      ],
      "transitions": [
        { "from": "draft", "to": "sent", "label": "Send Quote" },
        { "from": "sent", "to": "accepted", "label": "Mark Accepted" },
        { "from": "draft", "to": "lost", "label": "Mark Lost" },
        { "from": "sent", "to": "lost", "label": "Mark Lost" },
        { "from": "sent", "to": "expired", "label": "Mark Expired" }
      ],
      "required_fields_by_state": {
        "sent": ["biz_quote.customer_id", "biz_quote.expiry_date"],
        "accepted": ["biz_quote.customer_id", "biz_quote.expiry_date"],
        "lost": ["biz_quote.loss_reason"],
        "expired": ["biz_quote.loss_reason"]
      }
    }
  ],
  "triggers": [
    { "id": "biz_quotes.record.biz_quote.created", "label": "Quote created", "event": "record.created", "entity_id": "entity.biz_quote" },
    { "id": "biz_quotes.record.biz_quote.updated", "label": "Quote updated", "event": "record.updated", "entity_id": "entity.biz_quote" },
    { "id": "biz_quotes.record.biz_quote_line.created", "label": "Quote Line created", "event": "record.created", "entity_id": "entity.biz_quote_line" },
    { "id": "biz_quotes.record.biz_quote_line.updated", "label": "Quote Line updated", "event": "record.updated", "entity_id": "entity.biz_quote_line" },
    { "id": "biz_quotes.workflow.biz_quote.status_changed", "label": "Quote status changed", "event": "workflow.status_changed", "entity_id": "entity.biz_quote", "status_field": "biz_quote.status" },
    { "id": "biz_quotes.action.quote_new.clicked", "label": "New Quote clicked", "event": "action.clicked", "action_id": "action.quote_new" },
    { "id": "biz_quotes.action.quote_mark_sent.clicked", "label": "Mark Sent clicked", "event": "action.clicked", "action_id": "action.quote_mark_sent" },
    { "id": "biz_quotes.action.quote_mark_accepted.clicked", "label": "Mark Accepted clicked", "event": "action.clicked", "action_id": "action.quote_mark_accepted" },
    { "id": "biz_quotes.action.quote_convert_to_order.clicked", "label": "Create Order clicked", "event": "action.clicked", "action_id": "action.quote_convert_to_order" },
    { "id": "biz_quotes.action.quote_open_lost_modal.clicked", "label": "Mark Lost clicked", "event": "action.clicked", "action_id": "action.quote_open_lost_modal" },
    { "id": "biz_quotes.action.quote_open_expired_modal.clicked", "label": "Mark Expired clicked", "event": "action.clicked", "action_id": "action.quote_open_expired_modal" }
  ],
  "transformations": [
    {
      "key": "quote_to_customer_order",
      "source_entity_id": "entity.biz_quote",
      "target_entity_id": "entity.biz_order",
      "field_mappings": {
        "biz_order.customer_id": { "from": "biz_quote.customer_id" },
        "biz_order.source_quote_number": { "from": "biz_quote.quote_number" },
        "biz_order.sales_entity": { "from": "biz_quote.sales_entity" },
        "biz_order.order_date": { "ref": "$today" },
        "biz_order.currency": { "from": "biz_quote.currency" },
        "biz_order.customer_reference": { "from": "biz_quote.customer_reference" },
        "biz_order.delivery_terms": { "from": "biz_quote.shipping_terms" },
        "biz_order.notes": { "from": "biz_quote.internal_notes" },
        "biz_order.status": { "value": "draft" }
      },
      "child_mappings": [
        {
          "source_entity_id": "entity.biz_quote_line",
          "target_entity_id": "entity.biz_order_line",
          "source_link_field": "biz_quote_line.quote_id",
          "target_link_field": "biz_order_line.customer_order_id",
          "field_mappings": {
            "biz_order_line.product_id": { "from": "biz_quote_line.product_id" },
            "biz_order_line.description": { "from": "biz_quote_line.description" },
            "biz_order_line.sales_entity_snapshot": { "from": "biz_quote_line.sales_entity_snapshot" },
            "biz_order_line.currency_snapshot": { "from": "biz_quote_line.currency_snapshot" },
            "biz_order_line.uom": { "from": "biz_quote_line.uom" },
            "biz_order_line.quantity": { "from": "biz_quote_line.quantity" },
            "biz_order_line.unit_price": { "from": "biz_quote_line.unit_price" },
            "biz_order_line.unit_cost_snapshot": { "from": "biz_quote_line.default_buy_price_snapshot" },
            "biz_order_line.source_quote_line_ref": { "ref": "$source.id" }
          }
        }
      ],
      "link_fields": {
        "source_to_target": "biz_quote.linked_customer_order_id",
        "target_to_source": "biz_order.source_quote_id"
      },
      "source_update": {
        "patch": {
          "biz_quote.status": "accepted"
        }
      },
      "validation": {
        "require_source_fields": ["biz_quote.quote_number", "biz_quote.customer_id"],
        "require_child_records": true,
        "prevent_if_target_linked": true
      }
    }
  ],
  "actions": [
    { "id": "action.quote_new", "kind": "open_form", "label": "New Quote", "target": "biz_quote.form" },
    {
      "id": "action.quote_mark_sent",
      "kind": "update_record",
      "entity_id": "entity.biz_quote",
      "label": "Mark Sent",
      "patch": { "biz_quote.status": "sent" },
      "confirm": {
        "title": "Mark quote as sent?",
        "body": "Use this once the commercial quote has actually been shared with the customer."
      },
      "visible_when": { "op": "eq", "field": "biz_quote.status", "value": "draft" },
      "enabled_when": {
        "op": "and",
        "conditions": [
          { "op": "exists", "field": "biz_quote.customer_id" },
          { "op": "exists", "field": "biz_quote.expiry_date" },
          { "op": "gt", "field": "biz_quote.grand_total", "value": 0 }
        ]
      }
    },
    {
      "id": "action.quote_mark_accepted",
      "kind": "update_record",
      "entity_id": "entity.biz_quote",
      "label": "Mark Accepted",
      "patch": { "biz_quote.status": "accepted" },
      "confirm": {
        "title": "Mark quote as accepted?",
        "body": "Use this once the customer has accepted the quote and the deal is ready for order conversion."
      },
      "visible_when": {
        "op": "and",
        "conditions": [
          { "op": "eq", "field": "biz_quote.status", "value": "sent" },
          { "op": "not", "condition": { "op": "exists", "field": "biz_quote.linked_customer_order_id" } }
        ]
      },
      "enabled_when": {
        "op": "and",
        "conditions": [
          { "op": "exists", "field": "biz_quote.customer_id" },
          { "op": "exists", "field": "biz_quote.expiry_date" },
          { "op": "gt", "field": "biz_quote.grand_total", "value": 0 }
        ]
      }
    },
    {
      "id": "action.quote_convert_to_order",
      "kind": "transform_record",
      "entity_id": "entity.biz_quote",
      "label": "Create Order",
      "transformation_key": "quote_to_customer_order",
      "visible_when": {
        "op": "and",
        "conditions": [
          { "op": "eq", "field": "biz_quote.status", "value": "accepted" },
          { "op": "not", "condition": { "op": "exists", "field": "biz_quote.linked_customer_order_id" } }
        ]
      },
      "enabled_when": {
        "op": "and",
        "conditions": [
          { "op": "exists", "field": "biz_quote.customer_id" },
          { "op": "gt", "field": "biz_quote.grand_total", "value": 0 }
        ]
      },
      "confirm": {
        "title": "Create order from quote?",
        "body": "This will create an Order and copy the accepted quote lines."
      }
    },
    {
      "id": "action.quote_open_lost_modal",
      "kind": "update_record",
      "entity_id": "entity.biz_quote",
      "label": "Mark Lost",
      "modal_id": "modal.quote_mark_lost",
      "visible_when": {
        "op": "or",
        "conditions": [
          { "op": "eq", "field": "biz_quote.status", "value": "draft" },
          { "op": "eq", "field": "biz_quote.status", "value": "sent" }
        ]
      }
    },
    {
      "id": "action.quote_open_expired_modal",
      "kind": "update_record",
      "entity_id": "entity.biz_quote",
      "label": "Mark Expired",
      "modal_id": "modal.quote_mark_expired",
      "visible_when": { "op": "eq", "field": "biz_quote.status", "value": "sent" }
    }
  ],
