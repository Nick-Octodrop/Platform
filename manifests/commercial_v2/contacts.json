{
  "manifest_version": "1.3",
  "module": {
    "id": "biz_contacts",
    "key": "biz_contacts",
    "name_key": "contacts.module.name",
    "name": "Contacts",
    "version": "1.0.0",
    "description_key": "contacts.module.description",
    "description": "Customers, suppliers, factory partners, and linked people for the commercial workflow.",
    "category": "Commercial",
    "icon_key": "lucide:Users"
  },
  "app": {
    "home": "page:biz_contact.list_page",
    "defaults": {
      "entity_home_page": "page:biz_contact.list_page",
      "entity_form_page": "page:biz_contact.form_page",
      "entities": {
        "entity.biz_contact": {
          "entity_home_page": "page:biz_contact.list_page",
          "entity_form_page": "page:biz_contact.form_page"
        },
        "entity.biz_contact_person": {
          "entity_home_page": "page:biz_contact_person.list_page",
          "entity_form_page": "page:biz_contact_person.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Commercial",
        "mode": "inline",
        "items": [
          {
            "menu_label_key": "contacts.navigation.contacts",
            "label": "Contacts",
            "to": "page:biz_contact.list_page"
          },
          {
            "label": "People",
            "to": "page:biz_contact_person.list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.biz_contact",
      "label_key": "contacts.entity.contact",
      "label": "Contact",
      "display_field": "biz_contact.name",
      "fields": [
        {
          "id": "biz_contact.id",
          "type": "uuid",
          "label_key": "contacts.fields.id",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "biz_contact.name",
          "type": "string",
          "label_key": "contacts.fields.name",
          "label": "Company / Account Name",
          "required": true
        },
        {
          "id": "biz_contact.legal_name",
          "type": "string",
          "label": "Legal Name"
        },
        {
          "id": "biz_contact.contact_code",
          "type": "string",
          "label": "Account Code"
        },
        {
          "id": "biz_contact.contact_type",
          "type": "enum",
          "label_key": "contacts.fields.contact_type",
          "label": "Type",
          "required": true,
          "default": "customer",
          "options": [
            {
              "value": "customer",
              "label_key": "contacts.options.contact_type.customer",
              "label": "Customer",
              "status_label_key": "contacts.entities.biz_contact.fields.contact_type.options.customer"
            },
            {
              "value": "supplier",
              "label_key": "contacts.options.contact_type.supplier",
              "label": "Supplier",
              "status_label_key": "contacts.entities.biz_contact.fields.contact_type.options.supplier"
            },
            {
              "value": "factory_partner",
              "label_key": "contacts.options.contact_type.factory_partner",
              "label": "Factory Partner",
              "status_label_key": "contacts.entities.biz_contact.fields.contact_type.options.factory_partner"
            }
          ]
        },
        {
          "id": "biz_contact.company_entity_scope",
          "type": "tags",
          "label_key": "contacts.fields.company_entity_scope",
          "label": "Entity Scope"
        },
        {
          "id": "biz_contact.currency_preference",
          "type": "enum",
          "label_key": "contacts.fields.currency_preference",
          "label": "Currency Preference",
          "default": "EUR",
          "options": [
            {
              "value": "EUR",
              "label": "EUR",
              "status_label_key": "contacts.entities.biz_contact.fields.currency_preference.options.eur",
              "label_key": "contacts.entities.biz_contact.fields.currency_preference.options.eur"
            },
            {
              "value": "USD",
              "label": "USD",
              "status_label_key": "contacts.entities.biz_contact.fields.currency_preference.options.usd",
              "label_key": "contacts.entities.biz_contact.fields.currency_preference.options.usd"
            },
            {
              "value": "GBP",
              "label": "GBP",
              "status_label_key": "contacts.entities.biz_contact.fields.currency_preference.options.gbp",
              "label_key": "contacts.entities.biz_contact.fields.currency_preference.options.gbp"
            },
            {
              "value": "AED",
              "label": "AED",
              "status_label_key": "contacts.entities.biz_contact.fields.currency_preference.options.aed",
              "label_key": "contacts.entities.biz_contact.fields.currency_preference.options.aed"
            }
          ]
        },
        {
          "id": "biz_contact.default_payment_terms",
          "type": "string",
          "label": "Default Sales Payment Terms"
        },
        {
          "id": "biz_contact.default_incoterm",
          "type": "string",
          "label": "Default Sales Incoterm"
        },
        {
          "id": "biz_contact.default_sales_tax_percent",
          "type": "number",
          "label": "Default Sales Tax %",
          "default": 0
        },
        {
          "id": "biz_contact.email",
          "type": "string",
          "label_key": "contacts.fields.email",
          "label": "Main Email"
        },
        {
          "id": "biz_contact.phone",
          "type": "string",
          "label_key": "contacts.fields.phone",
          "label": "Main Phone"
        },
        {
          "id": "biz_contact.website",
          "type": "string",
          "label_key": "contacts.fields.website",
          "label": "Website"
        },
        {
          "id": "biz_contact.country",
          "type": "string",
          "label_key": "contacts.fields.country",
          "label": "Country"
        },
        {
          "id": "biz_contact.tax_registration_type",
          "type": "enum",
          "label": "Tax Registration Type",
          "default": "vat",
          "options": [
            {
              "value": "vat",
              "label": "VAT"
            },
            {
              "value": "gst",
              "label": "GST"
            },
            {
              "value": "sales_tax",
              "label": "Sales Tax"
            },
            {
              "value": "other",
              "label": "Other"
            }
          ]
        },
        {
          "id": "biz_contact.tax_number",
          "type": "string",
          "label": "VAT / Tax Registration Number"
        },
        {
          "id": "biz_contact.company_number",
          "type": "string",
          "label": "Company Registration Number"
        },
        {
          "id": "biz_contact.supplier_reference",
          "type": "string",
          "label": "Supplier / Factory Reference",
          "visible_when": {
            "op": "in",
            "field": "biz_contact.contact_type",
            "value": [
              "supplier",
              "factory_partner"
            ]
          }
        },
        {
          "id": "biz_contact.production_country",
          "type": "string",
          "label": "Production Country",
          "visible_when": {
            "op": "in",
            "field": "biz_contact.contact_type",
            "value": [
              "supplier",
              "factory_partner"
            ]
          }
        },
        {
          "id": "biz_contact.supplier_payment_terms",
          "type": "string",
          "label": "Default Purchase Payment Terms",
          "visible_when": {
            "op": "in",
            "field": "biz_contact.contact_type",
            "value": [
              "supplier",
              "factory_partner"
            ]
          }
        },
        {
          "id": "biz_contact.supplier_incoterm_default",
          "type": "string",
          "label": "Default Purchase Incoterm",
          "visible_when": {
            "op": "in",
            "field": "biz_contact.contact_type",
            "value": [
              "supplier",
              "factory_partner"
            ]
          }
        },
        {
          "id": "biz_contact.billing_street",
          "type": "string",
          "label_key": "contacts.fields.billing_street",
          "label": "Billing Street"
        },
        {
          "id": "biz_contact.billing_street2",
          "type": "string",
          "label_key": "contacts.fields.billing_street2",
          "label": "Billing Street 2"
        },
        {
          "id": "biz_contact.billing_city",
          "type": "string",
          "label_key": "contacts.fields.billing_city",
          "label": "Billing City"
        },
        {
          "id": "biz_contact.billing_state",
          "type": "string",
          "label_key": "contacts.fields.billing_state",
          "label": "Billing State / Region"
        },
        {
          "id": "biz_contact.billing_postcode",
          "type": "string",
          "label_key": "contacts.fields.billing_postcode",
          "label": "Billing Postcode"
        },
        {
          "id": "biz_contact.billing_country",
          "type": "string",
          "label_key": "contacts.fields.billing_country",
          "label": "Billing Country"
        },
        {
          "id": "biz_contact.shipping_street",
          "type": "string",
          "label_key": "contacts.fields.shipping_street",
          "label": "Shipping Street"
        },
        {
          "id": "biz_contact.shipping_street2",
          "type": "string",
          "label_key": "contacts.fields.shipping_street2",
          "label": "Shipping Street 2"
        },
        {
          "id": "biz_contact.shipping_city",
          "type": "string",
          "label_key": "contacts.fields.shipping_city",
          "label": "Shipping City"
        },
        {
          "id": "biz_contact.shipping_state",
          "type": "string",
          "label_key": "contacts.fields.shipping_state",
          "label": "Shipping State / Region"
        },
        {
          "id": "biz_contact.shipping_postcode",
          "type": "string",
          "label_key": "contacts.fields.shipping_postcode",
          "label": "Shipping Postcode"
        },
        {
          "id": "biz_contact.shipping_country",
          "type": "string",
          "label_key": "contacts.fields.shipping_country",
          "label": "Shipping Country"
        },
        {
          "id": "biz_contact.notes",
          "type": "text",
          "label_key": "contacts.fields.notes",
          "label": "Notes"
        },
        {
          "id": "biz_contact.xero_contact_id",
          "type": "string",
          "label": "Xero Contact ID",
          "readonly": true
        },
        {
          "id": "biz_contact.xero_last_sync_status",
          "type": "string",
          "label": "Xero Sync Status",
          "readonly": true
        },
        {
          "id": "biz_contact.xero_last_sync_at",
          "type": "datetime",
          "label": "Xero Last Sync At",
          "readonly": true
        },
        {
          "id": "biz_contact.xero_last_sync_error",
          "type": "text",
          "label": "Xero Sync Error",
          "readonly": true
        },
        {
          "id": "biz_contact.is_active",
          "type": "bool",
          "label_key": "contacts.fields.is_active",
          "label": "Active",
          "default": true
        }
      ]
    },
    {
      "id": "entity.biz_contact_person",
      "label": "Contact Person",
      "display_field": "biz_contact_person.display_name",
      "fields": [
        {
          "id": "biz_contact_person.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "biz_contact_person.company_id",
          "type": "lookup",
          "label": "Company / Account",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name",
          "ui": {
            "populate_from_lookup": {
              "field_map": {
                "biz_contact_person.company_contact_type_snapshot": "biz_contact.contact_type",
                "biz_contact_person.company_entity_scope_snapshot": "biz_contact.company_entity_scope"
              }
            }
          },
          "required": true
        },
        {
          "id": "biz_contact_person.company_contact_type_snapshot",
          "type": "enum",
          "label": "Company Contact Type Snapshot",
          "readonly": true,
          "options": [
            {
              "value": "customer",
              "label": "Customer"
            },
            {
              "value": "supplier",
              "label": "Supplier"
            },
            {
              "value": "factory_partner",
              "label": "Factory Partner"
            }
          ]
        },
        {
          "id": "biz_contact_person.company_entity_scope_snapshot",
          "type": "tags",
          "label": "Entity Scope Snapshot",
          "readonly": true
        },
        {
          "id": "biz_contact_person.display_name",
          "type": "string",
          "label": "Contact Name",
          "required": true
        },
        {
          "id": "biz_contact_person.first_name",
          "type": "string",
          "label": "First Name"
        },
        {
          "id": "biz_contact_person.last_name",
          "type": "string",
          "label": "Last Name"
        },
        {
          "id": "biz_contact_person.role_type",
          "type": "enum",
          "label": "Role",
          "default": "sales",
          "options": [
            {
              "value": "sales",
              "label": "Sales"
            },
            {
              "value": "finance",
              "label": "Finance"
            },
            {
              "value": "procurement",
              "label": "Procurement"
            },
            {
              "value": "logistics",
              "label": "Logistics"
            },
            {
              "value": "operations",
              "label": "Operations"
            },
            {
              "value": "technical",
              "label": "Technical"
            },
            {
              "value": "executive",
              "label": "Executive"
            },
            {
              "value": "other",
              "label": "Other"
            }
          ]
        },
        {
          "id": "biz_contact_person.job_title",
          "type": "string",
          "label": "Job Title"
        },
        {
          "id": "biz_contact_person.department",
          "type": "string",
          "label": "Department"
        },
        {
          "id": "biz_contact_person.email",
          "type": "string",
          "label": "Email"
        },
        {
          "id": "biz_contact_person.phone",
          "type": "string",
          "label": "Phone"
        },
        {
          "id": "biz_contact_person.mobile",
          "type": "string",
          "label": "Mobile"
        },
        {
          "id": "biz_contact_person.preferred_language",
          "type": "string",
          "label": "Preferred Language"
        },
        {
          "id": "biz_contact_person.is_primary",
          "type": "bool",
          "label": "Primary Contact",
          "default": false
        },
        {
          "id": "biz_contact_person.receives_quotes",
          "type": "bool",
          "label": "Receives Quotes",
          "default": true
        },
        {
          "id": "biz_contact_person.receives_invoices",
          "type": "bool",
          "label": "Receives Invoices",
          "default": false
        },
        {
          "id": "biz_contact_person.receives_logistics_updates",
          "type": "bool",
          "label": "Receives Logistics Updates",
          "default": false
        },
        {
          "id": "biz_contact_person.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "biz_contact_person.is_active",
          "type": "bool",
          "label": "Active",
          "default": true
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.contact_new",
      "kind": "open_form",
      "action_label_key": "contacts.actions.new",
      "label": "New Contact",
      "target": "biz_contact.form"
    },
    {
      "id": "action.contact_person_new",
      "kind": "open_form",
      "label": "New Person",
      "target": "biz_contact_person.form"
    },
    {
      "id": "action.contact_deactivate",
      "kind": "update_record",
      "entity_id": "entity.biz_contact",
      "action_label_key": "contacts.actions.deactivate",
      "label": "Deactivate",
      "patch": {
        "biz_contact.is_active": false
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_contact.is_active",
        "value": true
      }
    },
    {
      "id": "action.contact_activate",
      "kind": "update_record",
      "entity_id": "entity.biz_contact",
      "action_label_key": "contacts.actions.activate",
      "label": "Activate",
      "patch": {
        "biz_contact.is_active": true
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_contact.is_active",
        "value": false
      }
    },
    {
      "id": "action.contact_person_deactivate",
      "kind": "update_record",
      "entity_id": "entity.biz_contact_person",
      "label": "Deactivate",
      "patch": {
        "biz_contact_person.is_active": false
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_contact_person.is_active",
        "value": true
      }
    },
    {
      "id": "action.contact_person_activate",
      "kind": "update_record",
      "entity_id": "entity.biz_contact_person",
      "label": "Activate",
      "patch": {
        "biz_contact_person.is_active": true
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_contact_person.is_active",
        "value": false
      }
    }
  ],
  "views": [
    {
      "id": "biz_contact.list",
      "kind": "list",
      "entity": "entity.biz_contact",
      "columns": [
        {
          "field_id": "biz_contact.name"
        },
        {
          "field_id": "biz_contact.contact_type"
        },
        {
          "field_id": "biz_contact.country"
        },
        {
          "field_id": "biz_contact.currency_preference"
        },
        {
          "field_id": "biz_contact.email"
        },
        {
          "field_id": "biz_contact.phone"
        },
        {
          "field_id": "biz_contact.is_active"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.contact_new"
          }
        ],
        "open_record_target": "page:biz_contact.form_page",
        "search": {
          "enabled": true,
          "placeholder_key": "contacts.search.placeholder",
          "placeholder": "Search contacts...",
          "fields": [
            "biz_contact.name",
            "biz_contact.legal_name",
            "biz_contact.contact_code",
            "biz_contact.email",
            "biz_contact.country",
            "biz_contact.billing_city",
            "biz_contact.shipping_city"
          ]
        },
        "filters": [
          {
            "id": "all",
            "label_key": "contacts.filters.all",
            "label": "All Contacts",
            "domain": {
              "op": "exists",
              "field": "biz_contact.name"
            }
          },
          {
            "id": "customers",
            "label_key": "contacts.filters.customers",
            "label": "Customers",
            "domain": {
              "op": "eq",
              "field": "biz_contact.contact_type",
              "value": "customer"
            }
          },
          {
            "id": "suppliers",
            "label_key": "contacts.filters.suppliers",
            "label": "Suppliers",
            "domain": {
              "op": "eq",
              "field": "biz_contact.contact_type",
              "value": "supplier"
            }
          },
          {
            "id": "factory_partners",
            "label_key": "contacts.filters.factory_partners",
            "label": "Factory Partners",
            "domain": {
              "op": "eq",
              "field": "biz_contact.contact_type",
              "value": "factory_partner"
            }
          },
          {
            "id": "active",
            "label_key": "contacts.filters.active",
            "label": "Active",
            "domain": {
              "op": "eq",
              "field": "biz_contact.is_active",
              "value": true
            }
          }
        ]
      }
    },
    {
      "id": "biz_contact.form",
      "kind": "form",
      "entity": "entity.biz_contact",
      "sections": [
        {
          "id": "main",
          "section_title_key": "contacts.sections.main",
          "title": "Contact Account",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_contact.name",
            "biz_contact.legal_name",
            "biz_contact.contact_code",
            "biz_contact.contact_type",
            "biz_contact.company_entity_scope",
            "biz_contact.country",
            "biz_contact.currency_preference",
            "biz_contact.default_payment_terms",
            "biz_contact.default_incoterm",
            "biz_contact.default_sales_tax_percent",
            "biz_contact.tax_registration_type",
            "biz_contact.tax_number",
            "biz_contact.company_number",
            "biz_contact.is_active"
          ]
        },
        {
          "id": "channels",
          "title": "Main Channels",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_contact.email",
            "biz_contact.phone",
            "biz_contact.website"
          ]
        },
        {
          "id": "supplier",
          "title": "Supplier / Factory Defaults",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_contact.supplier_reference",
            "biz_contact.production_country",
            "biz_contact.supplier_payment_terms",
            "biz_contact.supplier_incoterm_default"
          ]
        },
        {
          "id": "addresses",
          "section_title_key": "contacts.sections.addresses",
          "title": "Addresses",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_contact.billing_street",
            "biz_contact.billing_street2",
            "biz_contact.billing_city",
            "biz_contact.billing_state",
            "biz_contact.billing_postcode",
            "biz_contact.billing_country",
            "biz_contact.shipping_street",
            "biz_contact.shipping_street2",
            "biz_contact.shipping_city",
            "biz_contact.shipping_state",
            "biz_contact.shipping_postcode",
            "biz_contact.shipping_country"
          ]
        },
        {
          "id": "notes",
          "section_title_key": "contacts.sections.notes",
          "title": "Notes",
          "fields": [
            "biz_contact.notes"
          ]
        },
        {
          "id": "xero",
          "title": "Xero Link",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_contact.xero_contact_id",
            "biz_contact.xero_last_sync_status",
            "biz_contact.xero_last_sync_at",
            "biz_contact.xero_last_sync_error"
          ]
        }
      ],
      "header": {
        "secondary_actions": [
          {
            "action_id": "action.contact_activate"
          },
          {
            "action_id": "action.contact_deactivate"
          }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "summary",
          "tabs": [
            {
              "id": "summary",
              "label": "Summary",
              "tab_label_key": "common.summary",
              "sections": [
                "main",
                "channels",
                "supplier"
              ]
            },
            {
              "id": "people",
              "label": "People",
              "sections": [],
              "content": [
                {
                  "kind": "related_list",
                  "entity_id": "entity.biz_contact_person",
                  "target": "view:biz_contact_person.list",
                  "record_domain": {
                    "op": "eq",
                    "field": "biz_contact_person.company_id",
                    "value": {
                      "ref": "$record.id"
                    }
                  },
