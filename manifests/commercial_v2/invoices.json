  "pages": [
    {
      "id": "biz_invoice.list_page",
      "title": "Invoices",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          { "kind": "navigate", "label": "New Invoice", "target": "page:biz_invoice.form_page" }
        ]
      },
      "content": [
        {
          "kind": "stat_cards",
          "columns": 4,
          "cards": [
            {
              "id": "invoice_open_receivables_count",
              "label": "Open Receivables",
              "subtitle": "Draft, issued and part paid",
              "entity_id": "entity.biz_invoice",
              "measure": "count",
              "domain": { "op": "in", "field": "biz_invoice.status", "value": ["draft", "issued", "part_paid"] },
              "icon": "lucide:ReceiptText",
              "tone": "primary",
              "format": "number"
            },
            {
              "id": "invoice_part_paid_count",
              "label": "Part Paid",
              "subtitle": "Collections still in progress",
              "entity_id": "entity.biz_invoice",
              "measure": "count",
              "domain": { "op": "eq", "field": "biz_invoice.status", "value": "part_paid" },
              "icon": "lucide:WalletCards",
              "tone": "warning",
              "format": "number"
            },
            {
              "id": "invoice_paid_count",
              "label": "Paid",
              "subtitle": "Fully settled invoices",
              "entity_id": "entity.biz_invoice",
              "measure": "count",
              "domain": { "op": "eq", "field": "biz_invoice.status", "value": "paid" },
              "icon": "lucide:CircleDollarSign",
              "tone": "success",
              "format": "number"
            },
            {
              "id": "invoice_credit_note_count",
              "label": "Credit Notes",
              "subtitle": "Commercial reversals",
              "entity_id": "entity.biz_invoice",
              "measure": "count",
              "domain": { "op": "eq", "field": "biz_invoice.invoice_type", "value": "credit_note" },
              "icon": "lucide:Undo2",
              "tone": "accent",
              "format": "number"
            }
          ]
        },
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.biz_invoice",
              "default_mode": "list",
              "default_filter_id": "open_receivables",
              "modes": [
                { "mode": "list", "target": "view:biz_invoice.list" },
                { "mode": "kanban", "target": "view:biz_invoice.kanban", "default_group_by": "biz_invoice.status" },
                { "mode": "calendar", "target": "view:biz_invoice.calendar" },
                { "mode": "graph", "target": "view:biz_invoice.graph" },
                { "mode": "pivot", "target": "view:biz_invoice.list", "default_group_by": "biz_invoice.status" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "biz_invoice.form_page",
      "title": "Invoice",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.biz_invoice",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "view", "target": "view:biz_invoice.form" }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "chatter", "entity_id": "entity.biz_invoice", "record_ref": "$record.id" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "biz_invoice_line.list_page",
      "title": "Invoice Lines",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.biz_invoice_line",
              "default_mode": "list",
              "modes": [
                { "mode": "list", "target": "view:biz_invoice_line.list" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "biz_invoice_line.form_page",
      "title": "Invoice Line",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.biz_invoice_line",
          "record_id_query": "record",
          "content": [
            {
              "kind": "container",
              "variant": "card",
              "content": [
                { "kind": "view", "target": "view:biz_invoice_line.form" }
              ]
            }
          ]
        }
      ]
    }
  ],
  "modals": [
    {
      "id": "modal.invoice_cancel",
      "title": "Cancel Invoice",
      "description": "Record the cancellation reason before removing this invoice from the active receivables flow.",
      "entity_id": "entity.biz_invoice",
      "fields": [
        "biz_invoice.cancellation_reason"
      ],
      "actions": [
        {
          "kind": "update_record",
          "label": "Cancel Invoice",
          "entity_id": "entity.biz_invoice",
          "patch": {
            "biz_invoice.status": "cancelled",
            "biz_invoice.cancellation_reason": { "ref": "$record.biz_invoice.cancellation_reason" }
          },
          "close_on_success": true
        },
        {
          "kind": "close_modal",
          "label": "Keep Open",
          "variant": "ghost"
        }
      ]
    }
  ],
  "interfaces": {
    "dashboardable": [
      {
        "entity_id": "entity.biz_invoice",
        "enabled": true,
        "scope": "module_and_global",
        "date_field": "biz_invoice.invoice_date",
        "measures": [
          "count",
          "sum:biz_invoice.invoice_total"
        ],
        "group_bys": [
          "biz_invoice.status",
          "biz_invoice.invoice_type",
          "biz_invoice.sales_entity",
          "biz_invoice.currency"
        ],
        "default_widgets": [
          {
            "id": "invoices_by_status",
            "type": "group",
            "title": "Invoices by Status",
            "group_by": "biz_invoice.status",
            "measure": "count"
          }
        ]
      }
    ]
  }
