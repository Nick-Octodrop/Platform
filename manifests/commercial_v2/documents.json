{
  "manifest_version": "1.3",
  "module": {
    "id": "biz_documents",
    "key": "biz_documents",
    "name": "Documents",
    "version": "1.0.0",
    "description": "Document control for commercial records, including quote PDFs, order packs, supplier documents, invoice files, and signed customer documents.",
    "category": "Commercial",
    "icon_key": "lucide:FolderOpen",
    "name_key": "documents.module.name",
    "description_key": "documents.module.description"
  },
  "depends_on": {
    "required": [
      {
        "module": "biz_contacts",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_quotes",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_orders",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_purchase_orders",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_invoices",
        "version": ">=1.0.0"
      }
    ]
  },
  "app": {
    "home": "page:biz_document.list_page",
    "defaults": {
      "entity_home_page": "page:biz_document.list_page",
      "entity_form_page": "page:biz_document.form_page",
      "entities": {
        "entity.biz_document": {
          "entity_home_page": "page:biz_document.list_page",
          "entity_form_page": "page:biz_document.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Commercial",
        "mode": "inline",
        "items": [
          {
            "label": "Documents",
            "to": "page:biz_document.list_page",
            "menu_label_key": "documents.navigation.biz_document_list_page"
          },
          {
            "label": "Quote Docs",
            "to": "page:biz_document.quote_docs_page",
            "menu_label_key": "documents.navigation.biz_document_quote_docs_page"
          },
          {
            "label": "Invoice Docs",
            "to": "page:biz_document.invoice_docs_page",
            "menu_label_key": "documents.navigation.biz_document_invoice_docs_page"
          },
          {
            "label": "Supplier Docs",
            "to": "page:biz_document.supplier_docs_page",
            "menu_label_key": "documents.navigation.biz_document_supplier_docs_page"
          },
          {
            "label": "Archived",
            "to": "page:biz_document.archived_page",
            "menu_label_key": "documents.navigation.biz_document_archived_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.biz_document",
      "label": "Document",
      "display_field": "biz_document.name",
      "fields": [
        {
          "id": "biz_document.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true,
          "label_key": "documents.entities.biz_document.fields.id.label"
        },
        {
          "id": "biz_document.name",
          "type": "string",
          "label": "Document Name",
          "required": true,
          "label_key": "documents.entities.biz_document.fields.name.label"
        },
        {
          "id": "biz_document.document_type",
          "type": "enum",
          "label": "Type",
          "required": true,
          "default": "other",
          "options": [
            {
              "value": "quote_pdf",
              "label": "Quote PDF",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.quote_pdf",
              "label_key": "documents.entities.biz_document.fields.document_type.options.quote_pdf"
            },
            {
              "value": "order_confirmation",
              "label": "Order Confirmation",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.order_confirmation",
              "label_key": "documents.entities.biz_document.fields.document_type.options.order_confirmation"
            },
            {
              "value": "purchase_order_pdf",
              "label": "Purchase Order PDF",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.purchase_order_pdf",
              "label_key": "documents.entities.biz_document.fields.document_type.options.purchase_order_pdf"
            },
            {
              "value": "invoice_pdf",
              "label": "Invoice PDF",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.invoice_pdf",
              "label_key": "documents.entities.biz_document.fields.document_type.options.invoice_pdf"
            },
            {
              "value": "quote_script_source",
              "label": "Quote Script Source",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.quote_script_source",
              "label_key": "documents.entities.biz_document.fields.document_type.options.quote_script_source"
            },
            {
              "value": "quote_template_source",
              "label": "Quote Template Source",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.quote_template_source",
              "label_key": "documents.entities.biz_document.fields.document_type.options.quote_template_source"
            },
            {
              "value": "invoice_template_source",
              "label": "Invoice Template Source",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.invoice_template_source",
              "label_key": "documents.entities.biz_document.fields.document_type.options.invoice_template_source"
            },
            {
              "value": "letterhead_source",
              "label": "Letterhead Source",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.letterhead_source",
              "label_key": "documents.entities.biz_document.fields.document_type.options.letterhead_source"
            },
            {
              "value": "supplier_document",
              "label": "Supplier Document",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.supplier_document",
              "label_key": "documents.entities.biz_document.fields.document_type.options.supplier_document"
            },
            {
              "value": "shipping_document",
              "label": "Shipping Document",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.shipping_document",
              "label_key": "documents.entities.biz_document.fields.document_type.options.shipping_document"
            },
            {
              "value": "compliance_document",
              "label": "Compliance Document",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.compliance_document",
              "label_key": "documents.entities.biz_document.fields.document_type.options.compliance_document"
            },
            {
              "value": "signed_customer_document",
              "label": "Signed Customer Document",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.signed_customer_document",
              "label_key": "documents.entities.biz_document.fields.document_type.options.signed_customer_document"
            },
            {
              "value": "xero_export",
              "label": "Xero Export",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.xero_export",
              "label_key": "documents.entities.biz_document.fields.document_type.options.xero_export"
            },
            {
              "value": "other",
              "label": "Other",
              "status_label_key": "documents.entities.biz_document.fields.document_type.options.other",
              "label_key": "documents.entities.biz_document.fields.document_type.options.other"
            }
          ],
          "label_key": "documents.entities.biz_document.fields.document_type.label"
        },
        {
          "id": "biz_document.status",
          "type": "enum",
          "label": "Status",
          "required": true,
          "default": "draft",
          "ui": {
            "widget": "steps"
          },
          "options": [
            {
              "value": "draft",
              "label": "Draft",
              "status_label_key": "documents.entities.biz_document.fields.status.options.draft",
              "label_key": "documents.entities.biz_document.fields.status.options.draft"
            },
            {
              "value": "approved",
              "label": "Approved",
              "status_label_key": "documents.entities.biz_document.fields.status.options.approved",
              "label_key": "documents.entities.biz_document.fields.status.options.approved"
            },
            {
              "value": "sent",
              "label": "Sent",
              "status_label_key": "documents.entities.biz_document.fields.status.options.sent",
              "label_key": "documents.entities.biz_document.fields.status.options.sent"
            },
            {
              "value": "signed",
              "label": "Signed",
              "status_label_key": "documents.entities.biz_document.fields.status.options.signed",
              "label_key": "documents.entities.biz_document.fields.status.options.signed"
            },
            {
              "value": "archived",
              "label": "Archived",
              "status_label_key": "documents.entities.biz_document.fields.status.options.archived",
              "label_key": "documents.entities.biz_document.fields.status.options.archived"
            }
          ],
          "label_key": "documents.entities.biz_document.fields.status.label"
        },
        {
          "id": "biz_document.contact_id",
          "type": "lookup",
          "label": "Contact",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name"
        },
        {
          "id": "biz_document.source_entity_label",
          "type": "string",
          "label": "Source Entity"
        },
        {
          "id": "biz_document.source_record_label",
          "type": "string",
          "label": "Source Record"
        },
        {
          "id": "biz_document.source_entity_id",
          "type": "string",
          "label": "Source Entity ID",
          "readonly": true
        },
        {
          "id": "biz_document.source_record_id",
          "type": "string",
          "label": "Source Record ID",
          "readonly": true
        },
        {
          "id": "biz_document.source_field_id",
          "type": "string",
          "label": "Source Attachment Field",
          "readonly": true
        },
        {
          "id": "biz_document.file_name",
          "type": "string",
          "label": "File Name",
          "readonly": true
        },
        {
          "id": "biz_document.file_extension",
          "type": "string",
          "label": "File Type",
          "readonly": true
        },
        {
          "id": "biz_document.mime_type",
          "type": "string",
          "label": "MIME Type",
          "readonly": true
        },
        {
          "id": "biz_document.related_contact_id",
          "type": "lookup",
          "label": "Legacy Contact",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name",
          "readonly": true
        },
        {
          "id": "biz_document.related_quote_id",
          "type": "lookup",
          "label": "Legacy Quote",
          "entity": "entity.biz_quote",
          "display_field": "biz_quote.quote_number",
          "readonly": true
        },
        {
          "id": "biz_document.related_order_id",
          "type": "lookup",
          "label": "Legacy Order",
          "entity": "entity.biz_order",
          "display_field": "biz_order.order_number",
          "readonly": true
        },
        {
          "id": "biz_document.related_purchase_order_id",
          "type": "lookup",
          "label": "Legacy Purchase Order",
          "entity": "entity.biz_purchase_order",
          "display_field": "biz_purchase_order.po_number",
          "readonly": true
        },
        {
          "id": "biz_document.related_invoice_id",
          "type": "lookup",
          "label": "Legacy Invoice",
          "entity": "entity.biz_invoice",
          "display_field": "biz_invoice.invoice_number",
          "readonly": true
        },
        {
          "id": "biz_document.sales_entity",
          "type": "enum",
          "label": "Entity",
          "required": true,
          "help_text": "Choose the entity this document belongs to. Documents created from quotes, orders, or invoices copy this automatically.",
          "options": [
            {
              "value": "NLight BV",
              "label": "NLight BV",
              "status_label_key": "documents.entities.biz_document.fields.sales_entity.options.nlight_bv",
              "label_key": "documents.entities.biz_document.fields.sales_entity.options.nlight_bv"
            },
            {
              "value": "EcoTech FZCO",
              "label": "EcoTech FZCO",
              "status_label_key": "documents.entities.biz_document.fields.sales_entity.options.ecotech_fzco",
              "label_key": "documents.entities.biz_document.fields.sales_entity.options.ecotech_fzco"
            }
          ],
          "label_key": "documents.entities.biz_document.fields.sales_entity.label"
        },
        {
          "id": "biz_document.owner_user_id",
          "type": "user",
          "label": "Owner",
          "label_key": "documents.entities.biz_document.fields.owner_user_id.label"
        },
        {
          "id": "biz_document.document_date",
          "type": "date",
          "label": "Document Date",
          "label_key": "documents.entities.biz_document.fields.document_date.label"
        },
        {
          "id": "biz_document.expiry_date",
          "type": "date",
          "label": "Expiry Date",
          "label_key": "documents.entities.biz_document.fields.expiry_date.label"
        },
        {
          "id": "biz_document.external_system",
          "type": "enum",
          "label": "External System",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "None",
              "status_label_key": "documents.entities.biz_document.fields.external_system.options.none",
              "label_key": "documents.entities.biz_document.fields.external_system.options.none"
            },
            {
              "value": "pipedrive",
              "label": "Pipedrive",
              "status_label_key": "documents.entities.biz_document.fields.external_system.options.pipedrive",
              "label_key": "documents.entities.biz_document.fields.external_system.options.pipedrive"
            },
            {
              "value": "xero",
              "label": "Xero",
              "status_label_key": "documents.entities.biz_document.fields.external_system.options.xero",
              "label_key": "documents.entities.biz_document.fields.external_system.options.xero"
            },
            {
              "value": "clickup",
              "label": "ClickUp",
              "status_label_key": "documents.entities.biz_document.fields.external_system.options.clickup",
              "label_key": "documents.entities.biz_document.fields.external_system.options.clickup"
            },
            {
              "value": "email",
              "label": "Email",
              "status_label_key": "documents.entities.biz_document.fields.external_system.options.email",
              "label_key": "documents.entities.biz_document.fields.external_system.options.email"
            }
          ],
          "label_key": "documents.entities.biz_document.fields.external_system.label"
        },
        {
          "id": "biz_document.external_reference",
          "type": "string",
          "label": "External Reference",
          "label_key": "documents.entities.biz_document.fields.external_reference.label"
        },
        {
          "id": "biz_document.attachments",
          "type": "attachments",
          "label": "Files",
          "label_key": "documents.entities.biz_document.fields.attachments.label"
        },
        {
          "id": "biz_document.archive_reason",
          "type": "text",
          "label": "Archive Reason",
          "required_when": {
            "op": "eq",
            "field": "biz_document.status",
            "value": "archived"
          },
          "label_key": "documents.entities.biz_document.fields.archive_reason.label"
        },
        {
          "id": "biz_document.notes",
          "type": "text",
          "label": "Notes",
          "label_key": "documents.entities.biz_document.fields.notes.label"
        }
      ],
      "label_key": "documents.entities.biz_document.label"
    }
  ],
  "actions": [
    {
      "id": "action.document_new",
      "kind": "open_form",
      "label": "New Document",
      "target": "biz_document.form",
      "action_label_key": "documents.actions.action_document_new.label"
    },
    {
      "id": "action.document_approve",
      "kind": "update_record",
      "entity_id": "entity.biz_document",
      "label": "Approve",
      "patch": {
        "biz_document.status": "approved"
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_document.status",
        "value": "draft"
      },
      "enabled_when": {
        "op": "and",
        "conditions": [
          {
            "op": "exists",
            "field": "biz_document.name"
          },
          {
            "op": "exists",
            "field": "biz_document.document_type"
          }
        ]
      },
      "action_label_key": "documents.actions.action_document_approve.label"
    },
    {
      "id": "action.document_mark_sent",
      "kind": "update_record",
      "entity_id": "entity.biz_document",
      "label": "Mark Sent",
      "patch": {
        "biz_document.status": "sent"
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_document.status",
        "value": "approved"
      },
      "action_label_key": "documents.actions.action_document_mark_sent.label"
    },
    {
      "id": "action.document_mark_signed",
      "kind": "update_record",
      "entity_id": "entity.biz_document",
      "label": "Mark Signed",
      "patch": {
        "biz_document.status": "signed"
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_document.status",
        "value": "sent"
      },
      "action_label_key": "documents.actions.action_document_mark_signed.label"
    },
    {
      "id": "action.document_open_archive_modal",
      "kind": "update_record",
      "entity_id": "entity.biz_document",
      "label": "Archive",
      "modal_id": "modal.document_archive",
      "visible_when": {
        "op": "in",
        "field": "biz_document.status",
        "value": [
          "draft",
          "approved",
          "sent",
          "signed"
        ]
      },
      "action_label_key": "documents.actions.action_document_open_archive_modal.label"
    }
  ],
  "views": [
    {
      "id": "biz_document.list",
      "kind": "list",
      "entity": "entity.biz_document",
      "columns": [
        {
          "field_id": "biz_document.name"
        },
        {
          "field_id": "biz_document.file_extension"
        },
        {
          "field_id": "biz_document.document_type"
        },
        {
          "field_id": "biz_document.source_entity_label"
        },
        {
          "field_id": "biz_document.source_record_label"
        },
        {
          "field_id": "biz_document.status"
        },
        {
          "field_id": "biz_document.sales_entity"
        },
        {
          "field_id": "biz_document.document_date"
        },
        {
          "field_id": "biz_document.external_system"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.document_new"
          }
        ],
        "open_record_target": "page:biz_document.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search documents...",
          "fields": [
            "biz_document.name",
            "biz_document.file_name",
            "biz_document.external_reference",
            "biz_document.source_record_label",
            "biz_document.notes"
          ],
          "placeholder_key": "documents.views.list.search.placeholder"
        },
        "filters": [
          {
            "id": "active",
            "label": "Active Documents",
            "domain": {
              "op": "in",
              "field": "biz_document.status",
              "value": [
                "draft",
                "approved",
                "sent",
                "signed"
              ]
            },
            "label_key": "documents.views.list.filters.active.label"
          },
          {
            "id": "draft",
            "label": "Draft",
            "domain": {
              "op": "eq",
              "field": "biz_document.status",
              "value": "draft"
            },
            "label_key": "documents.views.list.filters.draft.label"
          },
          {
            "id": "approved",
            "label": "Approved",
            "domain": {
              "op": "eq",
              "field": "biz_document.status",
              "value": "approved"
            },
            "label_key": "documents.views.list.filters.approved.label"
          },
          {
            "id": "sent",
            "label": "Sent",
            "domain": {
              "op": "eq",
              "field": "biz_document.status",
              "value": "sent"
            },
            "label_key": "documents.views.list.filters.sent.label"
          },
          {
            "id": "signed",
            "label": "Signed",
            "domain": {
              "op": "eq",
              "field": "biz_document.status",
              "value": "signed"
            },
            "label_key": "documents.views.list.filters.signed.label"
          },
          {
            "id": "archived",
            "label": "Archived",
            "domain": {
              "op": "eq",
              "field": "biz_document.status",
              "value": "archived"
            },
            "label_key": "documents.views.list.filters.archived.label"
          },
          {
            "id": "quote_docs",
            "label": "Quote PDFs",
            "domain": {
              "op": "eq",
              "field": "biz_document.document_type",
              "value": "quote_pdf"
            },
            "label_key": "documents.views.list.filters.quote_docs.label"
          },
          {
            "id": "invoice_docs",
            "label": "Invoice PDFs",
            "domain": {
              "op": "eq",
              "field": "biz_document.document_type",
              "value": "invoice_pdf"
            },
            "label_key": "documents.views.list.filters.invoice_docs.label"
          },
          {
            "id": "supplier_docs",
            "label": "Supplier Documents",
            "domain": {
              "op": "in",
              "field": "biz_document.document_type",
              "value": [
                "purchase_order_pdf",
                "supplier_document"
              ]
            },
            "label_key": "documents.views.list.filters.supplier_docs.label"
          }
        ]
      }
    },
    {
      "id": "biz_document.form",
      "kind": "form",
      "entity": "entity.biz_document",
      "sections": [
        {
          "id": "summary",
          "title": "Document",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_document.name",
            "biz_document.status",
            "biz_document.document_type",
            "biz_document.sales_entity",
            "biz_document.contact_id",
            "biz_document.owner_user_id",
            "biz_document.document_date",
            "biz_document.expiry_date"
          ],
          "section_title_key": "documents.views.form.sections.summary.title"
        },
        {
          "id": "source",
          "title": "Source",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_document.source_entity_label",
            "biz_document.source_record_label",
            "biz_document.source_entity_id",
            "biz_document.source_record_id"
          ],
          "section_title_key": "documents.views.form.sections.links.title"
        },
        {
          "id": "file_details",
          "title": "File Details",
          "layout": "columns",
          "columns": 2,
          "fields": [
            {
              "kind": "divider",
              "id": "document_file_details_divider",
              "spacing": "compact",
              "label": "File Details"
            },
            "biz_document.file_name",
            "biz_document.file_extension",
            "biz_document.mime_type"
          ]
        },
        {
          "id": "external",
          "title": "External System",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "biz_document.external_system",
            "biz_document.external_reference"
          ],
          "section_title_key": "documents.views.form.sections.external.title"
        },
        {
          "id": "files",
          "title": "Files",
          "fields": [
            "biz_document.attachments"
          ],
          "section_title_key": "documents.views.form.sections.files.title"
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "biz_document.archive_reason",
