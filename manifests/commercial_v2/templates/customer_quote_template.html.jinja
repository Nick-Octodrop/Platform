<div class="page-bg"></div>

<div class="repeat-header">
  <div class="repeat-header-left">
    <div class="header-brand">
      {% if logo_url %}
      <img src="{{ logo_url }}" alt="{{ brand_name }}" class="header-logo" />
      {% else %}
      <div class="header-brand-fallback">{{ brand_name }}</div>
      {% endif %}
    </div>
  </div>
  <div class="repeat-header-middle">
    {% if brand_address_line_1 %}<div>{{ brand_address_line_1 }}</div>{% endif %}
    {% if brand_address_line_2 %}<div>{{ brand_address_line_2 }}</div>{% endif %}
    {% if brand_postcode or brand_city or brand_region %}
    <div>{{ brand_postcode }}{% if brand_postcode and (brand_city or brand_region) %} {% endif %}{{ brand_city }}{% if brand_region %} {{ brand_region }}{% endif %}</div>
    {% endif %}
    {% if brand_country %}<div>{{ brand_country }}</div>{% endif %}
  </div>
  <div class="repeat-header-right">
    {% if brand_phone %}<div>Tel. {{ brand_phone }}</div>{% endif %}
    {% if brand_website %}<div>{{ brand_website }}</div>{% endif %}
    {% if brand_email %}<div>{{ brand_email }}</div>{% endif %}
    {% if brand_vat %}<div>VAT Reg. No. {{ brand_vat }}</div>{% endif %}
    {% if company_registration_number %}<div>CoC {{ company_registration_number }}</div>{% endif %}
    <div class="quote-title">
      <span class="label">QUOTATION NO.</span>
      <span class="value">{{ quote_number }}</span>
    </div>
  </div>
</div>

<div class="repeat-footer"></div>

<div class="doc">
  <table class="page-frame">
    <thead>
      <tr><td><div class="frame-top"></div></td></tr>
    </thead>
    <tfoot>
      <tr><td><div class="frame-bottom"></div></td></tr>
    </tfoot>
    <tbody>
      <tr>
        <td>
          <div class="frame-body">
            <section class="cover-page">
              <div class="recipient-meta">
                <div class="recipient-block">
                  {% if contact_name %}<div>{{ contact_name }}</div>{% endif %}
                  {% if customer_name and customer_name != contact_name %}<div>{{ customer_name }}</div>{% endif %}
                  {% if contact_email %}<div>{{ contact_email }}</div>{% endif %}
                  {% if contact_phone %}<div>{{ contact_phone }}</div>{% endif %}
                </div>
                <div class="meta-card-wrap">
                  <div class="meta-card">
                    <div class="meta-row">
                      <div class="meta-label">Date:</div>
                      <div class="meta-value">{{ quote_date }}</div>
                    </div>
                    <div class="meta-row">
                      <div class="meta-label">Site:</div>
                      <div class="meta-value">{{ site_label }}</div>
                    </div>
                    <div class="meta-row">
                      <div class="meta-label">Valid For:</div>
                      <div class="meta-value">30 Day(s)</div>
                    </div>
                    <div class="meta-row">
                      <div class="meta-label">Valid Until:</div>
                      <div class="meta-value">{{ expiry_date }}</div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="panel cover-panel">
                {% if opening_message %}
                <div class="richtext richtext-body">{{ opening_message|richtext }}</div>
                {% else %}
                <div class="body-copy">Please find enclosed our quotation and commercial proposal for your review.</div>
                {% endif %}
              </div>

              {% if shipping_terms or incoterm or payment_terms or validity_notes %}
              <div class="panel terms-panel">
                {% if shipping_terms %}
                <div class="section-title">Delivery Terms</div>
                <div class="fine-copy" style="margin-bottom:8px;">{{ shipping_terms }}</div>
                {% endif %}
                {% if incoterm %}
                <div class="section-title">Incoterm</div>
                <div class="fine-copy" style="margin-bottom:8px;">{{ incoterm }}</div>
                {% endif %}
                {% if payment_terms %}
                <div class="section-title">Payment Terms</div>
                <div class="fine-copy" style="margin-bottom:8px;">{{ payment_terms }}</div>
                {% endif %}
                {% if validity_notes %}
                <div class="section-title">Validity Notes</div>
                <div class="richtext richtext-fine">{{ validity_notes|richtext }}</div>
                {% endif %}
              </div>
              {% endif %}
            </section>

            <section class="flow-section">
              {% if quote_script_body %}
              <div class="panel">
                <div class="richtext richtext-body">{{ quote_script_body|richtext }}</div>
              </div>
              {% endif %}

              {% if transport_disclaimer %}
              <div class="panel">
                <div class="section-title">Transport Disclaimer</div>
                <div class="richtext richtext-fine">{{ transport_disclaimer|richtext }}</div>
              </div>
              {% endif %}

              {% if closing_text %}
              <div class="panel">
                <div class="richtext richtext-fine">{{ closing_text|richtext }}</div>
              </div>
              {% endif %}

              {% if customer_notes %}
              <div class="panel">
                <div class="section-title">Project Notes</div>
                <div class="richtext richtext-fine">{{ customer_notes|richtext }}</div>
              </div>
              {% endif %}

              <div class="table-card summary-card">
                <div class="summary-head">Summary</div>
                <table class="summary-table">
                  {% for line in quote_lines %}
                  <tr>
                    <td class="summary-label">{{ line['biz_quote_line.description'] if line is defined and line and line['biz_quote_line.description'] is defined and line['biz_quote_line.description'] else ('Line ' ~ loop.index) }}</td>
                    <td class="summary-value">{% if currency_symbol %}{{ currency_symbol }}{% endif %}{{ line['biz_quote_line.line_total'] if line is defined and line and line['biz_quote_line.line_total'] is defined and line['biz_quote_line.line_total'] else 0 }}{% if not currency_symbol and currency_code %} {{ currency_code }}{% endif %}</td>
                  </tr>
                  {% endfor %}
                </table>
                <div class="summary-note">
                  {% if tax_percent %}All prices are shown with {{ tax_percent }}% VAT / sales tax treatment applied.{% else %}All prices are shown with the current quote tax treatment applied.{% endif %}
                  {% if payment_terms %} Payment terms: {{ payment_terms }}.{% endif %}
                </div>
              </div>
            </section>

            <section class="pricing-section page-break-before">
              <div class="pricing-page">
                <div>
                  <div class="pricing-page-title">Detailed Pricing</div>
                  <div class="table-card detail-card">
                    <table class="detail-table">
                      <thead>
                        <tr>
                          <th>Description</th>
                          <th class="detail-value">Qty</th>
                          <th class="detail-value">UOM</th>
                          <th class="detail-value">Unit Price</th>
                          <th class="detail-value">Total</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% for line in quote_lines %}
                        {% set spec_parts = [] %}
                        {% if line is defined and line and line['biz_quote_line.wattage_snapshot'] is defined and line['biz_quote_line.wattage_snapshot'] %}{% set _ = spec_parts.append(line['biz_quote_line.wattage_snapshot'] ~ 'W') %}{% endif %}
                        {% if line is defined and line and line['biz_quote_line.spectrum_snapshot'] is defined and line['biz_quote_line.spectrum_snapshot'] %}{% set _ = spec_parts.append(line['biz_quote_line.spectrum_snapshot']) %}{% endif %}
                        {% if line is defined and line and line['biz_quote_line.input_voltage_snapshot'] is defined and line['biz_quote_line.input_voltage_snapshot'] %}{% set _ = spec_parts.append(line['biz_quote_line.input_voltage_snapshot']) %}{% endif %}
                        {% if line is defined and line and line['biz_quote_line.ppf_umol_s_snapshot'] is defined and line['biz_quote_line.ppf_umol_s_snapshot'] %}{% set _ = spec_parts.append('PPF ' ~ line['biz_quote_line.ppf_umol_s_snapshot']) %}{% endif %}
                        {% if line is defined and line and line['biz_quote_line.ppe_umol_per_w_snapshot'] is defined and line['biz_quote_line.ppe_umol_per_w_snapshot'] %}{% set _ = spec_parts.append('PPE ' ~ line['biz_quote_line.ppe_umol_per_w_snapshot']) %}{% endif %}
                        {% if line is defined and line and line['biz_quote_line.ip_rating_snapshot'] is defined and line['biz_quote_line.ip_rating_snapshot'] %}{% set _ = spec_parts.append(line['biz_quote_line.ip_rating_snapshot']) %}{% endif %}
                        <tr>
                          <td>
                            <div>{{ line['biz_quote_line.description'] if line is defined and line and line['biz_quote_line.description'] is defined and line['biz_quote_line.description'] else '' }}</div>
                            {% if spec_parts %}<div class="line-specs">{{ spec_parts|join(' | ') }}</div>{% endif %}
                          </td>
                          <td class="detail-value">{{ line['biz_quote_line.quantity'] if line is defined and line and line['biz_quote_line.quantity'] is defined and line['biz_quote_line.quantity'] else '' }}</td>
                          <td class="detail-value">{{ line['biz_quote_line.uom'] if line is defined and line and line['biz_quote_line.uom'] is defined and line['biz_quote_line.uom'] else '' }}</td>
                          <td class="detail-value">{% if currency_symbol %}{{ currency_symbol }}{% endif %}{{ line['biz_quote_line.unit_price'] if line is defined and line and line['biz_quote_line.unit_price'] is defined and line['biz_quote_line.unit_price'] else '' }}{% if not currency_symbol and currency_code %} {{ currency_code }}{% endif %}</td>
                          <td class="detail-value">{% if currency_symbol %}{{ currency_symbol }}{% endif %}{{ line['biz_quote_line.line_total'] if line is defined and line and line['biz_quote_line.line_total'] is defined and line['biz_quote_line.line_total'] else '' }}{% if not currency_symbol and currency_code %} {{ currency_code }}{% endif %}</td>
                        </tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="pricing-page-bottom">
                  <div class="final-totals">
                    <table>
                      <tr>
                        <td class="label">Sub-Total ex VAT</td>
                        <td class="value">{% if currency_symbol %}{{ currency_symbol }}{% endif %}{{ subtotal }}{% if not currency_symbol and currency_code %} {{ currency_code }}{% endif %}</td>
                      </tr>
                      {% if discount_total %}
                      <tr>
                        <td class="label">Discount</td>
                        <td class="value">{% if currency_symbol %}{{ currency_symbol }}{% endif %}{{ discount_total }}{% if not currency_symbol and currency_code %} {{ currency_code }}{% endif %}</td>
                      </tr>
                      {% endif %}
                      <tr>
                        <td class="label">VAT</td>
                        <td class="value">{% if currency_symbol %}{{ currency_symbol }}{% endif %}{{ tax_total }}{% if not currency_symbol and currency_code %} {{ currency_code }}{% endif %}</td>
                      </tr>
                      <tr>
                        <td class="label">Total inc VAT</td>
                        <td class="value">{% if currency_symbol %}{{ currency_symbol }}{% endif %}{{ grand_total }}{% if not currency_symbol and currency_code %} {{ currency_code }}{% endif %}</td>
                      </tr>
                    </table>
                  </div>

                  <div class="payment-divider"></div>

                  {% if bank_name or bank_account_name or bank_account_number or bank_bic or bank_iban %}
                  <div class="payment-area">
                    <div class="payment-title-wrap">
                      <div class="payment-title">How To Pay</div>
                    </div>
                    <div class="payment-side">
                      <div class="payment-badge">Quotation No. {{ quote_number }}</div>
                      <div class="pay-card">
                        <div class="pay-method">Direct Deposit</div>
                        <div class="pay-row">
                          <div class="pay-label">Bank</div>
                          <div class="pay-value">{{ bank_name }}</div>
                        </div>
                        <div class="pay-row">
                          <div class="pay-label">Acc. Name</div>
                          <div class="pay-value">{{ bank_account_name }}</div>
                        </div>
                        <div class="pay-row">
                          <div class="pay-label">Sort Code</div>
                          <div class="pay-value">&nbsp;</div>
                        </div>
                        <div class="pay-row">
                          <div class="pay-label">Acc. No.</div>
                          <div class="pay-value">{{ bank_account_number }}</div>
                        </div>
                        <div class="pay-row">
                          <div class="pay-label">BIC</div>
                          <div class="pay-value">{{ bank_bic }}</div>
                        </div>
                        <div class="pay-row">
                          <div class="pay-label">IBAN</div>
                          <div class="pay-value">{{ bank_iban }}</div>
                        </div>
                      </div>
                    </div>
                  </div>
                  {% endif %}
                </div>
              </div>
            </section>

          </div>
        </td>
      </tr>
    </tbody>
  </table>
</div>
