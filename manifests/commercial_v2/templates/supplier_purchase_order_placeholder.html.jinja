{% set po_lines = lines if lines is defined and lines else (line_items if line_items is defined and line_items else (formatted_line_items if formatted_line_items is defined and formatted_line_items else [])) %}
{% set brand_name = template_branding.brand_name if template_branding is defined and template_branding and template_branding.brand_name is defined and template_branding.brand_name else (workspace.name if workspace is defined and workspace and workspace.name is defined and workspace.name else 'NLight') %}
{% set po_number = record['biz_purchase_order.po_number'] if record is defined and record and record['biz_purchase_order.po_number'] is defined and record['biz_purchase_order.po_number'] else 'Draft PO' %}
{% set po_status = record['biz_purchase_order.status'] if record is defined and record and record['biz_purchase_order.status'] is defined and record['biz_purchase_order.status'] else 'Draft' %}
{% set po_date = record['biz_purchase_order.po_date'] if record is defined and record and record['biz_purchase_order.po_date'] is defined and record['biz_purchase_order.po_date'] else '' %}
{% set expected_ship_date = record['biz_purchase_order.expected_ship_date'] if record is defined and record and record['biz_purchase_order.expected_ship_date'] is defined and record['biz_purchase_order.expected_ship_date'] else '' %}
{% set expected_arrival_date = record['biz_purchase_order.expected_arrival_date'] if record is defined and record and record['biz_purchase_order.expected_arrival_date'] is defined and record['biz_purchase_order.expected_arrival_date'] else '' %}
{% set supplier_name = record['biz_purchase_order.supplier_id_label'] if record is defined and record and record['biz_purchase_order.supplier_id_label'] is defined and record['biz_purchase_order.supplier_id_label'] else '' %}
{% set supplier_contact_name = record['biz_purchase_order.supplier_contact_name'] if record is defined and record and record['biz_purchase_order.supplier_contact_name'] is defined and record['biz_purchase_order.supplier_contact_name'] else '' %}
{% set supplier_contact_email = record['biz_purchase_order.supplier_contact_email'] if record is defined and record and record['biz_purchase_order.supplier_contact_email'] is defined and record['biz_purchase_order.supplier_contact_email'] else '' %}
{% set supplier_reference = record['biz_purchase_order.supplier_reference'] if record is defined and record and record['biz_purchase_order.supplier_reference'] is defined and record['biz_purchase_order.supplier_reference'] else '' %}
{% set currency = record['biz_purchase_order.currency'] if record is defined and record and record['biz_purchase_order.currency'] is defined and record['biz_purchase_order.currency'] else '' %}
{% set po_total = record['biz_purchase_order.po_total'] if record is defined and record and record['biz_purchase_order.po_total'] is defined and record['biz_purchase_order.po_total'] else 0 %}
<style>
  body { font-family: Arial, sans-serif; color: #1f2937; font-size: 12px; line-height: 1.45; }
  .header { display: table; width: 100%; border-bottom: 2px solid #e879b8; padding-bottom: 14px; margin-bottom: 22px; }
  .left, .right { display: table-cell; vertical-align: top; width: 50%; }
  .right { text-align: right; color: #4b5563; }
  h1 { margin: 0 0 8px; font-size: 24px; color: #111827; }
  h2 { margin: 24px 0 10px; font-size: 15px; color: #111827; }
  table { width: 100%; border-collapse: collapse; margin-top: 8px; }
  th { text-align: left; background: #f8f4f7; color: #374151; font-size: 11px; padding: 8px; border-bottom: 1px solid #e5e7eb; }
  td { padding: 8px; border-bottom: 1px solid #e5e7eb; vertical-align: top; }
  .amount { text-align: right; white-space: nowrap; }
  .summary { margin-left: auto; width: 45%; }
  .muted { color: #6b7280; }
</style>
<div class="header">
  <div class="left">
    <h1>Purchase Order</h1>
    <div><strong>{{ po_number }}</strong></div>
    <div class="muted">Status: {{ po_status }}</div>
  </div>
  <div class="right">
    <strong>{{ brand_name }}</strong><br>
    PO date: {{ po_date }}<br>
    Expected ship: {{ expected_ship_date }}<br>
    Expected arrival: {{ expected_arrival_date }}
  </div>
</div>

<h2>Supplier</h2>
<table>
  <tr><td>Supplier</td><td>{{ supplier_name }}</td></tr>
  <tr><td>Contact</td><td>{{ supplier_contact_name }}</td></tr>
  <tr><td>Email</td><td>{{ supplier_contact_email }}</td></tr>
  <tr><td>Reference</td><td>{{ supplier_reference }}</td></tr>
</table>

<h2>Purchase Lines</h2>
<table>
  <thead>
    <tr>
      <th>Product</th>
      <th>Description</th>
      <th class="amount">Qty</th>
      <th class="amount">Unit Cost</th>
      <th class="amount">Total</th>
    </tr>
  </thead>
  <tbody>
    {% for line in po_lines %}
    <tr>
      <td>{{ line['biz_purchase_order_line.product_name_snapshot'] if line['biz_purchase_order_line.product_name_snapshot'] is defined else line.product_name_snapshot if line.product_name_snapshot is defined else '' }}</td>
      <td>{{ line['biz_purchase_order_line.description'] if line['biz_purchase_order_line.description'] is defined else line.description if line.description is defined else 'Line item' }}</td>
      <td class="amount">{{ line['biz_purchase_order_line.quantity'] if line['biz_purchase_order_line.quantity'] is defined else line.quantity if line.quantity is defined else '' }}</td>
      <td class="amount">{{ line['biz_purchase_order_line.unit_cost'] if line['biz_purchase_order_line.unit_cost'] is defined else line.unit_cost if line.unit_cost is defined else '' }}</td>
      <td class="amount">{{ line['biz_purchase_order_line.line_total'] if line['biz_purchase_order_line.line_total'] is defined else line.line_total if line.line_total is defined else '' }}</td>
    </tr>
    {% else %}
    <tr><td colspan="5" class="muted">No lines on this purchase order yet.</td></tr>
    {% endfor %}
  </tbody>
</table>

<table class="summary">
  <tr><td><strong>Currency</strong></td><td class="amount">{{ currency }}</td></tr>
  <tr><td><strong>PO Total</strong></td><td class="amount">{{ po_total }}</td></tr>
</table>
