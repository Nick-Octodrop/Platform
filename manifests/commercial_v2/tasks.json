          "label": "Mark Done",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.open_done.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.open_done.label"
        },
        {
          "from": "in_progress",
          "to": "done",
          "label": "Mark Done",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.in_progress_done.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.in_progress_done.label"
        },
        {
          "from": "blocked",
          "to": "done",
          "label": "Mark Done",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.blocked_done.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.blocked_done.label"
        },
        {
          "from": "open",
          "to": "cancelled",
          "label": "Cancel",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.open_cancelled.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.open_cancelled.label"
        },
        {
          "from": "in_progress",
          "to": "cancelled",
          "label": "Cancel",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.in_progress_cancelled.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.in_progress_cancelled.label"
        },
        {
          "from": "blocked",
          "to": "cancelled",
          "label": "Cancel",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.blocked_cancelled.label",
