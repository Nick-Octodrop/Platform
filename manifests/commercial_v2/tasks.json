  "views": [
    {
      "id": "biz_task.list",
      "kind": "list",
      "entity": "entity.biz_task",
      "columns": [
        {
          "field_id": "biz_task.title"
        },
        {
          "field_id": "biz_task.task_type"
        },
        {
          "field_id": "biz_task.status"
        },
        {
          "field_id": "biz_task.priority"
        },
        {
          "field_id": "biz_task.sales_entity"
        },
        {
          "field_id": "biz_task.assignee_user_id"
        },
        {
          "field_id": "biz_task.due_date"
        },
        {
          "field_id": "biz_task.company_id"
        },
        {
          "field_id": "biz_task.opportunity_id"
        },
        {
          "field_id": "biz_task.order_id"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.biz_task_new"
          }
        ],
        "open_record_target": "page:biz_task.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search tasks...",
          "fields": [
            "biz_task.title",
            "biz_task.description",
            "biz_task.blocked_reason",
            "biz_task.cancel_reason"
          ],
          "placeholder_key": "tasks.views.list.search.placeholder"
        },
        "filters": [
          {
            "id": "open",
            "label": "Open Work",
            "domain": {
              "op": "in",
              "field": "biz_task.status",
              "value": [
                "open",
                "in_progress",
                "blocked"
              ]
            },
            "label_key": "tasks.views.list.filters.open.label"
          },
          {
            "id": "mine",
            "label": "My Tasks",
            "domain": {
              "op": "or",
              "conditions": [
                {
                  "op": "eq",
                  "field": "biz_task.assignee_user_id",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                },
                {
                  "op": "eq",
                  "field": "biz_task.owner_user_id",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                },
                {
                  "op": "contains",
                  "field": "biz_task.participant_user_ids",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                }
              ]
            },
            "label_key": "tasks.views.list.filters.mine.label"
          },
          {
            "id": "team",
            "label": "Team Tasks",
            "domain": {
              "op": "eq",
              "field": "biz_task.visibility",
              "value": "team"
            },
            "label_key": "tasks.views.list.filters.team.label"
          },
          {
            "id": "overdue",
            "label": "Overdue",
            "domain": {
              "op": "and",
              "conditions": [
                {
                  "op": "in",
                  "field": "biz_task.status",
                  "value": [
                    "open",
                    "in_progress",
                    "blocked"
                  ]
                },
                {
                  "op": "lte",
                  "field": "biz_task.due_date",
                  "value": {
                    "ref": "$today"
                  }
                }
              ]
            },
            "label_key": "tasks.views.list.filters.overdue.label"
          },
          {
            "id": "crm",
            "label": "CRM Tasks",
            "domain": {
              "op": "or",
              "conditions": [
                {
                  "op": "exists",
                  "field": "biz_task.lead_id"
                },
                {
                  "op": "exists",
                  "field": "biz_task.opportunity_id"
                }
              ]
            },
            "label_key": "tasks.views.list.filters.crm.label"
          },
          {
            "id": "operations",
            "label": "Operations",
            "domain": {
              "op": "or",
              "conditions": [
                {
                  "op": "exists",
                  "field": "biz_task.order_id"
                },
                {
                  "op": "exists",
                  "field": "biz_task.purchase_order_id"
                }
              ]
            },
            "label_key": "tasks.views.list.filters.operations.label"
          },
          {
            "id": "finance",
            "label": "Finance",
            "domain": {
              "op": "exists",
              "field": "biz_task.invoice_id"
            },
            "label_key": "tasks.views.list.filters.finance.label"
          },
          {
            "id": "blocked",
            "label": "Blocked",
            "domain": {
              "op": "eq",
              "field": "biz_task.status",
              "value": "blocked"
            },
            "label_key": "tasks.views.list.filters.blocked.label"
          },
          {
            "id": "done",
            "label": "Done",
            "domain": {
              "op": "eq",
              "field": "biz_task.status",
              "value": "done"
            },
            "label_key": "tasks.views.list.filters.done.label"
          }
        ]
      }
    },
