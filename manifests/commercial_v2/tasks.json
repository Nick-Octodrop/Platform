{
  "manifest_version": "1.3",
  "module": {
    "id": "biz_tasks",
    "key": "biz_tasks",
    "name": "Tasks",
    "version": "1.0.0",
    "description": "Tasks for follow-ups, handoffs, and internal work.",
    "category": "Operations",
    "icon_key": "lucide:ListTodo",
    "name_key": "tasks.module.name",
    "description_key": "tasks.module.description"
  },
  "depends_on": {
    "required": [
      {
        "module": "biz_contacts",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_quotes",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_orders",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_purchase_orders",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_invoices",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_documents",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_crm",
        "version": ">=1.0.0"
      }
    ]
  },
  "app": {
    "home": "page:biz_task.list_page",
    "defaults": {
      "entity_home_page": "page:biz_task.list_page",
      "entity_form_page": "page:biz_task.form_page",
      "entities": {
        "entity.biz_task": {
          "entity_home_page": "page:biz_task.list_page",
          "entity_form_page": "page:biz_task.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Operations",
        "mode": "inline",
        "items": [
          {
            "label": "Tasks",
            "to": "page:biz_task.list_page",
            "menu_label_key": "tasks.navigation.biz_task_list_page"
          },
          {
            "label": "My Tasks",
            "to": "page:biz_task.mine_page",
            "menu_label_key": "tasks.navigation.biz_task_mine_page"
          },
          {
            "label": "Overdue",
            "to": "page:biz_task.overdue_page",
            "menu_label_key": "tasks.navigation.biz_task_overdue_page"
          },
          {
            "label": "CRM",
            "to": "page:biz_task.crm_page",
            "menu_label_key": "tasks.navigation.biz_task_crm_page"
          },
          {
            "label": "Operations",
            "to": "page:biz_task.operations_page",
            "menu_label_key": "tasks.navigation.biz_task_operations_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.biz_task",
      "label": "Task",
      "display_field": "biz_task.title",
      "fields": [
        {
          "id": "biz_task.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true,
          "label_key": "tasks.entities.biz_task.fields.id.label"
        },
        {
          "id": "biz_task.title",
          "type": "string",
          "label": "Task",
          "required": true,
          "label_key": "tasks.entities.biz_task.fields.title.label"
        },
        {
          "id": "biz_task.task_type",
          "type": "enum",
          "label": "Type",
          "default": "follow_up",
          "options": [
            {
              "value": "follow_up",
              "label": "Follow-Up",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.follow_up",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.follow_up"
            },
            {
              "value": "quote",
              "label": "Quote Work",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.quote",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.quote"
            },
            {
              "value": "order_handoff",
              "label": "Order Handoff",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.order_handoff",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.order_handoff"
            },
            {
              "value": "procurement",
              "label": "Procurement",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.procurement",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.procurement"
            },
            {
              "value": "finance",
              "label": "Finance",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.finance",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.finance"
            },
            {
              "value": "document",
              "label": "Document",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.document",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.document"
            },
            {
              "value": "site_visit",
              "label": "Site Visit",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.site_visit",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.site_visit"
            },
            {
              "value": "internal",
              "label": "Internal",
              "status_label_key": "tasks.entities.biz_task.fields.task_type.options.internal",
              "label_key": "tasks.entities.biz_task.fields.task_type.options.internal"
            }
          ],
          "label_key": "tasks.entities.biz_task.fields.task_type.label"
        },
        {
          "id": "biz_task.status",
          "type": "enum",
          "label": "Status",
          "default": "open",
          "ui": {
            "widget": "steps"
          },
          "options": [
            {
              "value": "open",
              "label": "Open",
              "status_label_key": "tasks.entities.biz_task.fields.status.options.open",
              "label_key": "tasks.entities.biz_task.fields.status.options.open"
            },
            {
              "value": "in_progress",
              "label": "In Progress",
              "status_label_key": "tasks.entities.biz_task.fields.status.options.in_progress",
              "label_key": "tasks.entities.biz_task.fields.status.options.in_progress"
            },
            {
              "value": "blocked",
              "label": "Blocked",
              "status_label_key": "tasks.entities.biz_task.fields.status.options.blocked",
              "label_key": "tasks.entities.biz_task.fields.status.options.blocked"
            },
            {
              "value": "done",
              "label": "Done",
              "status_label_key": "tasks.entities.biz_task.fields.status.options.done",
              "label_key": "tasks.entities.biz_task.fields.status.options.done"
            },
            {
              "value": "cancelled",
              "label": "Cancelled",
              "status_label_key": "tasks.entities.biz_task.fields.status.options.cancelled",
              "label_key": "tasks.entities.biz_task.fields.status.options.cancelled"
            }
          ],
          "label_key": "tasks.entities.biz_task.fields.status.label"
        },
        {
          "id": "biz_task.priority",
          "type": "enum",
          "label": "Priority",
          "default": "normal",
          "options": [
            {
              "value": "low",
              "label": "Low",
              "status_label_key": "tasks.entities.biz_task.fields.priority.options.low",
              "label_key": "tasks.entities.biz_task.fields.priority.options.low"
            },
            {
              "value": "normal",
              "label": "Normal",
              "status_label_key": "tasks.entities.biz_task.fields.priority.options.normal",
              "label_key": "tasks.entities.biz_task.fields.priority.options.normal"
            },
            {
              "value": "high",
              "label": "High",
              "status_label_key": "tasks.entities.biz_task.fields.priority.options.high",
              "label_key": "tasks.entities.biz_task.fields.priority.options.high"
            },
            {
              "value": "urgent",
              "label": "Urgent",
              "status_label_key": "tasks.entities.biz_task.fields.priority.options.urgent",
              "label_key": "tasks.entities.biz_task.fields.priority.options.urgent"
            }
          ],
          "label_key": "tasks.entities.biz_task.fields.priority.label"
        },
        {
          "id": "biz_task.owner_user_id",
          "type": "user",
          "label": "Owner",
          "label_key": "tasks.entities.biz_task.fields.owner_user_id.label"
        },
        {
          "id": "biz_task.assignee_user_id",
          "type": "user",
          "label": "Assignee",
          "label_key": "tasks.entities.biz_task.fields.assignee_user_id.label"
        },
        {
          "id": "biz_task.participant_user_ids",
          "type": "users",
          "label": "Participants",
          "label_key": "tasks.entities.biz_task.fields.participant_user_ids.label"
        },
        {
          "id": "biz_task.visibility",
          "type": "enum",
          "label": "Visibility",
          "default": "team",
          "options": [
            {
              "value": "private",
              "label": "Private",
              "status_label_key": "tasks.entities.biz_task.fields.visibility.options.private",
              "label_key": "tasks.entities.biz_task.fields.visibility.options.private"
            },
            {
              "value": "team",
              "label": "Team",
              "status_label_key": "tasks.entities.biz_task.fields.visibility.options.team",
              "label_key": "tasks.entities.biz_task.fields.visibility.options.team"
            },
            {
              "value": "directors",
              "label": "Directors",
              "status_label_key": "tasks.entities.biz_task.fields.visibility.options.directors",
              "label_key": "tasks.entities.biz_task.fields.visibility.options.directors"
            }
          ],
          "label_key": "tasks.entities.biz_task.fields.visibility.label"
        },
        {
          "id": "biz_task.sales_entity",
          "type": "enum",
          "label": "Entity",
          "help_text": "Owning entity/team for this task.",
          "options": [
            {
              "value": "NLight BV",
              "label": "NLight BV",
              "status_label_key": "tasks.entities.biz_task.fields.sales_entity.options.nlight_bv",
              "label_key": "tasks.entities.biz_task.fields.sales_entity.options.nlight_bv"
            },
            {
              "value": "EcoTech FZCO",
              "label": "EcoTech FZCO",
              "status_label_key": "tasks.entities.biz_task.fields.sales_entity.options.ecotech_fzco",
              "label_key": "tasks.entities.biz_task.fields.sales_entity.options.ecotech_fzco"
            }
          ],
          "label_key": "tasks.entities.biz_task.fields.sales_entity.label"
        },
        {
          "id": "biz_task.start_date",
          "type": "date",
          "label": "Start Date",
          "label_key": "tasks.entities.biz_task.fields.start_date.label"
        },
        {
          "id": "biz_task.due_date",
          "type": "date",
          "label": "Due Date",
          "label_key": "tasks.entities.biz_task.fields.due_date.label"
        },
        {
          "id": "biz_task.company_id",
          "type": "lookup",
          "label": "Company",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name",
          "label_key": "tasks.entities.biz_task.fields.company_id.label"
        },
        {
          "id": "biz_task.lead_id",
          "type": "lookup",
          "label": "Lead",
          "entity": "entity.crm_lead",
          "display_field": "crm_lead.title",
          "label_key": "tasks.entities.biz_task.fields.lead_id.label"
        },
        {
          "id": "biz_task.opportunity_id",
          "type": "lookup",
          "label": "Opportunity",
          "entity": "entity.crm_opportunity",
          "display_field": "crm_opportunity.title",
          "label_key": "tasks.entities.biz_task.fields.opportunity_id.label"
        },
        {
          "id": "biz_task.site_id",
          "type": "lookup",
          "label": "Site",
          "entity": "entity.crm_site",
          "display_field": "crm_site.name",
          "label_key": "tasks.entities.biz_task.fields.site_id.label"
        },
        {
          "id": "biz_task.quote_id",
          "type": "lookup",
          "label": "Quote",
          "entity": "entity.biz_quote",
          "display_field": "biz_quote.quote_number",
          "label_key": "tasks.entities.biz_task.fields.quote_id.label"
        },
        {
          "id": "biz_task.order_id",
          "type": "lookup",
          "label": "Order",
          "entity": "entity.biz_order",
          "display_field": "biz_order.order_number",
          "label_key": "tasks.entities.biz_task.fields.order_id.label"
        },
        {
          "id": "biz_task.purchase_order_id",
          "type": "lookup",
          "label": "Purchase Order",
          "entity": "entity.biz_purchase_order",
          "display_field": "biz_purchase_order.po_number",
          "label_key": "tasks.entities.biz_task.fields.purchase_order_id.label"
        },
        {
          "id": "biz_task.invoice_id",
          "type": "lookup",
          "label": "Invoice",
          "entity": "entity.biz_invoice",
          "display_field": "biz_invoice.invoice_number",
          "label_key": "tasks.entities.biz_task.fields.invoice_id.label"
        },
        {
          "id": "biz_task.document_id",
          "type": "lookup",
          "label": "Document",
          "entity": "entity.biz_document",
          "display_field": "biz_document.name",
          "label_key": "tasks.entities.biz_task.fields.document_id.label"
        },
        {
          "id": "biz_task.blocked_reason",
          "type": "text",
          "label": "Blocked Reason",
          "required_when": {
            "op": "eq",
            "field": "biz_task.status",
            "value": "blocked"
          },
          "label_key": "tasks.entities.biz_task.fields.blocked_reason.label"
        },
        {
          "id": "biz_task.cancel_reason",
          "type": "text",
          "label": "Cancel Reason",
          "required_when": {
            "op": "eq",
            "field": "biz_task.status",
            "value": "cancelled"
          },
          "label_key": "tasks.entities.biz_task.fields.cancel_reason.label"
        },
        {
          "id": "biz_task.description",
          "type": "text",
          "label": "Description",
          "label_key": "tasks.entities.biz_task.fields.description.label"
        },
        {
          "id": "biz_task.attachments",
          "type": "attachments",
          "label": "Attachments",
          "label_key": "tasks.entities.biz_task.fields.attachments.label"
        },
        {
          "id": "biz_task.created_at",
          "type": "datetime",
          "label": "Created At",
          "readonly": true,
          "label_key": "tasks.entities.biz_task.fields.created_at.label"
        }
      ],
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
        "allow_attachments": true,
        "tracked_fields": [
          "biz_task.title",
          "biz_task.task_type",
          "biz_task.status",
          "biz_task.priority",
          "biz_task.owner_user_id",
          "biz_task.assignee_user_id",
          "biz_task.participant_user_ids",
          "biz_task.visibility",
          "biz_task.sales_entity",
          "biz_task.start_date",
          "biz_task.due_date",
          "biz_task.company_id",
          "biz_task.lead_id",
          "biz_task.opportunity_id",
          "biz_task.site_id",
          "biz_task.quote_id",
          "biz_task.order_id",
          "biz_task.purchase_order_id",
          "biz_task.invoice_id",
          "biz_task.document_id",
          "biz_task.blocked_reason",
          "biz_task.cancel_reason",
          "biz_task.description"
        ]
      },
      "label_key": "tasks.entities.biz_task.label"
    }
  ],
  "actions": [
    {
      "id": "action.biz_task_new",
      "kind": "open_form",
      "label": "New Task",
      "target": "biz_task.form",
      "action_label_key": "tasks.actions.action_biz_task_new.label"
    },
    {
      "id": "action.biz_task_start",
      "kind": "update_record",
      "entity_id": "entity.biz_task",
      "label": "Start",
      "patch": {
        "biz_task.status": "in_progress"
      },
      "visible_when": {
        "op": "in",
        "field": "biz_task.status",
        "value": [
          "open",
          "blocked"
        ]
      },
      "action_label_key": "tasks.actions.action_biz_task_start.label"
    },
    {
      "id": "action.biz_task_block",
      "kind": "update_record",
      "entity_id": "entity.biz_task",
      "label": "Block",
      "modal_id": "modal.biz_task_block",
      "visible_when": {
        "op": "in",
        "field": "biz_task.status",
        "value": [
          "open",
          "in_progress"
        ]
      },
      "action_label_key": "tasks.actions.action_biz_task_block.label"
    },
    {
      "id": "action.biz_task_done",
      "kind": "update_record",
      "entity_id": "entity.biz_task",
      "label": "Mark Done",
      "patch": {
        "biz_task.status": "done"
      },
      "visible_when": {
        "op": "in",
        "field": "biz_task.status",
        "value": [
          "open",
          "in_progress",
          "blocked"
        ]
      },
      "action_label_key": "tasks.actions.action_biz_task_done.label"
    },
    {
      "id": "action.biz_task_cancel",
      "kind": "update_record",
      "entity_id": "entity.biz_task",
      "label": "Cancel",
      "modal_id": "modal.biz_task_cancel",
      "visible_when": {
        "op": "in",
        "field": "biz_task.status",
        "value": [
          "open",
          "in_progress",
          "blocked"
        ]
      },
      "action_label_key": "tasks.actions.action_biz_task_cancel.label"
    }
  ],
  "workflows": [
