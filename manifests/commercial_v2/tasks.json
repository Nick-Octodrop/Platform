          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.open_in_progress.label"
        },
        {
          "from": "open",
          "to": "blocked",
          "label": "Block",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.open_blocked.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.open_blocked.label"
        },
        {
          "from": "in_progress",
          "to": "blocked",
          "label": "Block",
          "action_label_key": "tasks.workflows.biz_task_status_workflow.transitions.in_progress_blocked.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.transitions.in_progress_blocked.label"
        },
        {
          "from": "blocked",
          "to": "in_progress",
          "label": "Resume",
