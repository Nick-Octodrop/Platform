          "label_key": "tasks.workflows.biz_task_status_workflow.states.open.label"
        },
        {
          "id": "in_progress",
          "label": "In Progress",
          "status_label_key": "tasks.workflows.biz_task_status_workflow.states.in_progress.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.states.in_progress.label"
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "status_label_key": "tasks.workflows.biz_task_status_workflow.states.blocked.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.states.blocked.label"
        },
        {
          "id": "done",
          "label": "Done",
          "status_label_key": "tasks.workflows.biz_task_status_workflow.states.done.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.states.done.label"
        },
        {
          "id": "cancelled",
          "label": "Cancelled",
          "status_label_key": "tasks.workflows.biz_task_status_workflow.states.cancelled.label",
          "label_key": "tasks.workflows.biz_task_status_workflow.states.cancelled.label"
        }
