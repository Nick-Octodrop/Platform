      "label": "Task created",
      "event": "record.created",
      "entity_id": "entity.biz_task"
    },
    {
      "id": "biz_tasks.record.biz_task.updated",
      "label": "Task updated",
      "event": "record.updated",
      "entity_id": "entity.biz_task"
    },
    {
