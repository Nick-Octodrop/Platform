{
  "manifest_version": "1.3",
  "module": {
    "id": "biz_calendar",
    "key": "biz_calendar",
    "name": "Calendar",
    "version": "1.0.0",
    "description": "Team calendar for sales follow-ups, site visits, order handoffs, procurement calls, and finance milestones.",
    "category": "Operations",
    "icon_key": "lucide:CalendarDays",
    "name_key": "calendar.module.name",
    "description_key": "calendar.module.description"
  },
  "depends_on": {
    "required": [
      {
        "module": "biz_contacts",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_quotes",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_orders",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_purchase_orders",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_invoices",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_crm",
        "version": ">=1.0.0"
      },
      {
        "module": "biz_tasks",
        "version": ">=1.0.0"
      }
    ]
  },
  "app": {
    "home": "page:biz_calendar_event.calendar_page",
    "defaults": {
      "entity_home_page": "page:biz_calendar_event.list_page",
      "entity_form_page": "page:biz_calendar_event.form_page",
      "entities": {
        "entity.biz_calendar_event": {
          "entity_home_page": "page:biz_calendar_event.list_page",
          "entity_form_page": "page:biz_calendar_event.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Operations",
        "mode": "inline",
        "items": [
          {
            "label": "Calendar",
            "to": "page:biz_calendar_event.calendar_page",
            "menu_label_key": "calendar.navigation.biz_calendar_event_calendar_page"
          },
          {
            "label": "My Calendar",
            "to": "page:biz_calendar_event.mine_page",
            "menu_label_key": "calendar.navigation.biz_calendar_event_mine_page"
          },
          {
            "label": "Site Visits",
            "to": "page:biz_calendar_event.site_visits_page",
            "menu_label_key": "calendar.navigation.biz_calendar_event_site_visits_page"
          },
          {
            "label": "Operations",
            "to": "page:biz_calendar_event.operations_page",
            "menu_label_key": "calendar.navigation.biz_calendar_event_operations_page"
          },
          {
            "label": "Finance",
            "to": "page:biz_calendar_event.finance_page",
            "menu_label_key": "calendar.navigation.biz_calendar_event_finance_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.biz_calendar_event",
      "label": "Calendar Event",
      "display_field": "biz_calendar_event.title",
      "fields": [
        {
          "id": "biz_calendar_event.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true,
          "label_key": "calendar.entities.biz_calendar_event.fields.id.label"
        },
        {
          "id": "biz_calendar_event.title",
          "type": "string",
          "label": "Event",
          "required": true,
          "label_key": "calendar.entities.biz_calendar_event.fields.title.label"
        },
        {
          "id": "biz_calendar_event.event_type",
          "type": "enum",
          "label": "Type",
          "default": "meeting",
          "options": [
            {
              "value": "call",
              "label": "Call",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.call",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.call"
            },
            {
              "value": "meeting",
              "label": "Meeting",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.meeting",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.meeting"
            },
            {
              "value": "site_visit",
              "label": "Site Visit",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.site_visit",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.site_visit"
            },
            {
              "value": "quote_follow_up",
              "label": "Quote Follow-Up",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.quote_follow_up",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.quote_follow_up"
            },
            {
              "value": "order_handoff",
              "label": "Order Handoff",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.order_handoff",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.order_handoff"
            },
            {
              "value": "supplier_check_in",
              "label": "Supplier Check-In",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.supplier_check_in",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.supplier_check_in"
            },
            {
              "value": "finance_review",
              "label": "Finance Review",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.finance_review",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.finance_review"
            },
            {
              "value": "internal",
              "label": "Internal",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.internal",
              "label_key": "calendar.entities.biz_calendar_event.fields.event_type.options.internal"
            }
          ],
          "label_key": "calendar.entities.biz_calendar_event.fields.event_type.label"
        },
        {
          "id": "biz_calendar_event.status",
          "type": "enum",
          "label": "Status",
          "default": "planned",
          "ui": {
            "widget": "steps"
          },
          "options": [
            {
              "value": "planned",
              "label": "Planned",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.status.options.planned",
              "label_key": "calendar.entities.biz_calendar_event.fields.status.options.planned"
            },
            {
              "value": "confirmed",
              "label": "Confirmed",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.status.options.confirmed",
              "label_key": "calendar.entities.biz_calendar_event.fields.status.options.confirmed"
            },
            {
              "value": "done",
              "label": "Done",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.status.options.done",
              "label_key": "calendar.entities.biz_calendar_event.fields.status.options.done"
            },
            {
              "value": "cancelled",
              "label": "Cancelled",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.status.options.cancelled",
              "label_key": "calendar.entities.biz_calendar_event.fields.status.options.cancelled"
            }
          ],
          "label_key": "calendar.entities.biz_calendar_event.fields.status.label"
        },
        {
          "id": "biz_calendar_event.start_at",
          "type": "datetime",
          "label": "Start",
          "required": true,
          "label_key": "calendar.entities.biz_calendar_event.fields.start_at.label"
        },
        {
          "id": "biz_calendar_event.end_at",
          "type": "datetime",
          "label": "End",
          "label_key": "calendar.entities.biz_calendar_event.fields.end_at.label"
        },
        {
          "id": "biz_calendar_event.all_day",
          "type": "bool",
          "label": "All Day",
          "default": false,
          "label_key": "calendar.entities.biz_calendar_event.fields.all_day.label"
        },
        {
          "id": "biz_calendar_event.owner_user_id",
          "type": "user",
          "label": "Owner",
          "label_key": "calendar.entities.biz_calendar_event.fields.owner_user_id.label"
        },
        {
          "id": "biz_calendar_event.participant_user_ids",
          "type": "users",
          "label": "Participants",
          "label_key": "calendar.entities.biz_calendar_event.fields.participant_user_ids.label"
        },
        {
          "id": "biz_calendar_event.visibility",
          "type": "enum",
          "label": "Visibility",
          "default": "team",
          "options": [
            {
              "value": "private",
              "label": "Private",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.visibility.options.private",
              "label_key": "calendar.entities.biz_calendar_event.fields.visibility.options.private"
            },
            {
              "value": "team",
              "label": "Team",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.visibility.options.team",
              "label_key": "calendar.entities.biz_calendar_event.fields.visibility.options.team"
            },
            {
              "value": "directors",
              "label": "Directors",
              "status_label_key": "calendar.entities.biz_calendar_event.fields.visibility.options.directors",
              "label_key": "calendar.entities.biz_calendar_event.fields.visibility.options.directors"
            }
          ],
          "label_key": "calendar.entities.biz_calendar_event.fields.visibility.label"
        },
        {
          "id": "biz_calendar_event.location",
          "type": "string",
          "label": "Location",
          "label_key": "calendar.entities.biz_calendar_event.fields.location.label"
        },
        {
          "id": "biz_calendar_event.company_id",
          "type": "lookup",
          "label": "Company",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name",
          "label_key": "calendar.entities.biz_calendar_event.fields.company_id.label"
        },
        {
          "id": "biz_calendar_event.lead_id",
          "type": "lookup",
          "label": "Lead",
          "entity": "entity.crm_lead",
          "display_field": "crm_lead.title",
          "label_key": "calendar.entities.biz_calendar_event.fields.lead_id.label"
        },
        {
          "id": "biz_calendar_event.opportunity_id",
          "type": "lookup",
          "label": "Opportunity",
          "entity": "entity.crm_opportunity",
          "display_field": "crm_opportunity.title",
          "label_key": "calendar.entities.biz_calendar_event.fields.opportunity_id.label"
        },
        {
          "id": "biz_calendar_event.site_id",
          "type": "lookup",
          "label": "Site",
          "entity": "entity.crm_site",
          "display_field": "crm_site.name",
          "label_key": "calendar.entities.biz_calendar_event.fields.site_id.label"
        },
        {
          "id": "biz_calendar_event.task_id",
          "type": "lookup",
          "label": "Task",
          "entity": "entity.biz_task",
          "display_field": "biz_task.title",
          "label_key": "calendar.entities.biz_calendar_event.fields.task_id.label"
        },
        {
          "id": "biz_calendar_event.quote_id",
          "type": "lookup",
          "label": "Quote",
          "entity": "entity.biz_quote",
          "display_field": "biz_quote.quote_number",
          "label_key": "calendar.entities.biz_calendar_event.fields.quote_id.label"
        },
        {
          "id": "biz_calendar_event.order_id",
          "type": "lookup",
          "label": "Order",
          "entity": "entity.biz_order",
          "display_field": "biz_order.order_number",
          "label_key": "calendar.entities.biz_calendar_event.fields.order_id.label"
        },
        {
          "id": "biz_calendar_event.purchase_order_id",
          "type": "lookup",
          "label": "Purchase Order",
          "entity": "entity.biz_purchase_order",
          "display_field": "biz_purchase_order.po_number",
          "label_key": "calendar.entities.biz_calendar_event.fields.purchase_order_id.label"
        },
        {
          "id": "biz_calendar_event.invoice_id",
          "type": "lookup",
          "label": "Invoice",
          "entity": "entity.biz_invoice",
          "display_field": "biz_invoice.invoice_number",
          "label_key": "calendar.entities.biz_calendar_event.fields.invoice_id.label"
        },
        {
          "id": "biz_calendar_event.description",
          "type": "text",
          "label": "Description",
          "label_key": "calendar.entities.biz_calendar_event.fields.description.label"
        },
        {
          "id": "biz_calendar_event.cancel_reason",
          "type": "text",
          "label": "Cancel Reason",
          "required_when": {
            "op": "eq",
            "field": "biz_calendar_event.status",
            "value": "cancelled"
          },
          "label_key": "calendar.entities.biz_calendar_event.fields.cancel_reason.label"
        },
        {
          "id": "biz_calendar_event.attachments",
          "type": "attachments",
          "label": "Attachments",
          "label_key": "calendar.entities.biz_calendar_event.fields.attachments.label"
        },
        {
          "id": "biz_calendar_event.created_at",
          "type": "datetime",
          "label": "Created At",
          "readonly": true,
          "label_key": "calendar.entities.biz_calendar_event.fields.created_at.label"
        }
      ],
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
        "allow_attachments": true,
        "tracked_fields": [
          "biz_calendar_event.title",
          "biz_calendar_event.event_type",
          "biz_calendar_event.status",
          "biz_calendar_event.start_at",
          "biz_calendar_event.end_at",
          "biz_calendar_event.all_day",
          "biz_calendar_event.owner_user_id",
          "biz_calendar_event.participant_user_ids",
          "biz_calendar_event.visibility",
          "biz_calendar_event.location",
          "biz_calendar_event.company_id",
          "biz_calendar_event.lead_id",
          "biz_calendar_event.opportunity_id",
          "biz_calendar_event.site_id",
          "biz_calendar_event.task_id",
          "biz_calendar_event.quote_id",
          "biz_calendar_event.order_id",
          "biz_calendar_event.purchase_order_id",
          "biz_calendar_event.invoice_id",
          "biz_calendar_event.description",
          "biz_calendar_event.cancel_reason"
        ]
      },
      "label_key": "calendar.entities.biz_calendar_event.label"
    }
  ],
  "actions": [
    {
      "id": "action.biz_calendar_event_new",
      "kind": "open_form",
      "label": "New Event",
      "target": "biz_calendar_event.form",
      "action_label_key": "calendar.actions.action_biz_calendar_event_new.label"
    },
    {
      "id": "action.biz_calendar_event_confirm",
      "kind": "update_record",
      "entity_id": "entity.biz_calendar_event",
      "label": "Confirm",
      "patch": {
        "biz_calendar_event.status": "confirmed"
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_calendar_event.status",
        "value": "planned"
      },
      "action_label_key": "calendar.actions.action_biz_calendar_event_confirm.label"
    },
    {
      "id": "action.biz_calendar_event_done",
      "kind": "update_record",
      "entity_id": "entity.biz_calendar_event",
      "label": "Mark Done",
      "patch": {
        "biz_calendar_event.status": "done"
      },
      "visible_when": {
        "op": "in",
        "field": "biz_calendar_event.status",
        "value": [
          "planned",
          "confirmed"
        ]
      },
      "action_label_key": "calendar.actions.action_biz_calendar_event_done.label"
    },
    {
      "id": "action.biz_calendar_event_cancel",
      "kind": "update_record",
      "entity_id": "entity.biz_calendar_event",
      "label": "Cancel",
      "modal_id": "modal.biz_calendar_event_cancel",
      "visible_when": {
        "op": "in",
        "field": "biz_calendar_event.status",
        "value": [
          "planned",
          "confirmed"
        ]
      },
      "action_label_key": "calendar.actions.action_biz_calendar_event_cancel.label"
    }
  ],
  "workflows": [
    {
      "id": "biz_calendar_event_status_workflow",
      "entity": "entity.biz_calendar_event",
      "status_field": "biz_calendar_event.status",
      "states": [
        {
          "id": "planned",
          "label": "Planned",
          "required_fields": [
            "biz_calendar_event.title",
            "biz_calendar_event.start_at"
          ],
          "status_label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.planned.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.planned.label"
        },
        {
          "id": "confirmed",
          "label": "Confirmed",
          "status_label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.confirmed.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.confirmed.label"
        },
        {
          "id": "done",
          "label": "Done",
          "status_label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.done.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.done.label"
        },
        {
          "id": "cancelled",
          "label": "Cancelled",
          "status_label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.cancelled.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.states.cancelled.label"
        }
      ],
      "transitions": [
        {
          "from": "planned",
          "to": "confirmed",
          "label": "Confirm",
          "action_label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.planned_confirmed.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.planned_confirmed.label"
        },
        {
          "from": "planned",
          "to": "done",
          "label": "Mark Done",
          "action_label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.planned_done.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.planned_done.label"
        },
        {
          "from": "confirmed",
          "to": "done",
          "label": "Mark Done",
          "action_label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.confirmed_done.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.confirmed_done.label"
        },
        {
          "from": "planned",
          "to": "cancelled",
          "label": "Cancel",
          "action_label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.planned_cancelled.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.planned_cancelled.label"
        },
        {
          "from": "confirmed",
          "to": "cancelled",
          "label": "Cancel",
          "action_label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.confirmed_cancelled.label",
          "label_key": "calendar.workflows.biz_calendar_event_status_workflow.transitions.confirmed_cancelled.label"
        }
      ],
      "required_fields_by_state": {
        "cancelled": [
          "biz_calendar_event.cancel_reason"
        ]
      }
    }
  ],
  "triggers": [
    {
      "id": "biz_calendar.record.biz_calendar_event.created",
      "label": "Calendar Event created",
      "event": "record.created",
      "entity_id": "entity.biz_calendar_event"
    },
    {
      "id": "biz_calendar.record.biz_calendar_event.updated",
      "label": "Calendar Event updated",
      "event": "record.updated",
      "entity_id": "entity.biz_calendar_event"
    },
    {
      "id": "biz_calendar.workflow.biz_calendar_event.status_changed",
      "label": "Calendar Event status changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.biz_calendar_event",
      "status_field": "biz_calendar_event.status"
    },
    {
      "id": "biz_calendar.action.biz_calendar_event_new.clicked",
      "label": "New Event clicked",
      "event": "action.clicked",
      "action_id": "action.biz_calendar_event_new"
    },
    {
      "id": "biz_calendar.action.biz_calendar_event_confirm.clicked",
      "label": "Confirm clicked",
      "event": "action.clicked",
      "action_id": "action.biz_calendar_event_confirm"
    },
    {
      "id": "biz_calendar.action.biz_calendar_event_done.clicked",
      "label": "Mark Done clicked",
      "event": "action.clicked",
      "action_id": "action.biz_calendar_event_done"
    },
    {
      "id": "biz_calendar.action.biz_calendar_event_cancel.clicked",
      "label": "Cancel clicked",
      "event": "action.clicked",
      "action_id": "action.biz_calendar_event_cancel"
    }
  ],
  "views": [
    {
      "id": "biz_calendar_event.list",
      "kind": "list",
      "entity": "entity.biz_calendar_event",
      "columns": [
        {
          "field_id": "biz_calendar_event.title"
        },
        {
          "field_id": "biz_calendar_event.event_type"
        },
        {
          "field_id": "biz_calendar_event.status"
        },
        {
          "field_id": "biz_calendar_event.start_at"
        },
        {
          "field_id": "biz_calendar_event.owner_user_id"
        },
        {
          "field_id": "biz_calendar_event.company_id"
        },
        {
          "field_id": "biz_calendar_event.opportunity_id"
        },
        {
          "field_id": "biz_calendar_event.order_id"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.biz_calendar_event_new"
          }
        ],
        "open_record_target": "page:biz_calendar_event.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search calendar...",
          "fields": [
            "biz_calendar_event.title",
            "biz_calendar_event.location",
            "biz_calendar_event.description"
          ],
          "placeholder_key": "calendar.views.list.search.placeholder"
        },
        "filters": [
          {
            "id": "planned",
            "label": "Planned",
            "domain": {
              "op": "in",
              "field": "biz_calendar_event.status",
              "value": [
                "planned",
                "confirmed"
              ]
            },
            "label_key": "calendar.views.list.filters.planned.label"
          },
          {
            "id": "mine",
            "label": "My Calendar",
            "domain": {
              "op": "or",
              "conditions": [
                {
                  "op": "eq",
                  "field": "biz_calendar_event.owner_user_id",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                },
                {
                  "op": "contains",
                  "field": "biz_calendar_event.participant_user_ids",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                }
              ]
            },
            "label_key": "calendar.views.list.filters.mine.label"
          },
          {
            "id": "crm",
            "label": "CRM Events",
            "domain": {
              "op": "or",
              "conditions": [
                {
                  "op": "exists",
                  "field": "biz_calendar_event.lead_id"
                },
                {
                  "op": "exists",
                  "field": "biz_calendar_event.opportunity_id"
                }
              ]
            },
            "label_key": "calendar.views.list.filters.crm.label"
          },
          {
            "id": "site_visits",
            "label": "Site Visits",
            "domain": {
              "op": "eq",
              "field": "biz_calendar_event.event_type",
              "value": "site_visit"
            },
            "label_key": "calendar.views.list.filters.site_visits.label"
          },
          {
