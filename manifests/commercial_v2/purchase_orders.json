  "modals": [
    {
      "id": "modal.purchase_order_hold",
      "title": "Put Purchase Order On Hold",
      "description": "Capture why the supplier-side flow is being paused.",
      "entity_id": "entity.biz_purchase_order",
      "fields": [
        "biz_purchase_order.hold_reason"
      ],
      "actions": [
        {
          "kind": "update_record",
          "entity_id": "entity.biz_purchase_order",
          "label": "Put On Hold",
          "patch": {
            "biz_purchase_order.status_before_hold": { "ref": "$record.biz_purchase_order.status" },
            "biz_purchase_order.status": "on_hold",
            "biz_purchase_order.hold_reason": { "ref": "$record.biz_purchase_order.hold_reason" }
          }
        },
        {
          "kind": "close_modal",
          "label": "Close",
          "variant": "ghost"
        }
      ]
    },
    {
      "id": "modal.purchase_order_cancel",
      "title": "Cancel Purchase Order",
      "description": "Capture why this PO is being cancelled.",
      "entity_id": "entity.biz_purchase_order",
      "fields": [
        "biz_purchase_order.cancellation_reason"
      ],
      "actions": [
        {
          "kind": "update_record",
          "entity_id": "entity.biz_purchase_order",
          "label": "Cancel Purchase Order",
          "patch": {
            "biz_purchase_order.status": "cancelled",
            "biz_purchase_order.cancellation_reason": { "ref": "$record.biz_purchase_order.cancellation_reason" }
          }
        },
        {
          "kind": "close_modal",
          "label": "Close",
          "variant": "ghost"
        }
      ]
    }
  ],
