              "subtitle": "Supplier has shipped",
              "entity_id": "entity.biz_purchase_order",
              "measure": "count",
              "domain": { "op": "eq", "field": "biz_purchase_order.status", "value": "shipped" },
              "icon": "lucide:Truck",
              "tone": "success",
              "format": "number"
            },
            {
              "id": "purchase_orders_received_count",
              "label": "Received",
              "subtitle": "Awaiting closeout",
              "entity_id": "entity.biz_purchase_order",
              "measure": "count",
