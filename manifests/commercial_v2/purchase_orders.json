              "domain": { "op": "eq", "field": "biz_purchase_order.status", "value": "draft" },
              "icon": "lucide:FileClock",
              "tone": "primary",
              "format": "number"
            },
            {
              "id": "purchase_orders_production_count",
              "label": "In Production",
              "subtitle": "Confirmed with supplier",
              "entity_id": "entity.biz_purchase_order",
              "measure": "count",
              "domain": { "op": "eq", "field": "biz_purchase_order.status", "value": "in_production" },
              "icon": "lucide:Factory",
              "tone": "warning",
              "format": "number"
            },
            {
              "id": "purchase_orders_shipped_count",
