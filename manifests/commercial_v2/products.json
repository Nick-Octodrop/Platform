{
  "manifest_version": "1.3",
  "module": {
    "id": "biz_products",
    "key": "biz_products",
    "name": "Products",
    "version": "1.0.0",
    "description": "Product catalogue items for quoting and supplier purchasing.",
    "category": "Commercial",
    "icon_key": "lucide:Package2",
    "name_key": "products.module.name",
    "description_key": "products.module.description"
  },
  "depends_on": {
    "required": [
      {
        "module": "biz_contacts",
        "version": ">=1.0.0"
      }
    ]
  },
  "app": {
    "home": "page:biz_product.list_page",
    "defaults": {
      "entity_home_page": "page:biz_product.list_page",
      "entity_form_page": "page:biz_product.form_page",
      "entities": {
        "entity.biz_product": {
          "entity_home_page": "page:biz_product.list_page",
          "entity_form_page": "page:biz_product.form_page"
        },
        "entity.biz_product_supplier": {
          "entity_home_page": "page:biz_product_supplier.list_page",
          "entity_form_page": "page:biz_product_supplier.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Commercial",
        "mode": "inline",
        "items": [
          {
            "label": "Products",
            "to": "page:biz_product.list_page",
            "menu_label_key": "products.navigation.biz_product_list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.biz_product",
      "label": "Product",
      "display_field": "biz_product.name",
      "fields": [
        {
          "id": "biz_product.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true,
          "label_key": "products.entities.biz_product.fields.id.label"
        },
        {
          "id": "biz_product.code",
          "type": "string",
          "label": "Code",
          "required": true,
          "label_key": "products.entities.biz_product.fields.code.label"
        },
        {
          "id": "biz_product.name",
          "type": "string",
          "label": "Name",
          "required": true,
          "label_key": "products.entities.biz_product.fields.name.label"
        },
        {
          "id": "biz_product.description",
          "type": "text",
          "label": "Description",
          "label_key": "products.entities.biz_product.fields.description.label"
        },
        {
          "id": "biz_product.category",
          "type": "string",
          "label": "Category",
          "label_key": "products.entities.biz_product.fields.category.label"
        },
        {
          "id": "biz_product.uom",
          "type": "enum",
          "label": "UOM",
          "default": "EA",
          "options": [
            {
              "value": "EA",
              "label": "Each",
              "status_label_key": "products.entities.biz_product.fields.uom.options.ea",
              "label_key": "products.entities.biz_product.fields.uom.options.ea"
            },
            {
              "value": "SET",
              "label": "Set",
              "status_label_key": "products.entities.biz_product.fields.uom.options.set",
              "label_key": "products.entities.biz_product.fields.uom.options.set"
            },
            {
              "value": "KIT",
              "label": "Kit",
              "status_label_key": "products.entities.biz_product.fields.uom.options.kit",
              "label_key": "products.entities.biz_product.fields.uom.options.kit"
            },
            {
              "value": "LOT",
              "label": "Lot",
              "status_label_key": "products.entities.biz_product.fields.uom.options.lot",
              "label_key": "products.entities.biz_product.fields.uom.options.lot"
            },
            {
              "value": "PALLET",
              "label": "Pallet",
              "status_label_key": "products.entities.biz_product.fields.uom.options.pallet",
              "label_key": "products.entities.biz_product.fields.uom.options.pallet"
            },
            {
              "value": "CONTAINER",
              "label": "Container",
              "status_label_key": "products.entities.biz_product.fields.uom.options.container",
              "label_key": "products.entities.biz_product.fields.uom.options.container"
            },
            {
              "value": "M",
              "label": "Meter",
              "status_label_key": "products.entities.biz_product.fields.uom.options.m",
              "label_key": "products.entities.biz_product.fields.uom.options.m"
            }
          ],
          "label_key": "products.entities.biz_product.fields.uom.label"
        },
        {
          "id": "biz_product.default_sales_currency",
          "type": "enum",
          "label": "Sales Currency",
          "default": "EUR",
          "options": [
            {
              "value": "EUR",
              "label": "EUR",
              "status_label_key": "products.entities.biz_product.fields.default_sales_currency.options.eur",
              "label_key": "products.entities.biz_product.fields.default_sales_currency.options.eur"
            },
            {
              "value": "USD",
              "label": "USD",
              "status_label_key": "products.entities.biz_product.fields.default_sales_currency.options.usd",
              "label_key": "products.entities.biz_product.fields.default_sales_currency.options.usd"
            },
            {
              "value": "GBP",
              "label": "GBP",
              "status_label_key": "products.entities.biz_product.fields.default_sales_currency.options.gbp",
              "label_key": "products.entities.biz_product.fields.default_sales_currency.options.gbp"
            },
            {
              "value": "AED",
              "label": "AED",
              "status_label_key": "products.entities.biz_product.fields.default_sales_currency.options.aed",
              "label_key": "products.entities.biz_product.fields.default_sales_currency.options.aed"
            }
          ],
          "label_key": "products.entities.biz_product.fields.default_sales_currency.label"
        },
        {
          "id": "biz_product.default_sales_price",
          "type": "number",
          "label": "Sales Price",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "biz_product.default_sales_currency",
            "precision": 2
          },
          "label_key": "products.entities.biz_product.fields.default_sales_price.label"
        },
        {
          "id": "biz_product.default_purchase_currency",
          "type": "enum",
          "label": "Purchase Currency",
          "default": "USD",
          "options": [
            {
              "value": "EUR",
              "label": "EUR",
              "status_label_key": "products.entities.biz_product.fields.default_purchase_currency.options.eur",
              "label_key": "products.entities.biz_product.fields.default_purchase_currency.options.eur"
            },
            {
              "value": "USD",
              "label": "USD",
              "status_label_key": "products.entities.biz_product.fields.default_purchase_currency.options.usd",
              "label_key": "products.entities.biz_product.fields.default_purchase_currency.options.usd"
            },
            {
              "value": "GBP",
              "label": "GBP",
              "status_label_key": "products.entities.biz_product.fields.default_purchase_currency.options.gbp",
              "label_key": "products.entities.biz_product.fields.default_purchase_currency.options.gbp"
            },
            {
              "value": "AED",
              "label": "AED",
              "status_label_key": "products.entities.biz_product.fields.default_purchase_currency.options.aed",
              "label_key": "products.entities.biz_product.fields.default_purchase_currency.options.aed"
            }
          ],
          "label_key": "products.entities.biz_product.fields.default_purchase_currency.label"
        },
        {
          "id": "biz_product.default_buy_price",
          "type": "number",
          "label": "Buy Price",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "biz_product.default_purchase_currency",
            "precision": 2
          },
          "label_key": "products.entities.biz_product.fields.default_buy_price.label"
        },
        {
          "id": "biz_product.fulfilment_mode",
          "type": "enum",
          "label": "Fulfilment Mode",
          "default": "made_to_order",
          "options": [
            {
              "value": "made_to_order",
              "label": "Made To Order",
              "status_label_key": "products.entities.biz_product.fields.fulfilment_mode.options.made_to_order",
              "label_key": "products.entities.biz_product.fields.fulfilment_mode.options.made_to_order"
            },
            {
              "value": "stocked",
              "label": "Stocked",
              "status_label_key": "products.entities.biz_product.fields.fulfilment_mode.options.stocked",
              "label_key": "products.entities.biz_product.fields.fulfilment_mode.options.stocked"
            },
            {
              "value": "hybrid",
              "label": "Hybrid",
              "status_label_key": "products.entities.biz_product.fields.fulfilment_mode.options.hybrid",
              "label_key": "products.entities.biz_product.fields.fulfilment_mode.options.hybrid"
            }
          ],
          "label_key": "products.entities.biz_product.fields.fulfilment_mode.label"
        },
        {
          "id": "biz_product.on_hand_qty",
          "type": "number",
          "label": "On Hand Qty",
          "default": 0,
          "visible_when": {
            "op": "in",
            "field": "biz_product.fulfilment_mode",
            "value": [
              "stocked",
              "hybrid"
            ]
          }
        },
        {
          "id": "biz_product.reserved_qty",
          "type": "number",
          "label": "Reserved Qty",
          "default": 0,
          "visible_when": {
            "op": "in",
            "field": "biz_product.fulfilment_mode",
            "value": [
              "stocked",
              "hybrid"
            ]
          }
        },
        {
          "id": "biz_product.available_qty",
          "type": "number",
          "label": "Available Qty",
          "readonly": true,
          "default": 0,
          "visible_when": {
            "op": "in",
            "field": "biz_product.fulfilment_mode",
            "value": [
              "stocked",
              "hybrid"
            ]
          },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "gt",
                "field": "biz_product.on_hand_qty",
                "value": {
                  "ref": "$current.biz_product.reserved_qty"
                }
              },
              "then": {
                "op": "sub",
                "args": [
                  {
                    "ref": "$current.biz_product.on_hand_qty"
                  },
                  {
                    "ref": "$current.biz_product.reserved_qty"
                  }
                ]
              },
              "else": 0
            }
          }
        },
        {
          "id": "biz_product.reorder_point_qty",
          "type": "number",
          "label": "Reorder Point Qty",
          "default": 0,
          "visible_when": {
            "op": "in",
            "field": "biz_product.fulfilment_mode",
            "value": [
              "stocked",
              "hybrid"
            ]
          }
        },
        {
          "id": "biz_product.lead_time_weeks",
          "type": "number",
          "label": "Lead Time (Weeks)",
          "default": 0,
          "label_key": "products.entities.biz_product.fields.lead_time_weeks.label"
        },
        {
          "id": "biz_product.minimum_order_quantity",
          "type": "number",
          "label": "Minimum Order Quantity",
          "default": 1,
          "label_key": "products.entities.biz_product.fields.minimum_order_quantity.label"
        },
        {
          "id": "biz_product.supplier_source_count",
          "type": "number",
          "label": "Supplier Sources",
          "readonly": true,
          "default": 0,
          "compute": {
            "aggregate": {
              "op": "count",
              "entity": "entity.biz_product_supplier",
              "where": {
                "op": "eq",
                "field": "biz_product_supplier.product_id",
                "value": {
                  "ref": "$parent.id"
                }
              }
            }
          }
        },
        {
          "id": "biz_product.active_supplier_source_count",
          "type": "number",
          "label": "Active Supplier Sources",
          "readonly": true,
          "default": 0,
          "compute": {
            "aggregate": {
              "op": "count",
              "entity": "entity.biz_product_supplier",
              "where": {
                "op": "and",
                "conditions": [
                  {
                    "op": "eq",
                    "field": "biz_product_supplier.product_id",
                    "value": {
                      "ref": "$parent.id"
                    }
                  },
                  {
                    "op": "eq",
                    "field": "biz_product_supplier.is_active",
                    "value": true
                  }
                ]
              }
            }
          }
        },
        {
          "id": "biz_product.preferred_supplier_id",
          "type": "lookup",
          "label": "Preferred Supplier",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name",
          "label_key": "products.entities.biz_product.fields.preferred_supplier_id.label"
        },
        {
          "id": "biz_product.supplier_factory_reference",
          "type": "string",
          "label": "Supplier / Factory Ref",
          "label_key": "products.entities.biz_product.fields.supplier_factory_reference.label"
        },
        {
          "id": "biz_product.stock_notes",
          "type": "text",
          "label": "Stock Notes",
          "visible_when": {
            "op": "in",
            "field": "biz_product.fulfilment_mode",
            "value": [
              "stocked",
              "hybrid"
            ]
          }
        },
        {
          "id": "biz_product.internal_notes",
          "type": "text",
          "label": "Internal Notes",
          "label_key": "products.entities.biz_product.fields.internal_notes.label"
        },
        {
          "id": "biz_product.is_active",
          "type": "bool",
          "label": "Active",
          "default": true,
          "label_key": "products.entities.biz_product.fields.is_active.label"
        }
      ],
      "label_key": "products.entities.biz_product.label"
    },
    {
      "id": "entity.biz_product_supplier",
      "label": "Product Supplier",
      "display_field": "biz_product_supplier.product_name_snapshot",
      "fields": [
        {
          "id": "biz_product_supplier.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "biz_product_supplier.product_id",
          "type": "lookup",
          "label": "Product",
          "entity": "entity.biz_product",
          "display_field": "biz_product.name",
          "required": true,
          "ui": {
            "populate_from_lookup": {
              "field_map": {
                "biz_product_supplier.product_name_snapshot": "biz_product.name",
                "biz_product_supplier.product_code_snapshot": "biz_product.code",
                "biz_product_supplier.purchase_description": "biz_product.description",
                "biz_product_supplier.uom_snapshot": "biz_product.uom",
                "biz_product_supplier.purchase_currency": "biz_product.default_purchase_currency",
                "biz_product_supplier.unit_cost": "biz_product.default_buy_price",
                "biz_product_supplier.minimum_order_quantity": "biz_product.minimum_order_quantity",
                "biz_product_supplier.lead_time_weeks": "biz_product.lead_time_weeks"
              }
            }
          }
        },
        {
          "id": "biz_product_supplier.product_name_snapshot",
          "type": "string",
          "label": "Product Name",
          "readonly": true
        },
        {
          "id": "biz_product_supplier.product_code_snapshot",
          "type": "string",
          "label": "Product Code",
          "readonly": true
        },
        {
          "id": "biz_product_supplier.supplier_id",
          "type": "lookup",
          "label": "Supplier",
          "entity": "entity.biz_contact",
          "display_field": "biz_contact.name",
          "required": true,
          "domain": {
            "op": "in",
            "field": "biz_contact.contact_type",
            "value": [
              "supplier",
              "factory_partner"
            ]
          },
          "ui": {
            "populate_from_lookup": {
              "field_map": {
                "biz_product_supplier.supplier_name_snapshot": "biz_contact.name",
                "biz_product_supplier.purchase_currency": "biz_contact.currency_preference",
                "biz_product_supplier.supplier_incoterm": "biz_contact.supplier_incoterm_default"
              }
            }
          }
        },
        {
          "id": "biz_product_supplier.supplier_name_snapshot",
          "type": "string",
          "label": "Supplier Name",
          "readonly": true
        },
        {
          "id": "biz_product_supplier.supplier_sku",
          "type": "string",
          "label": "Supplier SKU / Factory Ref"
        },
        {
          "id": "biz_product_supplier.purchase_description",
          "type": "text",
          "label": "Purchase Description"
        },
        {
          "id": "biz_product_supplier.uom_snapshot",
          "type": "enum",
          "label": "UOM",
          "default": "EA",
          "options": [
            { "value": "EA", "label": "Each" },
            { "value": "SET", "label": "Set" },
            { "value": "KIT", "label": "Kit" },
            { "value": "LOT", "label": "Lot" },
            { "value": "PALLET", "label": "Pallet" },
            { "value": "CONTAINER", "label": "Container" },
            { "value": "M", "label": "Meter" }
          ]
        },
        {
          "id": "biz_product_supplier.purchase_currency",
          "type": "enum",
          "label": "Purchase Currency",
          "default": "USD",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" },
            { "value": "GBP", "label": "GBP" },
            { "value": "AED", "label": "AED" }
          ]
        },
        {
          "id": "biz_product_supplier.unit_cost",
          "type": "number",
          "label": "Unit Cost",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "biz_product_supplier.purchase_currency",
            "precision": 2
          }
        },
        {
          "id": "biz_product_supplier.minimum_order_quantity",
          "type": "number",
          "label": "MOQ",
          "default": 1
        },
        {
          "id": "biz_product_supplier.lead_time_weeks",
          "type": "number",
          "label": "Lead Time (Weeks)",
          "default": 0
        },
        {
          "id": "biz_product_supplier.supplier_incoterm",
          "type": "string",
          "label": "Supplier Incoterm"
        },
        {
          "id": "biz_product_supplier.is_primary",
          "type": "bool",
          "label": "Primary Supplier",
          "default": false
        },
        {
          "id": "biz_product_supplier.is_active",
          "type": "bool",
          "label": "Active",
          "default": true
        },
        {
          "id": "biz_product_supplier.notes",
          "type": "text",
          "label": "Notes"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.product_new",
      "kind": "open_form",
      "label": "New Product",
      "target": "biz_product.form",
      "action_label_key": "products.actions.action_product_new.label"
    },
    {
      "id": "action.product_activate",
      "kind": "update_record",
      "entity_id": "entity.biz_product",
      "label": "Activate",
      "patch": {
        "biz_product.is_active": true
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_product.is_active",
        "value": false
      },
      "action_label_key": "products.actions.action_product_activate.label"
    },
    {
      "id": "action.product_deactivate",
      "kind": "update_record",
      "entity_id": "entity.biz_product",
      "label": "Deactivate",
      "patch": {
        "biz_product.is_active": false
      },
      "visible_when": {
        "op": "eq",
        "field": "biz_product.is_active",
        "value": true
      },
      "action_label_key": "products.actions.action_product_deactivate.label"
    }
  ],
  "views": [
    {
      "id": "biz_product.list",
      "kind": "list",
      "entity": "entity.biz_product",
      "columns": [
        {
          "field_id": "biz_product.code"
        },
        {
          "field_id": "biz_product.name"
        },
        {
          "field_id": "biz_product.default_sales_price"
        },
        {
          "field_id": "biz_product.default_sales_currency"
        },
        {
          "field_id": "biz_product.default_buy_price"
        },
        {
          "field_id": "biz_product.default_purchase_currency"
        },
        {
          "field_id": "biz_product.fulfilment_mode"
        },
        {
          "field_id": "biz_product.available_qty"
        },
        {
          "field_id": "biz_product.preferred_supplier_id"
        },
        {
          "field_id": "biz_product.is_active"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.product_new"
          }
        ],
        "open_record_target": "page:biz_product.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search products...",
          "fields": [
            "biz_product.code",
            "biz_product.name",
            "biz_product.description"
          ],
          "placeholder_key": "products.views.list.search.placeholder"
        },
        "filters": [
          {
            "id": "active",
            "label": "Active Products",
            "domain": {
              "op": "eq",
              "field": "biz_product.is_active",
              "value": true
            },
            "label_key": "products.views.list.filters.active.label"
          },
          {
            "id": "inactive",
            "label": "Inactive Products",
            "domain": {
              "op": "eq",
              "field": "biz_product.is_active",
              "value": false
            },
            "label_key": "products.views.list.filters.inactive.label"
          },
          {
            "id": "eur_sales",
            "label": "EUR Sales Items",
            "domain": {
              "op": "eq",
              "field": "biz_product.default_sales_currency",
              "value": "EUR"
            },
            "label_key": "products.views.list.filters.eur_sales.label"
          },
          {
            "id": "usd_sales",
            "label": "USD Sales Items",
            "domain": {
              "op": "eq",
              "field": "biz_product.default_sales_currency",
              "value": "USD"
            },
            "label_key": "products.views.list.filters.usd_sales.label"
          },
          {
            "id": "stocked",
            "label": "Stocked Items",
            "domain": {
              "op": "in",
              "field": "biz_product.fulfilment_mode",
              "value": [
                "stocked",
                "hybrid"
              ]
            }
          },
          {
            "id": "unsourced",
            "label": "Unsourced Buy Items",
            "domain": {
              "op": "and",
              "conditions": [
                {
                  "op": "in",
                  "field": "biz_product.fulfilment_mode",
                  "value": [
                    "made_to_order",
                    "hybrid"
                  ]
                },
                {
                  "op": "eq",
                  "field": "biz_product.active_supplier_source_count",
                  "value": 0
                }
              ]
            }
          },
          {
            "id": "low_stock",
            "label": "Low Stock",
            "domain": {
              "op": "and",
              "conditions": [
                {
                  "op": "in",
                  "field": "biz_product.fulfilment_mode",
                  "value": [
                    "stocked",
                    "hybrid"
