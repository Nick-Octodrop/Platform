  "pages": [
    {
      "id": "biz_product.list_page",
      "title": "Products",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "stat_cards",
          "columns": 4,
          "cards": [
            {
              "id": "active_products",
              "label": "Active Products",
              "subtitle": "Sellable catalogue items",
              "entity_id": "entity.biz_product",
              "measure": "count",
              "domain": {
                "op": "eq",
                "field": "biz_product.is_active",
                "value": true
              },
              "icon": "lucide:Package2",
              "tone": "primary",
              "format": "number"
            },
          {
            "id": "stocked_products",
            "label": "Stocked SKUs",
            "subtitle": "Stocked and hybrid items",
              "entity_id": "entity.biz_product",
              "measure": "count",
              "domain": {
                "op": "in",
                "field": "biz_product.fulfilment_mode",
                "value": [
                  "stocked",
                  "hybrid"
                ]
              },
              "icon": "lucide:Boxes",
              "tone": "success",
              "format": "number"
            },
            {
              "id": "unsourced_products",
              "label": "Unsourced Products",
              "subtitle": "Buy-side items without active supplier rows",
              "entity_id": "entity.biz_product",
              "measure": "count",
              "domain": {
                "op": "and",
                "conditions": [
                  {
                    "op": "in",
                    "field": "biz_product.fulfilment_mode",
                    "value": [
                      "made_to_order",
                      "hybrid"
                    ]
                  },
                  {
                    "op": "eq",
                    "field": "biz_product.active_supplier_source_count",
                    "value": 0
                  }
                ]
              },
              "icon": "lucide:Link2Off",
              "tone": "warning",
              "format": "number"
            },
            {
              "id": "low_stock_products",
              "label": "Low Stock",
              "subtitle": "At or below reorder point",
              "entity_id": "entity.biz_product",
              "measure": "count",
              "domain": {
                "op": "and",
                "conditions": [
                  {
                    "op": "in",
                    "field": "biz_product.fulfilment_mode",
                    "value": [
                      "stocked",
                      "hybrid"
                    ]
                  },
                  {
                    "op": "gt",
                    "field": "biz_product.reorder_point_qty",
                    "value": 0
                  },
                  {
                    "op": "lte",
                    "field": "biz_product.available_qty",
                    "value": {
                      "ref": "$current.biz_product.reorder_point_qty"
                    }
                  }
                ]
              },
              "icon": "lucide:TriangleAlert",
              "tone": "warning",
              "format": "number"
            },
            {
              "id": "inactive_products",
              "label": "Inactive",
              "subtitle": "Removed from new quoting",
              "entity_id": "entity.biz_product",
              "measure": "count",
              "domain": {
                "op": "eq",
                "field": "biz_product.is_active",
                "value": false
              },
              "icon": "lucide:Archive",
              "tone": "accent",
              "format": "number"
            }
          ]
        },
