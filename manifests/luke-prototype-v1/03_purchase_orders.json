{
  "manifest_version": "1.3",
  "module": {
    "id": "luke_purchase_orders",
    "key": "luke_purchase_orders",
    "name": "Purchase Orders",
    "version": "1.0.0",
    "description": "Supplier purchasing for the N-Light workflow prototype.",
    "category": "Prototype",
    "icon_key": "lucide:Truck"
  },
  "depends_on": {
    "required": [
      { "module": "luke_contacts", "version": ">=1.0.0" },
      { "module": "luke_products", "version": ">=1.0.0" }
    ]
  },
  "app": {
    "home": "page:nl_purchase_order.list_page",
    "defaults": {
      "entity_home_page": "page:nl_purchase_order.list_page",
      "entity_form_page": "page:nl_purchase_order.form_page",
      "entities": {
        "entity.nl_purchase_order": {
          "entity_home_page": "page:nl_purchase_order.list_page",
          "entity_form_page": "page:nl_purchase_order.form_page"
        },
        "entity.nl_purchase_order_line": {
          "entity_home_page": "page:nl_purchase_order_line.list_page",
          "entity_form_page": "page:nl_purchase_order_line.form_page"
        }
      }
    }
  },
  "entities": [
    {
      "id": "entity.nl_purchase_order",
      "display_field": "nl_purchase_order.po_number",
      "fields": [
        { "id": "nl_purchase_order.id", "type": "uuid", "label": "ID", "readonly": true },
        { "id": "nl_purchase_order.po_number", "type": "string", "label": "PO Number", "readonly": true },
        {
          "id": "nl_purchase_order.status",
          "type": "enum",
          "label": "Status",
          "required": true,
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "sent_to_supplier", "label": "Sent to Supplier" },
            { "value": "confirmed", "label": "Confirmed" },
            { "value": "in_production", "label": "In Production" },
            { "value": "shipped", "label": "Shipped" },
            { "value": "received", "label": "Received" },
            { "value": "closed", "label": "Closed" },
            { "value": "cancelled", "label": "Cancelled" }
          ]
        },
        {
          "id": "nl_purchase_order.supplier_id",
          "type": "lookup",
          "label": "Supplier",
          "entity": "entity.nl_contact",
          "display_field": "nl_contact.name",
          "required": true
        },
        {
          "id": "nl_purchase_order.purchasing_entity",
          "type": "enum",
          "label": "Purchasing Entity",
          "default": "EcoTech FZCO",
          "options": [
            { "value": "NLight BV", "label": "NLight BV" },
            { "value": "EcoTech FZCO", "label": "EcoTech FZCO" }
          ]
        },
        { "id": "nl_purchase_order.source_customer_order_id", "type": "string", "label": "Source Customer Order ID", "readonly": true },
        { "id": "nl_purchase_order.source_customer_order_number", "type": "string", "label": "Source Customer Order", "readonly": true },
        { "id": "nl_purchase_order.po_date", "type": "date", "label": "PO Date" },
        {
          "id": "nl_purchase_order.currency",
          "type": "enum",
          "label": "Currency",
          "default": "USD",
          "options": [
            { "value": "EUR", "label": "EUR" },
            { "value": "USD", "label": "USD" }
          ]
        },
        { "id": "nl_purchase_order.supplier_reference", "type": "string", "label": "Supplier Reference" },
        { "id": "nl_purchase_order.incoterm", "type": "string", "label": "Incoterm" },
        { "id": "nl_purchase_order.expected_ship_date", "type": "date", "label": "Expected Ship Date" },
        { "id": "nl_purchase_order.expected_arrival_date", "type": "date", "label": "Expected Arrival Date" },
        { "id": "nl_purchase_order.notes", "type": "text", "label": "Notes" },
        {
          "id": "nl_purchase_order.po_total",
          "type": "number",
          "label": "PO Total",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency_field": "nl_purchase_order.currency", "precision": 2 },
          "compute": {
            "aggregate": {
              "op": "sum",
              "entity": "entity.nl_purchase_order_line",
              "field": "nl_purchase_order_line.line_total",
              "where": {
                "op": "eq",
                "field": "nl_purchase_order_line.purchase_order_id",
                "value": { "ref": "$parent.id" }
              }
            }
          }
        },
        {
          "id": "nl_purchase_order.freight_estimate",
          "type": "number",
          "label": "Freight Estimate",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "nl_purchase_order.currency", "precision": 2 }
        },
        {
          "id": "nl_purchase_order.landed_cost_estimate",
          "type": "number",
          "label": "Landed Cost Estimate",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency_field": "nl_purchase_order.currency", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "add",
                  "args": [
                    { "ref": "$current.nl_purchase_order.po_total" },
                    { "ref": "$current.nl_purchase_order.freight_estimate" }
                  ]
                },
                2
              ]
            }
          }
        }
      ]
    },
    {
      "id": "entity.nl_purchase_order_line",
      "display_field": "nl_purchase_order_line.description",
      "fields": [
        { "id": "nl_purchase_order_line.id", "type": "uuid", "label": "ID", "readonly": true },
        {
          "id": "nl_purchase_order_line.purchase_order_id",
          "type": "lookup",
          "label": "Purchase Order",
          "entity": "entity.nl_purchase_order",
          "display_field": "nl_purchase_order.po_number",
          "required": true
        },
        {
          "id": "nl_purchase_order_line.product_id",
          "type": "lookup",
          "label": "Product",
          "entity": "entity.nl_product",
          "display_field": "nl_product.name"
        },
        { "id": "nl_purchase_order_line.description", "type": "string", "label": "Description", "required": true },
        {
          "id": "nl_purchase_order_line.uom",
          "type": "enum",
          "label": "UOM",
          "default": "EA",
          "options": [
            { "value": "EA", "label": "Each" },
            { "value": "SET", "label": "Set" },
            { "value": "KIT", "label": "Kit" },
            { "value": "LOT", "label": "Lot" }
          ]
        },
        { "id": "nl_purchase_order_line.quantity", "type": "number", "label": "Qty", "default": 1 },
        { "id": "nl_purchase_order_line.unit_cost", "type": "number", "label": "Unit Cost", "default": 0 },
        {
          "id": "nl_purchase_order_line.line_total",
          "type": "number",
          "label": "Line Total",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    { "ref": "$current.nl_purchase_order_line.quantity" },
                    { "ref": "$current.nl_purchase_order_line.unit_cost" }
                  ]
                },
                2
              ]
            }
          }
        },
        { "id": "nl_purchase_order_line.source_order_line_ref", "type": "string", "label": "Source Order Line Ref", "readonly": true }
      ]
    }
  ],
  "workflows": [
    {
      "id": "purchase_order_status_workflow",
      "entity": "entity.nl_purchase_order",
      "status_field": "nl_purchase_order.status",
      "states": [
        { "id": "draft", "label": "Draft" },
        { "id": "sent_to_supplier", "label": "Sent to Supplier" },
        { "id": "confirmed", "label": "Confirmed" },
        { "id": "in_production", "label": "In Production" },
        { "id": "shipped", "label": "Shipped" },
        { "id": "received", "label": "Received" },
        { "id": "closed", "label": "Closed" },
        { "id": "cancelled", "label": "Cancelled" }
      ]
    }
  ],
  "actions": [
    { "id": "action.refresh", "kind": "refresh", "label": "Refresh" },
    { "id": "action.purchase_order_new", "kind": "open_form", "label": "New Purchase Order", "target": "nl_purchase_order.form" },
    {
      "id": "action.purchase_order_mark_sent",
      "kind": "update_record",
      "entity_id": "entity.nl_purchase_order",
      "label": "Mark Sent",
      "patch": { "nl_purchase_order.status": "sent_to_supplier" },
      "visible_when": { "op": "eq", "field": "nl_purchase_order.status", "value": "draft" }
    },
    {
      "id": "action.purchase_order_confirm",
      "kind": "update_record",
      "entity_id": "entity.nl_purchase_order",
      "label": "Confirm PO",
      "patch": { "nl_purchase_order.status": "confirmed" },
      "visible_when": { "op": "eq", "field": "nl_purchase_order.status", "value": "sent_to_supplier" }
    },
    {
      "id": "action.purchase_order_mark_in_production",
      "kind": "update_record",
      "entity_id": "entity.nl_purchase_order",
      "label": "Mark In Production",
      "patch": { "nl_purchase_order.status": "in_production" },
      "visible_when": { "op": "eq", "field": "nl_purchase_order.status", "value": "confirmed" }
    },
    {
      "id": "action.purchase_order_mark_shipped",
      "kind": "update_record",
      "entity_id": "entity.nl_purchase_order",
      "label": "Mark Shipped",
      "patch": { "nl_purchase_order.status": "shipped" },
      "visible_when": { "op": "eq", "field": "nl_purchase_order.status", "value": "in_production" }
    },
    {
      "id": "action.purchase_order_mark_received",
      "kind": "update_record",
      "entity_id": "entity.nl_purchase_order",
      "label": "Mark Received",
      "patch": { "nl_purchase_order.status": "received" },
      "visible_when": { "op": "eq", "field": "nl_purchase_order.status", "value": "shipped" }
    },
    {
      "id": "action.purchase_order_close",
      "kind": "update_record",
      "entity_id": "entity.nl_purchase_order",
      "label": "Close PO",
      "patch": { "nl_purchase_order.status": "closed" },
      "visible_when": { "op": "eq", "field": "nl_purchase_order.status", "value": "received" }
    },
    {
      "id": "action.purchase_order_cancel",
      "kind": "update_record",
      "entity_id": "entity.nl_purchase_order",
      "label": "Cancel PO",
      "patch": { "nl_purchase_order.status": "cancelled" },
      "visible_when": {
        "op": "or",
        "conditions": [
          { "op": "eq", "field": "nl_purchase_order.status", "value": "draft" },
          { "op": "eq", "field": "nl_purchase_order.status", "value": "sent_to_supplier" },
          { "op": "eq", "field": "nl_purchase_order.status", "value": "confirmed" },
          { "op": "eq", "field": "nl_purchase_order.status", "value": "in_production" }
        ]
      }
    }
  ],
  "views": [
    {
      "id": "nl_purchase_order.list",
      "kind": "list",
      "entity": "entity.nl_purchase_order",
      "columns": [
        { "field_id": "nl_purchase_order.po_number" },
        { "field_id": "nl_purchase_order.po_date" },
        { "field_id": "nl_purchase_order.supplier_id" },
        { "field_id": "nl_purchase_order.source_customer_order_number" },
        { "field_id": "nl_purchase_order.purchasing_entity" },
        { "field_id": "nl_purchase_order.currency" },
        { "field_id": "nl_purchase_order.po_total" },
        { "field_id": "nl_purchase_order.status" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.purchase_order_new" }],
        "open_record_target": "page:nl_purchase_order.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search purchase orders...",
          "fields": ["nl_purchase_order.po_number", "nl_purchase_order.supplier_reference", "nl_purchase_order.source_customer_order_number"]
        },
        "filters": [
          { "id": "draft", "label": "Draft POs", "domain": { "op": "eq", "field": "nl_purchase_order.status", "value": "draft" } },
          { "id": "sent", "label": "Sent POs", "domain": { "op": "eq", "field": "nl_purchase_order.status", "value": "sent_to_supplier" } },
          { "id": "production", "label": "In Production", "domain": { "op": "eq", "field": "nl_purchase_order.status", "value": "in_production" } },
          { "id": "shipped", "label": "Shipped", "domain": { "op": "eq", "field": "nl_purchase_order.status", "value": "shipped" } },
          { "id": "received", "label": "Received", "domain": { "op": "eq", "field": "nl_purchase_order.status", "value": "received" } }
        ]
      }
    },
    {
      "id": "nl_purchase_order.form",
      "kind": "form",
      "entity": "entity.nl_purchase_order",
      "sections": [
        {
          "id": "summary",
          "title": "Purchase Order",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_purchase_order.po_number",
            "nl_purchase_order.status",
            "nl_purchase_order.supplier_id",
            "nl_purchase_order.purchasing_entity",
            "nl_purchase_order.source_customer_order_number",
            "nl_purchase_order.currency",
            "nl_purchase_order.po_date",
            "nl_purchase_order.supplier_reference",
            "nl_purchase_order.incoterm",
            "nl_purchase_order.expected_ship_date",
            "nl_purchase_order.expected_arrival_date",
            "nl_purchase_order.notes"
          ]
        },
        {
          "id": "financials",
          "title": "Costs",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_purchase_order.po_total",
            "nl_purchase_order.freight_estimate",
            "nl_purchase_order.landed_cost_estimate"
          ]
        },
        {
          "id": "lines",
          "title": "PO Lines",
          "line_editor": {
            "entity_id": "entity.nl_purchase_order_line",
            "parent_field": "nl_purchase_order_line.purchase_order_id",
            "item_lookup_field": "nl_purchase_order_line.product_id",
            "item_lookup_entity": "entity.nl_product",
            "item_lookup_display_field": "nl_product.name",
            "item_field_map": {
              "nl_purchase_order_line.description": "nl_product.description",
              "nl_purchase_order_line.uom": "nl_product.uom",
              "nl_purchase_order_line.unit_cost": "nl_product.default_buy_price"
            },
            "defaults": {
              "nl_purchase_order_line.uom": "EA",
              "nl_purchase_order_line.quantity": 1,
              "nl_purchase_order_line.unit_cost": 0
            },
            "description_field": "nl_purchase_order_line.description",
            "columns": [
              { "field_id": "nl_purchase_order_line.product_id", "label": "Product", "readonly": true },
              { "field_id": "nl_purchase_order_line.description", "label": "Description" },
              { "field_id": "nl_purchase_order_line.uom", "label": "UOM" },
              { "field_id": "nl_purchase_order_line.quantity", "label": "Qty", "type": "number" },
              { "field_id": "nl_purchase_order_line.unit_cost", "label": "Unit Cost", "type": "number" },
              { "field_id": "nl_purchase_order_line.line_total", "label": "Line Total", "type": "number" }
            ]
          }
        }
      ],
      "header": {
        "statusbar": { "field_id": "nl_purchase_order.status" },
        "secondary_actions": [
          { "action_id": "action.purchase_order_mark_sent" },
          { "action_id": "action.purchase_order_confirm" },
          { "action_id": "action.purchase_order_mark_in_production" },
          { "action_id": "action.purchase_order_mark_shipped" },
          { "action_id": "action.purchase_order_mark_received" },
          { "action_id": "action.purchase_order_close" },
          { "action_id": "action.purchase_order_cancel" },
          { "action_id": "action.refresh" }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "summary",
          "tabs": [
            { "id": "summary", "label": "Summary", "sections": ["summary"] },
            { "id": "lines", "label": "PO Lines", "sections": ["lines"] },
            { "id": "financials", "label": "Status / Logistics", "sections": ["financials"] }
          ]
        }
      }
    },
    {
      "id": "nl_purchase_order.kanban",
      "kind": "kanban",
      "entity": "entity.nl_purchase_order",
      "card": {
        "title_field": "nl_purchase_order.po_number",
        "subtitle_fields": [
          "nl_purchase_order.supplier_id",
          "nl_purchase_order.expected_ship_date"
        ],
        "badge_fields": [
          "nl_purchase_order.status",
          "nl_purchase_order.po_total"
        ]
      }
    },
    {
      "id": "nl_purchase_order.calendar",
      "kind": "calendar",
      "entity": "entity.nl_purchase_order",
      "calendar": {
        "title_field": "nl_purchase_order.po_number",
        "date_start": "nl_purchase_order.expected_ship_date",
        "date_end": "nl_purchase_order.expected_arrival_date",
        "color_field": "nl_purchase_order.status",
        "default_scale": "month"
      }
    },
    {
      "id": "nl_purchase_order.graph",
      "kind": "graph",
      "entity": "entity.nl_purchase_order",
      "default": {
        "type": "bar",
        "group_by": "nl_purchase_order.status",
        "measure": "sum:nl_purchase_order.po_total"
      }
    },
    {
      "id": "nl_purchase_order_line.list",
      "kind": "list",
      "entity": "entity.nl_purchase_order_line",
      "columns": [
        { "field_id": "nl_purchase_order_line.purchase_order_id" },
        { "field_id": "nl_purchase_order_line.product_id" },
        { "field_id": "nl_purchase_order_line.description" },
        { "field_id": "nl_purchase_order_line.uom" },
        { "field_id": "nl_purchase_order_line.quantity" },
        { "field_id": "nl_purchase_order_line.unit_cost" },
        { "field_id": "nl_purchase_order_line.line_total" }
      ],
      "header": {
        "open_record_target": "page:nl_purchase_order_line.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search PO lines...",
          "fields": ["nl_purchase_order_line.description", "nl_purchase_order_line.source_order_line_ref"]
        }
      }
    },
    {
      "id": "nl_purchase_order_line.form",
      "kind": "form",
      "entity": "entity.nl_purchase_order_line",
      "sections": [
        {
          "id": "main",
          "title": "PO Line",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "nl_purchase_order_line.purchase_order_id",
            "nl_purchase_order_line.product_id",
            "nl_purchase_order_line.description",
            "nl_purchase_order_line.uom",
            "nl_purchase_order_line.quantity",
            "nl_purchase_order_line.unit_cost",
            "nl_purchase_order_line.line_total",
            "nl_purchase_order_line.source_order_line_ref"
          ]
        }
      ]
    }
  ],
  "pages": [
    {
      "id": "nl_purchase_order.list_page",
      "title": "Purchase Orders",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          { "action_id": "action.refresh" },
          { "kind": "navigate", "label": "New Purchase Order", "target": "page:nl_purchase_order.form_page" }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.nl_purchase_order",
              "default_mode": "kanban",
              "default_filter_id": "draft",
              "modes": [
                { "mode": "list", "target": "view:nl_purchase_order.list" },
                { "mode": "kanban", "target": "view:nl_purchase_order.kanban", "default_group_by": "nl_purchase_order.status" },
                { "mode": "calendar", "target": "view:nl_purchase_order.calendar" },
                { "mode": "graph", "target": "view:nl_purchase_order.graph" },
                { "mode": "pivot", "target": "view:nl_purchase_order.list", "default_group_by": "nl_purchase_order.status" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "nl_purchase_order.form_page",
      "title": "Purchase Order",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.nl_purchase_order",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "view", "target": "view:nl_purchase_order.form" }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        { "kind": "chatter", "entity_id": "entity.nl_purchase_order", "record_ref": "$record.id" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "nl_purchase_order_line.list_page",
      "title": "PO Lines",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.nl_purchase_order_line",
              "default_mode": "list",
              "modes": [
                { "mode": "list", "target": "view:nl_purchase_order_line.list" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "nl_purchase_order_line.form_page",
      "title": "PO Line",
      "layout": "single",
      "header": { "variant": "none" },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.nl_purchase_order_line",
          "record_id_query": "record",
          "content": [
            {
              "kind": "container",
              "variant": "card",
              "content": [
                { "kind": "view", "target": "view:nl_purchase_order_line.form" }
              ]
            }
          ]
        }
      ]
    }
  ],
  "transformations": []
}
