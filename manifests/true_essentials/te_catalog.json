{
  "manifest_version": "1.3",
  "module": {
    "id": "te_catalog",
    "key": "te_catalog",
    "name": "Catalog",
    "version": "1.0.0",
    "description": "Product master records for True Essentials with retail pricing, buy-side cost visibility, and stock controls.",
    "category": "True Essentials",
    "icon_key": "lucide:Package2"
  },
  "app": {
    "home": "page:te_product.home_page",
    "defaults": {
      "entity_home_page": "page:te_product.list_page",
      "entity_form_page": "page:te_product.form_page",
      "entities": {
        "entity.te_product": {
          "entity_home_page": "page:te_product.list_page",
          "entity_form_page": "page:te_product.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Catalog",
        "mode": "inline",
        "items": [
          { "label": "Home", "to": "page:te_product.home_page" },
          { "label": "Products", "to": "page:te_product.list_page" },
          { "label": "Pricing Review", "to": "page:te_product.pricing_page" },
          { "label": "Stock Watch", "to": "page:te_product.stock_page" }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.te_product",
      "label": "Product",
      "display_field": "te_product.title",
      "fields": [
        { "id": "te_product.id", "type": "uuid", "label": "ID", "readonly": true },
        {
          "id": "te_product.sku",
          "type": "string",
          "label": "SKU",
          "required": true,
          "help_text": "Use a stable internal SKU. Do not expose UUIDs as business-facing identifiers."
        },
        { "id": "te_product.title", "type": "string", "label": "Product Name", "required": true },
        { "id": "te_product.variant_name", "type": "string", "label": "Variant" },
        {
          "id": "te_product.uom_category",
          "type": "enum",
          "label": "UOM Category",
          "default": "unit",
          "options": [
            { "value": "unit", "label": "Unit" },
            { "value": "pack", "label": "Pack" }
          ]
        },
        {
          "id": "te_product.uom",
          "type": "enum",
          "label": "Base UOM",
          "default": "EA",
          "options": [
            { "value": "EA", "label": "Each" },
            { "value": "PACK", "label": "Pack" },
            { "value": "CASE", "label": "Case" }
          ],
          "help_text": "Use an explicit unit of measure so pricing, purchasing, and stock logic stay consistent."
        },
        {
          "id": "te_product.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "active", "label": "Active" },
            { "value": "discontinued", "label": "Discontinued" },
            { "value": "archived", "label": "Archived" }
          ],
          "ui": { "widget": "steps" }
        },
        {
          "id": "te_product.sales_currency",
          "type": "enum",
          "label": "Retail Currency",
          "default": "NZD",
          "options": [
            { "value": "NZD", "label": "NZD" }
          ],
          "help_text": "True Essentials retail pricing is maintained in NZD."
        },
        {
          "id": "te_product.retail_price",
          "type": "number",
          "label": "Retail Sell Price",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "te_product.sales_currency", "precision": 2 }
        },
        {
          "id": "te_product.buy_currency",
          "type": "enum",
          "label": "Buy Currency",
          "default": "USD",
          "options": [
            { "value": "USD", "label": "USD" },
            { "value": "NZD", "label": "NZD" }
          ],
          "help_text": "Keep buy-side currency separate from retail currency. Most supplier buying will be recorded in USD."
        },
        {
          "id": "te_product.buy_price",
          "type": "number",
          "label": "Buy Price",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "te_product.buy_currency", "precision": 2 },
          "help_text": "Use this as the current supplier buy price before NZD conversion."
        },
        {
          "id": "te_product.buy_fx_rate_to_nzd",
          "type": "number",
          "label": "FX Rate To NZD",
          "default": 1,
          "help_text": "Use 1 when the buy price is already NZD. Otherwise record the FX rate being used to convert supplier cost into NZD."
        },
        {
          "id": "te_product.converted_buy_price_nzd",
          "type": "number",
          "label": "Converted Buy Price (NZD)",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "eq",
                "field": "te_product.buy_currency",
                "value": "NZD"
              },
              "then": {
                "ref": "$current.te_product.buy_price"
              },
              "else": {
                "op": "round",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      { "ref": "$current.te_product.buy_price" },
                      { "ref": "$current.te_product.buy_fx_rate_to_nzd" }
                    ]
                  },
                  2
                ]
              }
            }
          },
          "help_text": "Operational NZD equivalent of the current buy price."
        },
        {
          "id": "te_product.standard_cost_nzd",
          "type": "number",
          "label": "Landed Cost Override (NZD)",
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "help_text": "Use this only when freight, duties, or packaging mean the FX-converted buy price is not the true landed NZD cost."
        },
        {
          "id": "te_product.effective_cost_nzd",
          "type": "number",
          "label": "Effective Cost (NZD)",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "gt",
                "field": "te_product.standard_cost_nzd",
                "value": 0
              },
              "then": {
                "ref": "$current.te_product.standard_cost_nzd"
              },
              "else": {
                "ref": "$current.te_product.converted_buy_price_nzd"
              }
            }
          },
          "help_text": "This is the NZD cost used for margin and stock value."
        },
        {
          "id": "te_product.gross_margin_nzd",
          "type": "number",
          "label": "Gross Margin (NZD)",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    { "ref": "$current.te_product.retail_price" },
                    { "ref": "$current.te_product.effective_cost_nzd" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "te_product.gross_margin_percent",
          "type": "number",
          "label": "Gross Margin %",
          "readonly": true,
          "default": 0,
          "format": { "kind": "percent", "precision": 2 },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "gt",
                "field": "te_product.retail_price",
                "value": 0
              },
              "then": {
                "op": "round",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "div",
                        "args": [
                          { "ref": "$current.te_product.gross_margin_nzd" },
                          { "ref": "$current.te_product.retail_price" }
                        ]
                      },
                      100
                    ]
                  },
                  2
                ]
              },
              "else": 0
            }
          }
        },
        {
          "id": "te_product.track_stock",
          "type": "bool",
          "label": "Track Stock",
          "default": true,
          "help_text": "Turn this off only for non-stocked, virtual, or bundle-only items."
        },
        {
          "id": "te_product.stock_on_hand",
          "type": "number",
          "label": "Stock On Hand",
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_product.uom", "precision": 0 }
        },
        {
          "id": "te_product.stock_reserved",
          "type": "number",
          "label": "Stock Reserved",
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_product.uom", "precision": 0 },
          "help_text": "Use this for quantities already committed to sales or channel demand."
        },
        {
          "id": "te_product.stock_available",
          "type": "number",
          "label": "Available Stock",
          "readonly": true,
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_product.uom", "precision": 0 },
          "compute": {
            "expression": {
              "op": "sub",
              "args": [
                { "ref": "$current.te_product.stock_on_hand" },
                { "ref": "$current.te_product.stock_reserved" }
              ]
            }
          }
        },
        {
          "id": "te_product.reorder_point",
          "type": "number",
          "label": "Reorder Point",
          "default": 5,
          "format": { "kind": "measurement", "unit_field": "te_product.uom", "precision": 0 },
          "help_text": "When available stock falls to or below this level, the SKU should be reviewed for replenishment."
        },
        {
          "id": "te_product.reorder_qty",
          "type": "number",
          "label": "Suggested Reorder Qty",
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_product.uom", "precision": 0 }
        },
        {
          "id": "te_product.inventory_value_nzd",
          "type": "number",
          "label": "Inventory Value (NZD)",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    { "ref": "$current.te_product.stock_on_hand" },
                    { "ref": "$current.te_product.effective_cost_nzd" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "te_product.retail_stock_value_nzd",
          "type": "number",
          "label": "Retail Stock Value (NZD)",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    { "ref": "$current.te_product.stock_on_hand" },
                    { "ref": "$current.te_product.retail_price" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "te_product.available_retail_value_nzd",
          "type": "number",
          "label": "Available Retail Value (NZD)",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    { "ref": "$current.te_product.stock_available" },
                    { "ref": "$current.te_product.retail_price" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "te_product.stock_gross_profit_value_nzd",
          "type": "number",
          "label": "Stock Gross Profit Value (NZD)",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency": "NZD", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    { "ref": "$current.te_product.retail_stock_value_nzd" },
                    { "ref": "$current.te_product.inventory_value_nzd" }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "te_product.is_in_stock",
          "type": "bool",
          "label": "In Stock",
          "readonly": true,
          "default": false,
          "compute": {
            "expression": {
              "op": "and",
              "args": [
                { "ref": "$current.te_product.track_stock" },
                {
                  "op": "gt",
                  "args": [
                    { "ref": "$current.te_product.stock_available" },
                    0
                  ]
                }
              ]
            }
          }
        },
        {
          "id": "te_product.is_low_stock",
          "type": "bool",
          "label": "Low Stock",
          "readonly": true,
          "default": false,
          "compute": {
            "expression": {
              "op": "and",
              "args": [
                { "ref": "$current.te_product.track_stock" },
                {
                  "op": "gt",
                  "args": [
                    { "ref": "$current.te_product.stock_available" },
                    0
                  ]
                },
                {
                  "op": "lte",
                  "args": [
                    { "ref": "$current.te_product.stock_available" },
                    { "ref": "$current.te_product.reorder_point" }
                  ]
                }
              ]
            }
          }
        },
        {
          "id": "te_product.is_out_of_stock",
          "type": "bool",
          "label": "Out Of Stock",
          "readonly": true,
          "default": false,
          "compute": {
            "expression": {
              "op": "and",
              "args": [
                { "ref": "$current.te_product.track_stock" },
                {
                  "op": "lte",
                  "args": [
                    { "ref": "$current.te_product.stock_available" },
                    0
                  ]
                }
              ]
            }
          }
        },
        { "id": "te_product.shopify_handle", "type": "string", "label": "Shopify Handle" },
        { "id": "te_product.shopify_product_url", "type": "string", "label": "Shopify URL" },
        {
          "id": "te_product.attachments",
          "type": "attachments",
          "label": "Images / Product Files",
          "help_text": "Use this for product images, packaging references, and supplier-backed product files."
        },
        { "id": "te_product.notes", "type": "text", "label": "Internal Notes" }
      ]
    }
  ],
  "interfaces": {
    "dashboardable": [
      {
        "entity_id": "entity.te_product",
        "enabled": true,
        "scope": "module_and_global",
        "measures": [
          "count",
          "sum:te_product.inventory_value_nzd",
          "sum:te_product.retail_stock_value_nzd",
          "sum:te_product.stock_gross_profit_value_nzd"
        ],
        "group_bys": [
          "te_product.status",
          "te_product.uom_category",
          "te_product.buy_currency",
          "te_product.track_stock"
        ]
      }
    ]
  },
  "workflows": [
    {
      "id": "workflow.te_product",
      "entity": "entity.te_product",
      "status_field": "te_product.status",
      "states": [
        { "id": "draft", "label": "Draft", "order": 1 },
        { "id": "active", "label": "Active", "order": 2 },
        { "id": "discontinued", "label": "Discontinued", "order": 3 },
        { "id": "archived", "label": "Archived", "order": 4 }
      ],
      "transitions": [
        { "from": "draft", "to": "active", "label": "Activate" },
        { "from": "active", "to": "discontinued", "label": "Discontinue" },
        { "from": "discontinued", "to": "active", "label": "Reactivate" },
        { "from": "active", "to": "archived", "label": "Archive" },
        { "from": "discontinued", "to": "archived", "label": "Archive" }
      ]
    }
  ],
  "actions": [
    { "id": "action.te_product_new", "kind": "open_form", "label": "New Product", "target": "te_product.form" },
    {
      "id": "action.te_product_activate",
      "kind": "update_record",
      "entity_id": "entity.te_product",
      "label": "Activate",
      "patch": { "te_product.status": "active" },
      "visible_when": {
        "op": "in",
        "field": "te_product.status",
        "value": ["draft", "discontinued"]
      }
    },
    {
      "id": "action.te_product_discontinue",
      "kind": "update_record",
      "entity_id": "entity.te_product",
      "label": "Discontinue",
      "patch": { "te_product.status": "discontinued" },
      "visible_when": { "op": "eq", "field": "te_product.status", "value": "active" }
    },
    {
      "id": "action.te_product_archive",
      "kind": "update_record",
      "entity_id": "entity.te_product",
      "label": "Archive",
      "patch": { "te_product.status": "archived" },
      "visible_when": { "op": "not", "condition": { "op": "eq", "field": "te_product.status", "value": "archived" } }
    }
  ],
  "views": [
    {
      "id": "te_product.list",
      "kind": "list",
      "entity": "entity.te_product",
      "columns": [
        { "field_id": "te_product.sku" },
        { "field_id": "te_product.title" },
        { "field_id": "te_product.status" },
        { "field_id": "te_product.retail_price" },
        { "field_id": "te_product.effective_cost_nzd" },
        { "field_id": "te_product.gross_margin_percent" },
        { "field_id": "te_product.stock_available" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.te_product_new" }],
        "open_record_target": "page:te_product.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search products, SKUs, or Shopify handles...",
          "fields": ["te_product.sku", "te_product.title", "te_product.variant_name", "te_product.shopify_handle"]
        },
        "filters": [
          { "id": "active", "label": "Active", "domain": { "op": "eq", "field": "te_product.status", "value": "active" } },
          { "id": "draft", "label": "Draft", "domain": { "op": "eq", "field": "te_product.status", "value": "draft" } },
          {
            "id": "low_stock",
            "label": "Low Stock",
            "domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_product.status", "value": "active" },
                { "op": "eq", "field": "te_product.is_low_stock", "value": true }
              ]
            }
          },
          {
            "id": "out_of_stock",
            "label": "Out Of Stock",
            "domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_product.status", "value": "active" },
                { "op": "eq", "field": "te_product.is_out_of_stock", "value": true }
              ]
            }
          },
          { "id": "discontinued", "label": "Discontinued", "domain": { "op": "eq", "field": "te_product.status", "value": "discontinued" } },
          { "id": "archived", "label": "Archived", "domain": { "op": "eq", "field": "te_product.status", "value": "archived" } }
        ]
      }
    },
    {
      "id": "te_product.pricing_list",
      "kind": "list",
      "entity": "entity.te_product",
      "columns": [
        { "field_id": "te_product.sku" },
        { "field_id": "te_product.title" },
        { "field_id": "te_product.status" },
        { "field_id": "te_product.buy_currency" },
        { "field_id": "te_product.buy_price" },
        { "field_id": "te_product.converted_buy_price_nzd" },
        { "field_id": "te_product.standard_cost_nzd" },
        { "field_id": "te_product.effective_cost_nzd" },
        { "field_id": "te_product.retail_price" },
        { "field_id": "te_product.gross_margin_nzd" },
        { "field_id": "te_product.gross_margin_percent" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.te_product_new" }],
        "open_record_target": "page:te_product.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search products by SKU, title, or pricing notes...",
          "fields": ["te_product.sku", "te_product.title", "te_product.variant_name", "te_product.notes"]
        },
        "filters": [
          { "id": "active", "label": "Active", "domain": { "op": "eq", "field": "te_product.status", "value": "active" } },
          {
            "id": "usd_buy_side",
            "label": "USD Buy Side",
            "domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_product.status", "value": "active" },
                { "op": "eq", "field": "te_product.buy_currency", "value": "USD" }
              ]
            }
          },
          {
            "id": "low_margin",
            "label": "Low Margin",
            "domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_product.status", "value": "active" },
                { "op": "lt", "field": "te_product.gross_margin_percent", "value": 35 }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "te_product.stock_list",
      "kind": "list",
      "entity": "entity.te_product",
      "columns": [
        { "field_id": "te_product.sku" },
        { "field_id": "te_product.title" },
        { "field_id": "te_product.status" },
        { "field_id": "te_product.track_stock" },
        { "field_id": "te_product.stock_on_hand" },
        { "field_id": "te_product.stock_reserved" },
        { "field_id": "te_product.stock_available" },
        { "field_id": "te_product.reorder_point" },
        { "field_id": "te_product.reorder_qty" },
        { "field_id": "te_product.inventory_value_nzd" },
        { "field_id": "te_product.retail_stock_value_nzd" },
        { "field_id": "te_product.available_retail_value_nzd" },
        { "field_id": "te_product.stock_gross_profit_value_nzd" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.te_product_new" }],
        "open_record_target": "page:te_product.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search stock items, SKUs, or inventory notes...",
          "fields": ["te_product.sku", "te_product.title", "te_product.variant_name", "te_product.notes"]
        },
        "filters": [
          {
            "id": "tracked_active",
            "label": "Tracked Active",
            "domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_product.status", "value": "active" },
                { "op": "eq", "field": "te_product.track_stock", "value": true }
              ]
            }
          },
          {
            "id": "low_stock",
            "label": "Low Stock",
            "domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_product.status", "value": "active" },
                { "op": "eq", "field": "te_product.is_low_stock", "value": true }
              ]
            }
          },
          {
            "id": "out_of_stock",
            "label": "Out Of Stock",
            "domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_product.status", "value": "active" },
