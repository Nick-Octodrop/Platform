{
  "manifest_version": "1.3",
  "module": {
    "id": "te_purchasing",
    "key": "te_purchasing",
    "name": "Purchasing",
    "name_key": "te_purchasing.module.name",
    "version": "1.1.0",
    "description": "Operational supplier ordering for True Essentials.",
    "description_key": "te_purchasing.module.description",
    "category": "True Essentials",
    "icon_key": "lucide:ShoppingCart"
  },
  "depends_on": {
    "required": [
      { "module": "te_sourcing", "version": ">=1.0.0" },
      { "module": "te_suppliers", "version": ">=1.0.0" },
      { "module": "te_catalog", "version": ">=1.0.0" }
    ]
  },
  "app": {
    "home": "page:te_purchase_order.home_page",
    "defaults": {
      "entity_home_page": "page:te_purchase_order.list_page",
      "entity_form_page": "page:te_purchase_order.form_page",
      "entities": {
        "entity.te_purchase_order": {
          "entity_home_page": "page:te_purchase_order.list_page",
          "entity_form_page": "page:te_purchase_order.form_page"
        },
        "entity.te_purchase_order_line": {
          "entity_home_page": "page:te_purchase_order_line.list_page",
          "entity_form_page": "page:te_purchase_order_line.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Purchasing",
        "group_key": "te_purchasing.navigation.group",
        "mode": "inline",
        "items": [
          { "label": "Home", "to": "page:te_purchase_order.home_page", "menu_label_key": "te_purchasing.navigation.home_page" },
          { "label": "Supplier Orders", "to": "page:te_purchase_order.list_page", "menu_label_key": "te_purchasing.navigation.list_page" },
          { "label": "Open Supplier Orders", "to": "page:te_purchase_order.open_page", "menu_label_key": "te_purchasing.navigation.open_page" }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.te_purchase_order",
      "label": "Supplier Order",
      "display_field": "te_purchase_order.po_number",
      "fields": [
        { "id": "te_purchase_order.id", "type": "uuid", "label": "ID", "readonly": true },
        {
          "id": "te_purchase_order.po_number",
          "type": "string",
          "label": "Supplier Order Number",
          "readonly": true,
          "help_text": "Use settings-driven numbering for internal supplier orders. Do not hardcode numbering formats into module logic."
        },
        {
          "id": "te_purchase_order.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "placed", "label": "Ordered" },
            { "value": "partially_received", "label": "Partially Received" },
            { "value": "received", "label": "Received" },
            { "value": "cancelled", "label": "Cancelled" }
          ],
          "ui": { "widget": "steps" }
        },
        {
          "id": "te_purchase_order.supplier_id",
          "type": "lookup",
          "label": "Supplier",
          "entity": "entity.te_supplier",
          "display_field": "te_supplier.name",
          "required": true,
          "domain": { "op": "eq", "field": "te_supplier.status", "value": "active" },
          "help_text": "Changing supplier changes which supplier-linked items are valid on the Line Items tab. Review line items after supplier changes."
        },
        {
          "id": "te_purchase_order.supplier_contact_id",
          "type": "lookup",
          "label": "Supplier Contact",
          "entity": "entity.te_supplier_contact",
          "display_field": "te_supplier_contact.full_name",
          "domain": {
            "op": "and",
            "conditions": [
              { "op": "eq", "field": "te_supplier_contact.supplier_id", "value": { "ref": "$record.te_purchase_order.supplier_id" } },
              { "op": "eq", "field": "te_supplier_contact.is_active", "value": true }
            ]
          },
          "help_text": "This list is filtered to contacts for the selected supplier."
        },
        {
          "id": "te_purchase_order.order_method",
          "type": "enum",
          "label": "Order Method",
          "default": "website",
          "options": [
            { "value": "website", "label": "Website" },
            { "value": "portal", "label": "Supplier Portal" },
            { "value": "email", "label": "Email" },
            { "value": "phone", "label": "Phone" },
            { "value": "manual_po", "label": "Formal PO" }
          ],
          "help_text": "Use the method that matches how the order was actually placed with the supplier."
        },
        { "id": "te_purchase_order.order_date", "type": "date", "label": "Order Date", "required": true },
        { "id": "te_purchase_order.expected_date", "type": "date", "label": "Expected Delivery Date" },
        { "id": "te_purchase_order.received_date", "type": "date", "label": "Received Date", "required_when": { "op": "eq", "field": "te_purchase_order.status", "value": "received" } },
        {
          "id": "te_purchase_order.currency",
          "type": "enum",
          "label": "Currency",
          "default": "USD",
          "options": [
            { "value": "NZD", "label": "NZD" },
            { "value": "USD", "label": "USD" }
          ]
        },
        {
          "id": "te_purchase_order.external_order_ref",
          "type": "string",
          "label": "External Order Reference",
          "help_text": "Store the supplier website order number, portal reference, or emailed confirmation ID here."
        },
        {
          "id": "te_purchase_order.order_url",
          "type": "string",
          "label": "Supplier Order URL",
          "help_text": "Link back to the supplier page or portal order when the order was placed online."
        },
        { "id": "te_purchase_order.supplier_reference", "type": "string", "label": "Supplier Reference" },
        { "id": "te_purchase_order.tracking_number", "type": "string", "label": "Tracking Number" },
        { "id": "te_purchase_order.tracking_url", "type": "string", "label": "Tracking URL" },
        {
          "id": "te_purchase_order.po_total",
          "type": "number",
          "label": "Order Total",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency_field": "te_purchase_order.currency", "precision": 2 },
          "compute": {
            "aggregate": {
              "op": "sum",
              "entity": "entity.te_purchase_order_line",
              "field": "te_purchase_order_line.line_total",
              "where": {
                "op": "eq",
                "field": "te_purchase_order_line.purchase_order_id",
                "value": { "ref": "$parent.id" }
              }
            }
          }
        },
        {
          "id": "te_purchase_order.freight_estimate",
          "type": "number",
          "label": "Freight Estimate",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "te_purchase_order.currency", "precision": 2 }
        },
        {
          "id": "te_purchase_order.landed_total",
          "type": "number",
          "label": "Estimated Landed Total",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency_field": "te_purchase_order.currency", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "add",
                  "args": [
                    { "ref": "$current.te_purchase_order.po_total" },
                    { "ref": "$current.te_purchase_order.freight_estimate" }
                  ]
                },
                2
              ]
            }
          }
        },
        { "id": "te_purchase_order.supplier_documents", "type": "attachments", "label": "Supplier Files / Screenshots" },
        {
          "id": "te_purchase_order.cancellation_reason",
          "type": "text",
          "label": "Cancellation Reason",
          "required_when": { "op": "eq", "field": "te_purchase_order.status", "value": "cancelled" },
          "help_text": "Capture why the order was cancelled so the activity trail is useful later."
        },
        { "id": "te_purchase_order.notes", "type": "text", "label": "Internal Notes" }
      ]
    },
    {
      "id": "entity.te_purchase_order_line",
      "label": "Supplier Order Line",
      "display_field": "te_purchase_order_line.description",
      "fields": [
        { "id": "te_purchase_order_line.id", "type": "uuid", "label": "ID", "readonly": true },
        {
          "id": "te_purchase_order_line.purchase_order_id",
          "type": "lookup",
          "label": "Supplier Order",
          "entity": "entity.te_purchase_order",
          "display_field": "te_purchase_order.po_number",
          "required": true
        },
        {
          "id": "te_purchase_order_line.supplier_id_snapshot",
          "type": "lookup",
          "label": "Supplier Snapshot",
          "entity": "entity.te_supplier",
          "display_field": "te_supplier.name"
        },
        {
          "id": "te_purchase_order_line.currency_snapshot",
          "type": "enum",
          "label": "Currency Snapshot",
          "default": "USD",
          "options": [
            { "value": "NZD", "label": "NZD" },
            { "value": "USD", "label": "USD" }
          ]
        },
        {
          "id": "te_purchase_order_line.order_status_snapshot",
          "type": "enum",
          "label": "PO Status",
          "readonly": true,
          "default": "draft",
          "options": [
            { "value": "draft", "label": "Draft" },
            { "value": "placed", "label": "Ordered" },
            { "value": "partially_received", "label": "Partially Received" },
            { "value": "received", "label": "Received" },
            { "value": "cancelled", "label": "Cancelled" }
          ],
          "help_text": "Maintained from the supplier order so catalogue stock-on-order only counts active orders."
        },
        {
          "id": "te_purchase_order_line.supplier_product_id",
          "type": "lookup",
          "label": "Supplier Product",
          "entity": "entity.te_supplier_product",
          "display_field": "te_supplier_product.supplier_item_name",
          "required": true,
          "domain": {
            "op": "and",
            "conditions": [
              { "op": "eq", "field": "te_supplier_product.supplier_id", "value": { "ref": "$record.te_purchase_order_line.supplier_id_snapshot" } },
              { "op": "eq", "field": "te_supplier_product.is_active", "value": true }
            ]
          },
          "help_text": "Only active supplier-linked products for the selected supplier are available here."
        },
        {
          "id": "te_purchase_order_line.product_id",
          "type": "lookup",
          "label": "Product",
          "entity": "entity.te_product",
          "display_field": "te_product.title",
          "readonly": true,
          "help_text": "This is pulled from the selected supplier offer so stock and replenishment reporting stay product-centric."
        },
        { "id": "te_purchase_order_line.description", "type": "string", "label": "Description", "required": true },
        {
          "id": "te_purchase_order_line.order_uom",
          "type": "enum",
          "label": "Order UOM",
          "default": "EA",
          "options": [
            { "value": "EA", "label": "Each" },
            { "value": "PACK", "label": "Pack" },
            { "value": "CASE", "label": "Case" }
          ]
        },
        {
          "id": "te_purchase_order_line.quantity",
          "type": "number",
          "label": "Quantity",
          "default": 1,
          "format": { "kind": "measurement", "unit_field": "te_purchase_order_line.order_uom", "precision": 0 }
        },
        {
          "id": "te_purchase_order_line.received_quantity",
          "type": "number",
          "label": "Received Quantity",
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_purchase_order_line.order_uom", "precision": 0 },
          "help_text": "Use this to track what has physically arrived against the ordered quantity."
        },
        {
          "id": "te_purchase_order_line.stock_posted_quantity",
          "type": "number",
          "label": "Stock Posted Quantity",
          "readonly": true,
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_purchase_order_line.order_uom", "precision": 0 },
          "help_text": "Quantity already posted into catalogue stock on hand. Used to prevent duplicate receipt postings."
        },
        {
          "id": "te_purchase_order_line.open_quantity",
          "type": "number",
          "label": "Open Quantity",
          "readonly": true,
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_purchase_order_line.order_uom", "precision": 0 },
          "compute": {
            "expression": {
              "op": "max",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    { "ref": "$current.te_purchase_order_line.quantity" },
                    { "ref": "$current.te_purchase_order_line.received_quantity" }
                  ]
                },
                0
              ]
            }
          }
        },
        {
          "id": "te_purchase_order_line.stock_on_order_quantity",
          "type": "number",
          "label": "Stock On Order Quantity",
          "readonly": true,
          "default": 0,
          "format": { "kind": "measurement", "unit_field": "te_purchase_order_line.order_uom", "precision": 0 },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "in",
                "field": "te_purchase_order_line.order_status_snapshot",
                "value": ["placed", "partially_received"]
              },
              "then": { "ref": "$current.te_purchase_order_line.open_quantity" },
              "else": 0
            }
          },
          "help_text": "Open quantity counted in catalogue stock-on-order. Draft, received, and cancelled supplier orders count as zero."
        },
        {
          "id": "te_purchase_order_line.unit_cost",
          "type": "number",
          "label": "Unit Cost",
          "default": 0,
          "format": { "kind": "currency", "currency_field": "te_purchase_order_line.currency_snapshot", "precision": 2 }
        },
        {
          "id": "te_purchase_order_line.line_total",
          "type": "number",
          "label": "Line Total",
          "readonly": true,
          "default": 0,
          "format": { "kind": "currency", "currency_field": "te_purchase_order_line.currency_snapshot", "precision": 2 },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    { "ref": "$current.te_purchase_order_line.quantity" },
                    { "ref": "$current.te_purchase_order_line.unit_cost" }
                  ]
                },
                2
              ]
            }
          }
        },
        { "id": "te_purchase_order_line.notes", "type": "text", "label": "Line Notes" }
      ]
    }
  ],
  "interfaces": {
    "dashboardable": [
      {
        "entity_id": "entity.te_purchase_order",
        "enabled": true,
        "scope": "module_and_global",
        "date_field": "te_purchase_order.order_date",
        "measures": [
          "count",
          "sum:te_purchase_order.po_total"
        ],
        "group_bys": [
          "te_purchase_order.status",
          "te_purchase_order.currency",
          "te_purchase_order.supplier_id"
        ]
      },
      {
        "entity_id": "entity.te_purchase_order_line",
        "enabled": true,
        "scope": "module_and_global",
        "measures": [
          "count",
          "sum:te_purchase_order_line.line_total"
        ],
        "group_bys": [
          "te_purchase_order_line.order_uom",
          "te_purchase_order_line.currency_snapshot"
        ]
      }
    ]
  },
  "workflows": [
    {
      "id": "workflow.te_purchase_order",
      "entity": "entity.te_purchase_order",
      "status_field": "te_purchase_order.status",
      "states": [
        { "id": "draft", "label": "Draft", "order": 1, "required_fields": ["te_purchase_order.supplier_id", "te_purchase_order.currency"] },
        { "id": "placed", "label": "Ordered", "order": 2, "required_fields": ["te_purchase_order.supplier_id", "te_purchase_order.order_date", "te_purchase_order.order_method"] },
        { "id": "partially_received", "label": "Partially Received", "order": 3, "required_fields": ["te_purchase_order.supplier_id", "te_purchase_order.order_date", "te_purchase_order.order_method"] },
        { "id": "received", "label": "Received", "order": 4, "required_fields": ["te_purchase_order.received_date"] },
        { "id": "cancelled", "label": "Cancelled", "order": 5, "required_fields": ["te_purchase_order.cancellation_reason"] }
      ],
      "transitions": [
        { "from": "draft", "to": "placed", "label": "Mark Ordered" },
        { "from": "placed", "to": "partially_received", "label": "Mark Partially Received" },
        { "from": "placed", "to": "received", "label": "Mark Received" },
        { "from": "partially_received", "to": "received", "label": "Mark Fully Received" },
        { "from": "draft", "to": "cancelled", "label": "Cancel" },
        { "from": "placed", "to": "cancelled", "label": "Cancel" },
        { "from": "partially_received", "to": "cancelled", "label": "Cancel" }
      ]
    }
  ],
  "actions": [
    { "id": "action.te_purchase_order_new", "kind": "open_form", "label": "New Supplier Order", "target": "te_purchase_order.form" },
    {
      "id": "action.te_purchase_order_place",
      "kind": "update_record",
      "entity_id": "entity.te_purchase_order",
      "label": "Mark Ordered",
      "patch": { "te_purchase_order.status": "placed" },
      "confirm": {
        "title": "Mark supplier order as ordered?",
        "body": "Use this after the order has actually been placed with the supplier site, portal, email, phone workflow, or formal PO."
      },
      "visible_when": { "op": "eq", "field": "te_purchase_order.status", "value": "draft" },
      "enabled_when": {
        "op": "and",
        "conditions": [
          { "op": "exists", "field": "te_purchase_order.supplier_id" },
          { "op": "exists", "field": "te_purchase_order.order_method" },
          { "op": "gt", "field": "te_purchase_order.po_total", "value": 0 }
        ]
      }
    },
    {
      "id": "action.te_purchase_order_partial_receive",
      "kind": "update_record",
      "entity_id": "entity.te_purchase_order",
      "label": "Mark Partially Received",
      "patch": { "te_purchase_order.status": "partially_received" },
      "visible_when": { "op": "eq", "field": "te_purchase_order.status", "value": "placed" }
    },
    {
      "id": "action.te_purchase_order_receive",
      "kind": "update_record",
      "entity_id": "entity.te_purchase_order",
      "label": "Mark Fully Received",
      "patch": { "te_purchase_order.status": "received" },
      "visible_when": {
        "op": "in",
        "field": "te_purchase_order.status",
        "value": ["placed", "partially_received"]
      },
      "enabled_when": { "op": "exists", "field": "te_purchase_order.received_date" }
    },
    {
      "id": "action.te_purchase_order_open_cancel_modal",
      "kind": "update_record",
      "entity_id": "entity.te_purchase_order",
      "label": "Cancel Order",
      "modal_id": "modal.te_purchase_order_cancel",
      "visible_when": {
        "op": "in",
        "field": "te_purchase_order.status",
        "value": ["draft", "placed", "partially_received"]
      }
    }
  ],
  "views": [
    {
      "id": "te_purchase_order.list",
      "kind": "list",
      "entity": "entity.te_purchase_order",
      "columns": [
        { "field_id": "te_purchase_order.po_number" },
        { "field_id": "te_purchase_order.order_date" },
        { "field_id": "te_purchase_order.supplier_id" },
        { "field_id": "te_purchase_order.order_method" },
        { "field_id": "te_purchase_order.external_order_ref" },
        { "field_id": "te_purchase_order.currency" },
        { "field_id": "te_purchase_order.po_total" },
        { "field_id": "te_purchase_order.status" }
      ],
      "header": {
        "primary_actions": [{ "action_id": "action.te_purchase_order_new" }],
        "open_record_target": "page:te_purchase_order.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search supplier orders...",
          "fields": ["te_purchase_order.po_number", "te_purchase_order.external_order_ref", "te_purchase_order.supplier_reference"]
        },
        "filters": [
          {
            "id": "open",
            "label": "Open Orders",
            "domain": {
              "op": "in",
              "field": "te_purchase_order.status",
              "value": ["draft", "placed", "partially_received"]
            }
          },
          { "id": "draft", "label": "Draft", "domain": { "op": "eq", "field": "te_purchase_order.status", "value": "draft" } },
          { "id": "placed", "label": "Ordered", "domain": { "op": "eq", "field": "te_purchase_order.status", "value": "placed" } },
          { "id": "partially_received", "label": "Partially Received", "domain": { "op": "eq", "field": "te_purchase_order.status", "value": "partially_received" } },
          { "id": "received", "label": "Received", "domain": { "op": "eq", "field": "te_purchase_order.status", "value": "received" } },
          { "id": "cancelled", "label": "Cancelled", "domain": { "op": "eq", "field": "te_purchase_order.status", "value": "cancelled" } }
        ]
      }
    },
    {
      "id": "te_purchase_order.form",
      "kind": "form",
      "entity": "entity.te_purchase_order",
      "sections": [
        {
          "id": "summary",
          "title": "Supplier Order",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "te_purchase_order.po_number",
            "te_purchase_order.status",
            "te_purchase_order.supplier_id",
            "te_purchase_order.supplier_contact_id",
            "te_purchase_order.order_method",
            "te_purchase_order.order_date",
            "te_purchase_order.expected_date",
            "te_purchase_order.received_date",
            "te_purchase_order.currency",
            "te_purchase_order.external_order_ref",
            "te_purchase_order.supplier_reference",
            "te_purchase_order.order_url",
            "te_purchase_order.tracking_number",
            "te_purchase_order.tracking_url"
          ]
        },
        {
          "id": "financials",
          "title": "Costs",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "te_purchase_order.po_total",
            "te_purchase_order.freight_estimate",
            "te_purchase_order.landed_total"
          ]
        },
        {
          "id": "line_items",
          "title": "Line Items",
          "line_editor": {
            "entity_id": "entity.te_purchase_order_line",
            "parent_field": "te_purchase_order_line.purchase_order_id",
            "item_lookup_field": "te_purchase_order_line.supplier_product_id",
            "item_lookup_entity": "entity.te_supplier_product",
            "item_lookup_display_field": "te_supplier_product.supplier_item_name",
            "item_lookup_domain": {
              "op": "and",
              "conditions": [
                { "op": "eq", "field": "te_supplier_product.supplier_id", "value": { "ref": "$record.te_purchase_order.supplier_id" } },
                { "op": "eq", "field": "te_supplier_product.is_active", "value": true }
              ]
            },
