{
  "manifest_version": "1.3",
  "module": {
    "id": "catalog",
    "key": "catalog",
    "name": "Catalog",
    "version": "1.5.0",
    "description": "Shared item catalog for Paul Construction with purchasable materials aligned to site usage logging in the PWA.",
    "category": "Construction",
    "icon_key": "lucide:Package",
    "name_key": "catalog.module.name",
    "description_key": "catalog.module.description"
  },
  "depends_on": {
    "required": []
  },
  "app": {
    "home": "page:item.list_page",
    "defaults": {
      "entity_home_page": "page:item.list_page",
      "entity_form_page": "page:item.form_page",
      "entities": {
        "entity.item": {
          "entity_home_page": "page:item.list_page",
          "entity_form_page": "page:item.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Catalog",
        "mode": "inline",
        "items": [
          {
            "label": "Items",
            "to": "page:item.list_page",
            "menu_label_key": "catalog.navigation.item_list_page"
          },
          {
            "label": "Sellable",
            "to": "page:item.sellable_page",
            "menu_label_key": "catalog.navigation.item_sellable_page"
          },
          {
            "label": "Purchasable",
            "to": "page:item.purchasable_page",
            "menu_label_key": "catalog.navigation.item_purchasable_page"
          }
        ],
        "group_key": "catalog.navigation.group"
      }
    ]
  },
  "entities": [
    {
      "id": "entity.item",
      "display_field": "item.name",
      "fields": [
        {
          "id": "item.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true,
          "label_key": "catalog.entities.item.fields.id.label"
        },
        {
          "id": "item.code",
          "type": "string",
          "label": "Code",
          "required": true,
          "label_key": "catalog.entities.item.fields.code.label"
        },
        {
          "id": "item.name",
          "type": "string",
          "label": "Name",
          "required": true,
          "label_key": "catalog.entities.item.fields.name.label"
        },
        {
          "id": "item.type",
          "type": "enum",
          "label": "Type",
          "default": "storable",
          "options": [
            {
              "value": "storable",
              "label": "Storable Product",
              "status_label_key": "catalog.entities.item.fields.type.options.storable",
              "label_key": "catalog.entities.item.fields.type.options.storable"
            },
            {
              "value": "consumable",
              "label": "Consumable",
              "status_label_key": "catalog.entities.item.fields.type.options.consumable",
              "label_key": "catalog.entities.item.fields.type.options.consumable"
            },
            {
              "value": "service",
              "label": "Service",
              "status_label_key": "catalog.entities.item.fields.type.options.service",
              "label_key": "catalog.entities.item.fields.type.options.service"
            },
            {
              "value": "labor",
              "label": "Labor",
              "status_label_key": "catalog.entities.item.fields.type.options.labor",
              "label_key": "catalog.entities.item.fields.type.options.labor"
            }
          ],
          "label_key": "catalog.entities.item.fields.type.label"
        },
        {
          "id": "item.material_type",
          "type": "string",
          "label": "Material Type",
          "default": "other",
          "label_key": "catalog.entities.item.fields.material_type.label"
        },
        {
          "id": "item.fulfillment_method",
          "type": "enum",
          "label": "Fulfillment",
          "default": "purchase",
          "options": [
            {
              "value": "purchase",
              "label": "Purchase",
              "status_label_key": "catalog.entities.item.fields.fulfillment_method.options.purchase",
              "label_key": "catalog.entities.item.fields.fulfillment_method.options.purchase"
            },
            {
              "value": "manufacture",
              "label": "Manufacture",
              "status_label_key": "catalog.entities.item.fields.fulfillment_method.options.manufacture",
              "label_key": "catalog.entities.item.fields.fulfillment_method.options.manufacture"
            },
            {
              "value": "subcontract",
              "label": "Subcontract",
              "status_label_key": "catalog.entities.item.fields.fulfillment_method.options.subcontract",
              "label_key": "catalog.entities.item.fields.fulfillment_method.options.subcontract"
            },
            {
              "value": "manual",
              "label": "Manual / Time",
              "status_label_key": "catalog.entities.item.fields.fulfillment_method.options.manual",
              "label_key": "catalog.entities.item.fields.fulfillment_method.options.manual"
            }
          ],
          "label_key": "catalog.entities.item.fields.fulfillment_method.label"
        },
        {
          "id": "item.can_sell",
          "type": "enum",
          "label": "Can Be Sold",
          "default": "yes",
          "options": [
            {
              "value": "yes",
              "label": "Yes",
              "status_label_key": "catalog.entities.item.fields.can_sell.options.yes",
              "label_key": "catalog.entities.item.fields.can_sell.options.yes"
            },
            {
              "value": "no",
              "label": "No",
              "status_label_key": "catalog.entities.item.fields.can_sell.options.no",
              "label_key": "catalog.entities.item.fields.can_sell.options.no"
            }
          ],
          "label_key": "catalog.entities.item.fields.can_sell.label"
        },
        {
          "id": "item.can_purchase",
          "type": "enum",
          "label": "Can Be Purchased",
          "default": "yes",
          "options": [
            {
              "value": "yes",
              "label": "Yes",
              "status_label_key": "catalog.entities.item.fields.can_purchase.options.yes",
              "label_key": "catalog.entities.item.fields.can_purchase.options.yes"
            },
            {
              "value": "no",
              "label": "No",
              "status_label_key": "catalog.entities.item.fields.can_purchase.options.no",
              "label_key": "catalog.entities.item.fields.can_purchase.options.no"
            }
          ],
          "label_key": "catalog.entities.item.fields.can_purchase.label"
        },
        {
          "id": "item.show_in_workers_app",
          "type": "bool",
          "label": "Show In Workers App",
          "default": false,
          "label_key": "catalog.entities.item.fields.show_in_workers_app.label"
        },
        {
          "id": "item.uom",
          "type": "string",
          "label": "Unit of Measure",
          "default": "Unit",
          "label_key": "catalog.entities.item.fields.uom.label"
        },
        {
          "id": "item.uom_category",
          "type": "enum",
          "label": "UoM Category",
          "default": "unit",
          "options": [
            {
              "value": "unit",
              "label": "Unit",
              "status_label_key": "catalog.entities.item.fields.uom_category.options.unit",
              "label_key": "catalog.entities.item.fields.uom_category.options.unit"
            },
            {
              "value": "time",
              "label": "Time",
              "status_label_key": "catalog.entities.item.fields.uom_category.options.time",
              "label_key": "catalog.entities.item.fields.uom_category.options.time"
            },
            {
              "value": "length",
              "label": "Length",
              "status_label_key": "catalog.entities.item.fields.uom_category.options.length",
              "label_key": "catalog.entities.item.fields.uom_category.options.length"
            },
            {
              "value": "area",
              "label": "Area",
              "status_label_key": "catalog.entities.item.fields.uom_category.options.area",
              "label_key": "catalog.entities.item.fields.uom_category.options.area"
            },
            {
              "value": "volume",
              "label": "Volume",
              "status_label_key": "catalog.entities.item.fields.uom_category.options.volume",
              "label_key": "catalog.entities.item.fields.uom_category.options.volume"
            },
            {
              "value": "weight",
              "label": "Weight",
              "status_label_key": "catalog.entities.item.fields.uom_category.options.weight",
              "label_key": "catalog.entities.item.fields.uom_category.options.weight"
            }
          ],
          "label_key": "catalog.entities.item.fields.uom_category.label"
        },
        {
          "id": "item.sales_currency",
          "type": "string",
          "label": "Sales Currency",
          "default": "USD",
          "label_key": "catalog.entities.item.fields.sales_currency.label"
        },
        {
          "id": "item.purchase_currency",
          "type": "string",
          "label": "Purchase Currency",
          "default": "USD",
          "label_key": "catalog.entities.item.fields.purchase_currency.label"
        },
        {
          "id": "item.sales_price",
          "type": "number",
          "label": "Sales Price",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "item.sales_currency",
            "precision": 2
          },
          "label_key": "catalog.entities.item.fields.sales_price.label"
        },
        {
          "id": "item.cost_price",
          "type": "number",
          "label": "Cost",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "item.purchase_currency",
            "precision": 2
          },
          "label_key": "catalog.entities.item.fields.cost_price.label"
        },
        {
          "id": "item.tax_rate",
          "type": "number",
          "label": "Tax Rate (%)",
          "default": 0,
          "format": {
            "kind": "percent",
            "precision": 2
          },
          "label_key": "catalog.entities.item.fields.tax_rate.label"
        },
        {
          "id": "item.lead_time_days",
          "type": "number",
          "label": "Lead Time (Days)",
          "default": 0,
          "format": {
            "kind": "measurement",
            "unit": "days",
            "precision": 0
          },
          "label_key": "catalog.entities.item.fields.lead_time_days.label"
        },
        {
          "id": "item.margin_amount",
          "type": "number",
          "label": "Margin",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "item.sales_currency",
            "precision": 2
          },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    {
                      "ref": "$current.item.sales_price"
                    },
                    {
                      "ref": "$current.item.cost_price"
                    }
                  ]
                },
                2
              ]
            }
          },
          "label_key": "catalog.entities.item.fields.margin_amount.label"
        },
        {
          "id": "item.margin_percent",
          "type": "number",
          "label": "Margin (%)",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "percent",
            "precision": 2
          },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "gt",
                "field": "item.sales_price",
                "value": 0
              },
              "then": {
                "op": "round",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "div",
                        "args": [
                          {
                            "ref": "$current.item.margin_amount"
                          },
                          {
                            "ref": "$current.item.sales_price"
                          }
                        ]
                      },
                      100
                    ]
                  },
                  2
                ]
              },
              "else": 0
            }
          },
          "label_key": "catalog.entities.item.fields.margin_percent.label"
        },
        {
          "id": "item.status",
          "type": "enum",
          "label": "Status",
          "default": "active",
          "ui": {
            "widget": "steps"
          },
          "options": [
            {
              "value": "active",
              "label": "Active",
              "status_label_key": "catalog.entities.item.fields.status.options.active",
              "label_key": "catalog.entities.item.fields.status.options.active"
            },
            {
              "value": "inactive",
              "label": "Inactive",
              "status_label_key": "catalog.entities.item.fields.status.options.inactive",
              "label_key": "catalog.entities.item.fields.status.options.inactive"
            }
          ],
          "label_key": "catalog.entities.item.fields.status.label"
        },
        {
          "id": "item.description",
          "type": "text",
          "label": "Description",
          "label_key": "catalog.entities.item.fields.description.label"
        },
        {
          "id": "item.tags",
          "type": "tags",
          "label": "Tags",
          "label_key": "catalog.entities.item.fields.tags.label"
        },
        {
          "id": "item.created_at",
          "type": "datetime",
          "label": "Created At",
          "label_key": "catalog.entities.item.fields.created_at.label"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.item_new",
      "kind": "open_form",
      "label": "+ New Item",
      "target": "item.form",
      "action_label_key": "catalog.actions.action_item_new.label"
    },
    {
      "id": "action.item_set_active",
      "kind": "update_record",
      "label": "Set Active",
      "entity_id": "entity.item",
      "patch": {
        "item.status": "active"
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.status",
        "value": "inactive"
      },
      "visible_when": {
        "op": "eq",
        "field": "item.status",
        "value": "inactive"
      },
      "action_label_key": "catalog.actions.action_item_set_active.label"
    },
    {
      "id": "action.item_set_inactive",
      "kind": "update_record",
      "label": "Set Inactive",
      "entity_id": "entity.item",
      "patch": {
        "item.status": "inactive"
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.status",
        "value": "active"
      },
      "visible_when": {
        "op": "eq",
        "field": "item.status",
        "value": "active"
      },
      "action_label_key": "catalog.actions.action_item_set_inactive.label"
    },
    {
      "id": "action.item_add_to_workers_app",
      "kind": "update_record",
      "label": "Add To Workers App",
      "entity_id": "entity.item",
      "patch": {
        "item.show_in_workers_app": true
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.show_in_workers_app",
        "value": false
      },
      "visible_when": {
        "op": "eq",
        "field": "item.show_in_workers_app",
        "value": false
      },
      "action_label_key": "catalog.actions.action_item_add_to_workers_app.label"
    },
    {
      "id": "action.item_remove_from_workers_app",
      "kind": "update_record",
      "label": "Remove From Workers App",
      "entity_id": "entity.item",
      "patch": {
        "item.show_in_workers_app": false
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.show_in_workers_app",
        "value": true
      },
      "visible_when": {
        "op": "eq",
        "field": "item.show_in_workers_app",
        "value": true
      },
      "action_label_key": "catalog.actions.action_item_remove_from_workers_app.label"
    }
  ],
  "triggers": [
    {
      "id": "catalog.record.item.created",
      "event": "record.created",
      "entity_id": "entity.item"
    },
    {
      "id": "catalog.record.item.updated",
      "event": "record.updated",
      "entity_id": "entity.item"
    },
    {
      "id": "catalog.action.item_new.clicked",
      "event": "action.clicked",
      "action_id": "action.item_new"
    },
    {
      "id": "catalog.action.item_set_active.clicked",
      "event": "action.clicked",
      "action_id": "action.item_set_active"
    },
    {
      "id": "catalog.action.item_set_inactive.clicked",
      "event": "action.clicked",
      "action_id": "action.item_set_inactive"
    },
    {
      "id": "catalog.action.item_add_to_workers_app.clicked",
      "event": "action.clicked",
      "action_id": "action.item_add_to_workers_app"
    },
    {
      "id": "catalog.action.item_remove_from_workers_app.clicked",
      "event": "action.clicked",
      "action_id": "action.item_remove_from_workers_app"
    }
  ],
  "views": [
    {
      "id": "item.list",
      "kind": "list",
      "entity": "entity.item",
      "columns": [
        {
          "field_id": "item.code"
        },
        {
          "field_id": "item.name"
        },
        {
          "field_id": "item.type"
        },
        {
          "field_id": "item.material_type"
        },
        {
          "field_id": "item.fulfillment_method"
        },
        {
          "field_id": "item.show_in_workers_app"
        },
        {
          "field_id": "item.status"
        },
        {
          "field_id": "item.sales_price"
        },
        {
          "field_id": "item.cost_price"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.item_new"
          }
        ],
        "open_record_target": "page:item.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search items...",
          "fields": [
            "item.code",
            "item.name",
            "item.description"
          ],
          "placeholder_key": "catalog.views.item_list.search.placeholder"
        },
        "filters": [
          {
            "id": "active",
            "label": "Active",
            "domain": {
              "op": "eq",
              "field": "item.status",
              "value": "active"
            },
            "label_key": "catalog.views.item_list.filters.active.label"
          },
          {
            "id": "sellable",
            "label": "Sellable",
            "domain": {
              "op": "eq",
              "field": "item.can_sell",
              "value": "yes"
            },
            "label_key": "catalog.views.item_list.filters.sellable.label"
          },
          {
            "id": "purchasable",
            "label": "Purchasable",
            "domain": {
              "op": "eq",
              "field": "item.can_purchase",
              "value": "yes"
            },
            "label_key": "catalog.views.item_list.filters.purchasable.label"
          },
          {
            "id": "inactive",
            "label": "Inactive",
            "domain": {
              "op": "eq",
              "field": "item.status",
              "value": "inactive"
            },
            "label_key": "catalog.views.item_list.filters.inactive.label"
          },
          {
            "id": "products",
            "label": "Products",
            "domain": {
              "op": "in",
              "field": "item.type",
              "value": [
                "storable",
                "consumable"
              ]
            },
            "label_key": "catalog.views.item_list.filters.products.label"
          },
          {
            "id": "materials",
            "label": "Materials",
            "domain": {
              "op": "and",
              "conditions": [
                {
                  "op": "eq",
                  "field": "item.can_purchase",
                  "value": "yes"
                },
                {
                  "op": "in",
                  "field": "item.type",
                  "value": [
                    "storable",
                    "consumable"
                  ]
                }
              ]
            },
            "label_key": "catalog.views.item_list.filters.materials.label"
          },
          {
            "id": "workers_app",
            "label": "Workers App",
            "domain": {
              "op": "eq",
              "field": "item.show_in_workers_app",
              "value": true
            },
            "label_key": "catalog.views.item_list.filters.workers_app.label"
          },
          {
            "id": "services",
            "label": "Services",
            "domain": {
              "op": "in",
              "field": "item.type",
              "value": [
                "service",
                "labor"
              ]
            },
            "label_key": "catalog.views.item_list.filters.services.label"
          }
        ]
      }
    },
    {
      "id": "item.kanban",
      "kind": "kanban",
      "entity": "entity.item",
      "card": {
        "title_field": "item.name",
        "subtitle_fields": [
          "item.code",
          "item.fulfillment_method"
        ],
        "badge_fields": [
          "item.type",
          "item.material_type",
          "item.show_in_workers_app",
          "item.status",
          "item.sales_price"
        ]
      }
    },
    {
      "id": "item.form",
      "kind": "form",
      "entity": "entity.item",
      "sections": [
        {
          "id": "general",
          "title": "General",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "item.code",
            "item.name",
            "item.type",
            "item.material_type",
            "item.fulfillment_method",
            "item.show_in_workers_app",
            "item.status",
            "item.uom_category",
            "item.uom",
            "item.tags"
          ],
          "section_title_key": "catalog.views.item_form.sections.general.title"
        },
        {
          "id": "commercial",
          "title": "Commercial",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "item.can_sell",
            "item.can_purchase",
            "item.sales_currency",
            "item.purchase_currency",
            "item.sales_price",
            "item.cost_price",
            "item.margin_amount",
            "item.margin_percent",
            "item.tax_rate",
            "item.lead_time_days"
          ],
          "section_title_key": "catalog.views.item_form.sections.commercial.title"
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "item.description"
          ],
          "section_title_key": "catalog.views.item_form.sections.notes.title"
        }
      ],
      "header": {
        "secondary_actions": [
          {
            "action_id": "action.item_set_active"
          },
          {
            "action_id": "action.item_set_inactive"
          },
          {
            "action_id": "action.item_add_to_workers_app"
          },
          {
            "action_id": "action.item_remove_from_workers_app"
          }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "general_tab",
          "tabs": [
            {
              "id": "general_tab",
              "label": "General",
              "sections": [
                "general"
              ],
              "tab_label_key": "catalog.views.item_form.tabs.general_tab.label"
            },
            {
              "id": "commercial_tab",
              "label": "Commercial",
              "sections": [
                "commercial"
              ],
              "tab_label_key": "catalog.views.item_form.tabs.commercial_tab.label"
            },
            {
              "id": "notes_tab",
              "label": "Notes",
              "sections": [
                "notes"
              ],
              "tab_label_key": "catalog.views.item_form.tabs.notes_tab.label"
            }
          ]
        },
        "statusbar": {
          "field_id": "item.status"
        }
      },
