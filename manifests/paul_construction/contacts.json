{
  "manifest_version": "1.3",
  "module": {
    "id": "contacts",
    "key": "contacts",
    "name": "Contacts",
    "version": "1.5.0",
    "description": "Central contact management for companies, people, customers, suppliers, and service sites.",
    "category": "Foundation",
    "icon_key": "lucide:Users",
    "name_key": "contacts.module.name",
    "description_key": "contacts.module.description"
  },
  "app": {
    "home": "page:contact.list_page",
    "defaults": {
      "entity_home_page": "page:contact.list_page",
      "entity_form_page": "page:contact.form_page",
      "entities": {
        "entity.contact": {
          "entity_home_page": "page:contact.list_page",
          "entity_form_page": "page:contact.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Contacts",
        "mode": "inline",
        "items": [
          {
            "label": "All Contacts",
            "to": "page:contact.list_page",
            "menu_label_key": "contacts.navigation.contact_list_page"
          },
          {
            "label": "My Contacts",
            "to": "page:contact.mine_page",
            "menu_label_key": "contacts.navigation.contact_mine_page"
          },
          {
            "label": "Companies",
            "to": "page:contact.companies_page",
            "menu_label_key": "contacts.navigation.contact_companies_page"
          },
          {
            "label": "People",
            "to": "page:contact.people_page",
            "menu_label_key": "contacts.navigation.contact_people_page"
          },
          {
            "label": "Customers",
            "to": "page:contact.customers_page",
            "menu_label_key": "contacts.navigation.contact_customers_page"
          },
          {
            "label": "Suppliers",
            "to": "page:contact.suppliers_page",
            "menu_label_key": "contacts.navigation.contact_suppliers_page"
          },
          {
            "label": "Service Sites",
            "to": "page:contact.service_sites_page",
            "menu_label_key": "contacts.navigation.contact_service_sites_page"
          }
        ],
        "group_key": "contacts.navigation.group"
      }
    ]
  },
  "entities": [
    {
      "id": "entity.contact",
      "display_field": "contact.name",
      "fields": [
        {
          "id": "contact.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true,
          "label_key": "contacts.entities.contact.fields.id.label"
        },
        {
          "id": "contact.name",
          "type": "string",
          "label": "Name",
          "required": true,
          "label_key": "contacts.entities.contact.fields.name.label"
        },
        {
          "id": "contact.title",
          "type": "enum",
          "label": "Title",
          "options": [
            {
              "value": "mr",
              "label": "Mr.",
              "status_label_key": "contacts.entities.contact.fields.title.options.mr",
              "label_key": "contacts.entities.contact.fields.title.options.mr"
            },
            {
              "value": "mrs",
              "label": "Mrs.",
              "status_label_key": "contacts.entities.contact.fields.title.options.mrs",
              "label_key": "contacts.entities.contact.fields.title.options.mrs"
            },
            {
              "value": "ms",
              "label": "Ms.",
              "status_label_key": "contacts.entities.contact.fields.title.options.ms",
              "label_key": "contacts.entities.contact.fields.title.options.ms"
            },
            {
              "value": "dr",
              "label": "Dr.",
              "status_label_key": "contacts.entities.contact.fields.title.options.dr",
              "label_key": "contacts.entities.contact.fields.title.options.dr"
            }
          ],
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          },
          "label_key": "contacts.entities.contact.fields.title.label"
        },
        {
          "id": "contact.company_legal_name",
          "type": "string",
          "label": "Legal Name",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "company"
          },
          "label_key": "contacts.entities.contact.fields.company_legal_name.label"
        },
        {
          "id": "contact.first_name",
          "type": "string",
          "label": "First Name",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          },
          "label_key": "contacts.entities.contact.fields.first_name.label"
        },
        {
          "id": "contact.last_name",
          "type": "string",
          "label": "Last Name",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          },
          "label_key": "contacts.entities.contact.fields.last_name.label"
        },
        {
          "id": "contact.job_title",
          "type": "string",
          "label": "Job Title",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          },
          "label_key": "contacts.entities.contact.fields.job_title.label"
        },
        {
          "id": "contact.company_type",
          "type": "enum",
          "label": "Type",
          "default": "company",
          "options": [
            {
              "value": "company",
              "label": "Company",
              "status_label_key": "contacts.entities.contact.fields.company_type.options.company",
              "label_key": "contacts.entities.contact.fields.company_type.options.company"
            },
            {
              "value": "person",
              "label": "Person",
              "status_label_key": "contacts.entities.contact.fields.company_type.options.person",
              "label_key": "contacts.entities.contact.fields.company_type.options.person"
            }
          ],
          "label_key": "contacts.entities.contact.fields.company_type.label"
        },
        {
          "id": "contact.parent_company_id",
          "type": "lookup",
          "label": "Parent Company",
          "entity": "entity.contact",
          "display_field": "contact.name",
          "label_key": "contacts.entities.contact.fields.parent_company_id.label"
        },
        {
          "id": "contact.email",
          "type": "string",
          "label": "Email",
          "label_key": "contacts.entities.contact.fields.email.label"
        },
        {
          "id": "contact.phone",
          "type": "string",
          "label": "Phone",
          "label_key": "contacts.entities.contact.fields.phone.label"
        },
        {
          "id": "contact.mobile",
          "type": "string",
          "label": "Mobile",
          "label_key": "contacts.entities.contact.fields.mobile.label"
        },
        {
          "id": "contact.website",
          "type": "string",
          "label": "Website",
          "label_key": "contacts.entities.contact.fields.website.label"
        },
        {
          "id": "contact.language",
          "type": "string",
          "label": "Language",
          "label_key": "contacts.entities.contact.fields.language.label"
        },
        {
          "id": "contact.vat",
          "type": "string",
          "label": "Tax ID / VAT",
          "label_key": "contacts.entities.contact.fields.vat.label"
        },
        {
          "id": "contact.company_registry",
          "type": "string",
          "label": "Company Registry",
          "label_key": "contacts.entities.contact.fields.company_registry.label"
        },
        {
          "id": "contact.industry",
          "type": "string",
          "label": "Industry",
          "label_key": "contacts.entities.contact.fields.industry.label"
        },
        {
          "id": "contact.address_line_1",
          "type": "string",
          "label": "Address Line 1",
          "label_key": "contacts.entities.contact.fields.address_line_1.label"
        },
        {
          "id": "contact.address_line_2",
          "type": "string",
          "label": "Address Line 2",
          "label_key": "contacts.entities.contact.fields.address_line_2.label"
        },
        {
          "id": "contact.city",
          "type": "string",
          "label": "City",
          "label_key": "contacts.entities.contact.fields.city.label"
        },
        {
          "id": "contact.region",
          "type": "string",
          "label": "Region/State",
          "label_key": "contacts.entities.contact.fields.region.label"
        },
        {
          "id": "contact.postcode",
          "type": "string",
          "label": "Postcode",
          "label_key": "contacts.entities.contact.fields.postcode.label"
        },
        {
          "id": "contact.country",
          "type": "string",
          "label": "Country",
          "label_key": "contacts.entities.contact.fields.country.label"
        },
        {
          "id": "contact.latitude",
          "type": "number",
          "label": "Latitude",
          "label_key": "contacts.entities.contact.fields.latitude.label"
        },
        {
          "id": "contact.longitude",
          "type": "number",
          "label": "Longitude",
          "label_key": "contacts.entities.contact.fields.longitude.label"
        },
        {
          "id": "contact.place_id",
          "type": "string",
          "label": "Google Place ID",
          "readonly": true,
          "label_key": "contacts.entities.contact.fields.place_id.label"
        },
        {
          "id": "contact.address_type",
          "type": "enum",
          "label": "Address Type",
          "default": "contact",
          "options": [
            {
              "value": "contact",
              "label": "Contact",
              "status_label_key": "contacts.entities.contact.fields.address_type.options.contact",
              "label_key": "contacts.entities.contact.fields.address_type.options.contact"
            },
            {
              "value": "invoice",
              "label": "Invoice",
              "status_label_key": "contacts.entities.contact.fields.address_type.options.invoice",
              "label_key": "contacts.entities.contact.fields.address_type.options.invoice"
            },
            {
              "value": "delivery",
              "label": "Delivery",
              "status_label_key": "contacts.entities.contact.fields.address_type.options.delivery",
              "label_key": "contacts.entities.contact.fields.address_type.options.delivery"
            },
            {
              "value": "other",
              "label": "Other",
              "status_label_key": "contacts.entities.contact.fields.address_type.options.other",
              "label_key": "contacts.entities.contact.fields.address_type.options.other"
            }
          ],
          "label_key": "contacts.entities.contact.fields.address_type.label"
        },
        {
          "id": "contact.status",
          "type": "enum",
          "label": "Status",
          "default": "active",
          "options": [
            {
              "value": "active",
              "label": "Active",
              "status_label_key": "contacts.entities.contact.fields.status.options.active",
              "label_key": "contacts.entities.contact.fields.status.options.active"
            },
            {
              "value": "inactive",
              "label": "Inactive",
              "status_label_key": "contacts.entities.contact.fields.status.options.inactive",
              "label_key": "contacts.entities.contact.fields.status.options.inactive"
            }
          ],
          "label_key": "contacts.entities.contact.fields.status.label"
        },
        {
          "id": "contact.tags",
          "type": "tags",
          "label": "Tags",
          "label_key": "contacts.entities.contact.fields.tags.label"
        },
        {
          "id": "contact.owner_id",
          "type": "user",
          "label": "Owner",
          "label_key": "contacts.entities.contact.fields.owner_id.label"
        },
        {
          "id": "contact.notes",
          "type": "text",
          "label": "Notes",
          "label_key": "contacts.entities.contact.fields.notes.label"
        },
        {
          "id": "contact.is_customer",
          "type": "bool",
          "label": "Customer",
          "default": false,
          "label_key": "contacts.entities.contact.fields.is_customer.label"
        },
        {
          "id": "contact.is_supplier",
          "type": "bool",
          "label": "Supplier",
          "default": false,
          "label_key": "contacts.entities.contact.fields.is_supplier.label"
        },
        {
          "id": "contact.is_service_site",
          "type": "bool",
          "label": "Service Site",
          "default": false,
          "label_key": "contacts.entities.contact.fields.is_service_site.label"
        },
        {
          "id": "contact.customer_payment_terms",
          "type": "string",
          "label": "Customer Payment Terms",
          "label_key": "contacts.entities.contact.fields.customer_payment_terms.label"
        },
        {
          "id": "contact.supplier_payment_terms",
          "type": "string",
          "label": "Vendor Payment Terms",
          "label_key": "contacts.entities.contact.fields.supplier_payment_terms.label"
        },
        {
          "id": "contact.pricelist",
          "type": "string",
          "label": "Pricelist",
          "label_key": "contacts.entities.contact.fields.pricelist.label"
        },
        {
          "id": "contact.service_address_override",
          "type": "text",
          "label": "Service Address Override",
          "label_key": "contacts.entities.contact.fields.service_address_override.label"
        },
        {
          "id": "contact.attachments",
          "type": "attachments",
          "label": "Attachments",
          "label_key": "contacts.entities.contact.fields.attachments.label"
        },
        {
          "id": "contact.created_at",
          "type": "datetime",
          "label": "Created At",
          "label_key": "contacts.entities.contact.fields.created_at.label"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.contact_new",
      "kind": "open_form",
      "label": "+ New Contact",
      "target": "contact.form",
      "action_label_key": "contacts.actions.action_contact_new.label"
    },
    {
      "id": "action.contact_mark_inactive",
      "kind": "update_record",
      "label": "Mark Inactive",
      "entity_id": "entity.contact",
      "patch": {
        "contact.status": "inactive"
      },
      "enabled_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "active"
      },
      "visible_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "active"
      },
      "confirm": {
        "title": "Mark Inactive",
        "body": "This contact will be marked inactive.",
        "title_key": "contacts.actions.action_contact_mark_inactive.confirm.title"
      },
      "action_label_key": "contacts.actions.action_contact_mark_inactive.label"
    },
    {
      "id": "action.contact_reactivate",
      "kind": "update_record",
      "label": "Reactivate",
      "entity_id": "entity.contact",
      "patch": {
        "contact.status": "active"
      },
      "enabled_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "inactive"
      },
      "visible_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "inactive"
      },
      "action_label_key": "contacts.actions.action_contact_reactivate.label"
    }
  ],
  "triggers": [
    {
      "id": "contacts.record.contact.created",
      "event": "record.created",
      "entity_id": "entity.contact"
    },
    {
      "id": "contacts.record.contact.updated",
      "event": "record.updated",
      "entity_id": "entity.contact"
    },
    {
      "id": "contacts.workflow.contact.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.contact",
      "status_field": "contact.status"
    },
    {
      "id": "contacts.action.contact_new.clicked",
      "event": "action.clicked",
      "action_id": "action.contact_new"
    },
    {
      "id": "contacts.action.contact_mark_inactive.clicked",
      "event": "action.clicked",
      "action_id": "action.contact_mark_inactive"
    },
    {
      "id": "contacts.action.contact_reactivate.clicked",
      "event": "action.clicked",
      "action_id": "action.contact_reactivate"
    }
  ],
  "views": [
    {
      "id": "contact.list",
      "kind": "list",
      "entity": "entity.contact",
      "columns": [
        {
          "field_id": "contact.name"
        },
        {
          "field_id": "contact.company_type"
        },
        {
          "field_id": "contact.parent_company_id"
        },
        {
          "field_id": "contact.email"
        },
        {
          "field_id": "contact.phone"
        },
        {
          "field_id": "contact.city"
        },
        {
          "field_id": "contact.status"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.contact_new"
          }
        ],
        "open_record_target": "page:contact.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search contacts...",
          "fields": [
            "contact.name",
            "contact.company_legal_name",
            "contact.first_name",
            "contact.last_name",
            "contact.email",
            "contact.phone",
            "contact.city",
            "contact.region"
          ],
          "placeholder_key": "contacts.views.contact_list.search.placeholder"
        },
        "filters": [
          {
            "id": "active",
            "label": "Active",
            "domain": {
              "op": "eq",
              "field": "contact.status",
              "value": "active"
            },
            "label_key": "contacts.views.contact_list.filters.active.label"
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "contact.owner_id",
              "value": {
                "ref": "$actor.user_id"
              }
            },
            "label_key": "contacts.views.contact_list.filters.mine.label"
          },
          {
            "id": "companies",
            "label": "Companies",
            "domain": {
              "op": "eq",
              "field": "contact.company_type",
              "value": "company"
            },
            "label_key": "contacts.views.contact_list.filters.companies.label"
          },
          {
            "id": "people",
            "label": "People",
            "domain": {
              "op": "eq",
              "field": "contact.company_type",
              "value": "person"
            },
            "label_key": "contacts.views.contact_list.filters.people.label"
          },
          {
            "id": "customers",
            "label": "Customers",
            "domain": {
              "op": "eq",
              "field": "contact.is_customer",
              "value": true
            },
            "label_key": "contacts.views.contact_list.filters.customers.label"
          },
          {
            "id": "suppliers",
            "label": "Suppliers",
            "domain": {
              "op": "eq",
              "field": "contact.is_supplier",
              "value": true
            },
            "label_key": "contacts.views.contact_list.filters.suppliers.label"
          },
          {
            "id": "service_sites",
            "label": "Service Sites",
            "domain": {
              "op": "eq",
              "field": "contact.is_service_site",
              "value": true
            },
            "label_key": "contacts.views.contact_list.filters.service_sites.label"
          }
        ]
      }
    },
    {
      "id": "contact.kanban",
      "kind": "kanban",
      "entity": "entity.contact",
      "card": {
        "title_field": "contact.name",
        "subtitle_fields": [
          "contact.email",
          "contact.phone",
          "contact.city"
        ],
        "badge_fields": [
          "contact.tags",
          "contact.status"
        ]
      }
    },
    {
      "id": "contact.form",
      "kind": "form",
      "entity": "entity.contact",
      "sections": [
        {
          "id": "primary",
          "title": "Primary Details",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.name",
            "contact.title",
            "contact.company_legal_name",
            "contact.first_name",
            "contact.last_name",
            "contact.job_title",
            "contact.company_type",
            "contact.parent_company_id",
            "contact.status",
            "contact.owner_id",
            "contact.tags"
          ],
          "section_title_key": "contacts.views.contact_form.sections.primary.title"
        },
        {
          "id": "communication",
          "title": "Communication",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.email",
            "contact.website",
            "contact.phone",
            "contact.mobile",
            "contact.language"
          ],
          "section_title_key": "contacts.views.contact_form.sections.communication.title"
        },
        {
          "id": "address",
          "title": "Contacts & Addresses",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.address_type",
            "contact.address_line_1",
            "contact.address_line_2",
            "contact.city",
            "contact.region",
            "contact.postcode",
            "contact.country",
            "contact.latitude",
            "contact.longitude",
            "contact.service_address_override"
          ],
          "section_title_key": "contacts.views.contact_form.sections.address.title"
        },
        {
          "id": "classification",
          "title": "Sales & Purchase",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.is_customer",
            "contact.is_supplier",
            "contact.is_service_site",
            "contact.customer_payment_terms",
            "contact.supplier_payment_terms",
            "contact.pricelist"
          ],
          "section_title_key": "contacts.views.contact_form.sections.classification.title"
        },
        {
          "id": "accounting",
          "title": "Accounting",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.vat",
            "contact.company_registry",
            "contact.industry"
          ],
          "section_title_key": "contacts.views.contact_form.sections.accounting.title"
        },
        {
          "id": "notes",
          "title": "Internal Notes",
          "fields": [
            "contact.notes",
            "contact.attachments"
          ],
          "section_title_key": "contacts.views.contact_form.sections.notes.title"
        }
      ],
      "header": {
        "statusbar": {
          "field_id": "contact.status"
        },
        "secondary_actions": [
          {
            "action_id": "action.contact_mark_inactive"
          },
          {
            "action_id": "action.contact_reactivate"
          }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "contacts_addresses",
          "tabs": [
            {
              "id": "contacts_addresses",
              "label": "Contacts & Addresses",
              "sections": [
                "primary",
                "communication",
                "address"
              ],
              "tab_label_key": "contacts.views.contact_form.tabs.contacts_addresses.label"
            },
            {
              "id": "sales_purchase",
              "label": "Sales & Purchase",
              "sections": [
                "classification"
              ],
              "tab_label_key": "contacts.views.contact_form.tabs.sales_purchase.label"
            },
            {
              "id": "accounting_tab",
              "label": "Accounting",
              "sections": [
                "accounting"
              ],
              "tab_label_key": "contacts.views.contact_form.tabs.accounting_tab.label"
            },
            {
              "id": "internal_notes",
              "label": "Internal Notes",
              "sections": [
                "notes"
              ],
              "tab_label_key": "contacts.views.contact_form.tabs.internal_notes.label"
            }
          ]
        }
      },
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
