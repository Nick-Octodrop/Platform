          "display_field": "ai_plan.id"
        },
        {
          "id": "ai_patchset.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "validated",
              "label": "Validated"
            },
            {
              "value": "invalid",
              "label": "Invalid"
            },
            {
              "value": "approved",
              "label": "Approved"
            },
            {
              "value": "applied",
              "label": "Applied"
            },
            {
              "value": "rolled_back",
              "label": "Rolled Back"
            },
            {
              "value": "failed",
              "label": "Failed"
            }
          ]
