{
  "manifest_version": "1.3",
  "module": {
    "id": "octo_ai",
    "key": "octo_ai",
    "name": "Octo AI",
    "version": "1.0.1",
    "description": "Workspace-aware AI planning, patch generation, validation, apply, and rollback.",
    "category": "Admin",
    "icon_key": "lucide:Sparkles"
  },
  "app": {
    "home": "page:ai_session.list_page",
    "defaults": {
      "entity_home_page": "page:ai_session.list_page",
      "entity_form_page": "page:ai_session.form_page",
      "entities": {
        "entity.ai_session": {
          "entity_home_page": "page:ai_session.list_page",
          "entity_form_page": "page:ai_session.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Octo AI",
        "items": [
          {
            "label": "Sessions",
            "to": "page:ai_session.list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.ai_session",
      "display_field": "ai_session.title",
      "fields": [
        {
          "id": "ai_session.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "ai_session.title",
          "type": "string",
          "label": "Title",
          "required": true
        },
        {
          "id": "ai_session.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "planning",
              "label": "Planning"
            },
            {
              "value": "waiting_input",
              "label": "Waiting Input"
            },
            {
              "value": "ready_to_apply",
              "label": "Ready To Apply"
            },
            {
              "value": "applied",
              "label": "Applied"
            },
            {
              "value": "failed",
              "label": "Failed"
            },
            {
              "value": "archived",
              "label": "Archived"
            }
          ]
        },
        {
          "id": "ai_session.scope_mode",
          "type": "enum",
          "label": "Scope Mode",
          "default": "auto",
          "options": [
            {
              "value": "auto",
              "label": "Auto"
            },
            {
              "value": "current_item",
              "label": "Current Item"
            },
            {
              "value": "selected_items",
              "label": "Selected Items"
            },
            {
              "value": "workspace",
              "label": "Workspace"
            }
          ]
        },
        {
          "id": "ai_session.selected_artifact_type",
          "type": "enum",
          "label": "Selected Artifact Type",
          "default": "none",
          "options": [
            {
              "value": "module",
              "label": "Module"
            },
            {
              "value": "automation",
              "label": "Automation"
            },
            {
              "value": "integration",
              "label": "Integration"
            },
            {
              "value": "none",
              "label": "None"
            }
          ]
        },
        {
          "id": "ai_session.selected_artifact_key",
          "type": "string",
          "label": "Selected Artifact Key"
        },
        {
          "id": "ai_session.created_by",
          "type": "string",
          "label": "Created By"
        },
        {
          "id": "ai_session.last_activity_at",
          "type": "datetime",
          "label": "Last Activity"
        },
        {
          "id": "ai_session.last_error",
          "type": "text",
          "label": "Last Error"
        },
        {
          "id": "ai_session.summary",
          "type": "text",
          "label": "Summary"
        },
        {
          "id": "ai_session.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    },
    {
      "id": "entity.ai_message",
      "display_field": "ai_message.body",
      "fields": [
        {
          "id": "ai_message.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "ai_message.session_id",
          "type": "lookup",
          "label": "Session",
          "entity": "entity.ai_session",
          "display_field": "ai_session.title",
          "required": true
        },
        {
          "id": "ai_message.role",
          "type": "enum",
          "label": "Role",
          "options": [
            {
              "value": "user",
              "label": "User"
            },
            {
              "value": "assistant",
              "label": "Assistant"
            },
            {
              "value": "system",
              "label": "System"
            }
          ]
        },
        {
          "id": "ai_message.body",
          "type": "text",
          "label": "Body"
        },
        {
          "id": "ai_message.message_type",
          "type": "enum",
          "label": "Message Type",
          "options": [
            {
              "value": "chat",
              "label": "Chat"
            },
            {
              "value": "plan",
              "label": "Plan"
            },
            {
              "value": "question",
              "label": "Question"
            },
            {
              "value": "answer",
              "label": "Answer"
            },
            {
              "value": "apply_result",
              "label": "Apply Result"
            },
            {
              "value": "error",
              "label": "Error"
            }
          ]
        },
        {
          "id": "ai_message.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    },
    {
      "id": "entity.ai_plan",
      "display_field": "ai_plan.id",
      "fields": [
        {
          "id": "ai_plan.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "ai_plan.session_id",
          "type": "lookup",
          "label": "Session",
          "entity": "entity.ai_session",
          "display_field": "ai_session.title",
          "required": true
        },
        {
          "id": "ai_plan.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "approved",
              "label": "Approved"
            },
            {
              "value": "superseded",
              "label": "Superseded"
            },
            {
              "value": "rejected",
              "label": "Rejected"
            }
          ]
        },
        {
          "id": "ai_plan.scope_summary",
          "type": "text",
          "label": "Scope Summary"
        },
        {
          "id": "ai_plan.affected_artifacts_json",
          "type": "text",
          "label": "Affected Artifacts JSON"
        },
        {
          "id": "ai_plan.questions_json",
          "type": "text",
          "label": "Questions JSON"
        },
        {
          "id": "ai_plan.assumptions_json",
          "type": "text",
          "label": "Assumptions JSON"
        },
        {
          "id": "ai_plan.risks_json",
          "type": "text",
          "label": "Risks JSON"
        },
        {
          "id": "ai_plan.plan_json",
          "type": "text",
          "label": "Plan JSON"
        },
        {
          "id": "ai_plan.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    },
    {
      "id": "entity.ai_patchset",
      "display_field": "ai_patchset.id",
