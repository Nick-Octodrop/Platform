  "views": [
    {
      "id": "ai_session.list",
      "kind": "list",
      "entity": "entity.ai_session",
      "columns": [
        {
          "field_id": "ai_session.title",
          "label": "Title"
        },
        {
          "field_id": "ai_session.status",
          "label": "Status"
        },
        {
          "field_id": "ai_session.scope_mode",
          "label": "Scope"
        },
        {
          "field_id": "ai_session.selected_artifact_type",
          "label": "Artifact"
        },
        {
          "field_id": "ai_session.created_by",
          "label": "Created By"
        },
        {
          "field_id": "ai_session.last_activity_at",
          "label": "Last Activity"
        }
      ]
    },
    {
      "id": "ai_session.form",
      "kind": "form",
      "entity": "entity.ai_session",
      "sections": [
        {
          "id": "main",
          "title": "Session",
          "fields": [
            "ai_session.title",
            "ai_session.status",
            "ai_session.scope_mode",
            "ai_session.selected_artifact_type",
            "ai_session.selected_artifact_key",
            "ai_session.summary",
            "ai_session.last_error",
            "ai_session.created_by",
            "ai_session.last_activity_at"
          ]
        }
      ],
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
        "allow_attachments": true,
        "tracked_fields": [
          "ai_session.title",
          "ai_session.status",
          "ai_session.scope_mode",
          "ai_session.selected_artifact_type",
          "ai_session.selected_artifact_key",
          "ai_session.summary",
          "ai_session.last_error",
          "ai_session.created_by",
          "ai_session.last_activity_at"
        ]
      }
    }
  ],
  "pages": [
    {
      "id": "ai_session.list_page",
      "title": "AI Sessions",
      "layout": "single",
      "content": [
        {
          "kind": "view",
          "target": "ai_session.list"
        }
      ]
    },
    {
      "id": "ai_session.form_page",
      "title": "AI Session",
      "layout": "single",
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.ai_session",
          "record_id_query": "record",
          "content": [
            {
              "kind": "view",
              "target": "ai_session.form"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.ai_session_new",
      "kind": "open_form",
      "label": "New Session",
      "target": "ai_session.form"
    }
  ]
}
