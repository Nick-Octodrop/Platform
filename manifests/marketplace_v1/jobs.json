{
  "manifest_version": "1.3",
  "module": {
    "id": "jobs",
    "key": "jobs",
    "name": "Jobs",
    "version": "1.3.4",
    "description": "Operational job/work-order management with scheduling and execution tracking.",
    "category": "Operations",
    "icon_key": "lucide:BriefcaseBusiness"
  },
  "depends_on": {
    "required": [
      {
        "module": "contacts",
        "version": ">=1.0.0"
      },
      {
        "module": "catalog",
        "version": ">=1.1.0"
      }
    ],
    "optional": [
      {
        "module": "sales",
        "version": ">=1.6.2"
      }
    ]
  },
  "app": {
    "home": "page:job.list_page",
    "defaults": {
      "entity_home_page": "page:job.list_page",
      "entity_form_page": "page:job.form_page",
      "entities": {
        "entity.job": {
          "entity_home_page": "page:job.list_page",
          "entity_form_page": "page:job.form_page"
        },
        "entity.job_line": {
          "entity_home_page": "page:job_line.list_page",
          "entity_form_page": "page:job_line.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Jobs",
        "items": [
          {
            "label": "All Jobs",
            "to": "page:job.list_page"
          },
          {
            "label": "Schedule",
            "to": "page:job.calendar_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.job",
      "display_field": "job.number",
      "fields": [
        {
          "id": "job.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "job.number",
          "type": "string",
          "label": "Job Number",
          "required": true
        },
        {
          "id": "job.title",
          "type": "string",
          "label": "Title",
          "required": true
        },
        {
          "id": "job.contact_id",
          "type": "lookup",
          "label": "Contact",
          "entity": "entity.contact",
          "display_field": "contact.name",
          "required": true
        },
        {
          "id": "job.source_quote_id",
          "type": "lookup",
          "label": "Source Quote",
          "entity": "entity.quote",
          "display_field": "quote.number"
        },
        {
          "id": "job.status",
          "type": "enum",
          "label": "Status",
          "default": "new",
          "options": [
            {
              "value": "new",
              "label": "New"
            },
            {
              "value": "planned",
              "label": "Planned"
            },
            {
              "value": "in_progress",
              "label": "In Progress"
            },
            {
              "value": "on_hold",
              "label": "On Hold"
            },
            {
              "value": "completed",
              "label": "Completed"
            },
            {
              "value": "cancelled",
              "label": "Cancelled"
            }
          ]
        },
        {
          "id": "job.priority",
          "type": "enum",
          "label": "Priority",
          "default": "normal",
          "options": [
            {
              "value": "low",
              "label": "Low"
            },
            {
              "value": "normal",
              "label": "Normal"
            },
            {
              "value": "high",
              "label": "High"
            },
            {
              "value": "urgent",
              "label": "Urgent"
            }
          ]
        },
        {
          "id": "job.owner_id",
          "type": "user",
          "label": "Owner"
        },
        {
          "id": "job.assignee_id",
          "type": "user",
          "label": "Assignee"
        },
        {
          "id": "job.participant_ids",
          "type": "users",
          "label": "Participants"
        },
        {
          "id": "job.start_date",
          "type": "date",
          "label": "Start Date"
        },
        {
          "id": "job.due_date",
          "type": "date",
          "label": "Due Date"
        },
        {
          "id": "job.scheduled_start",
          "type": "datetime",
          "label": "Scheduled Start"
        },
        {
          "id": "job.scheduled_end",
          "type": "datetime",
          "label": "Scheduled End"
        },
        {
          "id": "job.location",
          "type": "string",
          "label": "Location"
        },
        {
          "id": "job.description",
          "type": "text",
          "label": "Description"
        },
        {
          "id": "job.internal_notes",
          "type": "text",
          "label": "Internal Notes"
        },
        {
          "id": "job.attachments",
          "type": "attachments",
          "label": "Attachments"
        },
        {
          "id": "job.total_estimate",
          "type": "number",
          "label": "Estimated Total",
          "default": 0
        },
        {
          "id": "job.actual_cost",
          "type": "number",
          "label": "Actual Cost",
          "default": 0
        },
        {
          "id": "job.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    },
    {
      "id": "entity.job_line",
      "display_field": "job_line.description",
      "fields": [
        {
          "id": "job_line.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "job_line.job_id",
          "type": "lookup",
          "label": "Job",
          "entity": "entity.job",
          "display_field": "job.number",
          "required": true
        },
        {
          "id": "job_line.item_id",
          "type": "lookup",
          "label": "Item",
          "entity": "entity.item",
          "display_field": "item.name",
          "required": true
        },
        {
          "id": "job_line.description",
          "type": "string",
          "label": "Description",
          "required": true
        },
        {
          "id": "job_line.qty",
          "type": "number",
          "label": "Qty",
          "default": 1
        },
        {
          "id": "job_line.unit_price",
          "type": "number",
          "label": "Unit Price",
          "default": 0
        },
        {
          "id": "job_line.tax_rate",
          "type": "number",
          "label": "Tax Rate (%)",
          "default": 0
        },
        {
          "id": "job_line.line_total",
          "type": "number",
          "label": "Line Total",
          "default": 0
        },
        {
          "id": "job_line.status",
          "type": "enum",
          "label": "Line Status",
          "default": "new",
          "options": [
            {
              "value": "new",
              "label": "New"
            },
            {
              "value": "in_progress",
              "label": "In Progress"
            },
            {
              "value": "done",
              "label": "Done"
            },
            {
              "value": "cancelled",
              "label": "Cancelled"
            }
          ]
        },
        {
          "id": "job_line.sort_order",
          "type": "number",
          "label": "Sort Order",
          "default": 10
        },
        {
          "id": "job_line.notes",
          "type": "text",
          "label": "Line Notes"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.job_new",
      "kind": "open_form",
      "label": "+ New Job",
      "target": "job.form"
    },
    {
      "id": "action.job_plan",
      "kind": "update_record",
      "label": "Plan",
      "entity_id": "entity.job",
      "patch": {
        "job.status": "planned"
      },
      "enabled_when": {
        "op": "eq",
        "field": "job.status",
        "value": "new"
      },
      "visible_when": {
        "op": "eq",
        "field": "job.status",
        "value": "new"
      }
    },
    {
      "id": "action.job_start",
      "kind": "update_record",
      "label": "Start",
      "entity_id": "entity.job",
      "patch": {
        "job.status": "in_progress"
      },
      "enabled_when": {
        "op": "in",
        "field": "job.status",
        "value": [
          "new",
          "planned",
          "on_hold"
        ]
      },
      "visible_when": {
        "op": "in",
        "field": "job.status",
        "value": [
          "new",
          "planned",
          "on_hold"
        ]
      }
    },
    {
      "id": "action.job_hold",
      "kind": "update_record",
      "label": "Put On Hold",
      "entity_id": "entity.job",
      "patch": {
        "job.status": "on_hold"
      },
      "enabled_when": {
        "op": "eq",
        "field": "job.status",
        "value": "in_progress"
      },
      "visible_when": {
        "op": "eq",
        "field": "job.status",
        "value": "in_progress"
      },
      "confirm": {
        "title": "Put Job On Hold",
        "body": "The job will be moved to On Hold."
      }
    },
    {
      "id": "action.job_complete",
      "kind": "update_record",
      "label": "Complete",
      "entity_id": "entity.job",
      "patch": {
        "job.status": "completed"
      },
      "enabled_when": {
        "op": "in",
        "field": "job.status",
        "value": [
          "planned",
          "in_progress",
          "on_hold"
        ]
      },
      "visible_when": {
        "op": "in",
        "field": "job.status",
        "value": [
          "planned",
          "in_progress",
          "on_hold"
        ]
      },
      "confirm": {
        "title": "Complete Job",
        "body": "Mark this job as completed?"
      }
    },
    {
      "id": "action.job_cancel",
      "kind": "update_record",
      "label": "Cancel",
      "entity_id": "entity.job",
      "patch": {
        "job.status": "cancelled"
      },
      "enabled_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "job.status",
          "value": [
            "completed",
            "cancelled"
          ]
        }
      },
      "visible_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "job.status",
          "value": [
            "completed",
            "cancelled"
          ]
        }
      },
      "confirm": {
        "title": "Cancel Job",
        "body": "This job will be cancelled."
      }
    }
  ],
  "triggers": [
    {
      "id": "jobs.record.job.created",
      "event": "record.created",
      "entity_id": "entity.job"
    },
    {
      "id": "jobs.record.job.updated",
      "event": "record.updated",
      "entity_id": "entity.job"
    },
    {
      "id": "jobs.record.job_line.created",
      "event": "record.created",
      "entity_id": "entity.job_line"
    },
    {
      "id": "jobs.record.job_line.updated",
      "event": "record.updated",
      "entity_id": "entity.job_line"
    },
    {
      "id": "jobs.workflow.job.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.job",
      "status_field": "job.status"
    },
    {
      "id": "jobs.action.job_new.clicked",
      "event": "action.clicked",
      "action_id": "action.job_new"
    },
    {
      "id": "jobs.action.job_plan.clicked",
      "event": "action.clicked",
      "action_id": "action.job_plan"
    },
    {
      "id": "jobs.action.job_start.clicked",
      "event": "action.clicked",
      "action_id": "action.job_start"
    },
    {
      "id": "jobs.action.job_hold.clicked",
      "event": "action.clicked",
      "action_id": "action.job_hold"
    },
    {
      "id": "jobs.action.job_complete.clicked",
      "event": "action.clicked",
      "action_id": "action.job_complete"
    },
    {
      "id": "jobs.action.job_cancel.clicked",
      "event": "action.clicked",
      "action_id": "action.job_cancel"
    }
  ],
  "views": [
    {
      "id": "job.list",
      "kind": "list",
      "entity": "entity.job",
      "columns": [
        {
          "field_id": "job.number"
        },
        {
          "field_id": "job.title"
        },
        {
          "field_id": "job.contact_id"
        },
        {
          "field_id": "job.status"
        },
        {
          "field_id": "job.priority"
        },
        {
          "field_id": "job.scheduled_start"
        },
        {
          "field_id": "job.assignee_id"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.job_new"
          }
        ],
        "open_record_target": "page:job.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search jobs...",
          "fields": [
            "job.number",
            "job.title",
            "job.location",
            "job.status",
            "job.assignee_id",
            "job.participant_ids"
          ]
        },
        "filters": [
          {
            "id": "open",
            "label": "Open",
            "domain": {
              "op": "not",
              "condition": {
                "op": "in",
                "field": "job.status",
                "value": [
                  "completed",
                  "cancelled"
                ]
              }
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "or",
              "conditions": [
                {
                  "op": "eq",
                  "field": "job.owner_id",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                },
                {
                  "op": "eq",
                  "field": "job.assignee_id",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                },
                {
                  "op": "contains",
                  "field": "job.participant_ids",
                  "value": {
                    "ref": "$actor.user_id"
                  }
                }
              ]
            }
          },
          {
            "id": "scheduled",
            "label": "Scheduled",
            "domain": {
              "op": "exists",
              "field": "job.scheduled_start"
            }
          }
        ]
      }
    },
    {
      "id": "job.kanban",
      "kind": "kanban",
      "entity": "entity.job",
      "card": {
        "title_field": "job.title",
        "subtitle_fields": [
          "job.number",
          "job.contact_id",
          "job.scheduled_start"
        ],
        "badge_fields": [
          "job.status",
          "job.priority",
          "job.participant_ids"
        ]
      }
    },
    {
      "id": "job.calendar",
      "kind": "calendar",
      "entity": "entity.job",
      "calendar": {
        "title_field": "job.title",
        "date_start": "job.scheduled_start",
        "date_end": "job.scheduled_end",
        "color_field": "job.assignee_id",
        "default_scale": "week"
      }
    },
    {
      "id": "job_line.list",
      "kind": "list",
      "entity": "entity.job_line",
      "columns": [
        {
          "field_id": "job_line.job_id"
        },
        {
          "field_id": "job_line.item_id"
        },
        {
          "field_id": "job_line.sort_order"
        },
        {
          "field_id": "job_line.description"
        },
        {
          "field_id": "job_line.qty"
        },
        {
          "field_id": "job_line.unit_price"
        },
        {
          "field_id": "job_line.tax_rate"
        },
        {
          "field_id": "job_line.line_total"
        },
        {
          "field_id": "job_line.status"
        }
      ],
      "header": {
        "open_record_target": "page:job_line.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search job lines...",
          "fields": [
            "job_line.description",
            "job_line.status"
          ]
        }
      }
    },
    {
      "id": "job_line.form",
      "kind": "form",
      "entity": "entity.job_line",
      "sections": [
        {
          "id": "main",
          "title": "Job Line",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "job_line.job_id",
            "job_line.item_id",
            "job_line.sort_order",
            "job_line.description",
            "job_line.qty",
            "job_line.unit_price",
            "job_line.tax_rate",
            "job_line.line_total",
            "job_line.status"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "job_line.notes"
          ]
        }
      ],
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
        "allow_attachments": true,
        "tracked_fields": [
          "job_line.job_id",
          "job_line.item_id",
          "job_line.sort_order",
          "job_line.description",
          "job_line.qty",
          "job_line.unit_price",
          "job_line.tax_rate",
          "job_line.line_total",
          "job_line.status",
          "job_line.notes"
        ]
      }
    },
    {
      "id": "job.form",
      "kind": "form",
      "entity": "entity.job",
      "sections": [
        {
          "id": "details",
          "title": "Job Details",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "job.number",
            "job.title",
            "job.contact_id",
            "job.source_quote_id",
            "job.status",
            "job.priority",
            "job.owner_id",
            "job.assignee_id",
            "job.participant_ids"
          ]
        },
        {
          "id": "schedule",
          "title": "Schedule",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "job.start_date",
            "job.due_date",
            "job.scheduled_start",
            "job.scheduled_end",
            "job.location"
          ]
        },
        {
          "id": "financials",
          "title": "Financials",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "job.total_estimate",
            "job.actual_cost"
          ]
        },
        {
          "id": "line_items",
          "title": "Line Items",
          "line_editor": {
            "entity_id": "entity.job_line",
            "parent_field": "job_line.job_id",
            "item_lookup_field": "job_line.item_id",
            "item_lookup_entity": "entity.item",
            "item_lookup_display_field": "item.name",
            "item_field_map": {
              "job_line.unit_price": "item.sales_price",
              "job_line.tax_rate": "item.tax_rate",
              "job_line.description": "item.description"
            },
            "description_field": "job_line.description",
            "defaults": {
              "job_line.qty": 1,
              "job_line.unit_price": 0,
              "job_line.tax_rate": 0
            },
            "columns": [
              {
                "field_id": "job_line.item_id",
                "label": "Item",
                "readonly": true
              },
              {
                "field_id": "job_line.description",
                "label": "Description"
              },
              {
                "field_id": "job_line.qty",
                "label": "Qty",
                "type": "number"
              },
              {
                "field_id": "job_line.unit_price",
                "label": "Unit Price",
                "type": "number"
              },
              {
                "field_id": "job_line.tax_rate",
                "label": "Tax %",
                "type": "number"
              },
              {
                "field_id": "job_line.line_total",
                "label": "Line Total",
                "type": "number"
              }
            ]
          }
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "job.description",
            "job.internal_notes",
            "job.attachments"
          ]
        }
      ],
      "header": {
        "statusbar": {
          "field_id": "job.status"
        },
        "secondary_actions": [
          {
            "action_id": "action.job_plan"
          },
          {
            "action_id": "action.job_start"
          },
          {
            "action_id": "action.job_hold"
          },
          {
            "action_id": "action.job_complete"
          },
          {
            "action_id": "action.job_cancel"
          }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "details_tab",
          "tabs": [
            {
              "id": "details_tab",
              "label": "Details",
              "sections": [
                "details"
              ]
            },
            {
              "id": "line_items_tab",
              "label": "Line Items",
              "sections": [
                "line_items"
              ]
            },
            {
              "id": "schedule_tab",
              "label": "Schedule",
              "sections": [
                "schedule"
              ]
            },
            {
              "id": "financials_tab",
              "label": "Financials",
              "sections": [
                "financials"
              ]
            },
            {
              "id": "notes_tab",
              "label": "Notes",
              "sections": [
                "notes"
              ]
            }
          ]
        }
      },
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
        "allow_attachments": true,
        "tracked_fields": [
          "job.number",
          "job.title",
          "job.contact_id",
          "job.source_quote_id",
          "job.status",
          "job.priority",
          "job.owner_id",
          "job.assignee_id",
          "job.participant_ids",
          "job.start_date",
          "job.due_date",
          "job.scheduled_start",
          "job.scheduled_end",
          "job.location",
          "job.total_estimate",
          "job.actual_cost",
          "job.description",
          "job.internal_notes"
        ]
      }
    },
    {
      "id": "job.graph",
      "kind": "graph",
      "entity": "entity.job",
      "default": {
        "type": "bar",
        "group_by": "job.status",
        "measure": "sum:job.total_estimate"
      }
    },
    {
      "id": "job_line.graph",
      "kind": "graph",
      "entity": "entity.job_line",
      "default": {
        "type": "bar",
        "group_by": "job_line.status",
        "measure": "sum:job_line.line_total"
      }
    }
  ],
  "pages": [
    {
      "id": "job.list_page",
      "title": "Jobs",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.job_new"
          }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.job",
              "default_mode": "kanban",
              "modes": [
