{
  "manifest_version": "1.3",
  "module": {
    "id": "outreach",
    "key": "outreach",
    "name": "Outreach",
    "version": "1.0.0",
    "description": "Outbound prospecting tracker for potential customers, outreach sends, replies, and conversion into Contacts.",
    "category": "Sales",
    "icon_key": "lucide:Megaphone"
  },
  "depends_on": {
    "required": [
      {
        "module": "contacts",
        "version": ">=1.0.0"
      },
      {
        "module": "catalog",
        "version": ">=1.1.0"
      }
    ]
  },
  "app": {
    "home": "page:outreach.list_page",
    "defaults": {
      "entity_home_page": "page:outreach.list_page",
      "entity_form_page": "page:outreach.form_page",
      "entities": {
        "entity.outreach": {
          "entity_home_page": "page:outreach.list_page",
          "entity_form_page": "page:outreach.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Outreach",
        "items": [
          {
            "label": "Prospects",
            "to": "page:outreach.list_page"
          },
          {
            "label": "Follow Up Calendar",
            "to": "page:outreach.calendar_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.outreach",
      "display_field": "outreach.company_name",
      "fields": [
        {
          "id": "outreach.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "outreach.prospect_name",
          "type": "string",
          "label": "Prospect",
          "required": true
        },
        {
          "id": "outreach.company_name",
          "type": "string",
          "label": "Company Name"
        },
        {
          "id": "outreach.email",
          "type": "string",
          "label": "Email",
          "required": true
        },
        {
          "id": "outreach.phone",
          "type": "string",
          "label": "Phone"
        },
        {
          "id": "outreach.catalog_item_id",
          "type": "lookup",
          "label": "Catalog Item",
          "entity": "entity.item",
          "display_field": "item.name"
        },
        {
          "id": "outreach.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "ready",
              "label": "Ready"
            },
            {
              "value": "sent",
              "label": "Sent"
            },
            {
              "value": "replied",
              "label": "Replied"
            },
            {
              "value": "interested",
              "label": "Interested"
            },
            {
              "value": "converted",
              "label": "Converted"
            },
            {
              "value": "archived",
              "label": "Archived"
            }
          ]
        },
        {
          "id": "outreach.channel",
          "type": "enum",
          "label": "Channel",
          "default": "email",
          "options": [
            {
              "value": "email",
              "label": "Email"
            },
            {
              "value": "phone",
              "label": "Phone"
            },
            {
              "value": "linkedin",
              "label": "LinkedIn"
            },
            {
              "value": "manual",
              "label": "Manual"
            }
          ]
        },
        {
          "id": "outreach.type",
          "type": "enum",
          "label": "Outreach Type",
          "options": [
            {
              "value": "partners",
              "label": "Partners"
            },
            {
              "value": "platform_clients",
              "label": "Platform Clients"
            },
            {
              "value": "clients",
              "label": "Clients"
            }
          ]
        },
        {
          "id": "outreach.owner_id",
          "type": "user",
          "label": "Owner"
        },
        {
          "id": "outreach.source",
          "type": "string",
          "label": "Source"
        },
        {
          "id": "outreach.segment",
          "type": "string",
          "label": "Segment"
        },
        {
          "id": "outreach.outreach_date",
          "type": "date",
          "label": "Outreach Date"
        },
        {
          "id": "outreach.follow_up_date",
          "type": "date",
          "label": "Follow Up Date"
        },
        {
          "id": "outreach.reply_summary",
          "type": "text",
          "label": "Reply Summary"
        },
        {
          "id": "outreach.next_step",
          "type": "text",
          "label": "Next Step"
        },
        {
          "id": "outreach.contact_id",
          "type": "lookup",
          "label": "Converted Contact",
          "entity": "entity.contact",
          "display_field": "contact.name",
          "readonly": true
        },
        {
          "id": "outreach.notes",
          "type": "text",
          "label": "Internal Notes"
        },
        {
          "id": "outreach.tags",
          "type": "tags",
          "label": "Tags"
        },
        {
          "id": "outreach.attachments",
          "type": "attachments",
          "label": "Attachments"
        },
        {
          "id": "outreach.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.outreach_new",
      "kind": "open_form",
      "label": "+ New Prospect",
      "target": "outreach.form"
    },
    {
      "id": "action.outreach_mark_ready",
      "kind": "update_record",
      "label": "Mark Ready",
      "entity_id": "entity.outreach",
      "patch": {
        "outreach.status": "ready"
      },
      "enabled_when": {
        "op": "eq",
        "field": "outreach.status",
        "value": "draft"
      },
      "visible_when": {
        "op": "eq",
        "field": "outreach.status",
        "value": "draft"
      }
    },
    {
      "id": "action.outreach_send",
      "kind": "update_record",
      "label": "Send Outreach",
      "entity_id": "entity.outreach",
      "patch": {
        "outreach.status": "sent"
      },
      "enabled_when": {
        "op": "in",
        "field": "outreach.status",
        "value": ["draft", "ready", "replied"]
      },
      "visible_when": {
        "op": "in",
        "field": "outreach.status",
        "value": ["draft", "ready", "replied"]
      },
      "confirm": {
        "title": "Send Outreach",
        "body": "This will mark the outreach as Sent so your automation can deliver the email."
      }
    },
    {
      "id": "action.outreach_mark_replied",
      "kind": "update_record",
      "label": "Mark Replied",
      "entity_id": "entity.outreach",
      "patch": {
        "outreach.status": "replied"
      },
      "enabled_when": {
        "op": "eq",
        "field": "outreach.status",
        "value": "sent"
      },
      "visible_when": {
        "op": "eq",
        "field": "outreach.status",
        "value": "sent"
      }
    },
    {
      "id": "action.outreach_mark_interested",
      "kind": "update_record",
      "label": "Mark Interested",
      "entity_id": "entity.outreach",
      "patch": {
        "outreach.status": "interested"
      },
      "enabled_when": {
        "op": "in",
        "field": "outreach.status",
        "value": ["sent", "replied"]
      },
      "visible_when": {
        "op": "in",
        "field": "outreach.status",
        "value": ["sent", "replied"]
      }
    },
    {
      "id": "action.outreach_convert_contact",
      "kind": "transform_record",
      "label": "Convert to Contact",
      "entity_id": "entity.outreach",
      "transformation_key": "outreach_to_contact",
      "enabled_when": {
        "op": "and",
        "conditions": [
          {
            "op": "in",
            "field": "outreach.status",
            "value": ["replied", "interested"]
          },
          {
            "op": "not",
            "condition": {
              "op": "exists",
              "field": "outreach.contact_id"
            }
          }
        ]
      },
      "visible_when": {
        "op": "and",
        "conditions": [
          {
            "op": "in",
            "field": "outreach.status",
            "value": ["replied", "interested"]
          },
          {
            "op": "not",
            "condition": {
              "op": "exists",
              "field": "outreach.contact_id"
            }
          }
        ]
      },
      "confirm": {
        "title": "Convert to Contact",
        "body": "Create a Contact from this outreach prospect?"
      }
    },
    {
      "id": "action.outreach_archive",
      "kind": "update_record",
      "label": "Archive",
      "entity_id": "entity.outreach",
      "patch": {
        "outreach.status": "archived"
      },
      "enabled_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "outreach.status",
          "value": ["converted", "archived"]
        }
      },
      "visible_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "outreach.status",
          "value": ["converted", "archived"]
        }
      },
      "confirm": {
        "title": "Archive Prospect",
        "body": "This outreach prospect will be archived."
      }
    }
  ],
  "triggers": [
    {
      "id": "outreach.record.outreach.created",
      "event": "record.created",
      "entity_id": "entity.outreach"
    },
    {
      "id": "outreach.record.outreach.updated",
      "event": "record.updated",
      "entity_id": "entity.outreach"
    },
    {
      "id": "outreach.workflow.outreach.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.outreach",
      "status_field": "outreach.status"
    },
    {
      "id": "outreach.action.outreach_new.clicked",
      "event": "action.clicked",
      "action_id": "action.outreach_new"
    },
    {
      "id": "outreach.action.outreach_mark_ready.clicked",
      "event": "action.clicked",
      "action_id": "action.outreach_mark_ready"
    },
    {
      "id": "outreach.action.outreach_send.clicked",
      "event": "action.clicked",
      "action_id": "action.outreach_send"
    },
    {
      "id": "outreach.action.outreach_mark_replied.clicked",
      "event": "action.clicked",
      "action_id": "action.outreach_mark_replied"
    },
    {
      "id": "outreach.action.outreach_mark_interested.clicked",
      "event": "action.clicked",
      "action_id": "action.outreach_mark_interested"
    },
    {
      "id": "outreach.action.outreach_convert_contact.clicked",
      "event": "action.clicked",
      "action_id": "action.outreach_convert_contact"
    },
    {
      "id": "outreach.action.outreach_archive.clicked",
      "event": "action.clicked",
      "action_id": "action.outreach_archive"
    }
  ],
  "views": [
    {
      "id": "outreach.list",
      "kind": "list",
      "entity": "entity.outreach",
      "columns": [
        { "field_id": "outreach.prospect_name" },
        { "field_id": "outreach.company_name" },
        { "field_id": "outreach.email" },
        { "field_id": "outreach.type" },
        { "field_id": "outreach.catalog_item_id" },
        { "field_id": "outreach.status" },
        { "field_id": "outreach.owner_id" },
        { "field_id": "outreach.follow_up_date" }
      ],
      "header": {
        "primary_actions": [
          { "action_id": "action.outreach_new" }
        ],
        "open_record_target": "page:outreach.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search prospects...",
          "fields": [
            "outreach.prospect_name",
            "outreach.company_name",
            "outreach.email",
            "outreach.phone",
            "outreach.type",
            "outreach.segment",
            "outreach.source"
          ]
        },
        "filters": [
          {
            "id": "all",
            "label": "All",
            "domain": {
              "op": "exists",
              "field": "outreach.status"
            }
          },
          {
            "id": "pipeline",
            "label": "Pipeline",
            "domain": {
              "op": "in",
              "field": "outreach.status",
              "value": ["draft", "ready", "sent", "replied", "interested"]
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "outreach.owner_id",
              "value": { "ref": "$actor.user_id" }
            }
          },
          {
            "id": "sent",
            "label": "Sent",
            "domain": {
              "op": "eq",
              "field": "outreach.status",
              "value": "sent"
            }
          },
          {
            "id": "interested",
            "label": "Interested",
            "domain": {
              "op": "eq",
              "field": "outreach.status",
              "value": "interested"
            }
          },
          {
            "id": "converted",
            "label": "Converted",
            "domain": {
              "op": "eq",
              "field": "outreach.status",
              "value": "converted"
            }
          },
          {
            "id": "archived",
            "label": "Archived",
            "domain": {
              "op": "eq",
              "field": "outreach.status",
              "value": "archived"
            }
          }
        ]
      }
    },
    {
      "id": "outreach.kanban",
      "kind": "kanban",
      "entity": "entity.outreach",
      "card": {
        "title_field": "outreach.company_name",
        "subtitle_fields": [
          "outreach.prospect_name",
          "outreach.email"
        ],
        "badge_fields": [
          "outreach.type",
          "outreach.status",
          "outreach.catalog_item_id",
          "outreach.tags"
        ]
      }
    },
    {
      "id": "outreach.calendar",
      "kind": "calendar",
      "entity": "entity.outreach",
      "calendar": {
        "title_field": "outreach.prospect_name",
        "date_start": "outreach.follow_up_date",
        "color_field": "outreach.owner_id",
        "default_scale": "month"
      }
    },
    {
      "id": "outreach.form",
      "kind": "form",
      "entity": "entity.outreach",
      "sections": [
        {
          "id": "main",
          "title": "Prospect",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "outreach.prospect_name",
            "outreach.company_name",
            "outreach.email",
            "outreach.phone",
            "outreach.type",
            "outreach.status",
            "outreach.owner_id",
            "outreach.catalog_item_id",
            "outreach.channel"
          ]
        },
        {
          "id": "outreach_details",
          "title": "Outreach Details",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "outreach.source",
            "outreach.segment",
            "outreach.outreach_date",
            "outreach.follow_up_date",
            "outreach.reply_summary",
            "outreach.next_step",
            "outreach.contact_id",
            "outreach.tags"
          ]
        },
        {
          "id": "internal_notes",
          "title": "Internal Notes",
          "fields": [
            "outreach.notes",
            "outreach.attachments"
          ]
        }
      ],
      "header": {
        "statusbar": {
          "field_id": "outreach.status"
        },
        "secondary_actions": [
          { "action_id": "action.outreach_mark_ready" },
          { "action_id": "action.outreach_send" },
          { "action_id": "action.outreach_mark_replied" },
          { "action_id": "action.outreach_mark_interested" },
          { "action_id": "action.outreach_convert_contact" },
          { "action_id": "action.outreach_archive" }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "prospect_tab",
          "tabs": [
            {
              "id": "prospect_tab",
              "label": "Prospect",
              "sections": ["main"]
            },
            {
              "id": "outreach_tab",
              "label": "Outreach",
              "sections": ["outreach_details"]
            },
            {
              "id": "internal_notes_tab",
              "label": "Internal Notes",
              "sections": ["internal_notes"]
            }
          ]
        }
      }
    },
    {
      "id": "outreach.graph",
      "kind": "graph",
      "entity": "entity.outreach",
      "default": {
        "type": "bar",
        "group_by": "outreach.status",
        "measure": "count"
      }
    }
  ],
  "pages": [
    {
      "id": "outreach.list_page",
      "title": "Outreach",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          { "action_id": "action.outreach_new" }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.outreach",
              "default_mode": "kanban",
              "modes": [
                {
                  "mode": "kanban",
                  "target": "view:outreach.kanban",
                  "default_group_by": "outreach.status"
                },
                {
                  "mode": "list",
                  "target": "view:outreach.list"
                },
                {
                  "mode": "calendar",
                  "target": "view:outreach.calendar"
                },
                {
                  "mode": "graph",
                  "target": "view:outreach.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:outreach.list",
                  "default_group_by": "outreach.status"
                }
              ],
              "default_filter_id": "all"
            }
          ]
        }
      ]
    },
    {
      "id": "outreach.form_page",
      "title": "Prospect",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.outreach",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "view",
                          "target": "view:outreach.form"
                        }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "chatter",
                          "entity_id": "entity.outreach",
                          "record_ref": "$record.id"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "outreach.calendar_page",
      "title": "Follow Up Calendar",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.outreach",
              "default_mode": "calendar",
              "modes": [
                {
                  "mode": "calendar",
                  "target": "view:outreach.calendar"
                },
                {
                  "mode": "list",
                  "target": "view:outreach.list"
                },
                {
                  "mode": "graph",
                  "target": "view:outreach.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:outreach.list",
                  "default_group_by": "outreach.status"
                }
              ],
              "default_filter_id": "all"
            }
          ]
        }
      ]
    }
  ],
  "interfaces": {
    "documentable": [
      {
        "entity_id": "entity.outreach",
        "enabled": true,
        "scope": "module_and_global",
        "attachment_field": "outreach.attachments",
        "title_field": "outreach.prospect_name",
        "owner_field": "outreach.owner_id",
        "category_field": "outreach.status",
        "date_field": "outreach.created_at",
        "record_label_field": "outreach.prospect_name",
        "preview_enabled": true,
        "allow_delete": true,
        "allow_download": true
      }
    ],
    "dashboardable": [
      {
        "entity_id": "entity.outreach",
        "enabled": true,
        "scope": "module_and_global",
        "date_field": "outreach.created_at",
        "measures": ["count"],
        "group_bys": [
          "outreach.type",
          "outreach.status",
          "outreach.owner_id",
          "outreach.channel",
          "outreach.catalog_item_id"
        ],
        "default_widgets": [
          {
            "id": "outreach_by_status",
            "type": "group",
            "title": "Outreach by Status",
            "group_by": "outreach.status",
            "measure": "count"
          },
          {
            "id": "outreach_by_owner",
            "type": "group",
            "title": "Outreach by Owner",
            "group_by": "outreach.owner_id",
            "measure": "count"
          }
        ]
      }
    ],
    "schedulable": [
      {
        "entity_id": "entity.outreach",
        "enabled": true,
        "scope": "module_only",
        "title_field": "outreach.prospect_name",
        "date_start": "outreach.follow_up_date",
        "owner_field": "outreach.owner_id",
        "status_field": "outreach.status",
        "color_field": "outreach.owner_id"
      }
    ]
  },
  "relations": [],
  "workflows": [
    {
      "id": "workflow.outreach_status",
      "entity": "entity.outreach",
      "status_field": "outreach.status",
      "states": [
        { "id": "draft", "label": "Draft", "order": 1 },
        { "id": "ready", "label": "Ready", "order": 2 },
        { "id": "sent", "label": "Sent", "order": 3 },
        { "id": "replied", "label": "Replied", "order": 4 },
        { "id": "interested", "label": "Interested", "order": 5 },
        { "id": "converted", "label": "Converted", "order": 6 },
        { "id": "archived", "label": "Archived", "order": 7 }
      ],
      "transitions": [
        { "from": "draft", "to": "ready", "label": "Mark Ready" },
        { "from": "draft", "to": "sent", "label": "Send Outreach" },
        { "from": "ready", "to": "sent", "label": "Send Outreach" },
        { "from": "sent", "to": "replied", "label": "Mark Replied" },
        { "from": "sent", "to": "interested", "label": "Mark Interested" },
        { "from": "replied", "to": "interested", "label": "Mark Interested" },
        { "from": "replied", "to": "converted", "label": "Convert to Contact" },
        { "from": "interested", "to": "converted", "label": "Convert to Contact" },
        { "from": "draft", "to": "archived", "label": "Archive" },
        { "from": "ready", "to": "archived", "label": "Archive" },
        { "from": "sent", "to": "archived", "label": "Archive" },
        { "from": "replied", "to": "archived", "label": "Archive" },
        { "from": "interested", "to": "archived", "label": "Archive" }
      ]
    }
