{
  "manifest_version": "1.3",
  "module": {
    "id": "contacts",
    "key": "contacts",
    "name": "Contacts",
    "version": "1.3.0",
    "description": "Central contact management for companies, people, customers, suppliers, and service sites.",
    "category": "Foundation",
    "icon_key": "lucide:Users"
  },
  "app": {
    "home": "page:contact.list_page",
    "defaults": {
      "entity_home_page": "page:contact.list_page",
      "entity_form_page": "page:contact.form_page",
      "entities": {
        "entity.contact": {
          "entity_home_page": "page:contact.list_page",
          "entity_form_page": "page:contact.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Contacts",
        "items": [
          {
            "label": "All Contacts",
            "to": "page:contact.list_page"
          },
          {
            "label": "Companies",
            "to": "page:contact.companies_page"
          },
          {
            "label": "People",
            "to": "page:contact.people_page"
          },
          {
            "label": "Customers",
            "to": "page:contact.customers_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.contact",
      "display_field": "contact.name",
      "fields": [
        {
          "id": "contact.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "contact.name",
          "type": "string",
          "label": "Name",
          "required": true
        },
        {
          "id": "contact.title",
          "type": "enum",
          "label": "Title",
          "options": [
            {
              "value": "mr",
              "label": "Mr."
            },
            {
              "value": "mrs",
              "label": "Mrs."
            },
            {
              "value": "ms",
              "label": "Ms."
            },
            {
              "value": "dr",
              "label": "Dr."
            }
          ],
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          }
        },
        {
          "id": "contact.company_legal_name",
          "type": "string",
          "label": "Legal Name",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "company"
          }
        },
        {
          "id": "contact.first_name",
          "type": "string",
          "label": "First Name",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          }
        },
        {
          "id": "contact.last_name",
          "type": "string",
          "label": "Last Name",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          }
        },
        {
          "id": "contact.job_title",
          "type": "string",
          "label": "Job Title",
          "visible_when": {
            "op": "eq",
            "field": "contact.company_type",
            "value": "person"
          }
        },
        {
          "id": "contact.company_type",
          "type": "enum",
          "label": "Type",
          "default": "company",
          "options": [
            {
              "value": "company",
              "label": "Company"
            },
            {
              "value": "person",
              "label": "Person"
            }
          ]
        },
        {
          "id": "contact.parent_company_id",
          "type": "lookup",
          "label": "Parent Company",
          "entity": "entity.contact",
          "display_field": "contact.name"
        },
        {
          "id": "contact.email",
          "type": "string",
          "label": "Email"
        },
        {
          "id": "contact.phone",
          "type": "string",
          "label": "Phone"
        },
        {
          "id": "contact.mobile",
          "type": "string",
          "label": "Mobile"
        },
        {
          "id": "contact.website",
          "type": "string",
          "label": "Website"
        },
        {
          "id": "contact.language",
          "type": "string",
          "label": "Language"
        },
        {
          "id": "contact.vat",
          "type": "string",
          "label": "Tax ID / VAT"
        },
        {
          "id": "contact.company_registry",
          "type": "string",
          "label": "Company Registry"
        },
        {
          "id": "contact.industry",
          "type": "string",
          "label": "Industry"
        },
        {
          "id": "contact.address_line_1",
          "type": "string",
          "label": "Address Line 1"
        },
        {
          "id": "contact.address_line_2",
          "type": "string",
          "label": "Address Line 2"
        },
        {
          "id": "contact.city",
          "type": "string",
          "label": "City"
        },
        {
          "id": "contact.region",
          "type": "string",
          "label": "Region/State"
        },
        {
          "id": "contact.postcode",
          "type": "string",
          "label": "Postcode"
        },
        {
          "id": "contact.country",
          "type": "string",
          "label": "Country"
        },
        {
          "id": "contact.address_type",
          "type": "enum",
          "label": "Address Type",
          "default": "contact",
          "options": [
            {
              "value": "contact",
              "label": "Contact"
            },
            {
              "value": "invoice",
              "label": "Invoice"
            },
            {
              "value": "delivery",
              "label": "Delivery"
            },
            {
              "value": "other",
              "label": "Other"
            }
          ]
        },
        {
          "id": "contact.status",
          "type": "enum",
          "label": "Status",
          "default": "active",
          "options": [
            {
              "value": "active",
              "label": "Active"
            },
            {
              "value": "inactive",
              "label": "Inactive"
            }
          ]
        },
        {
          "id": "contact.tags",
          "type": "tags",
          "label": "Tags"
        },
        {
          "id": "contact.owner_id",
          "type": "user",
          "label": "Owner"
        },
        {
          "id": "contact.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "contact.is_customer",
          "type": "bool",
          "label": "Customer",
          "default": false
        },
        {
          "id": "contact.is_supplier",
          "type": "bool",
          "label": "Supplier",
          "default": false
        },
        {
          "id": "contact.is_service_site",
          "type": "bool",
          "label": "Service Site",
          "default": false
        },
        {
          "id": "contact.customer_payment_terms",
          "type": "string",
          "label": "Customer Payment Terms"
        },
        {
          "id": "contact.supplier_payment_terms",
          "type": "string",
          "label": "Vendor Payment Terms"
        },
        {
          "id": "contact.pricelist",
          "type": "string",
          "label": "Pricelist"
        },
        {
          "id": "contact.service_address_override",
          "type": "text",
          "label": "Service Address Override"
        },
        {
          "id": "contact.attachments",
          "type": "attachments",
          "label": "Attachments"
        },
        {
          "id": "contact.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.contact_new",
      "kind": "open_form",
      "label": "+ New Contact",
      "target": "contact.form"
    },
    {
      "id": "action.contact_mark_inactive",
      "kind": "update_record",
      "label": "Mark Inactive",
      "entity_id": "entity.contact",
      "patch": {
        "contact.status": "inactive"
      },
      "enabled_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "active"
      },
      "visible_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "active"
      },
      "confirm": {
        "title": "Mark Inactive",
        "body": "This contact will be marked inactive."
      }
    },
    {
      "id": "action.contact_reactivate",
      "kind": "update_record",
      "label": "Reactivate",
      "entity_id": "entity.contact",
      "patch": {
        "contact.status": "active"
      },
      "enabled_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "inactive"
      },
      "visible_when": {
        "op": "eq",
        "field": "contact.status",
        "value": "inactive"
      }
    }
  ],
  "triggers": [
    {
      "id": "contacts.record.contact.created",
      "event": "record.created",
      "entity_id": "entity.contact"
    },
    {
      "id": "contacts.record.contact.updated",
      "event": "record.updated",
      "entity_id": "entity.contact"
    },
    {
      "id": "contacts.workflow.contact.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.contact",
      "status_field": "contact.status"
    },
    {
      "id": "contacts.action.contact_new.clicked",
      "event": "action.clicked",
      "action_id": "action.contact_new"
    },
    {
      "id": "contacts.action.contact_mark_inactive.clicked",
      "event": "action.clicked",
      "action_id": "action.contact_mark_inactive"
    },
    {
      "id": "contacts.action.contact_reactivate.clicked",
      "event": "action.clicked",
      "action_id": "action.contact_reactivate"
    }
  ],
  "views": [
    {
      "id": "contact.list",
      "kind": "list",
      "entity": "entity.contact",
      "columns": [
        {
          "field_id": "contact.name"
        },
        {
          "field_id": "contact.company_type"
        },
        {
          "field_id": "contact.parent_company_id"
        },
        {
          "field_id": "contact.email"
        },
        {
          "field_id": "contact.phone"
        },
        {
          "field_id": "contact.city"
        },
        {
          "field_id": "contact.status"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.contact_new"
          }
        ],
        "open_record_target": "page:contact.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search contacts...",
          "fields": [
            "contact.name",
            "contact.company_legal_name",
            "contact.first_name",
            "contact.last_name",
            "contact.email",
            "contact.phone",
            "contact.city",
            "contact.region"
          ]
        },
        "filters": [
          {
            "id": "active",
            "label": "Active",
            "domain": {
              "op": "eq",
              "field": "contact.status",
              "value": "active"
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "contact.owner_id",
              "value": {
                "ref": "$actor.user_id"
              }
            }
          },
          {
            "id": "companies",
            "label": "Companies",
            "domain": {
              "op": "eq",
              "field": "contact.company_type",
              "value": "company"
            }
          },
          {
            "id": "people",
            "label": "People",
            "domain": {
              "op": "eq",
              "field": "contact.company_type",
              "value": "person"
            }
          },
          {
            "id": "customers",
            "label": "Customers",
            "domain": {
              "op": "eq",
              "field": "contact.is_customer",
              "value": true
            }
          },
          {
            "id": "suppliers",
            "label": "Suppliers",
            "domain": {
              "op": "eq",
              "field": "contact.is_supplier",
              "value": true
            }
          },
          {
            "id": "service_sites",
            "label": "Service Sites",
            "domain": {
              "op": "eq",
              "field": "contact.is_service_site",
              "value": true
            }
          }
        ]
      }
    },
    {
      "id": "contact.kanban",
      "kind": "kanban",
      "entity": "entity.contact",
      "card": {
        "title_field": "contact.name",
        "subtitle_fields": [
          "contact.email",
          "contact.phone",
          "contact.city"
        ],
        "badge_fields": [
          "contact.tags",
          "contact.status"
        ]
      }
    },
    {
      "id": "contact.form",
      "kind": "form",
      "entity": "entity.contact",
      "sections": [
        {
          "id": "primary",
          "title": "Primary Details",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.name",
            "contact.title",
            "contact.company_legal_name",
            "contact.first_name",
            "contact.last_name",
            "contact.job_title",
            "contact.company_type",
            "contact.parent_company_id",
            "contact.status",
            "contact.owner_id",
            "contact.tags"
          ]
        },
        {
          "id": "communication",
          "title": "Communication",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.email",
            "contact.website",
            "contact.phone",
            "contact.mobile",
            "contact.language"
          ]
        },
        {
          "id": "address",
          "title": "Contacts & Addresses",
          "fields": [
            "contact.address_type",
            "contact.address_line_1",
            "contact.address_line_2",
            "contact.city",
            "contact.region",
            "contact.postcode",
            "contact.country",
            "contact.service_address_override"
          ]
        },
        {
          "id": "classification",
          "title": "Sales & Purchase",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.is_customer",
            "contact.is_supplier",
            "contact.is_service_site",
            "contact.customer_payment_terms",
            "contact.supplier_payment_terms",
            "contact.pricelist"
          ]
        },
        {
          "id": "accounting",
          "title": "Accounting",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "contact.vat",
            "contact.company_registry",
            "contact.industry"
          ]
        },
        {
          "id": "notes",
          "title": "Internal Notes",
          "fields": [
            "contact.notes",
            "contact.attachments"
          ]
        }
      ],
      "header": {
        "statusbar": {
          "field_id": "contact.status"
        },
        "secondary_actions": [
          {
            "action_id": "action.contact_mark_inactive"
          },
          {
            "action_id": "action.contact_reactivate"
          }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "contacts_addresses",
          "tabs": [
            {
              "id": "contacts_addresses",
              "label": "Contacts & Addresses",
              "sections": [
                "primary",
                "communication",
                "address"
              ]
            },
            {
              "id": "sales_purchase",
              "label": "Sales & Purchase",
              "sections": [
                "classification"
              ]
            },
            {
              "id": "accounting_tab",
              "label": "Accounting",
              "sections": [
                "accounting"
              ]
            },
            {
              "id": "internal_notes",
              "label": "Internal Notes",
              "sections": [
                "notes"
              ]
            }
          ]
        }
      }
    },
    {
      "id": "contact.graph",
      "kind": "graph",
      "entity": "entity.contact",
      "default": {
        "type": "bar",
        "group_by": "contact.status",
        "measure": "count"
      }
    }
  ],
  "pages": [
    {
      "id": "contact.list_page",
      "title": "Contacts",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.contact_new"
          }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.contact",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:contact.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:contact.kanban"
                },
                {
                  "mode": "graph",
                  "target": "view:contact.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:contact.list",
                  "default_group_by": "contact.status"
                }
              ],
              "default_filter_id": "active"
            }
          ]
        }
      ]
    },
    {
      "id": "contact.companies_page",
      "title": "Companies",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.contact",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:contact.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:contact.kanban"
                },
                {
                  "mode": "graph",
                  "target": "view:contact.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:contact.list",
                  "default_group_by": "contact.status"
                }
              ],
              "default_filter_id": "companies"
            }
          ]
        }
      ]
    },
    {
      "id": "contact.people_page",
      "title": "People",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.contact",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:contact.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:contact.kanban"
                },
                {
                  "mode": "graph",
                  "target": "view:contact.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:contact.list",
                  "default_group_by": "contact.status"
                }
              ],
              "default_filter_id": "people"
            }
          ]
        }
      ]
    },
    {
      "id": "contact.customers_page",
      "title": "Customers",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.contact",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:contact.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:contact.kanban"
                },
                {
                  "mode": "graph",
                  "target": "view:contact.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:contact.list",
                  "default_group_by": "contact.status"
                }
              ],
              "default_filter_id": "customers"
            }
          ]
        }
      ]
    },
    {
      "id": "contact.form_page",
      "title": "Contact",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.contact",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "view",
                          "target": "view:contact.form"
                        }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "chatter",
                          "entity_id": "entity.contact",
                          "record_ref": "$record.id"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "interfaces": {
    "documentable": [
      {
        "entity_id": "entity.contact",
        "enabled": true,
        "scope": "module_and_global",
        "attachment_field": "contact.attachments",
        "title_field": "contact.name",
        "owner_field": "contact.owner_id",
        "category_field": "contact.company_type",
        "date_field": "contact.created_at",
        "record_label_field": "contact.name",
        "preview_enabled": true,
        "allow_delete": true,
        "allow_download": true
      }
    ],
    "dashboardable": [
      {
        "entity_id": "entity.contact",
        "enabled": true,
        "scope": "module_and_global",
        "date_field": "contact.created_at",
        "measures": [
          "count"
        ],
        "group_bys": [
          "contact.company_type",
          "contact.status",
          "contact.region"
        ],
        "default_widgets": [
          {
            "id": "contacts_by_type",
            "type": "group",
            "title": "Contacts by Type",
            "group_by": "contact.company_type",
            "measure": "count"
          },
          {
            "id": "contacts_by_status",
            "type": "group",
            "title": "Contacts by Status",
            "group_by": "contact.status",
            "measure": "count"
          }
        ]
      }
    ]
  },
  "relations": [],
  "workflows": [
    {
      "id": "workflow.contact_status",
      "entity": "entity.contact",
      "status_field": "contact.status",
      "states": [
        {
          "id": "active",
          "label": "Active",
          "order": 1
        },
        {
          "id": "inactive",
          "label": "Inactive",
          "order": 2
        }
      ],
      "transitions": [
        {
          "from": "active",
          "to": "inactive",
          "label": "Mark Inactive"
        },
        {
          "from": "inactive",
          "to": "active",
          "label": "Reactivate"
        }
      ]
    }
  ],
  "transformations": [],
  "modals": [],
  "queries": {}
}
