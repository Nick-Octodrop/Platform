{
  "manifest_version": "1.3",
  "module": {
    "id": "field_service",
    "key": "field_service",
    "name": "Field Service",
    "version": "1.1.2",
    "description": "Dispatch, site visit, and field reporting on top of operational jobs.",
    "category": "Operations",
    "icon_key": "lucide:MapPinned"
  },
  "depends_on": {
    "required": [
      {
        "module": "contacts",
        "version": ">=1.0.0"
      },
      {
        "module": "jobs",
        "version": ">=1.3.1"
      }
    ],
    "optional": [
      {
        "module": "tasks",
        "version": ">=1.1.0"
      },
      {
        "module": "sales",
        "version": ">=1.6.2"
      }
    ]
  },
  "app": {
    "home": "page:site_visit.dispatch",
    "defaults": {
      "entity_home_page": "page:site_visit.dispatch",
      "entity_form_page": "page:site_visit.form_page",
      "entities": {
        "entity.site_visit": {
          "entity_home_page": "page:site_visit.dispatch",
          "entity_form_page": "page:site_visit.form_page"
        },
        "entity.service_report": {
          "entity_home_page": "page:service_report.list_page",
          "entity_form_page": "page:service_report.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Field Service",
        "items": [
          {
            "label": "Dispatch",
            "to": "page:site_visit.dispatch"
          },
          {
            "label": "Visits",
            "to": "page:site_visit.list_page"
          },
          {
            "label": "Reports",
            "to": "page:service_report.list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.site_visit",
      "display_field": "site_visit.job_id",
      "fields": [
        {
          "id": "site_visit.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "site_visit.job_id",
          "type": "lookup",
          "label": "Job",
          "entity": "entity.job",
          "display_field": "job.number",
          "required": true
        },
        {
          "id": "site_visit.contact_id",
          "type": "lookup",
          "label": "Contact",
          "entity": "entity.contact",
          "display_field": "contact.name"
        },
        {
          "id": "site_visit.status",
          "type": "enum",
          "label": "Status",
          "default": "planned",
          "options": [
            {
              "value": "planned",
              "label": "Planned"
            },
            {
              "value": "en_route",
              "label": "En Route"
            },
            {
              "value": "on_site",
              "label": "On Site"
            },
            {
              "value": "completed",
              "label": "Completed"
            },
            {
              "value": "cancelled",
              "label": "Cancelled"
            }
          ]
        },
        {
          "id": "site_visit.assignee_id",
          "type": "user",
          "label": "Technician"
        },
        {
          "id": "site_visit.scheduled_start",
          "type": "datetime",
          "label": "Scheduled Start",
          "required": true
        },
        {
          "id": "site_visit.scheduled_end",
          "type": "datetime",
          "label": "Scheduled End"
        },
        {
          "id": "site_visit.location",
          "type": "string",
          "label": "Location"
        },
        {
          "id": "site_visit.visit_type",
          "type": "string",
          "label": "Visit Type"
        },
        {
          "id": "site_visit.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "site_visit.attachments",
          "type": "attachments",
          "label": "Attachments"
        },
        {
          "id": "site_visit.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    },
    {
      "id": "entity.service_report",
      "display_field": "service_report.summary",
      "fields": [
        {
          "id": "service_report.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "service_report.job_id",
          "type": "lookup",
          "label": "Job",
          "entity": "entity.job",
          "display_field": "job.number",
          "required": true
        },
        {
          "id": "service_report.site_visit_id",
          "type": "lookup",
          "label": "Site Visit",
          "entity": "entity.site_visit",
          "display_field": "site_visit.job_id"
        },
        {
          "id": "service_report.technician_id",
          "type": "user",
          "label": "Technician"
        },
        {
          "id": "service_report.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "submitted",
              "label": "Submitted"
            },
            {
              "value": "approved",
              "label": "Approved"
            }
          ]
        },
        {
          "id": "service_report.summary",
          "type": "string",
          "label": "Summary",
          "required": true
        },
        {
          "id": "service_report.work_done",
          "type": "text",
          "label": "Work Done"
        },
        {
          "id": "service_report.follow_up_required",
          "type": "bool",
          "label": "Follow Up Required",
          "default": false
        },
        {
          "id": "service_report.customer_notes",
          "type": "text",
          "label": "Customer Notes"
        },
        {
          "id": "service_report.attachments",
          "type": "attachments",
          "label": "Attachments"
        },
        {
          "id": "service_report.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.site_visit_refresh",
      "kind": "refresh",
      "label": "Refresh"
    },
    {
      "id": "action.site_visit_new",
      "kind": "open_form",
      "label": "+ New Visit",
      "target": "site_visit.form"
    },
    {
      "id": "action.site_visit_en_route",
      "kind": "update_record",
      "label": "Mark En Route",
      "entity_id": "entity.site_visit",
      "patch": {
        "site_visit.status": "en_route"
      },
      "enabled_when": {
        "op": "eq",
        "field": "site_visit.status",
        "value": "planned"
      },
      "visible_when": {
        "op": "eq",
        "field": "site_visit.status",
        "value": "planned"
      }
    },
    {
      "id": "action.site_visit_on_site",
      "kind": "update_record",
      "label": "Mark On Site",
      "entity_id": "entity.site_visit",
      "patch": {
        "site_visit.status": "on_site"
      },
      "enabled_when": {
        "op": "eq",
        "field": "site_visit.status",
        "value": "en_route"
      },
      "visible_when": {
        "op": "eq",
        "field": "site_visit.status",
        "value": "en_route"
      }
    },
    {
      "id": "action.site_visit_complete",
      "kind": "update_record",
      "label": "Complete Visit",
      "entity_id": "entity.site_visit",
      "patch": {
        "site_visit.status": "completed"
      },
      "enabled_when": {
        "op": "in",
        "field": "site_visit.status",
        "value": [
          "en_route",
          "on_site"
        ]
      },
      "visible_when": {
        "op": "in",
        "field": "site_visit.status",
        "value": [
          "en_route",
          "on_site"
        ]
      }
    },
    {
      "id": "action.site_visit_cancel",
      "kind": "update_record",
      "label": "Cancel Visit",
      "entity_id": "entity.site_visit",
      "patch": {
        "site_visit.status": "cancelled"
      },
      "enabled_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "site_visit.status",
          "value": [
            "completed",
            "cancelled"
          ]
        }
      },
      "visible_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "site_visit.status",
          "value": [
            "completed",
            "cancelled"
          ]
        }
      },
      "confirm": {
        "title": "Cancel Visit",
        "body": "This visit will be cancelled."
      }
    },
    {
      "id": "action.service_report_new",
      "kind": "open_form",
      "label": "+ New Report",
      "target": "service_report.form"
    },
    {
      "id": "action.service_report_submit",
      "kind": "update_record",
      "label": "Submit Report",
      "entity_id": "entity.service_report",
      "patch": {
        "service_report.status": "submitted"
      },
      "enabled_when": {
        "op": "eq",
        "field": "service_report.status",
        "value": "draft"
      },
      "visible_when": {
        "op": "eq",
        "field": "service_report.status",
        "value": "draft"
      }
    },
    {
      "id": "action.service_report_approve",
      "kind": "update_record",
      "label": "Approve Report",
      "entity_id": "entity.service_report",
      "patch": {
        "service_report.status": "approved"
      },
      "enabled_when": {
        "op": "eq",
        "field": "service_report.status",
        "value": "submitted"
      },
      "visible_when": {
        "op": "eq",
        "field": "service_report.status",
        "value": "submitted"
      }
    }
  ],
  "triggers": [
    {
      "id": "field_service.record.site_visit.created",
      "event": "record.created",
      "entity_id": "entity.site_visit"
    },
    {
      "id": "field_service.record.site_visit.updated",
      "event": "record.updated",
      "entity_id": "entity.site_visit"
    },
    {
      "id": "field_service.record.service_report.created",
      "event": "record.created",
      "entity_id": "entity.service_report"
    },
    {
      "id": "field_service.record.service_report.updated",
      "event": "record.updated",
      "entity_id": "entity.service_report"
    },
    {
      "id": "field_service.workflow.site_visit.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.site_visit",
      "status_field": "site_visit.status"
    },
    {
      "id": "field_service.workflow.service_report.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.service_report",
      "status_field": "service_report.status"
    },
    {
      "id": "field_service.action.site_visit_refresh.clicked",
      "event": "action.clicked",
      "action_id": "action.site_visit_refresh"
    },
    {
      "id": "field_service.action.site_visit_new.clicked",
      "event": "action.clicked",
      "action_id": "action.site_visit_new"
    },
    {
      "id": "field_service.action.site_visit_en_route.clicked",
      "event": "action.clicked",
      "action_id": "action.site_visit_en_route"
    },
    {
      "id": "field_service.action.site_visit_on_site.clicked",
      "event": "action.clicked",
      "action_id": "action.site_visit_on_site"
    },
    {
      "id": "field_service.action.site_visit_complete.clicked",
      "event": "action.clicked",
      "action_id": "action.site_visit_complete"
    },
    {
      "id": "field_service.action.site_visit_cancel.clicked",
      "event": "action.clicked",
      "action_id": "action.site_visit_cancel"
    },
    {
      "id": "field_service.action.service_report_new.clicked",
      "event": "action.clicked",
      "action_id": "action.service_report_new"
    },
    {
      "id": "field_service.action.service_report_submit.clicked",
      "event": "action.clicked",
      "action_id": "action.service_report_submit"
    },
    {
      "id": "field_service.action.service_report_approve.clicked",
      "event": "action.clicked",
      "action_id": "action.service_report_approve"
    }
  ],
  "views": [
    {
      "id": "site_visit.list",
      "kind": "list",
      "entity": "entity.site_visit",
      "columns": [
        {
          "field_id": "site_visit.job_id"
        },
        {
          "field_id": "site_visit.status"
        },
        {
          "field_id": "site_visit.assignee_id"
        },
        {
          "field_id": "site_visit.scheduled_start"
        },
        {
          "field_id": "site_visit.location"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.site_visit_new"
          }
        ],
        "secondary_actions": [
          {
            "action_id": "action.site_visit_refresh"
          }
        ],
        "open_record_target": "page:site_visit.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search visits...",
          "fields": [
            "site_visit.job_id",
            "site_visit.status",
            "site_visit.assignee_id",
            "site_visit.location",
            "site_visit.visit_type"
          ]
        },
        "filters": [
          {
            "id": "open",
            "label": "Open",
            "domain": {
              "op": "not",
              "condition": {
                "op": "in",
                "field": "site_visit.status",
                "value": [
                  "completed",
                  "cancelled"
                ]
              }
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "site_visit.assignee_id",
              "value": {
                "ref": "$actor.user_id"
              }
            }
          }
        ]
      }
    },
    {
      "id": "site_visit.kanban",
      "kind": "kanban",
      "entity": "entity.site_visit",
      "card": {
        "title_field": "site_visit.job_id",
        "subtitle_fields": [
          "site_visit.assignee_id",
          "site_visit.scheduled_start"
        ],
        "badge_fields": [
          "site_visit.status",
          "site_visit.visit_type"
        ]
      }
    },
    {
      "id": "site_visit.calendar",
      "kind": "calendar",
      "entity": "entity.site_visit",
      "calendar": {
        "title_field": "site_visit.job_id",
        "date_start": "site_visit.scheduled_start",
        "date_end": "site_visit.scheduled_end",
        "color_field": "site_visit.assignee_id",
        "default_scale": "week"
      }
    },
    {
      "id": "site_visit.form",
      "kind": "form",
      "entity": "entity.site_visit",
      "sections": [
        {
          "id": "main",
          "title": "Visit",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "site_visit.job_id",
            "site_visit.contact_id",
            "site_visit.status",
            "site_visit.assignee_id",
            "site_visit.visit_type",
            "site_visit.location",
            "site_visit.scheduled_start",
            "site_visit.scheduled_end"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "site_visit.notes",
            "site_visit.attachments"
          ]
        }
      ],
      "header": {
        "statusbar": {
          "field_id": "site_visit.status"
        },
        "secondary_actions": [
          {
            "action_id": "action.site_visit_en_route"
          },
          {
            "action_id": "action.site_visit_on_site"
          },
          {
            "action_id": "action.site_visit_complete"
          },
          {
            "action_id": "action.site_visit_cancel"
          },
          {
            "action_id": "action.site_visit_refresh"
          }
        ]
      }
    },
    {
      "id": "service_report.list",
      "kind": "list",
      "entity": "entity.service_report",
      "columns": [
        {
          "field_id": "service_report.job_id"
        },
        {
          "field_id": "service_report.summary"
        },
        {
          "field_id": "service_report.technician_id"
        },
        {
          "field_id": "service_report.status"
        },
        {
          "field_id": "service_report.follow_up_required"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.service_report_new"
          }
        ],
        "secondary_actions": [
          {
            "action_id": "action.site_visit_refresh"
          }
        ],
        "open_record_target": "page:service_report.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search reports...",
          "fields": [
            "service_report.summary",
            "service_report.job_id",
            "service_report.technician_id",
            "service_report.status"
          ]
        },
        "filters": [
          {
            "id": "open",
            "label": "Open",
            "domain": {
              "op": "in",
              "field": "service_report.status",
              "value": [
                "draft",
                "submitted"
              ]
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "service_report.technician_id",
              "value": {
                "ref": "$actor.user_id"
              }
            }
          },
          {
            "id": "approved",
            "label": "Approved",
            "domain": {
              "op": "eq",
              "field": "service_report.status",
              "value": "approved"
            }
          }
        ]
      }
    },
    {
      "id": "service_report.kanban",
      "kind": "kanban",
      "entity": "entity.service_report",
      "card": {
        "title_field": "service_report.summary",
        "subtitle_fields": [
          "service_report.job_id",
          "service_report.technician_id"
        ],
        "badge_fields": [
          "service_report.status",
          "service_report.follow_up_required"
        ]
      }
    },
    {
      "id": "service_report.form",
      "kind": "form",
      "entity": "entity.service_report",
      "sections": [
        {
          "id": "summary",
          "title": "Report",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "service_report.job_id",
            "service_report.site_visit_id",
            "service_report.technician_id",
            "service_report.status",
            "service_report.summary",
            "service_report.follow_up_required"
          ]
        },
        {
          "id": "details",
          "title": "Details",
          "fields": [
            "service_report.work_done",
            "service_report.customer_notes",
            "service_report.attachments"
          ]
        }
      ],
      "header": {
        "statusbar": {
          "field_id": "service_report.status"
        },
        "secondary_actions": [
          {
            "action_id": "action.service_report_submit"
          },
          {
            "action_id": "action.service_report_approve"
          },
          {
            "action_id": "action.site_visit_refresh"
          }
        ]
      }
    },
    {
      "id": "site_visit.graph",
      "kind": "graph",
      "entity": "entity.site_visit",
      "default": {
        "type": "bar",
        "group_by": "site_visit.status",
        "measure": "count"
      }
    },
    {
      "id": "service_report.graph",
      "kind": "graph",
      "entity": "entity.service_report",
      "default": {
        "type": "bar",
        "group_by": "service_report.status",
        "measure": "count"
      }
    }
  ],
  "pages": [
    {
      "id": "site_visit.dispatch",
      "title": "Dispatch",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.site_visit_new"
          },
          {
            "action_id": "action.site_visit_refresh"
          }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.site_visit",
              "default_mode": "calendar",
              "modes": [
                {
                  "mode": "calendar",
                  "target": "view:site_visit.calendar"
                },
                {
                  "mode": "kanban",
                  "target": "view:site_visit.kanban",
                  "default_group_by": "site_visit.status"
                },
                {
                  "mode": "list",
                  "target": "view:site_visit.list"
                },
                {
                  "mode": "graph",
                  "target": "view:site_visit.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:site_visit.list",
                  "default_group_by": "site_visit.status"
                }
              ],
              "default_filter_id": "open"
            }
          ]
        }
      ]
    },
    {
      "id": "site_visit.form_page",
      "title": "Site Visit",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.site_visit",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "view",
                          "target": "view:site_visit.form"
                        }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "chatter",
                          "entity_id": "entity.site_visit",
                          "record_ref": "$record.id"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "site_visit.list_page",
      "title": "Visits",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.site_visit",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:site_visit.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:site_visit.kanban",
                  "default_group_by": "site_visit.status"
                },
                {
                  "mode": "calendar",
                  "target": "view:site_visit.calendar"
                },
                {
                  "mode": "graph",
                  "target": "view:site_visit.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:site_visit.list",
                  "default_group_by": "site_visit.status"
                }
              ],
