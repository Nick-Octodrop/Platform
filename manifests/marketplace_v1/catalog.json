{
  "manifest_version": "1.3",
  "module": {
    "id": "catalog",
    "key": "catalog",
    "name": "Catalog",
    "version": "1.1.0",
    "description": "Shared item catalog for products, manufactured goods, services, and labor used across modules.",
    "category": "Operations",
    "icon_key": "lucide:Package"
  },
  "depends_on": {
    "required": []
  },
  "app": {
    "home": "page:item.list_page",
    "defaults": {
      "entity_home_page": "page:item.list_page",
      "entity_form_page": "page:item.form_page",
      "entities": {
        "entity.item": {
          "entity_home_page": "page:item.list_page",
          "entity_form_page": "page:item.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Catalog",
        "items": [
          {
            "label": "Items",
            "to": "page:item.list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.item",
      "display_field": "item.name",
      "fields": [
        {
          "id": "item.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "item.code",
          "type": "string",
          "label": "Code",
          "required": true
        },
        {
          "id": "item.name",
          "type": "string",
          "label": "Name",
          "required": true
        },
        {
          "id": "item.type",
          "type": "enum",
          "label": "Type",
          "default": "storable",
          "options": [
            {
              "value": "storable",
              "label": "Storable Product"
            },
            {
              "value": "consumable",
              "label": "Consumable"
            },
            {
              "value": "service",
              "label": "Service"
            },
            {
              "value": "labor",
              "label": "Labor"
            }
          ]
        },
        {
          "id": "item.fulfillment_method",
          "type": "enum",
          "label": "Fulfillment",
          "default": "purchase",
          "options": [
            {
              "value": "purchase",
              "label": "Purchase"
            },
            {
              "value": "manufacture",
              "label": "Manufacture"
            },
            {
              "value": "subcontract",
              "label": "Subcontract"
            },
            {
              "value": "manual",
              "label": "Manual / Time"
            }
          ]
        },
        {
          "id": "item.can_sell",
          "type": "enum",
          "label": "Can Be Sold",
          "default": "yes",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ]
        },
        {
          "id": "item.can_purchase",
          "type": "enum",
          "label": "Can Be Purchased",
          "default": "yes",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ]
        },
        {
          "id": "item.uom",
          "type": "string",
          "label": "Unit of Measure",
          "default": "Unit"
        },
        {
          "id": "item.sales_price",
          "type": "number",
          "label": "Sales Price",
          "default": 0
        },
        {
          "id": "item.cost_price",
          "type": "number",
          "label": "Cost",
          "default": 0
        },
        {
          "id": "item.tax_rate",
          "type": "number",
          "label": "Tax Rate (%)",
          "default": 0
        },
        {
          "id": "item.lead_time_days",
          "type": "number",
          "label": "Lead Time (Days)",
          "default": 0
        },
        {
          "id": "item.status",
          "type": "enum",
          "label": "Status",
          "default": "active",
          "options": [
            {
              "value": "active",
              "label": "Active"
            },
            {
              "value": "inactive",
              "label": "Inactive"
            }
          ]
        },
        {
          "id": "item.description",
          "type": "text",
          "label": "Description"
        },
        {
          "id": "item.tags",
          "type": "tags",
          "label": "Tags"
        },
        {
          "id": "item.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.item_new",
      "kind": "open_form",
      "label": "+ New Item",
      "target": "item.form"
    },
    {
      "id": "action.item_set_active",
      "kind": "update_record",
      "label": "Set Active",
      "entity_id": "entity.item",
      "patch": {
        "item.status": "active"
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.status",
        "value": "inactive"
      },
      "visible_when": {
        "op": "eq",
        "field": "item.status",
        "value": "inactive"
      }
    },
    {
      "id": "action.item_set_inactive",
      "kind": "update_record",
      "label": "Set Inactive",
      "entity_id": "entity.item",
      "patch": {
        "item.status": "inactive"
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.status",
        "value": "active"
      },
      "visible_when": {
        "op": "eq",
        "field": "item.status",
        "value": "active"
      }
    }
  ],
  "triggers": [
    {
      "id": "catalog.record.item.created",
      "event": "record.created",
      "entity_id": "entity.item"
    },
    {
      "id": "catalog.record.item.updated",
      "event": "record.updated",
      "entity_id": "entity.item"
    },
    {
      "id": "catalog.action.item_new.clicked",
      "event": "action.clicked",
      "action_id": "action.item_new"
    },
    {
      "id": "catalog.action.item_set_active.clicked",
      "event": "action.clicked",
      "action_id": "action.item_set_active"
    },
    {
      "id": "catalog.action.item_set_inactive.clicked",
      "event": "action.clicked",
      "action_id": "action.item_set_inactive"
    }
  ],
  "views": [
    {
      "id": "item.list",
      "kind": "list",
      "entity": "entity.item",
      "columns": [
        {
          "field_id": "item.code"
        },
        {
          "field_id": "item.name"
        },
        {
          "field_id": "item.type"
        },
        {
          "field_id": "item.fulfillment_method"
        },
        {
          "field_id": "item.status"
        },
        {
          "field_id": "item.sales_price"
        },
        {
          "field_id": "item.cost_price"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.item_new"
          }
        ],
        "open_record_target": "page:item.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search items...",
          "fields": [
            "item.code",
            "item.name",
            "item.description"
          ]
        }
      }
    },
    {
      "id": "item.kanban",
      "kind": "kanban",
      "entity": "entity.item",
      "card": {
        "title_field": "item.name",
        "subtitle_fields": [
          "item.code",
          "item.fulfillment_method"
        ],
        "badge_fields": [
          "item.type",
          "item.status",
          "item.sales_price"
        ]
      }
    },
    {
      "id": "item.form",
      "kind": "form",
      "entity": "entity.item",
      "sections": [
        {
          "id": "general",
          "title": "General",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "item.code",
            "item.name",
            "item.type",
            "item.fulfillment_method",
            "item.status",
            "item.uom",
            "item.tags"
          ]
        },
        {
          "id": "commercial",
          "title": "Commercial",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "item.can_sell",
            "item.can_purchase",
            "item.sales_price",
            "item.cost_price",
            "item.tax_rate",
            "item.lead_time_days"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "item.description"
          ]
        }
      ],
      "header": {
        "secondary_actions": [
          {
            "action_id": "action.item_set_active"
          },
          {
            "action_id": "action.item_set_inactive"
          }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "general_tab",
          "tabs": [
            {
              "id": "general_tab",
              "label": "General",
              "sections": [
                "general"
              ]
            },
            {
              "id": "commercial_tab",
              "label": "Commercial",
              "sections": [
                "commercial"
              ]
            },
            {
              "id": "notes_tab",
              "label": "Notes",
              "sections": [
                "notes"
              ]
            }
          ]
        }
      }
    },
    {
      "id": "item.graph",
      "kind": "graph",
      "entity": "entity.item",
      "default": {
        "type": "bar",
        "group_by": "item.status",
        "measure": "count"
      }
    }
  ],
  "pages": [
    {
      "id": "item.list_page",
      "title": "Items",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.item_new"
          }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.item",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:item.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:item.kanban",
                  "default_group_by": "item.type"
                },
                {
                  "mode": "graph",
                  "target": "view:item.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:item.list",
                  "default_group_by": "item.status"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "item.form_page",
      "title": "Item",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.item",
          "record_id_query": "record",
          "content": [
            {
              "kind": "container",
              "variant": "card",
              "content": [
                {
                  "kind": "view",
                  "target": "view:item.form"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "interfaces": {
    "dashboardable": [
      {
        "entity_id": "entity.item",
        "enabled": true,
        "scope": "module_and_global",
        "date_field": "item.created_at",
        "measures": [
          "count"
        ],
        "group_bys": [
          "item.type",
          "item.fulfillment_method",
          "item.status"
        ],
        "default_widgets": [
          {
            "id": "items_by_type",
            "type": "group",
            "title": "Items by Type",
            "group_by": "item.type",
            "measure": "count"
          }
        ]
      }
    ]
  },
  "relations": [],
  "workflows": [],
  "transformations": [],
  "modals": [],
  "queries": {}
}
