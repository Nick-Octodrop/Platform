{
  "manifest_version": "1.3",
  "module": {
    "id": "shop_finance",
    "key": "shop_finance",
    "name": "Shop Finance",
    "version": "1.1.0",
    "description": "Commerce finance tracking for Shopify operations including sales, shipping income, ad spend, product costs, fees, and payout reconciliation by owner.",
    "category": "Finance",
    "icon_key": "lucide:ChartColumnBig"
  },
  "depends_on": {
    "required": [
      {
        "module": "catalog",
        "version": ">=1.1.0"
      }
    ]
  },
  "app": {
    "home": "page:finance_entry.list_page",
    "defaults": {
      "entity_home_page": "page:finance_entry.list_page",
      "entity_form_page": "page:finance_entry.form_page",
      "entities": {
        "entity.finance_entry": {
          "entity_home_page": "page:finance_entry.list_page",
          "entity_form_page": "page:finance_entry.form_page"
        },
        "entity.finance_payout": {
          "entity_home_page": "page:finance_payout.list_page",
          "entity_form_page": "page:finance_payout.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Shop Finance",
        "items": [
          {
            "label": "Ledger",
            "to": "page:finance_entry.list_page"
          },
          {
            "label": "Payouts",
            "to": "page:finance_payout.list_page"
          },
          {
            "label": "Reports",
            "to": "page:finance_reports.page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.finance_entry",
      "display_field": "finance_entry.description",
      "fields": [
        {
          "id": "finance_entry.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "finance_entry.entry_date",
          "type": "date",
          "label": "Entry Date",
          "required": true
        },
        {
          "id": "finance_entry.description",
          "type": "string",
          "label": "Description",
          "required": true
        },
        {
          "id": "finance_entry.entry_class",
          "type": "enum",
          "label": "Money Direction",
          "default": "expense",
          "options": [
            {
              "value": "income",
              "label": "Income"
            },
            {
              "value": "expense",
              "label": "Expense"
            },
            {
              "value": "adjustment",
              "label": "Adjustment"
            }
          ]
        },
        {
          "id": "finance_entry.category",
          "type": "enum",
          "label": "Category",
          "required": true,
          "options": [
            {
              "value": "product_sale",
              "label": "Product Sale"
            },
            {
              "value": "shipping_income",
              "label": "Shipping Income"
            },
            {
              "value": "refund",
              "label": "Refund"
            },
            {
              "value": "ad_spend",
              "label": "Ad Spend"
            },
            {
              "value": "platform_fee",
              "label": "Platform Fee"
            },
            {
              "value": "payment_fee",
              "label": "Payment Fee"
            },
            {
              "value": "shipping_cost",
              "label": "Shipping Cost"
            },
            {
              "value": "product_cost",
              "label": "Product Cost"
            },
            {
              "value": "app_subscription",
              "label": "App Subscription"
            },
            {
              "value": "contractor",
              "label": "Contractor / Labor"
            },
            {
              "value": "owner_draw",
              "label": "Owner Draw"
            },
            {
              "value": "other_income",
              "label": "Other Income"
            },
            {
              "value": "other_expense",
              "label": "Other Expense"
            }
          ]
        },
        {
          "id": "finance_entry.source_channel",
          "type": "enum",
          "label": "Source Channel",
          "default": "shopify",
          "options": [
            {
              "value": "shopify",
              "label": "Shopify"
            },
            {
              "value": "meta_ads",
              "label": "Meta Ads"
            },
            {
              "value": "google_ads",
              "label": "Google Ads"
            },
            {
              "value": "tiktok_ads",
              "label": "TikTok Ads"
            },
            {
              "value": "email",
              "label": "Email / Klaviyo"
            },
            {
              "value": "organic",
              "label": "Organic"
            },
            {
              "value": "bank",
              "label": "Bank"
            },
            {
              "value": "manual",
              "label": "Manual"
            },
            {
              "value": "other",
              "label": "Other"
            }
          ]
        },
        {
          "id": "finance_entry.catalog_item_id",
          "type": "lookup",
          "label": "Catalog Item",
          "entity": "entity.item",
          "display_field": "item.name"
        },
        {
          "id": "finance_entry.owner_id",
          "type": "user",
          "label": "Owner"
        },
        {
          "id": "finance_entry.order_reference",
          "type": "string",
          "label": "Order / Reference"
        },
        {
          "id": "finance_entry.payout_reference",
          "type": "string",
          "label": "Payout Reference"
        },
        {
          "id": "finance_entry.quantity",
          "type": "number",
          "label": "Quantity",
          "default": 1
        },
        {
          "id": "finance_entry.amount_gross",
          "type": "number",
          "label": "Gross Amount",
          "required": true,
          "default": 0
        },
        {
          "id": "finance_entry.amount_net",
          "type": "number",
          "label": "Net Cash Impact",
          "default": 0
        },
        {
          "id": "finance_entry.tax_amount",
          "type": "number",
          "label": "Tax Amount",
          "default": 0
        },
        {
          "id": "finance_entry.fee_amount",
          "type": "number",
          "label": "Fee Amount",
          "default": 0
        },
        {
          "id": "finance_entry.shipping_amount",
          "type": "number",
          "label": "Shipping Amount",
          "default": 0
        },
        {
          "id": "finance_entry.cogs_amount",
          "type": "number",
          "label": "COGS / Product Cost",
          "default": 0
        },
        {
          "id": "finance_entry.currency",
          "type": "string",
          "label": "Currency",
          "default": "NZD"
        },
        {
          "id": "finance_entry.payment_account",
          "type": "enum",
          "label": "Payment Account",
          "default": "shopify_payout",
          "options": [
            {
              "value": "shopify_payout",
              "label": "Shopify Payout"
            },
            {
              "value": "bank",
              "label": "Bank"
            },
            {
              "value": "card",
              "label": "Card"
            },
            {
              "value": "paypal",
              "label": "PayPal"
            },
            {
              "value": "manual",
              "label": "Manual"
            }
          ]
        },
        {
          "id": "finance_entry.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "posted",
              "label": "Posted"
            },
            {
              "value": "reconciled",
              "label": "Reconciled"
            },
            {
              "value": "archived",
              "label": "Archived"
            }
          ]
        },
        {
          "id": "finance_entry.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "finance_entry.receipts",
          "type": "attachments",
          "label": "Receipts / Proof"
        },
        {
          "id": "finance_entry.tags",
          "type": "tags",
          "label": "Tags"
        },
        {
          "id": "finance_entry.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    },
    {
      "id": "entity.finance_payout",
      "display_field": "finance_payout.payout_reference",
      "fields": [
        {
          "id": "finance_payout.id",
          "type": "uuid",
          "label": "ID",
          "readonly": true
        },
        {
          "id": "finance_payout.payout_reference",
          "type": "string",
          "label": "Payout Reference",
          "required": true
        },
        {
          "id": "finance_payout.provider",
          "type": "enum",
          "label": "Provider",
          "default": "shopify",
          "options": [
            {
              "value": "shopify",
              "label": "Shopify"
            },
            {
              "value": "paypal",
              "label": "PayPal"
            },
            {
              "value": "manual",
              "label": "Manual"
            }
          ]
        },
        {
          "id": "finance_payout.payout_date",
          "type": "date",
          "label": "Payout Date",
          "required": true
        },
        {
          "id": "finance_payout.period_start",
          "type": "date",
          "label": "Period Start"
        },
        {
          "id": "finance_payout.period_end",
          "type": "date",
          "label": "Period End"
        },
        {
          "id": "finance_payout.owner_id",
          "type": "user",
          "label": "Owner"
        },
        {
          "id": "finance_payout.gross_sales_amount",
          "type": "number",
          "label": "Gross Sales",
          "default": 0
        },
        {
          "id": "finance_payout.refund_amount",
          "type": "number",
          "label": "Refunds",
          "default": 0
        },
        {
          "id": "finance_payout.shipping_income_amount",
          "type": "number",
          "label": "Shipping Income",
          "default": 0
        },
        {
          "id": "finance_payout.fee_amount",
          "type": "number",
          "label": "Fees",
          "default": 0
        },
        {
          "id": "finance_payout.shipping_cost_amount",
          "type": "number",
          "label": "Shipping Costs",
          "default": 0
        },
        {
          "id": "finance_payout.ad_spend_amount",
          "type": "number",
          "label": "Ad Spend",
          "default": 0
        },
        {
          "id": "finance_payout.product_cost_amount",
          "type": "number",
          "label": "Product Costs",
          "default": 0
        },
        {
          "id": "finance_payout.net_payout_amount",
          "type": "number",
          "label": "Net Payout",
          "required": true,
          "default": 0
        },
        {
          "id": "finance_payout.currency",
          "type": "string",
          "label": "Currency",
          "default": "NZD"
        },
        {
          "id": "finance_payout.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "posted",
              "label": "Posted"
            },
            {
              "value": "reconciled",
              "label": "Reconciled"
            },
            {
              "value": "archived",
              "label": "Archived"
            }
          ]
        },
        {
          "id": "finance_payout.notes",
          "type": "text",
          "label": "Notes"
        },
        {
          "id": "finance_payout.statement_attachments",
          "type": "attachments",
          "label": "Statements"
        },
        {
          "id": "finance_payout.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.finance_entry_new",
      "kind": "open_form",
      "label": "+ New Entry",
      "target": "finance_entry.form"
    },
    {
      "id": "action.finance_payout_new",
      "kind": "open_form",
      "label": "+ New Payout",
      "target": "finance_payout.form"
    },
    {
      "id": "action.finance_entry_mark_posted",
      "kind": "update_record",
      "label": "Mark Posted",
      "entity_id": "entity.finance_entry",
      "patch": {
        "finance_entry.status": "posted"
      },
      "enabled_when": {
        "op": "eq",
        "field": "finance_entry.status",
        "value": "draft"
      },
      "visible_when": {
        "op": "eq",
        "field": "finance_entry.status",
        "value": "draft"
      }
    },
    {
      "id": "action.finance_entry_mark_reconciled",
      "kind": "update_record",
      "label": "Mark Reconciled",
      "entity_id": "entity.finance_entry",
      "patch": {
        "finance_entry.status": "reconciled"
      },
      "enabled_when": {
        "op": "in",
        "field": "finance_entry.status",
        "value": ["draft", "posted"]
      },
      "visible_when": {
        "op": "in",
        "field": "finance_entry.status",
        "value": ["draft", "posted"]
      }
    },
    {
      "id": "action.finance_entry_archive",
      "kind": "update_record",
      "label": "Archive",
      "entity_id": "entity.finance_entry",
      "patch": {
        "finance_entry.status": "archived"
      },
      "enabled_when": {
        "op": "not",
        "condition": {
          "op": "eq",
          "field": "finance_entry.status",
          "value": "archived"
        }
      },
      "visible_when": {
        "op": "not",
        "condition": {
          "op": "eq",
          "field": "finance_entry.status",
          "value": "archived"
        }
      }
    },
    {
      "id": "action.finance_payout_mark_posted",
      "kind": "update_record",
      "label": "Mark Posted",
      "entity_id": "entity.finance_payout",
      "patch": {
        "finance_payout.status": "posted"
      },
      "enabled_when": {
        "op": "eq",
        "field": "finance_payout.status",
        "value": "draft"
      },
      "visible_when": {
        "op": "eq",
        "field": "finance_payout.status",
        "value": "draft"
      }
    },
    {
      "id": "action.finance_payout_mark_reconciled",
      "kind": "update_record",
      "label": "Mark Reconciled",
      "entity_id": "entity.finance_payout",
      "patch": {
        "finance_payout.status": "reconciled"
      },
      "enabled_when": {
        "op": "in",
        "field": "finance_payout.status",
        "value": ["draft", "posted"]
      },
      "visible_when": {
        "op": "in",
        "field": "finance_payout.status",
        "value": ["draft", "posted"]
      }
    },
    {
      "id": "action.finance_payout_archive",
      "kind": "update_record",
      "label": "Archive",
      "entity_id": "entity.finance_payout",
      "patch": {
        "finance_payout.status": "archived"
      },
      "enabled_when": {
        "op": "not",
        "condition": {
          "op": "eq",
          "field": "finance_payout.status",
          "value": "archived"
        }
      },
      "visible_when": {
        "op": "not",
        "condition": {
          "op": "eq",
          "field": "finance_payout.status",
          "value": "archived"
        }
      }
    }
  ],
  "triggers": [
    {
      "id": "shop_finance.record.finance_entry.created",
      "event": "record.created",
      "entity_id": "entity.finance_entry"
    },
    {
      "id": "shop_finance.record.finance_entry.updated",
      "event": "record.updated",
      "entity_id": "entity.finance_entry"
    },
    {
      "id": "shop_finance.workflow.finance_entry.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.finance_entry",
      "status_field": "finance_entry.status"
    },
    {
      "id": "shop_finance.record.finance_payout.created",
      "event": "record.created",
      "entity_id": "entity.finance_payout"
    },
    {
      "id": "shop_finance.record.finance_payout.updated",
      "event": "record.updated",
      "entity_id": "entity.finance_payout"
    },
    {
      "id": "shop_finance.workflow.finance_payout.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.finance_payout",
      "status_field": "finance_payout.status"
    },
    {
      "id": "shop_finance.action.finance_entry_new.clicked",
      "event": "action.clicked",
      "action_id": "action.finance_entry_new"
    },
    {
      "id": "shop_finance.action.finance_payout_new.clicked",
      "event": "action.clicked",
      "action_id": "action.finance_payout_new"
    }
  ],
  "views": [
    {
      "id": "finance_entry.list",
      "kind": "list",
      "entity": "entity.finance_entry",
      "columns": [
        { "field_id": "finance_entry.entry_date" },
        { "field_id": "finance_entry.description" },
        { "field_id": "finance_entry.entry_class" },
        { "field_id": "finance_entry.category" },
        { "field_id": "finance_entry.amount_gross" },
        { "field_id": "finance_entry.amount_net" },
        { "field_id": "finance_entry.fee_amount" },
        { "field_id": "finance_entry.cogs_amount" },
        { "field_id": "finance_entry.owner_id" },
        { "field_id": "finance_entry.source_channel" },
        { "field_id": "finance_entry.status" }
      ],
      "header": {
        "primary_actions": [
          { "action_id": "action.finance_entry_new" }
        ],
        "open_record_target": "page:finance_entry.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search ledger entries...",
          "fields": [
            "finance_entry.description",
            "finance_entry.category",
            "finance_entry.order_reference",
            "finance_entry.payout_reference",
            "finance_entry.source_channel"
          ]
        },
        "filters": [
          {
            "id": "all",
            "label": "All",
            "domain": {
              "op": "exists",
              "field": "finance_entry.status"
            }
          },
          {
            "id": "open",
            "label": "Open",
            "domain": {
              "op": "in",
              "field": "finance_entry.status",
              "value": ["draft", "posted"]
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "finance_entry.owner_id",
              "value": { "ref": "$actor.user_id" }
            }
          },
          {
            "id": "income",
            "label": "Income",
            "domain": {
              "op": "eq",
              "field": "finance_entry.entry_class",
              "value": "income"
            }
          },
          {
            "id": "expense",
            "label": "Expenses",
            "domain": {
              "op": "eq",
              "field": "finance_entry.entry_class",
              "value": "expense"
            }
          },
          {
            "id": "ads",
            "label": "Ad Spend",
            "domain": {
              "op": "eq",
              "field": "finance_entry.category",
              "value": "ad_spend"
            }
          },
          {
            "id": "product_sales",
            "label": "Sales",
            "domain": {
              "op": "eq",
              "field": "finance_entry.category",
              "value": "product_sale"
            }
          },
          {
            "id": "reconciled",
            "label": "Reconciled",
            "domain": {
              "op": "eq",
              "field": "finance_entry.status",
              "value": "reconciled"
            }
          }
        ]
      }
    },
    {
      "id": "finance_payout.list",
      "kind": "list",
      "entity": "entity.finance_payout",
      "columns": [
        { "field_id": "finance_payout.payout_date" },
        { "field_id": "finance_payout.payout_reference" },
        { "field_id": "finance_payout.provider" },
        { "field_id": "finance_payout.gross_sales_amount" },
        { "field_id": "finance_payout.fee_amount" },
        { "field_id": "finance_payout.ad_spend_amount" },
        { "field_id": "finance_payout.net_payout_amount" },
        { "field_id": "finance_payout.owner_id" },
        { "field_id": "finance_payout.status" }
      ],
      "header": {
        "primary_actions": [
          { "action_id": "action.finance_payout_new" }
        ],
        "open_record_target": "page:finance_payout.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search payouts...",
          "fields": [
            "finance_payout.payout_reference",
            "finance_payout.provider"
          ]
        },
        "filters": [
          {
            "id": "all",
            "label": "All",
            "domain": {
              "op": "exists",
              "field": "finance_payout.status"
            }
          },
          {
            "id": "open",
            "label": "Open",
            "domain": {
              "op": "in",
              "field": "finance_payout.status",
              "value": ["draft", "posted"]
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "finance_payout.owner_id",
              "value": { "ref": "$actor.user_id" }
            }
          },
          {
            "id": "reconciled",
            "label": "Reconciled",
            "domain": {
              "op": "eq",
              "field": "finance_payout.status",
              "value": "reconciled"
            }
          }
        ]
      }
    },
    {
      "id": "finance_entry.graph",
      "kind": "graph",
      "entity": "entity.finance_entry",
      "default": {
        "type": "bar",
        "group_by": "finance_entry.category",
        "measure": "count"
      }
    },
    {
      "id": "finance_payout.graph",
      "kind": "graph",
      "entity": "entity.finance_payout",
      "default": {
        "type": "bar",
        "group_by": "finance_payout.status",
        "measure": "count"
      }
    },
    {
      "id": "finance_entry.form",
      "kind": "form",
      "entity": "entity.finance_entry",
      "sections": [
        {
          "id": "entry",
          "title": "Ledger Entry",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "finance_entry.entry_date",
            "finance_entry.description",
            "finance_entry.entry_class",
            "finance_entry.category",
            "finance_entry.owner_id",
            "finance_entry.source_channel",
            "finance_entry.catalog_item_id",
            "finance_entry.order_reference",
            "finance_entry.payout_reference",
            "finance_entry.quantity",
            "finance_entry.amount_gross",
            "finance_entry.amount_net",
            "finance_entry.tax_amount",
