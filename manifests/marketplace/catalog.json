{
  "manifest_version": "1.3",
  "module": {
    "id": "catalog",
    "key": "catalog",
    "name": "Catalog",
    "version": "1.4.0",
    "description": "Shared item catalog for products, manufactured goods, services, and labor used across modules.",
    "category": "Operations",
    "icon_key": "lucide:Package"
  },
  "depends_on": {
    "required": []
  },
  "app": {
    "home": "page:item.list_page",
    "defaults": {
      "entity_home_page": "page:item.list_page",
      "entity_form_page": "page:item.form_page",
      "entities": {
        "entity.item": {
          "entity_home_page": "page:item.list_page",
          "entity_form_page": "page:item.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Catalog",
        "items": [
          {
            "label": "Items",
            "to": "page:item.list_page"
          },
          {
            "label": "Sellable",
            "to": "page:item.sellable_page"
          },
          {
            "label": "Purchasable",
            "to": "page:item.purchasable_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.item",
      "display_field": "item.name",
      "fields": [
        {
          "id": "item.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "item.code",
          "type": "string",
          "label": "Code",
          "required": true
        },
        {
          "id": "item.name",
          "type": "string",
          "label": "Name",
          "required": true
        },
        {
          "id": "item.type",
          "type": "enum",
          "label": "Type",
          "default": "storable",
          "options": [
            {
              "value": "storable",
              "label": "Storable Product"
            },
            {
              "value": "consumable",
              "label": "Consumable"
            },
            {
              "value": "service",
              "label": "Service"
            },
            {
              "value": "labor",
              "label": "Labor"
            }
          ]
        },
        {
          "id": "item.fulfillment_method",
          "type": "enum",
          "label": "Fulfillment",
          "default": "purchase",
          "options": [
            {
              "value": "purchase",
              "label": "Purchase"
            },
            {
              "value": "manufacture",
              "label": "Manufacture"
            },
            {
              "value": "subcontract",
              "label": "Subcontract"
            },
            {
              "value": "manual",
              "label": "Manual / Time"
            }
          ]
        },
        {
          "id": "item.can_sell",
          "type": "enum",
          "label": "Can Be Sold",
          "default": "yes",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ]
        },
        {
          "id": "item.can_purchase",
          "type": "enum",
          "label": "Can Be Purchased",
          "default": "yes",
          "options": [
            {
              "value": "yes",
              "label": "Yes"
            },
            {
              "value": "no",
              "label": "No"
            }
          ]
        },
        {
          "id": "item.uom",
          "type": "string",
          "label": "Unit of Measure",
          "default": "Unit"
        },
        {
          "id": "item.uom_category",
          "type": "enum",
          "label": "UoM Category",
          "default": "unit",
          "options": [
            {
              "value": "unit",
              "label": "Unit"
            },
            {
              "value": "time",
              "label": "Time"
            },
            {
              "value": "length",
              "label": "Length"
            },
            {
              "value": "area",
              "label": "Area"
            },
            {
              "value": "volume",
              "label": "Volume"
            },
            {
              "value": "weight",
              "label": "Weight"
            }
          ]
        },
        {
          "id": "item.sales_currency",
          "type": "string",
          "label": "Sales Currency",
          "default": "USD"
        },
        {
          "id": "item.purchase_currency",
          "type": "string",
          "label": "Purchase Currency",
          "default": "USD"
        },
        {
          "id": "item.sales_price",
          "type": "number",
          "label": "Sales Price",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "item.sales_currency",
            "precision": 2
          }
        },
        {
          "id": "item.cost_price",
          "type": "number",
          "label": "Cost",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "item.purchase_currency",
            "precision": 2
          }
        },
        {
          "id": "item.tax_rate",
          "type": "number",
          "label": "Tax Rate (%)",
          "default": 0,
          "format": {
            "kind": "percent",
            "precision": 2
          }
        },
        {
          "id": "item.lead_time_days",
          "type": "number",
          "label": "Lead Time (Days)",
          "default": 0,
          "format": {
            "kind": "measurement",
            "unit": "days",
            "precision": 0
          }
        },
        {
          "id": "item.margin_amount",
          "type": "number",
          "label": "Margin",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "item.sales_currency",
            "precision": 2
          },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    {
                      "ref": "$current.item.sales_price"
                    },
                    {
                      "ref": "$current.item.cost_price"
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "item.margin_percent",
          "type": "number",
          "label": "Margin (%)",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "percent",
            "precision": 2
          },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "gt",
                "field": "item.sales_price",
                "value": 0
              },
              "then": {
                "op": "round",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "div",
                        "args": [
                          {
                            "ref": "$current.item.margin_amount"
                          },
                          {
                            "ref": "$current.item.sales_price"
                          }
                        ]
                      },
                      100
                    ]
                  },
                  2
                ]
              },
              "else": 0
            }
          }
        },
        {
          "id": "item.status",
          "type": "enum",
          "label": "Status",
          "default": "active",
          "ui": {
            "widget": "steps"
          },
          "options": [
            {
              "value": "active",
              "label": "Active"
            },
            {
              "value": "inactive",
              "label": "Inactive"
            }
          ]
        },
        {
          "id": "item.description",
          "type": "text",
          "label": "Description"
        },
        {
          "id": "item.tags",
          "type": "tags",
          "label": "Tags"
        },
        {
          "id": "item.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.item_new",
      "kind": "open_form",
      "label": "+ New Item",
      "target": "item.form"
    },
    {
      "id": "action.item_set_active",
      "kind": "update_record",
      "label": "Set Active",
      "entity_id": "entity.item",
      "patch": {
        "item.status": "active"
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.status",
        "value": "inactive"
      },
      "visible_when": {
        "op": "eq",
        "field": "item.status",
        "value": "inactive"
      }
    },
    {
      "id": "action.item_set_inactive",
      "kind": "update_record",
      "label": "Set Inactive",
      "entity_id": "entity.item",
      "patch": {
        "item.status": "inactive"
      },
      "enabled_when": {
        "op": "eq",
        "field": "item.status",
        "value": "active"
      },
      "visible_when": {
        "op": "eq",
        "field": "item.status",
        "value": "active"
      }
    }
  ],
  "triggers": [
    {
      "id": "catalog.record.item.created",
      "event": "record.created",
      "entity_id": "entity.item"
    },
    {
      "id": "catalog.record.item.updated",
      "event": "record.updated",
      "entity_id": "entity.item"
    },
    {
      "id": "catalog.action.item_new.clicked",
      "event": "action.clicked",
      "action_id": "action.item_new"
    },
    {
      "id": "catalog.action.item_set_active.clicked",
      "event": "action.clicked",
      "action_id": "action.item_set_active"
    },
    {
      "id": "catalog.action.item_set_inactive.clicked",
      "event": "action.clicked",
      "action_id": "action.item_set_inactive"
    }
  ],
  "views": [
    {
      "id": "item.list",
      "kind": "list",
      "entity": "entity.item",
      "columns": [
        {
          "field_id": "item.code"
        },
        {
          "field_id": "item.name"
        },
        {
          "field_id": "item.type"
        },
        {
          "field_id": "item.fulfillment_method"
        },
        {
          "field_id": "item.status"
        },
        {
          "field_id": "item.sales_price"
        },
        {
          "field_id": "item.cost_price"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.item_new"
          }
        ],
        "open_record_target": "page:item.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search items...",
          "fields": [
            "item.code",
            "item.name",
            "item.description"
          ]
        },
        "filters": [
          {
            "id": "active",
            "label": "Active",
            "domain": {
              "op": "eq",
              "field": "item.status",
              "value": "active"
            }
          },
          {
            "id": "sellable",
            "label": "Sellable",
            "domain": {
              "op": "eq",
              "field": "item.can_sell",
              "value": "yes"
            }
          },
          {
            "id": "purchasable",
            "label": "Purchasable",
            "domain": {
              "op": "eq",
              "field": "item.can_purchase",
              "value": "yes"
            }
          },
          {
            "id": "inactive",
            "label": "Inactive",
            "domain": {
              "op": "eq",
              "field": "item.status",
              "value": "inactive"
            }
          },
          {
            "id": "products",
            "label": "Products",
            "domain": {
              "op": "in",
              "field": "item.type",
              "value": [
                "storable",
                "consumable"
              ]
            }
          },
          {
            "id": "services",
            "label": "Services",
            "domain": {
              "op": "in",
              "field": "item.type",
              "value": [
                "service",
                "labor"
              ]
            }
          }
        ]
      }
    },
    {
      "id": "item.kanban",
      "kind": "kanban",
      "entity": "entity.item",
      "card": {
        "title_field": "item.name",
        "subtitle_fields": [
          "item.code",
          "item.fulfillment_method"
        ],
        "badge_fields": [
          "item.type",
          "item.status",
          "item.sales_price"
        ]
      }
    },
    {
      "id": "item.form",
      "kind": "form",
      "entity": "entity.item",
      "sections": [
        {
          "id": "general",
          "title": "General",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "item.code",
            "item.name",
            "item.type",
            "item.fulfillment_method",
            "item.status",
            "item.uom_category",
            "item.uom",
            "item.tags"
          ]
        },
        {
          "id": "commercial",
          "title": "Commercial",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "item.can_sell",
            "item.can_purchase",
            "item.sales_currency",
            "item.purchase_currency",
            "item.sales_price",
            "item.cost_price",
            "item.margin_amount",
            "item.margin_percent",
            "item.tax_rate",
            "item.lead_time_days"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "item.description"
          ]
        }
      ],
      "header": {
        "secondary_actions": [
          {
            "action_id": "action.item_set_active"
          },
          {
            "action_id": "action.item_set_inactive"
          }
        ],
        "tabs": {
          "style": "lifted",
          "default_tab": "general_tab",
          "tabs": [
            {
              "id": "general_tab",
              "label": "General",
              "sections": [
                "general"
              ]
            },
            {
              "id": "commercial_tab",
              "label": "Commercial",
              "sections": [
                "commercial"
              ]
            },
            {
              "id": "notes_tab",
              "label": "Notes",
              "sections": [
                "notes"
              ]
            }
          ]
        },
        "statusbar": {
          "field_id": "item.status"
        }
      },
      "activity": {
        "enabled": true,
        "show_changes": true,
        "allow_comments": true,
        "allow_attachments": true,
        "tracked_fields": [
          "item.code",
          "item.name",
          "item.type",
          "item.fulfillment_method",
          "item.status",
          "item.uom_category",
          "item.uom",
          "item.tags",
          "item.can_sell",
          "item.can_purchase",
          "item.sales_currency",
          "item.purchase_currency",
          "item.sales_price",
          "item.cost_price",
          "item.margin_amount",
          "item.margin_percent",
          "item.tax_rate",
          "item.lead_time_days",
          "item.description"
        ]
      }
    },
    {
      "id": "item.graph",
      "kind": "graph",
      "entity": "entity.item",
      "default": {
        "type": "bar",
        "group_by": "item.status",
        "measure": "count"
      }
    }
  ],
  "pages": [
    {
      "id": "item.dashboard_page",
      "title": "Catalog Home",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.item_new"
          }
        ]
      },
      "content": [
        {
          "kind": "stat_cards",
          "columns": 4,
          "cards": [
            {
              "id": "active_items",
              "label": "Active Items",
              "subtitle": "Current sellable and operational catalog",
              "entity_id": "entity.item",
              "measure": "count",
              "domain": {
                "op": "eq",
                "field": "item.status",
                "value": "active"
              },
              "icon": "lucide:Package",
              "tone": "primary",
              "format": "number",
              "target": "page:item.list_page"
            },
            {
              "id": "sellable_items",
              "label": "Sellable",
              "subtitle": "Commercially active offers",
              "entity_id": "entity.item",
              "measure": "count",
              "domain": {
                "op": "eq",
                "field": "item.can_sell",
                "value": "yes"
              },
              "icon": "lucide:BadgeDollarSign",
              "tone": "success",
              "format": "number",
              "target": "page:item.sellable_page"
            },
            {
              "id": "purchasable_items",
              "label": "Purchasable",
              "subtitle": "Sourceable items and services",
              "entity_id": "entity.item",
              "measure": "count",
              "domain": {
                "op": "eq",
                "field": "item.can_purchase",
                "value": "yes"
              },
              "icon": "lucide:Truck",
              "tone": "warning",
              "format": "number",
              "target": "page:item.purchasable_page"
            },
            {
              "id": "inactive_items",
              "label": "Inactive",
              "subtitle": "Hidden from day-to-day use",
              "entity_id": "entity.item",
              "measure": "count",
              "domain": {
                "op": "eq",
                "field": "item.status",
                "value": "inactive"
              },
              "icon": "lucide:Archive",
              "tone": "accent",
              "format": "number",
              "target": "page:item.inactive_page"
            }
          ]
        },
        {
          "kind": "grid",
          "columns": 12,
          "gap": "md",
          "items": [
            {
              "span": 8,
              "content": [
                {
                  "kind": "container",
                  "variant": "card",
                  "title": "Catalog Coverage",
                  "content": [
                    {
                      "kind": "view_modes",
                      "entity_id": "entity.item",
                      "compact": true,
                      "param_scope": "local",
                      "default_mode": "kanban",
                      "modes": [
                        {
                          "mode": "kanban",
                          "target": "view:item.kanban",
                          "default_group_by": "item.type"
                        },
                        {
                          "mode": "list",
                          "target": "view:item.list"
                        },
                        {
                          "mode": "graph",
                          "target": "view:item.graph"
                        }
                      ],
                      "default_filter_id": "active"
                    }
                  ]
                }
              ]
            },
            {
              "span": 4,
              "content": [
                {
                  "kind": "container",
                  "variant": "card",
                  "title": "Commercial Review",
                  "content": [
                    {
                      "kind": "view_modes",
                      "entity_id": "entity.item",
                      "compact": true,
                      "param_scope": "local",
                      "default_mode": "list",
                      "record_domain": {
                        "op": "eq",
                        "field": "item.can_sell",
                        "value": "yes"
                      },
                      "modes": [
                        {
                          "mode": "list",
                          "target": "view:item.list"
                        },
                        {
                          "mode": "graph",
                          "target": "view:item.graph"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "item.list_page",
      "title": "Items",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.item_new"
          }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.item",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:item.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:item.kanban",
                  "default_group_by": "item.type"
                },
                {
                  "mode": "graph",
                  "target": "view:item.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:item.list",
                  "default_group_by": "item.status"
                }
              ],
              "default_filter_id": "active"
            }
          ]
        }
      ]
    },
    {
      "id": "item.form_page",
      "title": "Item",
      "layout": "single",
      "header": {
        "variant": "none"
      },
      "content": [
        {
          "kind": "record",
          "entity_id": "entity.item",
          "record_id_query": "record",
          "content": [
            {
              "kind": "grid",
              "columns": 12,
              "gap": "md",
              "items": [
                {
                  "span": 8,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "view",
                          "target": "view:item.form"
                        }
                      ]
                    }
                  ]
                },
                {
                  "span": 4,
                  "content": [
                    {
                      "kind": "container",
                      "variant": "card",
                      "content": [
                        {
                          "kind": "chatter",
                          "entity_id": "entity.item",
                          "record_ref": "$record.id"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "item.board_page",
      "title": "Catalog Board",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.item_new"
          }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.item",
              "default_mode": "kanban",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:item.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:item.kanban",
                  "default_group_by": "item.type"
                },
                {
                  "mode": "graph",
                  "target": "view:item.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:item.list",
                  "default_group_by": "item.status"
                }
              ],
              "default_filter_id": "active"
            }
          ]
        }
      ]
    },
    {
      "id": "item.inactive_page",
      "title": "Inactive Items",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.item_new"
          }
        ]
      },
      "content": [
        {
          "kind": "container",
          "variant": "card",
          "content": [
            {
              "kind": "view_modes",
              "entity_id": "entity.item",
              "default_mode": "list",
              "modes": [
                {
                  "mode": "list",
                  "target": "view:item.list"
                },
                {
                  "mode": "kanban",
                  "target": "view:item.kanban",
                  "default_group_by": "item.type"
                },
                {
                  "mode": "graph",
                  "target": "view:item.graph"
                },
                {
                  "mode": "pivot",
                  "target": "view:item.list",
                  "default_group_by": "item.status"
                }
              ],
              "default_filter_id": "inactive"
            }
          ]
        }
      ]
    },
    {
      "id": "item.sellable_page",
      "title": "Sellable Items",
      "layout": "single",
      "header": {
        "variant": "none",
        "actions": [
          {
            "action_id": "action.item_new"
          }
        ]
