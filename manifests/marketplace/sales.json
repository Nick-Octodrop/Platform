{
  "manifest_version": "1.3",
  "module": {
    "id": "sales",
    "key": "sales",
    "name": "Sales",
    "version": "1.9.0",
    "description": "Quotation management for operational sales workflows and quote-to-job handoff.",
    "category": "Sales",
    "icon_key": "lucide:FileCheck2"
  },
  "depends_on": {
    "required": [
      {
        "module": "contacts",
        "version": ">=1.0.0"
      },
      {
        "module": "catalog",
        "version": ">=1.1.0"
      },
      {
        "module": "jobs",
        "version": ">=1.3.1"
      }
    ],
    "optional": [
      {
        "module": "crm",
        "version": ">=1.0.0"
      }
    ]
  },
  "app": {
    "home": "page:quote.list_page",
    "defaults": {
      "entity_home_page": "page:quote.list_page",
      "entity_form_page": "page:quote.form_page",
      "entities": {
        "entity.quote": {
          "entity_home_page": "page:quote.list_page",
          "entity_form_page": "page:quote.form_page"
        },
        "entity.quote_line": {
          "entity_home_page": "page:quote_line.list_page",
          "entity_form_page": "page:quote_line.form_page"
        }
      }
    },
    "nav": [
      {
        "group": "Sales",
        "items": [
          {
            "label": "Quotes",
            "to": "page:quote.list_page"
          },
          {
            "label": "Approved",
            "to": "page:quote.approved_page"
          },
          {
            "label": "Converted",
            "to": "page:quote.converted_page"
          },
          {
            "label": "Line Items",
            "to": "page:quote_line.list_page"
          }
        ]
      }
    ]
  },
  "entities": [
    {
      "id": "entity.quote",
      "display_field": "quote.number",
      "fields": [
        {
          "id": "quote.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "quote.number",
          "type": "string",
          "label": "Quote Number",
          "required": true
        },
        {
          "id": "quote.reference",
          "type": "string",
          "label": "Reference"
        },
        {
          "id": "quote.contact_id",
          "type": "lookup",
          "label": "Customer",
          "entity": "entity.contact",
          "display_field": "contact.name",
          "required": true
        },
        {
          "id": "quote.opportunity_id",
          "type": "lookup",
          "label": "Opportunity",
          "entity": "entity.opportunity",
          "display_field": "opportunity.title"
        },
        {
          "id": "quote.status",
          "type": "enum",
          "label": "Status",
          "default": "draft",
          "ui": {
            "widget": "steps"
          },
          "options": [
            {
              "value": "draft",
              "label": "Draft"
            },
            {
              "value": "sent",
              "label": "Sent"
            },
            {
              "value": "approved",
              "label": "Approved"
            },
            {
              "value": "rejected",
              "label": "Rejected"
            },
            {
              "value": "expired",
              "label": "Expired"
            },
            {
              "value": "converted",
              "label": "Converted"
            }
          ]
        },
        {
          "id": "quote.quote_date",
          "type": "date",
          "label": "Quote Date"
        },
        {
          "id": "quote.expiry_date",
          "type": "date",
          "label": "Expiry Date"
        },
        {
          "id": "quote.owner_id",
          "type": "user",
          "label": "Owner"
        },
        {
          "id": "quote.currency",
          "type": "string",
          "label": "Currency",
          "default": "USD"
        },
        {
          "id": "quote.discount_total",
          "type": "number",
          "label": "Discount",
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "quote.currency",
            "precision": 2
          }
        },
        {
          "id": "quote.subtotal",
          "type": "number",
          "label": "Subtotal",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "quote.currency",
            "precision": 2
          },
          "compute": {
            "aggregate": {
              "op": "sum",
              "entity": "entity.quote_line",
              "field": "quote_line.line_subtotal",
              "where": {
                "op": "eq",
                "field": "quote_line.quote_id",
                "value": {
                  "ref": "$parent.id"
                }
              }
            }
          }
        },
        {
          "id": "quote.tax",
          "type": "number",
          "label": "Tax",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "quote.currency",
            "precision": 2
          },
          "compute": {
            "aggregate": {
              "op": "sum",
              "entity": "entity.quote_line",
              "field": "quote_line.tax_amount",
              "where": {
                "op": "eq",
                "field": "quote_line.quote_id",
                "value": {
                  "ref": "$parent.id"
                }
              }
            }
          }
        },
        {
          "id": "quote.total",
          "type": "number",
          "label": "Total",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "quote.currency",
            "precision": 2
          },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "add",
                  "args": [
                    {
                      "op": "sub",
                      "args": [
                        {
                          "ref": "$current.quote.subtotal"
                        },
                        {
                          "ref": "$current.quote.discount_total"
                        }
                      ]
                    },
                    {
                      "ref": "$current.quote.tax"
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "quote.estimated_cost_total",
          "type": "number",
          "label": "Estimated Cost",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "quote.currency",
            "precision": 2
          },
          "compute": {
            "aggregate": {
              "op": "sum",
              "entity": "entity.quote_line",
              "field": "quote_line.buy_total",
              "where": {
                "op": "eq",
                "field": "quote_line.quote_id",
                "value": {
                  "ref": "$parent.id"
                }
              }
            }
          }
        },
        {
          "id": "quote.margin_amount",
          "type": "number",
          "label": "Estimated Margin",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "currency",
            "currency_field": "quote.currency",
            "precision": 2
          },
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "sub",
                  "args": [
                    {
                      "ref": "$current.quote.total"
                    },
                    {
                      "ref": "$current.quote.estimated_cost_total"
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "quote.margin_percent",
          "type": "number",
          "label": "Margin (%)",
          "readonly": true,
          "default": 0,
          "format": {
            "kind": "percent",
            "precision": 2
          },
          "compute": {
            "expression": {
              "op": "if",
              "condition": {
                "op": "gt",
                "field": "quote.total",
                "value": 0
              },
              "then": {
                "op": "round",
                "args": [
                  {
                    "op": "mul",
                    "args": [
                      {
                        "op": "div",
                        "args": [
                          {
                            "ref": "$current.quote.margin_amount"
                          },
                          {
                            "ref": "$current.quote.total"
                          }
                        ]
                      },
                      100
                    ]
                  },
                  2
                ]
              },
              "else": 0
            }
          }
        },
        {
          "id": "quote.notes",
          "type": "text",
          "label": "Customer Notes"
        },
        {
          "id": "quote.internal_notes",
          "type": "text",
          "label": "Internal Notes"
        },
        {
          "id": "quote.attachments",
          "type": "attachments",
          "label": "Attachments"
        },
        {
          "id": "quote.job_id",
          "type": "lookup",
          "label": "Job",
          "entity": "entity.job",
          "display_field": "job.number",
          "readonly": true
        },
        {
          "id": "quote.created_at",
          "type": "datetime",
          "label": "Created At"
        }
      ]
    },
    {
      "id": "entity.quote_line",
      "display_field": "quote_line.description",
      "fields": [
        {
          "id": "quote_line.id",
          "type": "uuid",
          "label": "Record ID",
          "readonly": true
        },
        {
          "id": "quote_line.quote_id",
          "type": "lookup",
          "label": "Quote",
          "entity": "entity.quote",
          "display_field": "quote.number",
          "required": true
        },
        {
          "id": "quote_line.item_id",
          "type": "lookup",
          "label": "Item",
          "entity": "entity.item",
          "display_field": "item.name",
          "required": true
        },
        {
          "id": "quote_line.description",
          "type": "string",
          "label": "Description",
          "required": true
        },
        {
          "id": "quote_line.uom",
          "type": "string",
          "label": "Unit of Measure",
          "default": "Unit"
        },
        {
          "id": "quote_line.qty",
          "type": "number",
          "label": "Qty",
          "default": 1,
          "format": {
            "kind": "measurement",
            "unit_field": "quote_line.uom",
            "precision": 2
          }
        },
        {
          "id": "quote_line.unit_price",
          "type": "number",
          "label": "Unit Price",
          "default": 0
        },
        {
          "id": "quote_line.unit_cost",
          "type": "number",
          "label": "Unit Cost",
          "default": 0
        },
        {
          "id": "quote_line.line_subtotal",
          "type": "number",
          "label": "Line Subtotal",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    {
                      "ref": "$current.quote_line.qty"
                    },
                    {
                      "ref": "$current.quote_line.unit_price"
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "quote_line.tax_rate",
          "type": "number",
          "label": "Tax Rate (%)",
          "default": 0,
          "format": {
            "kind": "percent",
            "precision": 2
          }
        },
        {
          "id": "quote_line.tax_amount",
          "type": "number",
          "label": "Tax Amount",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    {
                      "ref": "$current.quote_line.line_subtotal"
                    },
                    {
                      "op": "div",
                      "args": [
                        {
                          "ref": "$current.quote_line.tax_rate"
                        },
                        100
                      ]
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "quote_line.line_total",
          "type": "number",
          "label": "Line Total",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "add",
                  "args": [
                    {
                      "ref": "$current.quote_line.line_subtotal"
                    },
                    {
                      "ref": "$current.quote_line.tax_amount"
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "quote_line.buy_total",
          "type": "number",
          "label": "Estimated Cost",
          "readonly": true,
          "default": 0,
          "compute": {
            "expression": {
              "op": "round",
              "args": [
                {
                  "op": "mul",
                  "args": [
                    {
                      "ref": "$current.quote_line.qty"
                    },
                    {
                      "ref": "$current.quote_line.unit_cost"
                    }
                  ]
                },
                2
              ]
            }
          }
        },
        {
          "id": "quote_line.sort_order",
          "type": "number",
          "label": "Sort Order",
          "default": 10
        },
        {
          "id": "quote_line.notes",
          "type": "text",
          "label": "Line Notes"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "action.quote_new",
      "kind": "open_form",
      "label": "+ New Quote",
      "target": "quote.form"
    },
    {
      "id": "action.quote_mark_sent",
      "kind": "update_record",
      "label": "Send",
      "entity_id": "entity.quote",
      "patch": {
        "quote.status": "sent"
      },
      "enabled_when": {
        "op": "eq",
        "field": "quote.status",
        "value": "draft"
      },
      "visible_when": {
        "op": "eq",
        "field": "quote.status",
        "value": "draft"
      }
    },
    {
      "id": "action.quote_mark_approved",
      "kind": "update_record",
      "label": "Approve",
      "entity_id": "entity.quote",
      "patch": {
        "quote.status": "approved"
      },
      "enabled_when": {
        "op": "in",
        "field": "quote.status",
        "value": [
          "draft",
          "sent"
        ]
      },
      "visible_when": {
        "op": "in",
        "field": "quote.status",
        "value": [
          "draft",
          "sent"
        ]
      }
    },
    {
      "id": "action.quote_mark_rejected",
      "kind": "update_record",
      "label": "Reject",
      "entity_id": "entity.quote",
      "patch": {
        "quote.status": "rejected"
      },
      "enabled_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "quote.status",
          "value": [
            "rejected",
            "converted"
          ]
        }
      },
      "visible_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "quote.status",
          "value": [
            "rejected",
            "converted"
          ]
        }
      },
      "confirm": {
        "title": "Reject Quote",
        "body": "This quote will be marked as Rejected."
      }
    },
    {
      "id": "action.quote_mark_expired",
      "kind": "update_record",
      "label": "Mark Expired",
      "entity_id": "entity.quote",
      "patch": {
        "quote.status": "expired"
      },
      "enabled_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "quote.status",
          "value": [
            "approved",
            "converted",
            "expired"
          ]
        }
      },
      "visible_when": {
        "op": "not",
        "condition": {
          "op": "in",
          "field": "quote.status",
          "value": [
            "approved",
            "converted",
            "expired"
          ]
        }
      },
      "confirm": {
        "title": "Mark Quote Expired",
        "body": "This quote will be marked as Expired."
      }
    },
    {
      "id": "action.quote_mark_converted",
      "kind": "transform_record",
      "label": "Create Job",
      "entity_id": "entity.quote",
      "transformation_key": "quote_to_job",
      "enabled_when": {
        "op": "and",
        "conditions": [
          {
            "op": "eq",
            "field": "quote.status",
            "value": "approved"
          },
          {
            "op": "not",
            "condition": {
              "op": "exists",
              "field": "quote.job_id"
            }
          }
        ]
      },
      "visible_when": {
        "op": "and",
        "conditions": [
          {
            "op": "eq",
            "field": "quote.status",
            "value": "approved"
          },
          {
            "op": "not",
            "condition": {
              "op": "exists",
              "field": "quote.job_id"
            }
          }
        ]
      },
      "confirm": {
        "title": "Create Job",
        "body": "Create a Job and copy all quote lines?"
      }
    }
  ],
  "triggers": [
    {
      "id": "sales.record.quote.created",
      "event": "record.created",
      "entity_id": "entity.quote"
    },
    {
      "id": "sales.record.quote.updated",
      "event": "record.updated",
      "entity_id": "entity.quote"
    },
    {
      "id": "sales.record.quote_line.created",
      "event": "record.created",
      "entity_id": "entity.quote_line"
    },
    {
      "id": "sales.record.quote_line.updated",
      "event": "record.updated",
      "entity_id": "entity.quote_line"
    },
    {
      "id": "sales.workflow.quote.status_changed",
      "event": "workflow.status_changed",
      "entity_id": "entity.quote",
      "status_field": "quote.status"
    },
    {
      "id": "sales.action.quote_new.clicked",
      "event": "action.clicked",
      "action_id": "action.quote_new"
    },
    {
      "id": "sales.action.quote_mark_sent.clicked",
      "event": "action.clicked",
      "action_id": "action.quote_mark_sent"
    },
    {
      "id": "sales.action.quote_mark_approved.clicked",
      "event": "action.clicked",
      "action_id": "action.quote_mark_approved"
    },
    {
      "id": "sales.action.quote_mark_rejected.clicked",
      "event": "action.clicked",
      "action_id": "action.quote_mark_rejected"
    },
    {
      "id": "sales.action.quote_mark_expired.clicked",
      "event": "action.clicked",
      "action_id": "action.quote_mark_expired"
    },
    {
      "id": "sales.action.quote_mark_converted.clicked",
      "event": "action.clicked",
      "action_id": "action.quote_mark_converted"
    }
  ],
  "views": [
    {
      "id": "quote.list",
      "kind": "list",
      "entity": "entity.quote",
      "columns": [
        {
          "field_id": "quote.number"
        },
        {
          "field_id": "quote.contact_id"
        },
        {
          "field_id": "quote.status"
        },
        {
          "field_id": "quote.quote_date"
        },
        {
          "field_id": "quote.expiry_date"
        },
        {
          "field_id": "quote.total"
        }
      ],
      "header": {
        "primary_actions": [
          {
            "action_id": "action.quote_new"
          }
        ],
        "open_record_target": "page:quote.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search quotes...",
          "fields": [
            "quote.number",
            "quote.reference",
            "quote.status"
          ]
        },
        "filters": [
          {
            "id": "open",
            "label": "Open",
            "domain": {
              "op": "in",
              "field": "quote.status",
              "value": [
                "draft",
                "sent",
                "approved"
              ]
            }
          },
          {
            "id": "mine",
            "label": "Mine",
            "domain": {
              "op": "eq",
              "field": "quote.owner_id",
              "value": {
                "ref": "$actor.user_id"
              }
            }
          },
          {
            "id": "approved",
            "label": "Approved",
            "domain": {
              "op": "eq",
              "field": "quote.status",
              "value": "approved"
            }
          },
          {
            "id": "converted",
            "label": "Converted",
            "domain": {
              "op": "eq",
              "field": "quote.status",
              "value": "converted"
            }
          },
          {
            "id": "draft",
            "label": "Draft",
            "domain": {
              "op": "eq",
              "field": "quote.status",
              "value": "draft"
            }
          },
          {
            "id": "sent",
            "label": "Sent",
            "domain": {
              "op": "eq",
              "field": "quote.status",
              "value": "sent"
            }
          }
        ]
      }
    },
    {
      "id": "quote.kanban",
      "kind": "kanban",
      "entity": "entity.quote",
      "card": {
        "title_field": "quote.number",
        "subtitle_fields": [
          "quote.contact_id",
          "quote.expiry_date"
        ],
        "badge_fields": [
          "quote.status",
          "quote.total"
        ]
      }
    },
    {
      "id": "quote.calendar",
      "kind": "calendar",
      "entity": "entity.quote",
      "calendar": {
        "title_field": "quote.number",
        "date_start": "quote.expiry_date",
        "color_field": "quote.owner_id",
        "default_scale": "month"
      }
    },
    {
      "id": "quote_line.list",
      "kind": "list",
      "entity": "entity.quote_line",
      "columns": [
        {
          "field_id": "quote_line.quote_id"
        },
        {
          "field_id": "quote_line.item_id"
        },
        {
          "field_id": "quote_line.sort_order"
        },
        {
          "field_id": "quote_line.description"
        },
        {
          "field_id": "quote_line.qty"
        },
        {
          "field_id": "quote_line.unit_price"
        },
        {
          "field_id": "quote_line.tax_rate"
        },
        {
          "field_id": "quote_line.line_total"
        }
      ],
      "header": {
        "open_record_target": "page:quote_line.form_page",
        "search": {
          "enabled": true,
          "placeholder": "Search quote lines...",
          "fields": [
            "quote_line.description"
          ]
        }
      }
    },
    {
      "id": "quote_line.form",
      "kind": "form",
      "entity": "entity.quote_line",
      "sections": [
        {
          "id": "main",
          "title": "Quote Line",
          "layout": "columns",
          "columns": 2,
          "fields": [
            "quote_line.quote_id",
            "quote_line.item_id",
            "quote_line.sort_order",
            "quote_line.description",
            "quote_line.qty",
            "quote_line.unit_price",
            "quote_line.tax_rate",
            "quote_line.line_total"
          ]
        },
        {
          "id": "notes",
          "title": "Notes",
          "fields": [
            "quote_line.notes"
          ]
        }
      ],
      "header": {
        "tabs": {
          "style": "lifted",
          "default_tab": "quote_line_details_tab",
          "tabs": [
            {
              "id": "quote_line_details_tab",
